nl = trades.reduce((sum, t) => sum + t.pnl, 0);\\n  const avgPnl = totalPnl / tr
ades.length;\\n  \\n  // Calculate running P&L for drawdown analysis\\n  let run
ningPnl = 0;\\n  let peakPnl = 0;\\n  let maxDrawdown = 0;\\n  const pnlCurve = 
