s_bid: 50,\n120\t    yes_ask: 52,\n121\t    no_bid: 48,\n122\t    no_ask: 50,\n123\t    volume: 200000,\n124\t    open_interest: 75000,\n125\t  },\n126\t  {\n127\t    id: \"m8\",\n128\t    ticker: \"KXNF-20260501-T200000\",\n129\t    title: \"NFP above 200k\",\n130\t    category: \"Financial\",\n131\t    status: \"active\",\n132\t    yes_bid: 26,\n133\t    yes_ask: 28,\n134\t    no_bid: 72,\n135\t    no_ask: 74,\n136\t    volume: 180000,\n137\t    open_interest: 60000,\n138\t  },\n139\t];\n140\t\n141\t// ---------------------------------------------------------------------------\n142\t// Helpers\n143\t// ---------------------------------------------------------------------------\n144\t\n145\tfunction computeMidPrice(bid, ask) {\n146\t  if (bid != null && ask != null) return Math.round((bid + ask) / 2);\n147\t  if (bid != null) return bid;\n148\t  if (ask != null) return ask;\n149\t  return 50;\n150\t}\n151\t\n152\tfunction normalizeMarket(m) {\n153\t  const yesMid = computeMidPrice(m.yes_bid, m.yes_ask);\n154\t  const noMid = computeMidPrice(m.no_bid, m.no_ask);\n155\t  return {\n156\t    id: m.id || m.ticker,\n157\t    ticker: m.ticker,\n158\t    title: m.title,\n159\t    category: m.category || \"Unknown\",\n160\t    status: m.status || \"active\",\n161\t    yes_bid: m.yes_bid,\n162\t    yes_ask: m.yes_ask,\n163\t    no_bid: m.no_bid,\n164\t    no_ask: m.no_ask,\n165\t    yes_mid: yesMid,\n166\t    no_mid: noMid,\n167\t    volume: m.volume || 0,\n168\t    volume24h: m.volume || 0,\n169\t    open_interest: m.open_interest || 0,\n170\t  };\n171\t}\n172\t\n173\tasync function fetchMarkets(client) {\n174\t  if (USE_MOCK_FALLBACK) {\n175\t    console.log(\"[FALLBACK] No KALSHI_API_KEY set — using realistic mock market data\");\n176\t    return FALLBACK_MARKETS.map(normalizeMarket);\n177\t  }\n178\t\n179\t  const response = await client.getMarkets({ status: \"active\", limit: 20 });\n180\t  const markets = response.data?.markets || [];\n181\t  console.log(`Fetched ${markets.length} live markets from Kalshi`);\n182\t  return markets.map(normalizeMarket);\n183\t}\n184\t\n185\tasync function fetchCandles(client, ticker) {\n186\t  if (USE_MOCK_FALLBACK) {\n187\t    // Generate realistic synthetic candle history\n188\t    const basePrice = ticker === \"BTCW-25-DEC31\" ? 16 : ticker === \"UNEMP-25-MAR\" ? 56 : 86;\n189\t    return Array.from({ length: CANDLE_DAYS }, (_, i) => ({\n190\t      candle_time: new Date(Date.now() - (CANDLE_DAYS - 1 - i) * 86400000).toISOString(),\n191\t      yes_close: basePrice + Math.floor(Math.random() * 10 - 5),\n192\t      yes_volume: 10000 + Math.floor(Math.random() * 5000),\n193\t    }));\n194\t  }\n195\t\n196\t  const to = Date.now();\n197\t  const from = to - CANDLE_DAYS * 86400000;\n198\t  const response = await client.getCandles(ticker, { resolution: \"1d\", from, to });\n199\t  return response.data?.candles || [];\n200\t}\n201\t\n202\tfunction computeHistoryMetrics(candles) {\n203\t  if (!candles || candles.length < 2) {\n204\t    return { mean: 50, stddev: 10, priceChange: 0 };\n205\t  }\n206\t  const prices = candles.map((c) => c.yes_close || c.close || 50);\n207\t  const mean = prices.reduce((a, b) => a + b, 0) / prices.length;\n208\t  const variance = prices.reduce((sum, p) => sum + Math.pow(p - mean, 2), 0) / prices.length;\n209\t  const stddev = Math.sqrt(variance);\n210\t  const priceChange = prices[prices.length - 1] - prices[0];\n211\t  return { mean, stddev, priceChange };\n212\t}\n213\t\n214\t// ---------------------------------------------------------------------------\n215\t// Main\n216\t// ---------------------------------------------------------------------------\n217\t\n218\tasync function main() {\n219\t  console.log(\"=== Live Strategy Runner (Task 221) ===\\n\");\n220\t\n221\t  let client = null;\n222\t  if (!USE_MOCK_FALLBACK) {\n223\t    client = new KalshiClient({\n224\t      apiKey: process.env.KALSHI_API_KEY,\n225\t      demo: process.env.KALSHI_DEMO !== \"false\",\n226\t    });\n227\t  }\n228\t\n229\t  // 1. Fetch markets\n230\t  const markets = await fetchMarkets(client);\n231\t  if (markets.length < MIN_MARKETS) {\n232\t    console.error(`Need at least ${MIN_MARKETS} markets, got ${markets.length}`);\n233\t    process.exit(1);\n234\t  }\n235\t\n236\t  // 2. Select top markets by volume for analysis\n237\t  const selectedMarkets = markets.slice().sort((a, b) => b.volume - a.volume).slice(0, Math.max(MIN_MARKETS, 5));\n238\t  console.log(`Selected ${selectedMarkets.length} markets for signal generation`);\n239\t\n240\t  // 3. Fetch history and enrich markets\n241\t  const enrichedMarkets = [];\n242\t  for (const market of selectedMarkets) {\n243\t    const candles = await fetchCandles(client, market.ticker);\n244\t    const metrics = computeHistoryMetrics(candles);\n245\t    enrichedMarkets.push({\n246\t      ...market,\n247\t      price_history_mean: metrics.mean,\n248\t      price_history_stddev: metrics.stddev,\n249\t      price_change_24h: metrics.priceChange,\n250\t      candles,\n251\t    });\n252\t    console.log(`  ${market.ticker}: yes_mid=${market.yes_mid}c, mean=${metrics.mean.toFixed(1)}, stddev=${metrics.stddev.toFixed(1)}, change=${metrics.priceChange.toFixed(1)}c`);\n253\t  }\n254\t\n255\t  // 4. Run strategies (Task 256: Optimized configuration)\n256\t  // mean_reversion: ENABLED (85.7% win rate)\n257\t  // nfp_nowcast: ENABLED (53.7% win rate, Sharpe 0.237)\n258\t  // econ_edge: ENABLED (viable performer)\n259\t  // momentum: DISABLED (10% win rate — poor performance)\n260\t  // crypto_edge: DISABLED (11.1% win rate — poor performance)\n261\t  const engine = new SignalEngine({ minConfidence: 0.80, minEdge: 1 });\n262\t  const sizer = new PositionSizer({ accountBalance: 100000, maxRiskPerTrade: 0.02 });\n263\t\n264\t  const meanReversion = new MeanReversionStrategy({ zScoreThreshold: 1.0, minVolume: 1000 });\n265\t  // DISABLED: const momentum = new MomentumStrategy({ priceChangeThreshold: 3, minVolume: 1000 });\n266\t  // DISABLED: const cryptoEdge = new CryptoEdgeStrategy();\n267\t  const nfpNowcast = new NFPNowcastStrategy();\n268\t  const econEdge = new EconEdgeStrategy();\n269\t\n270\t  const mrSignals = engine.scan(enrichedMarkets, meanReversion);\n271\t  // DISABLED: const momSignals = engine.scan(enrichedMarkets, momentum);\n272\t  // DISABLED: const cryptoSignals = engine.scan(enrichedMarkets, cryptoEdge);\n273\t  const nfpSignals = engine.scan(enrichedMarkets, nfpNowcast);\n274\t  const econSignals = engine.scan(enrichedMarkets, econEdge);\n275\t  const momSignals = [];\n276\t  const cryptoSignals = [];\n277\t\n278\t  // 5. Size positions\n279\t  const marketMap = Object.fromEntries(\n280\t    enrichedMarkets.flatMap((m) => [[m.id, m], [m.ticker, m]])\n281\t  );\n282\t  const sizedMr = sizer.sizeSignals(mrSignals, marketMap);\n283\t  const sizedMom = sizer.sizeSignals(momSignals, marketMap);\n284\t  const sizedCrypto = sizer.sizeSignals(cryptoSignals, marketMap);\n285\t  const sizedNfp = sizer.sizeSignals(nfpSignals, marketMap);\n286\t  const sizedEcon = sizer.sizeSignals(econSignals, marketMap);\n287\t\n288\t  // 6. Build output signals\n289\t  const allSignals = [\n290\t    ...sizedMr.map((s) => ({ ...s, strategy: \"mean_reversion\", ticker: marketMap[s.marketId]?.ticker })),\n291\t    ...sizedMom.map((s) => ({ ...s, strategy: \"momentum\", ticker: marketMap[s.marketId]?.ticker })),\n292\t    ...sizedCrypto.map((s) => ({ ...s, strategy: \"crypto_edge\", ticker: s.ticker || marketMap[s.marketId]?.ticker || s.marketId })),\n293\t    ...sizedNfp.map((s) => ({ ...s, strategy: \"nfp_nowcast\", ticker: s.ticker || marketMap[s.marketId]?.ticker || s.marketId })),\n294\t    ...sizedEcon.map((s) => ({ ...s, strategy: \"econ_edge\", ticker: s.ticker || marketMap[s.marketId]?.ticker || s.marketId })),\n295\t  ];\n296\t\n297\t  // 7. Risk management check\n298\t  let approvedSignals = allSignals;\n299\t  let rejectedSignals = [];\n300\t  \n301\t  try {\n302\t    console.log(\"\\n🔒 Running risk checks...\");\n303\t    const riskSummary = await getRiskSummary();\n304\t    console.log(`  Risk Status: ${riskSummary.status}`);\n305\t    console.log(`  Daily P&L: $${(riskSummary.current.dailyPnL.total / 100).toFixed(2)}`);\n306\t    console.log(`  Total Exposure: $${(riskSummary.current.totalExposure / 100).toFixed(2)} / $${(riskSummary.limits.maxTotalExposure / 100).toFixed(2)}`);\n307\t    \n308\t    // Validate each signal against risk limits\n309\t    approvedSignals = [];\n310\t    \n311\t    for (const signal of allSignals) {\n312\t      const trade = {\n313\t        marketTicker: signal.ticker || signal.marketId,\n314\t        side: signal.side,\n315\t        quantity: signal.sizing?.contracts || 1,\n316\t        price: signal.currentPrice || 50,\n317\t      };\n318\t      \n319\t      const validation = await validateTrade(trade);\n320\t      if (validation.approved) {\n321\t        approvedSignals.push(signal);\n322\t      } else {\n323\t        rejectedSignals.push({ signal, reason: validation.reasons[0] });\n324\t      }\n325\t    }\n326\t    \n327\t    if (rejectedSignals.length > 0) {\n328\t      console.log(`  ⚠️  Risk rejected ${rejectedSignals.length} signals:`);\n329\t      rejectedSignals.forEach(r => console.log(`    - ${r.signal.ticker || r.signal.marketId}: ${r.reason}`));\n330\t    }\n331\t    console.log(`  ✅ Risk approved ${approvedSignals.length} signals`);\n332\t  } catch (riskErr) {\n333\t    console.log(`  ⚠️  Risk manager unavailable (${riskErr.message}) — approving all ${allSignals.length} signals`);\n334\t    approvedSignals = allSignals;\n335\t    rejectedSignals = [];\n336\t  }\n337\t\n338\t  // 8. Execute trades if requested (only approved signals)\n339\t  let executionReport = null;\n340\t  if (EXECUTE_TRADES && approvedSignals.length > 0) {\n341\t    if (PAPER_TRADING) {\n342\t      console.log(\"\\n📝 PAPER TRADING MODE — logging trades without execution\");\n343\t      executionReport = {\n344\t        mode: \"paper_trading\",\n345\t        executed: approvedSignals.length,\n346\t        rejected: 0,\n347\t        failed: 0,\n348\t        trades: approvedSignals.map(s => ({\n349\t          ticker: s.ticker || s.marketId,\n350\t          side: s.side,\n351\t          contracts: s.sizing?.contracts || 1,\n352\t          price: s.currentPrice,\n353\t          strategy: s.strategy,\n354\t          timestamp: new Date().toISOString(),\n355\t        })),\n356\t      };\n357\t      // Write paper trade log\n358\t      const paperTradeLogFile = path.join(__dirname, \"../../output/paper_trade_log.json\");\n359\t      fs.mkdirSync(path.dirname(paperTradeLogFile), { recursive: true });\n360\t      fs.writeFileSync(paperTradeLogFile, JSON.stringify(executionReport, null, 2));\n361\t      console.log(`  Logged ${executionReport.executed} paper trades to paper_trade_log.json`);\n362\t    } else {\n363\t      console.log(\"\\n🚀 LIVE TRADING MODE — executing real orders via Kalshi API\");\n364\t      const engine = new ExecutionEngine({\n365\t        kalshiClient: client,\n366\t        demoMode: false,\n367\t      });\n368\t      executionReport = await engine.executeSignals(approvedSignals, enrichedMarkets);\n369\t      console.log(`Executed: ${executionReport.executed}, Rejected: ${executionReport.rejected}, Failed: ${executionReport.failed}`);\n370\t    }\n371\t  } else if (EXECUTE_TRADES) {\n372\t    console.log(\"\\n⏸️  No signals passed risk checks — skipping execution\");\n373\t  }\n374\t\n375\t  const report = {\n376\t    generatedAt: new Date().toISOString(),\n377\t    source: USE_MOCK_FALLBACK ? \"mock_fallback\" : \"kalshi_live\",\n378\t    marketCount: enrichedMarkets.length,\n379\t    signalCount: allSignals.length,\n380\t    executed: executionReport ? true : false,\n381\t    executionReport: executionReport || undefined,\n382\t    markets: enrichedMarkets.map((m) => ({\n383\t      id: m.id,\n384\t      ticker: m.ticker,\n385\t      title: m.title,\n386\t      category: m.category,\n387\t      yesMid: m.yes_mid,\n388\t      noMid: m.no_mid,\n389\t      volume: m.volume,\n390\t      priceHistoryMean: m.price_history_mean,\n391\t      priceHistoryStddev: m.price_history_stddev,\n392\t      priceChange24h: m.price_change_24h,\n393\t    })),\n394\t    signals: allSignals.map((s) => ({\n395\t      strategy: s.strategy,\n396\t      marketId: s.marketId,\n397\t      ticker: marketMap[s.marketId]?.ticker,\n398\t      side: s.side,\n399\t      signalType: s.signalType,\n400\t      confidence: parseFloat(s.confidence.toFixed(4)),\n401\t      targetPrice: s.targetPrice,\n402\t      currentPrice: s.currentPrice,\n403\t      expectedEdge: s.expectedEdge,\n404\t      recommendedContracts: s.sizing.contracts,\n405\t      riskAmount: s.sizing.riskAmount,\n406\t      reason: s.reason,\n407\t    })),\n408\t  };\n409\t\n410\t  // 7. Write output\n411\t  fs.mkdirSync(path.dirname(OUTPUT_FILE), { recursive: true });\n412\t  fs.writeFileSync(OUTPUT_FILE, JSON.stringify(report, null, 2));\n413\t\n414\t  console.log(`\\n✅ Wrote ${allSignals.length} signals to ${OUTPUT_FILE}`);\n415\t  for (const s of allSignals) {\n416\t    console.log(`  [${s.strategy}] ${s.side.toUpperCase()} ${s.ticker} @ ${s.currentPrice}c — size=${s.sizing.contracts} contracts (conf=${(s.confidence * 100).toFixed(1)}%)`);\n417\t  }\n418\t}\n419\t\n420\tmain().catch((err) => {\n421\t  console.error(\"Fatal error:\", err);\n422\t  process.exit(1);\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"f84830d1-6822-4bac-9904-5c4ed4916476","uuid":"8f093204-cb74-4548-870e-bbbea7f98cd2","timestamp":"2026-04-03T18:12:42.031Z","tool_use_result":{"type":"text","file