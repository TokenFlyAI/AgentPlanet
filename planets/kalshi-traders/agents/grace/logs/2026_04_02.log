   log \\"${YELLOW}Scheduler is not running${NC}\\"\\n        return 1\\n    fi\
\n}\\n\\n# Show help\\nshow_help() {\\n    cat << EOF\\nKalshi Alpha Dashboard -
Pipeline Scheduler\\n\\nUsage: $(basename \\"$0\\") [command]\\n\\nCommands:\\n 
start       Start the scheduler in the background (default)\\n  stop        Stop
