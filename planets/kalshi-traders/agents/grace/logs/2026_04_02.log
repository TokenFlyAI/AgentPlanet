utes to generate fresh trading signals\\n#\\n# Usage:\\n#   ./run_scheduler.sh  
Start in background\\n#   ./run_scheduler.sh stop      # Stop the scheduler\\n# 
 ./run_scheduler.sh status    # Check if running\\n#\\n# Author: Grace (Data Eng
ineer)\\n# Task: #241 - Set up pipeline scheduler for live trading\\n#\\n\\nset 
-euo pipefail\\n\\n# Configuration\\nSCRIPT_DIR=\\"$(cd \\"$(dirname \\"${BASH_S
OURCE[0]}\\")\\" && pwd)\\"\\nPROJECT_ROOT=\\"$(cd \\"${SCRIPT_DIR}/../../..\\" 
&& pwd)\\"\\nLIVE_RUNNER=\\"${PROJECT_ROOT}/bob/backend/strategies/live_runner.j
s\\"\\nOUTPUT_DIR=\\"${PROJECT_ROOT}/bob/output\\"\\nLOG_DIR=\\"${PROJECT_ROOT}/
bob/backend/dashboard/logs\\"\\nPIDFILE=\\"${LOG_DIR}/scheduler.pid\\"\\nRUN_INT
ERVAL=600  # 10 minutes in seconds\\n\\n# Colors for output\\nRED=\'\\\\033[0;31
m\'\\nGREEN=\'\\\\033[0;32m\'\\nYELLOW=\'\\\\033[1;33m\'\\nNC=\'\\\\033[0m\' # N
o Color\\n\\n# Ensure directories exist\\nmkdir -p \\"${LOG_DIR}\\"\\nmkdir -p \
\"${OUTPUT_DIR}\\"\\n\\n# Logging function\\nlog() {\\n    local timestamp=$(dat
e \'+%Y-%m-%d %H:%M:%S\')\\n    echo -e \\"[${timestamp}] $1\\" | tee -a \\"${LO
G_DIR}/scheduler.log\\"\\n}\\n\\n# Check if Node.js is available\\ncheck_node() 
{\\n    if ! command -v node &> /dev/null; then\\n        log \\"${RED}ERROR: No
de.js is not installed or not in PATH${NC}\\"\\n        exit 1\\n    fi\\n    \\
n    local node_version=$(node --version)\\n    log \\"${GREEN}Node.js version: 
${node_version}${NC}\\"\\n}\\n\\n# Check if live_runner.js exists\\ncheck_runner
() {\\n    if [[ ! -f \\"${LIVE_RUNNER}\\" ]]; then\\n        log \\"${RED}ERROR
: live_runner.js not found at ${LIVE_RUNNER}${NC}\\"\\n        exit 1\\n    fi\\
n    log \\"${GREEN}Found live_runner.js${NC}\\"\\n}\\n\\n# Run the pipeline onc
e\\nrun_pipeline() {\\n    local timestamp=$(date \'+%Y%m%d_%H%M%S\')\\n    loca
l run_log=\\"${LOG_DIR}/run_${timestamp}.log\\"\\n    \\n    log \\"${YELLOW}Run
ning pipeline...${NC}\\"\\n    \\n    if cd \\"$(dirname \\"${LIVE_RUNNER}\\")\\
" && node live_runner.js > \\"${run_log}\\" 2>&1; then\\n        local signal_co
unt=$(grep -o \'\\"signalCount\\":[0-9]*\' \\"${OUTPUT_DIR}/trade_signals.json\\
" 2>/dev/null | cut -d: -f2 || echo \\"0\\")\\n        log \\"${GREEN}✓ Pipeline
completed successfully (${signal_count} signals generated)${NC}\\"\\n        \\n
og 2>/dev/null | tail -n +51 | xargs -r rm -f\\n        \\n        return 0\\n  
 else\\n        log \\"${RED}✗ Pipeline failed (see ${run_log})${NC}\\"\\n      
 return 1\\n    fi\\n}\\n\\n# Main scheduler loop\\nscheduler_loop() {\\n    log
\\"${GREEN}=== Kalshi Pipeline Scheduler Started ===${NC}\\"\\n    log \\"Config
uration:\\"\\n    log \\"  - Live runner: ${LIVE_RUNNER}\\"\\n    log \\"  - Out
put: ${OUTPUT_DIR}/trade_signals.json\\"\\n    log \\"  - Logs: ${LOG_DIR}\\"\\n
   log \\"  - Interval: ${RUN_INTERVAL} seconds (10 minutes)\\"\\n    log \\"\\"
\\n    \\n    # Run immediately on start\\n    run_pipeline\\n    \\n    # Sched
ule subsequent runs\\n    while true; do\\n        sleep \\"${RUN_INTERVAL}\\"\\
n        run_pipeline\\n    done\\n}\\n\\n# Start the scheduler\\nstart_schedule
r() {\\n    if [[ -f \\"${PIDFILE}\\" ]]; then\\n        local pid=$(cat \\"${PI
DFILE}\\")\\n        if ps -p \\"${pid}\\" > /dev/null 2>&1; then\\n            
log \\"${YELLOW}Scheduler is already running (PID: ${pid})${NC}\\"\\n           
exit 0\\n        else\\n            rm -f \\"${PIDFILE}\\"\\n        fi\\n    fi
\\n    \\n    check_node\\n    check_runner\\n    \\n    # Run in background\\n 
  scheduler_loop &\\n    local pid=$!\\n    echo $pid > \\"${PIDFILE}\\"\\n    \
\n    log \\"${GREEN}Scheduler started (PID: ${pid})${NC}\\"\\n    log \\"${GREE
