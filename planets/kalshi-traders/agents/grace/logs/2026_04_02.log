n\\n                local last_modified=$(stat -c %Y \\"${OUTPUT_DIR}/trade_sign
als.json\\" 2>/dev/null || stat -f %m \\"${OUTPUT_DIR}/trade_signals.json\\" 2>/
dev/null || echo \\"0\\")\\n                local now=$(date +%s)\\n            
   local age=$((now - last_modified))\\n                local age_min=$((age / 6
0))\\n                log \\"Last signal file update: ${age_min} minutes ago\\"\
\n            fi\\n            \\n            # Show recent log\\n            if
[[ -f \\"${LOG_DIR}/scheduler.log\\" ]]; then\\n                log \\"Recent ac
