)\n#   ./run_scheduler.sh &         # Start in background\n#   ./run_scheduler.s
h stop      # Stop the scheduler\n#   ./run_scheduler.sh status    # Check if ru
nning\n#\n# Author: Grace (Data Engineer)\n# Task: #241 - Set up pipeline schedu
ler for live trading\n#\n\nset -euo pipefail\n\n# Configuration\nSCRIPT_DIR="$(c
