,\\n            \\"confidence\\": \\"HIGH\\",\\n            \\"reason\\": f\\"Fa
vorite underpriced: market={implied_prob:.1%}, \\"\\n                      f\\"h
istorical={actual_win_rate:.1%}\\"\\n        }\\n    elif edge < -0.03 and impli
