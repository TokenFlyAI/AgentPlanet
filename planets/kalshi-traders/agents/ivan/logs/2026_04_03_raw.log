{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vuy4kSN1Q2GSc7zkyXHxcJ","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\t\"\"\"\n3\tLLM-Based Market Clustering Engine\n4\t\n5\tTask 344: Use LLM embeddings to identify hidden correlations in Kalshi markets\n6\t\n7\tInput: agents/public/markets_filtered.json\n8\tOutput: agents/public/market_clusters.json\n9\t\"\"\"\n10\t\n11\timport json\n12\timport numpy as np\n13\tfrom typing import List, Dict, Tuple\n14\tfrom dataclasses import dataclass\n15\timport re\n16\tfrom datetime import datetime\n17\t\n18\t\n19\t@dataclass\n20\tclass Market:\n21\t    \"\"\"Represents a Kalshi market\"\"\"\n22\t    ticker: str\n23\t    title: str\n24\t    category: str\n25\t    description: str = \"\"\n26\t    \n27\t    def to_text(self) -> str:\n28\t        \"\"\"Convert market to text for embedding\"\"\"\n29\t        return f\"{self.title}. Category: {self.category}. Ticker: {self.ticker}\"\n30\t\n31\t\n32\t@dataclass\n33\tclass Cluster:\n34\t    \"\"\"Represents a market cluster\"\"\"\n35\t    id: str\n36\t    label: str\n37\t    markets: List[str]\n38\t    correlation_strength: float\n39\t    description: str = \"\"\n40\t\n41\t\n42\tclass SimpleEmbeddingEngine:\n43\t    \"\"\"\n44\t    Simplified embedding engine using keyword-based vectors.\n45\t    \n46\t    In production, this would use OpenAI/Claude API for real embeddings.\n47\t    For this implementation, we use semantic keyword matching.\n48\t    \"\"\"\n49\t    \n50\t    # Domain-specific keywords for clustering\n51\t    DOMAIN_KEYWORDS = {\n52\t        'crypto': [\n53\t            'bitcoin', 'btc', 'ethereum', 'eth', 'crypto', 'cryptocurrency',\n54\t            'blockchain', 'digital asset', 'coin', 'token', 'altcoin',\n55\t            'defi', 'nft', 'mining', 'wallet', 'exchange'\n56\t        ],\n57\t        'politics': [\n58\t            'election', 'president', 'congress', 'senate', 'house',\n59\t            'vote', 'ballot', 'candidate', 'party', 'democrat', 'republican',\n60\t            'trump', 'biden', 'legislation', 'policy', 'government'\n61\t        ],\n62\t        'economics': [\n63\t            'fed', 'federal reserve', 'interest rate', 'inflation', 'cpi',\n64\t            'gdp', 'unemployment', 'jobs', 'nfp', 'recession', 'economy',\n65\t            'monetary policy', 'fiscal', 'treasury', 'dollar'\n66\t        ],\n67\t        'sports': [\n68\t            'super bowl', 'nba', 'nfl', 'mlb', 'nhl', 'championship',\n69\t            'playoff', 'game', 'match', 'team', 'player', 'season',\n70\t            'tournament', 'finals', 'world cup', 'olympics'\n71\t        ],\n72\t        'finance': [\n73\t            'sp500', 's&p', 'nasdaq', 'dow', 'index', 'stock', 'equity',\n74\t            'market', 'trading', 'volatility', 'bull', 'bear', 'rally',\n75\t            'correction', 'ipo', 'earnings'\n76\t        ],\n77\t        'weather': [\n78\t            'hurricane', 'storm', 'temperature', 'rain', 'snow', 'drought',\n79\t            'climate', 'weather', 'season', 'winter', 'summer', 'tornado'\n80\t        ],\n81\t        'technology': [\n82\t            'ai', 'artificial intelligence', 'tech', 'software', 'hardware',\n83\t            'semiconductor', 'chip', 'cloud', 'data', 'cyber', 'digital'\n84\t        ],\n85\t        'entertainment': [\n86\t            'movie', 'film', 'oscar', 'grammy', 'emmy', 'award',\n87\t            'celebrity', 'music', 'album', 'streaming', 'box office'\n88\t        ]\n89\t    }\n90\t    \n91\t    def __init__(self):\n92\t        self.dimensions = len(self.DOMAIN_KEYWORDS)\n93\t        self.domains = list(self.DOMAIN_KEYWORDS.keys())\n94\t    \n95\t    def embed(self, text: str) -> np.ndarray:\n96\t        \"\"\"\n97\t        Create embedding vector based on keyword presence.\n98\t        \n99\t        Returns normalized vector where each dimension represents\n100\t        strength of association with a domain.\n101\t        \"\"\"\n102\t        text_lower = text.lower()\n103\t        vector = np.zeros(self.dimensions)\n104\t        \n105\t        for i, (domain, keywords) in enumerate(self.DOMAIN_KEYWORDS.items()):\n106\t            score = 0\n107\t            for keyword in keywords:\n108\t                if keyword in text_lower:\n109\t                    # Weight exact matches higher\n110\t                    if f\" {keyword} \" in f\" {text_lower} \":\n111\t                        score += 2\n112\t                    else:\n113\t                        score += 1\n114\t            vector[i] = score\n115\t        \n116\t        # Normalize\n117\t        norm = np.linalg.norm(vector)\n118\t        if norm > 0:\n119\t            vector = vector / norm\n120\t        \n121\t        return vector\n122\t    \n123\t    def similarity(self, vec1: np.ndarray, vec2: np.ndarray) -> float:\n124\t        \"\"\"Cosine similarity between two vectors\"\"\"\n125\t        return np.dot(vec1, vec2)\n126\t\n127\t\n128\tclass MarketClusteringEngine:\n129\t    \"\"\"Main clustering engine for Kalshi markets\"\"\"\n130\t    \n131\t    def __init__(self, similarity_threshold: float = 0.3):\n132\t        self.embedder = SimpleEmbeddingEngine()\n133\t        self.similarity_threshold = similarity_threshold\n134\t    \n135\t    def load_markets(self, filepath: str) -> List[Market]:\n136\t        \"\"\"Load markets from JSON file\"\"\"\n137\t        try:\n138\t            with open(filepath, 'r') as f:\n139\t                data = json.load(f)\n140\t            \n141\t            markets = []\n142\t            # Support both 'markets' and 'qualifying_markets' keys\n143\t            market_items = data.get('markets', []) or data.get('qualifying_markets', [])\n144\t            for item in market_items:\n145\t                market = Market(\n146\t                    ticker=item.get('ticker', ''),\n147\t                    title=item.get('title', ''),\n148\t                    category=item.get('category', ''),\n149\t                    description=item.get('description', '')\n150\t                )\n151\t                markets.append(market)\n152\t            \n153\t            return markets\n154\t        except FileNotFoundError:\n155\t            print(f\"Warning: {filepath} not found. Using sample data.\")\n156\t            return self._get_sample_markets()\n157\t        except json.JSONDecodeError:\n158\t            print(f\"Warning: {filepath} is empty or invalid. Using sample data.\")\n159\t            return self._get_sample_markets()\n160\t    \n161\t    def _get_sample_markets(self) -> List[Market]:\n162\t        \"\"\"Sample markets for testing\"\"\"\n163\t        return [\n164\t            Market(\"BTCW-26-JUN-100K\", \"Will Bitcoin exceed $100,000 by June 2026?\", \"Crypto\"),\n165\t            Market(\"ETHW-26-DEC-5K\", \"Will Ethereum exceed $5,000 by December 2026?\", \"Crypto\"),\n166\t            Market(\"BTC-DOM-60\", \"Will Bitcoin dominance exceed 60%?\", \"Crypto\"),\n167\t            Market(\"ETH-BTC-RATIO\", \"Will ETH/BTC ratio exceed 0.08?\", \"Crypto\"),\n168\t            Market(\"US-PRES-2024\", \"Who will win the 2024 US Presidential election?\", \"Politics\"),\n169\t            Market(\"SENATE-CONTROL\", \"Which party will control the Senate?\", \"Politics\"),\n170\t            Market(\"FED-RATE-DEC\", \"Will Fed raise rates in December?\", \"Economics\"),\n171\t            Market(\"CPI-OVER-4\", \"Will CPI exceed 4%?\", \"Economics\"),\n172\t            Market(\"SP500-5000\", \"Will S&P 500 close above 5000?\", \"Finance\"),\n173\t            Market(\"NASDAQ-ALLTIME\", \"Will Nasdaq hit all-time high?\", \"Finance\"),\n174\t            Market(\"SUPER-BOWL-LVIII\", \"Who will win Super Bowl LVIII?\", \"Sports\"),\n175\t            Market(\"NBA-CHAMP-2024\", \"Who will win NBA Championship 2024?\", \"Sports\"),\n176\t            Market(\"HURRICANE-CAT5\", \"Will a Category 5 hurricane make landfall?\", \"Weather\"),\n177\t            Market(\"AI-BREAKTHROUGH\", \"Will there be major AI breakthrough?\", \"Technology\"),\n178\t            Market(\"OSCAR-BEST-PICTURE\", \"Which film wins Best Picture?\", \"Entertainment\"),\n179\t        ]\n180\t    \n181\t    def cluster_markets(self, markets: List[Market]) -> List[Cluster]:\n182\t        \"\"\"\n183\t        Cluster markets based on embedding similarity.\n184\t        \n185\t        Uses agglomerative clustering approach:\n186\t        1. Embed all markets\n187\t        2. Calculate pairwise similarities\n188\t        3. Group markets with similarity > threshold\n189\t        \"\"\"\n190\t        if not markets:\n191\t            return []\n192\t        \n193\t        # Embed all markets\n194\t        embeddings = {}\n195\t        for market in markets:\n196\t            text = market.to_text()\n197\t            embeddings[market.ticker] = self.embedder.embed(text)\n198\t        \n199\t        # Calculate pairwise similarities\n200\t        similarities = {}\n201\t        for i, m1 in enumerate(markets):\n202\t            for m2 in markets[i+1:]:\n203\t                sim = self.embedder.similarity(\n204\t                    embeddings[m1.ticker],\n205\t                    embeddings[m2.ticker]\n206\t                )\n207\t                if sim >= self.similarity_threshold:\n208\t                    similarities[(m1.ticker, m2.ticker)] = sim\n209\t        \n210\t        # Build clusters using connected components\n211\t        clusters = self._build_clusters(markets, similarities)\n212\t        \n213\t        return clusters\n214\t    \n215\t    def _build_clusters(self, markets: List[Market], similarities: Dict) -> List[Cluster]:\n216\t        \"\"\"Build clusters from similarity graph\"\"\"\n217\t        # Group by domain first\n218\t        domain_groups = {}\n219\t        \n220\t        for market in markets:\n221\t            text = market.to_text()\n222\t            embedding = self.embedder.embed(text)\n223\t            \n224\t            # Find dominant domain\n225\t            max_idx = np.argmax(embedding)\n226\t            domain = self.embedder.domains[max_idx]\n227\t            \n228\t            if domain not in domain_groups:\n229\t                domain_groups[domain] = []\n230\t            domain_groups[domain].append((market, embedding))\n231\t        \n232\t        # Create clusters\n233\t        clusters = []\n234\t        for domain, items in domain_groups.items():\n235\t            if len(items) < 2:\n236\t                continue\n237\t            \n238\t            market_tickers = [item[0].ticker for item in items]\n239\t            \n240\t            # Calculate average correlation strength\n241\t            avg_strength = 0\n242\t            count = 0\n243\t            for i, (_, emb1) in enumerate(items):\n244\t                for _, emb2 in items[i+1:]:\n245\t                    sim = self.embedder.similarity(emb1, emb2)\n246\t                    avg_strength += sim\n247\t                    count += 1\n248\t            \n249\t            if count > 0:\n250\t                avg_strength /= count\n251\t            \n252\t            cluster = Cluster(\n253\t                id=f\"{domain}_cluster\",\n254\t                label=f\"{domain.capitalize()} Markets\",\n255\t                markets=market_tickers,\n256\t                correlation_strength=round(avg_strength, 2),\n257\t                description=f\"Markets related to {domain}\"\n258\t            )\n259\t            clusters.append(cluster)\n260\t        \n261\t        # Sort by correlation strength\n262\t        clusters.sort(key=lambda c: c.correlation_strength, reverse=True)\n263\t        \n264\t        return clusters\n265\t    \n266\t    def find_hidden_correlations(self, markets: List[Market]) -> List[Dict]:\n267\t        \"\"\"\n268\t        Find non-obvious correlations between markets.\n269\t        \n270\t        Example: Crypto markets might correlate with tech stocks\n271\t        \"\"\"\n272\t        embeddings = {m.ticker: self.embedder.embed(m.to_text()) for m in markets}\n273\t        \n274\t        hidden = []\n275\t        for i, m1 in enumerate(markets):\n276\t            for m2 in markets[i+1:]:\n277\t                # Skip if same obvious category\n278\t                if m1.category == m2.category:\n279\t                    continue\n280\t                \n281\t                sim = self.embedder.similarity(\n282\t                    embeddings[m1.ticker],\n283\t                    embeddings[m2.ticker]\n284\t                )\n285\t                \n286\t                # High similarity across different categories = hidden correlation\n287\t                if sim >= 0.4:\n288\t                    hidden.append({\n289\t                        \"market1\": m1.ticker,\n290\t                        \"market2\": m2.ticker,\n291\t                        \"categories\": [m1.category, m2.category],\n292\t                        \"correlation\": round(sim, 2),\n293\t                        \"insight\": f\"{m1.category} market correlates with {m2.category} market\"\n294\t                    })\n295\t        \n296\t        return sorted(hidden, key=lambda x: x['correlation'], reverse=True)\n297\t    \n298\t    def generate_output(self, clusters: List[Cluster], hidden: List[Dict]) -> Dict:\n299\t        \"\"\"Generate final output JSON\"\"\"\n300\t        return {\n301\t            \"generated_at\": datetime.now().isoformat(),\n302\t            \"method\": \"LLM embedding similarity (keyword-based)\",\n303\t            \"similarity_threshold\": self.similarity_threshold,\n304\t            \"clusters\": [\n305\t                {\n306\t                    \"id\": c.id,\n307\t                    \"label\": c.label,\n308\t                    \"markets\": c.markets,\n309\t                    \"correlation_strength\": c.correlation_strength,\n310\t                    \"description\": c.description\n311\t                }\n312\t                for c in clusters\n313\t            ],\n314\t            \"hidden_correlations\": hidden[:10],  # Top 10\n315\t            \"summary\": {\n316\t                \"total_clusters\": len(clusters),\n317\t                \"total_markets_clustered\": sum(len(c.markets) for c in clusters),\n318\t                \"hidden_correlations_found\": len(hidden)\n319\t            }\n320\t        }\n321\t\n322\t\n323\tdef main():\n324\t    \"\"\"Main execution\"\"\"\n325\t    print(\"LLM-Based Market Clustering Engine — Task 344\")\n326\t    print(\"=\" * 60)\n327\t    \n328\t    # Initialize engine\n329\t    engine = MarketClusteringEngine(similarity_threshold=0.3)\n330\t    \n331\t    # Load markets\n332\t    input_path = \"../public/markets_filtered.json\"\n333\t    markets = engine.load_markets(input_path)\n334\t    print(f\"\\nLoaded {len(markets)} markets\")\n335\t    \n336\t    # Perform clustering\n337\t    print(\"\\nClustering markets...\")\n338\t    clusters = engine.cluster_markets(markets)\n339\t    print(f\"Found {len(clusters)} clusters\")\n340\t    \n341\t    # Find hidden correlations\n342\t    print(\"\\nFinding hidden correlations...\")\n343\t    hidden = engine.find_hidden_correlations(markets)\n344\t    print(f\"Found {len(hidden)} hidden correlations\")\n345\t    \n346\t    # Generate output\n347\t    output = engine.generate_output(clusters, hidden)\n348\t    \n349\t    # Display results\n350\t    print(\"\\n\" + \"=\" * 60)\n351\t    print(\"CLUSTERS\")\n352\t    print(\"=\" * 60)\n353\t    \n354\t    for cluster in clusters:\n355\t        print(f\"\\n{cluster.label} (strength: {cluster.correlation_strength})\")\n356\t        for ticker in cluster.markets:\n357\t            print(f\"  - {ticker}\")\n358\t    \n359\t    if hidden:\n360\t        print(\"\\n\" + \"=\" * 60)\n361\t        print(\"HIDDEN CORRELATIONS (Top 5)\")\n362\t        print(\"=\" * 60)\n363\t        \n364\t        for corr in hidden[:5]:\n365\t            print(f\"\\n{corr['market1']} <-> {corr['market2']}\")\n366\t            print(f\"  Correlation: {corr['correlation']}\")\n367\t            print(f\"  Insight: {corr['insight']}\")\n368\t    \n369\t    # Save output\n370\t    output_path = \"../public/market_clusters.json\"\n371\t    with open(output_path, 'w') as f:\n372\t        json.dump(output, f, indent=2)\n373\t    \n374\t    print(f\"\\n✅ Output saved to: {output_path}\")\n375\t    print(f\"   Total clusters: {output['summary']['total_clusters']}\")\n376\t    print(f\"   Markets clustered: {output['summary']['total_markets_clustered']}\")\n377\t    print(f\"   Hidden correlations: {output['summary']['hidden_correlations_found']}\")\n378\t    \n379\t    return output\n380\t\n381\t\n382\tif __name__ == '__main__':\n383\t    main()\n384\t"}]},"parent_tool_use_id":null,"session_id":"2314586d-4a22-49f4-97ca-864b80234997","uuid":"242abbd8-76fd-473e-99a7-fc2f12d81873","timestamp":"2026-04-04T05:46:25.836Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/chenyangcui/Documents/code/aicompany/planets/kalshi-traders/agents/ivan/output/llm_market_clustering.py","content":"#!/usr/bin/env python3\n\"\"\"\nLLM-Based Market Clustering Engine\n\nTask 344: Use LLM embeddings to identify hidden correlations in Kalshi markets\n\nInput: agents/public/markets_filtered.json\nOutput: agents/public/market_clusters.json\n\"\"\"\n\nimport json\nimport numpy as np\nfrom typing import List, Dict, Tuple\nfrom dataclasses import dataclass\nimport re\nfrom datetime import datetime\n\n\n@dataclass\nclass Market:\n    \"\"\"Represents a Kalshi market\"\"\"\n    ticker: str\n    title: str\n    category: str\n    description: str = \"\"\n    \n    def to_text(self) -> str:\n        \"\"\"Convert market to text for embedding\"\"\"\n        return f\"{self.title}. Category: {self.category}. Ticker: {self.ticker}\"\n\n\n@dataclass\nclass Cluster:\n    \"\"\"Represents a market cluster\"\"\"\n    id: str\n    label: str\n    markets: List[str]\n    correlation_strength: float\n    description: str = \"\"\n\n\nclass SimpleEmbeddingEngine:\n    \"\"\"\n    Simplified embedding engine using keyword-based vectors.\n    \n    In production, this would use OpenAI/Claude API for real embeddings.\n    For this implementation, we use semantic keyword matching.\n    \"\"\"\n    \n    # Domain-specific keywords for clustering\n    DOMAIN_KEYWORDS = {\n        'crypto': [\n            'bitcoin', 'btc', 'ethereum', 'eth', 'crypto', 'cryptocurrency',\n            'blockchain', 'digital asset', 'coin', 'token', 'altcoin',\n            'defi', 'nft', 'mining', 'wallet', 'exchange'\n        ],\n        'politics': [\n            'election', 'president', 'congress', 'senate', 'house',\n            'vote', 'ballot', 'candidate', 'party', 'democrat', 'republican',\n            'trump', 'biden', 'legislation', 'policy', 'government'\n        ],\n        'economics': [\n            'fed', 'federal reserve', 'interest rate', 'inflation', 'cpi',\n            'gdp', 'unemployment', 'jobs', 'nfp', 'recession', 'economy',\n            'monetary policy', 'fiscal', 'treasury', 'dollar'\n        ],\n        'sports': [\n            'super bowl', 'nba', 'nfl', 'mlb', 'nhl', 'championship',\n            'playoff', 'game', 'match', 'team', 'player', 'season',\n            'tournament', 'finals', 'world cup', 'olympics'\n        ],\n        'finance': [\n            'sp500', 's&p', 'nasdaq', 'dow', 'index', 'stock', 'equity',\n            'market', 'trading', 'volatility', 'bull', 'bear', 'rally',\n            'correction', 'ipo', 'earnings'\n        ],\n        'weather': [\n            'hurricane', 'storm', 'temperature', 'rain', 'snow', 'drought',\n            'climate', 'weather', 'season', 'winter', 'summer', 'tornado'\n        ],\n        'technology': [\n            'ai', 'artificial intelligence', 'tech', 'software', 'hardware',\n            'semiconductor', 'chip', 'cloud', 'data', 'cyber', 'digital'\n        ],\n        'entertainment': [\n            'movie', 'film', 'oscar', 'grammy', 'emmy', 'award',\n            'celebrity', 'music', 'album', 'streaming', 'box office'\n        ]\n    }\n    \n    def __init__(self):\n        self.dimensions = len(self.DOMAIN_KEYWORDS)\n        self.domains = list(self.DOMAIN_KEYWORDS.keys())\n    \n    def embed(self, text: str) -> np.ndarray:\n        \"\"\"\n        Create embedding vector based on keyword presence.\n        \n        Returns normalized vector where each dimension represents\n        strength of association with a domain.\n        \"\"\"\n        text_lower = text.lower()\n        vector = np.zeros(self.dimensions)\n        \n        for i, (domain, keywords) in enumerate(self.DOMAIN_KEYWORDS.items()):\n            score = 0\n            for keyword in keywords:\n                if keyword in text_lower:\n                    # Weight exact matches higher\n                    if f\" {keyword} \" in f\" {text_lower} \":\n                        score += 2\n                    else:\n                        score += 1\n            vector[i] = score\n        \n        # Normalize\n        norm = np.linalg.norm(vector)\n        if norm > 0:\n            vector = vector / norm\n        \n        return vector\n    \n    def similarity(self, vec1: np.ndarray, vec2: np.ndarray) -> float:\n        \"\"\"Cosine similarity between two vectors\"\"\"\n        return np.dot(vec1, vec2)\n\n\nclass MarketClusteringEngine:\n    \"\"\"Main clustering engine for Kalshi markets\"\"\"\n    \n    def __init__(self, similarity_threshold: float = 0.3):\n        self.embedder = SimpleEmbeddingEngine()\n        self.similarity_threshold = similarity_threshold\n    \n    def load_markets(self, filepath: str) -> List[Market]:\n        \"\"\"Load markets from JSON file\"\"\"\n        try:\n            with open(filepath, 'r') as f:\n                data = json.load(f)\n            \n            markets = []\n            # Support both 'markets' and 'qualifying_markets' keys\n            market_items = data.get('markets', []) or data.get('qualifying_markets', [])\n            for item in market_items:\n                market = Market(\n                    ticker=item.get('ticker', ''),\n                    title=item.get('title', ''),\n                    category=item.get('category', ''),\n                    description=item.get('description', '')\n                )\n                markets.append(market)\n            \n            return markets\n        except FileNotFoundError:\n            print(f\"Warning: {filepath} not found. Using sample data.\")\n            return self._get_sample_markets()\n        except json.JSONDecodeError:\n            print(f\"Warning: {filepath} is empty or invalid. Using sample data.\")\n            return self._get_sample_markets()\n    \n    def _get_sample_markets(self) -> List[Market]:\n        \"\"\"Sample markets for testing\"\"\"\n        return [\n            Market(\"BTCW-26-JUN-100K\", \"Will Bitcoin exceed $100,000 by June 2026?\", \"Crypto\"),\n            Market(\"ETHW-26-DEC-5K\", \"Will Ethereum exceed $5,000 by December 2026?\", \"Crypto\"),\n            Market(\"BTC-DOM-60\", \"Will Bitcoin dominance exceed 60%?\", \"Crypto\"),\n            Market(\"ETH-BTC-RATIO\", \"Will ETH/BTC ratio exceed 0.08?\", \"Crypto\"),\n            Market(\"US-PRES-2024\", \"Who will win the 2024 US Presidential election?\", \"Politics\"),\n            Market(\"SENATE-CONTROL\", \"Which party will control the Senate?\", \"Politics\"),\n            Market(\"FED-RATE-DEC\", \"Will Fed raise rates in December?\", \"Economics\"),\n            Market(\"CPI-OVER-4\", \"Will CPI exceed 4%?\", \"Economics\"),\n            Market(\"SP500-5000\", \"Will S&P 500 close above 5000?\", \"Finance\"),\n            Market(\"NASDAQ-ALLTIME\", \"Will Nasdaq hit all-time high?\", \"Finance\"),\n            Market(\"SUPER-BOWL-LVIII\", \"Who will win Super Bowl LVIII?\", \"Sports\"),\n            Market(\"NBA-CHAMP-2024\", \"Who will win NBA Championship 2024?\", \"Sports\"),\n            Market(\"HURRICANE-CAT5\", \"Will a Category 5 hurricane make landfall?\", \"Weather\"),\n            Market(\"AI-BREAKTHROUGH\", \"Will there be major AI breakthrough?\", \"Technology\"),\n            Market(\"OSCAR-BEST-PICTURE\", \"Which film wins Best Picture?\", \"Entertainment\"),\n        ]\n    \n    def cluster_markets(self, markets: List[Market]) -> List[Cluster]:\n        \"\"\"\n        Cluster markets based on embedding similarity.\n        \n        Uses agglomerative clustering approach:\n        1. Embed all markets\n        2. Calculate pairwise similarities\n        3. Group markets with similarity > threshold\n        \"\"\"\n        if not markets:\n            return []\n        \n        # Embed all markets\n        embeddings = {}\n        for market in markets:\n            text = market.to_text()\n            embeddings[market.ticker] = self.embedder.embed(text)\n        \n        # Calculate pairwise similarities\n        similarities = {}\n        for i, m1 in enumerate(markets):\n            for m2 in markets[i+1:]:\n                sim = self.embedder.similarity(\n                    embeddings[m1.ticker],\n                    embeddings[m2.ticker]\n                )\n                if sim >= self.similarity_threshold:\n                    similarities[(m1.ticker, m2.ticker)] = sim\n        \n        # Build clusters using connected components\n        clusters = self._build_clusters(markets, similarities)\n        \n        return clusters\n    \n    def _build_clusters(self, markets: List[Market], similarities: Dict) -> List[Cluster]:\n        \"\"\"Build clusters from similarity graph\"\"\"\n        # Group by domain first\n        domain_groups = {}\n        \n        for market in markets:\n            text = market.to_text()\n            embedding = self.embedder.embed(text)\n            \n            # Find dominant domain\n            max_idx = np.argmax(embedding)\n            domain = self.embedder.domains[max_idx]\n            \n            if domain not in domain_groups:\n                domain_groups[domain] = []\n            domain_groups[domain].append((market, embedding))\n        \n        # Create clusters\n        clusters = []\n        for domain, items in domain_groups.items():\n            if len(items) < 2:\n                continue\n            \n            market_tickers = [item[0].ticker for item in items]\n            \n            # Calculate average correlation strength\n            avg_strength = 0\n            count = 0\n            for i, (_, emb1) in enumerate(items):\n                for _, emb2 in items[i+1:]:\n                    sim = self.embedder.similarity(emb1, emb2)\n                    avg_strength += sim\n                    count += 1\n            \n            if count > 0:\n                avg_strength /= count\n            \n            cluster = Cluster(\n                id=f\"{domain}_cluster\",\n                label=f\"{domain.capitalize()} Markets\",\n                markets=market_tickers,\n                correlation_strength=round(avg_strength, 2),\n                description=f\"Markets related to {domain}\"\n            )\n            clusters.append(cluster)\n        \n        # Sort by correlation strength\n        clusters.sort(key=lambda c: c.correlation_strength, reverse=True)\n        \n        return clusters\n    \n    def find_hidden_correlations(self, markets: List[Market]) -> List[Dict]:\n        \"\"\"\n        Find non-obvious correlations between markets.\n        \n        Example: Crypto markets might correlate with tech stocks\n        \"\"\"\n        embeddings = {m.ticker: self.embedder.embed(m.to_text()) for m in markets}\n        \n        hidden = []\n        for i, m1 in enumerate(markets):\n            for m2 in markets[i+1:]:\n                # Skip if same obvious category\n                if m1.category == m2.category:\n                    continue\n                \n                sim = self.embedder.similarity(\n                    embeddings[m1.ticker],\n                    embeddings[m2.ticker]\n                )\n                \n                # High similarity across different categories = hidden correlation\n                if sim >= 0.4:\n                    hidden.append({\n                        \"market1\": m1.ticker,\n                        \"market2\": m2.ticker,\n                        \"categories\": [m1.category, m2.category],\n                        \"correlation\": round(sim, 2),\n                        \"insight\": f\"{m1.category} market correlates with {m2.category} market\"\n                    })\n        \n        return sorted(hidden, key=lambda x: x['correlation'], reverse=True)\n    \n    def generate_output(self, clusters: List[Cluster], hidden: List[Dict]) -> Dict:\n        \"\"\"Generate final output JSON\"\"\"\n        return {\n            \"generated_at\": datetime.now().isoformat(),\n            \"method\": \"LLM embedding similarity (keyword-based)\",\n            \"similarity_threshold\": self.similarity_threshold,\n            \"clusters\": [\n                {\n                    \"id\": c.id,\n                    \"label\": c.label,\n                    \"markets\": c.markets,\n                    \"correlation_strength\": c.correlation_strength,\n                    \"description\": c.description\n                }\n                for c in clusters\n            ],\n            \"hidden_correlations\": hidden[:10],  # Top 10\n            \"summary\": {\n                \"total_clusters\": len(clusters),\n                \"total_markets_clustered\": sum(len(c.markets) for c in clusters),\n                \"hidden_correlations_found\": len(hidden)\n            }\n        }\n\n\ndef main():\n    \"\"\"Main execution\"\"\"\n    print(\"LLM-Based Market Clustering Engine — Task 344\")\n    print(\"=\" * 60)\n    \n    # Initialize engine\n    engine = MarketClusteringEngine(similarity_threshold=0.3)\n    \n    # Load markets\n    input_path = \"../public/markets_filtered.json\"\n    markets = engine.load_markets(input_path)\n    print(f\"\\nLoaded {len(markets)} markets\")\n    \n    # Perform clustering\n    print(\"\\nClustering markets...\")\n    clusters = engine.cluster_markets(markets)\n    print(f\"Found {len(clusters)} clusters\")\n    \n    # Find hidden correlations\n    print(\"\\nFinding hidden correlations...\")\n    hidden = engine.find_hidden_correlations(markets)\n    print(f\"Found {len(hidden)} hidden correlations\")\n    \n    # Generate output\n    output = engine.generate_output(clusters, hidden)\n    \n    # Display results\n    print(\"\\n\" + \"=\" * 60)\n    print(\"CLUSTERS\")\n    print(\"=\" * 60)\n    \n    for cluster in clusters:\n        print(f\"\\n{cluster.label} (strength: {cluster.correlation_strength})\")\n        for ticker in cluster.markets:\n            print(f\"  - {ticker}\")\n    \n    if hidden:\n        print(\"\\n\" + \"=\" * 60)\n        print(\"HIDDEN CORRELATIONS (Top 5)\")\n        print(\"=\" * 60)\n        \n        for corr in hidden[:5]:\n            print(f\"\\n{corr['market1']} <-> {corr['market2']}\")\n            print(f\"  Correlation: {corr['correlation']}\")\n            print(f\"  Insight: {corr['insight']}\")\n    \n    # Save output\n    output_path = \"../public/market_clusters.json\"\n    with open(output_path, 'w') as f:\n        json.dump(output, f, indent=2)\n    \n    print(f\"\\n✅ Output saved to: {output_path}\")\n    print(f\"   Total clusters: {output['summary']['total_clusters']}\")\n    print(f\"   Markets clustered: {output['summary']['total_markets_clustered']}\")\n    print(f\"   Hidden correlations: {output['summary']['hidden_correlations_found']}\")\n    \n    return output\n\n\nif __name__ == '__main__':\n    main()\n","numLines":384,"startLine":1,"totalLines":384}}}
