t MIN_MARKETS = 3;\nconst CANDLE_DAYS = 7;\nconst OUTPUT_FILE = path.join(__dirname, \"../../output/trade_signals.json\");\nconst EXECUTE_TRADES = process.argv.includes(\"--execute\");\nconst PAPER_TRADING = process.env.PAPER_TRADING !== 'false';\n\n// Realistic fallback markets when API key is unavailable\nconst FALLBACK_MARKETS = [\n  {\n    id: \"m1\",\n    ticker: \"INXW-25-DEC31\",\n    title: \"S&P 500 to close above 5000\",\n    category: \"Economics\",\n    status: \"active\",\n    yes_bid: 85,\n    yes_ask: 87,\n    no_bid: 13,\n    no_ask: 15,\n    volume: 250000,\n    open_interest: 12000,\n  },\n  {\n    id: \"m2\",\n    ticker: \"BTCW-26-JUN30-80K\",\n    title: \"Will Bitcoin exceed $80,000 by June 30, 2026?\",\n    category: \"Crypto\",\n    status: \"active\",\n    yes_bid: 82,\n    yes_ask: 86,\n    no_bid: 14,\n    no_ask: 18,\n    volume: 720000,\n    open_interest: 8000,\n  },","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
