{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wpx4VyNqLgZ2LE8VjStUfF","type":"tool_result","content":"540\tusing data::RiskSummary;\n541\tusing data::TimestampUs;\n542\t\n543\tclass RiskManager {\n544\tpublic:\n545\t    RiskManager() : circuit_breaker_active_(false), circuit_breaker_triggered_at_(0) {}\n546\t\n547\t    RiskCheckResult pre_trade_check(const ArbitrageSignal& signal,\n548\t                                     const std::vector<OpenPosition>& positions,\n549\t                                     RiskSummary& summary,\n550\t                                     TimestampUs now_us) {\n551\t        (void)signal; (void)positions;\n552\t        RiskCheckResult result{true, {}, 0.0};\n553\t        double drawdown = calculate_max_drawdown(summary);\n554\t        if (drawdown >= config::MAX_DRAWDOWN_PERCENT) {\n555\t            result.approved = false;\n556\t            std::strncpy(result.rejection_reason, \"Max drawdown limit reached\", sizeof(result.rejection_reason) - 1);\n557\t            result.risk_score = 99.0;\n558\t            std::lock_guard<std::mutex> lock(mutex_);\n559\t            circuit_breaker_active_ = true;\n560\t            circuit_breaker_triggered_at_ = now_us;\n561\t            summary.circuit_breaker_triggered = true;\n562\t            return result;\n563\t        }\n564\t        if (is_circuit_breaker_active(summary)) {\n565\t            result.approved = false;\n566\t            std::strncpy(result.rejection_reason, \"Circuit breaker active\", sizeof(result.rejection_reason) - 1);\n567\t            result.risk_score = 100.0;\n568\t            return result;\n569\t        }\n570\t        if (summary.total_exposure_cents >= config::MAX_TOTAL_EXPOSURE_CENTS) {\n571\t            result.approved = false;\n572\t            std::strncpy(result.rejection_reason, \"Max exposure reached\", sizeof(result.rejection_reason) - 1);\n573\t            result.risk_score = 90.0;\n574\t            return result;\n575\t        }\n576\t        if (summary.realized_pnl_cents <= -static_cast<int64_t>(config::MAX_DAILY_LOSS_CENTS)) {\n577\t            result.approved = false;\n578\t            std::strncpy(result.rejection_reason, \"Daily loss limit reached\", sizeof(result.rejection_reason) - 1);\n579\t            result.risk_score = 95.0;\n580\t            return result;\n581\t        }\n582\t        return result;\n583\t    }\n584\t\n585\t    bool check_price_freshness(const char* ticker_a, const char* ticker_b,\n586\t                               TimestampUs price_time_a, TimestampUs price_time_b,\n587\t                               TimestampUs now_us) const {\n588\t        (void)ticker_a; (void)ticker_b;\n589\t        return (now_us - price_time_a) <= config::PRICE_FRESHNESS_US &&\n590\t               (now_us - price_time_b) <= config::PRICE_FRESHNESS_US;\n591\t    }\n592\t\n593\t    bool check_correlation_freshness(TimestampUs generated_at, TimestampUs now_us) const {\n594\t        return (now_us >= generated_at) && (now_us - generated_at) <= config::CORRELATION_FRESHNESS_US;\n595\t    }\n596\t\n597\t    bool is_circuit_breaker_active(const RiskSummary& summary) const {\n598\t        (void)summary;\n599\t        std::lock_guard<std::mutex> lock(mutex_);\n600\t        return circuit_breaker_active_;\n601\t    }\n602\t\n603\t    RiskCheckResult in_flight_check(const PairedOrder& order,\n604\t                                     data::Price current_price_a,\n605\t                                     data::Price current_price_b) const {\n606\t        RiskCheckResult result{true, {}, 0.0};\n607\t        if (order.leg_a.contracts + order.leg_b.contracts > config::MAX_POSITION_SIZE) {\n608\t            result.approved = false;\n609\t            std::strncpy(result.rejection_reason, \"Position size too large\", sizeof(result.rejection_reason) - 1);\n610\t            result.risk_score = 80.0;\n611\t            return result;\n612\t        }\n613\t        (void)current_price_a; (void)current_price_b;\n614\t        return result;\n615\t    }\n616\t\n617\t    bool check_position_size(uint32_t contracts) const noexcept {\n618\t        return contracts > 0 && contracts <= config::MAX_POSITION_SIZE;\n619\t    }\n620\t\n621\t    bool check_daily_loss_limit(int64_t additional_risk_cents, const RiskSummary& summary) const noexcept {\n622\t        return (summary.realized_pnl_cents - additional_risk_cents) > -static_cast<int64_t>(config::MAX_DAILY_LOSS_CENTS);\n623\t    }\n624\t\n625\t    bool check_exposure_limit(uint64_t additional_exposure_cents, const RiskSummary& summary) const noexcept {\n626\t        return summary.total_exposure_cents + additional_exposure_cents <= config::MAX_TOTAL_EXPOSURE_CENTS;\n627\t    }\n628\t\n629\t    void record_trade_outcome(bool is_win, int64_t pnl_cents, RiskSummary& summary, TimestampUs now_us) {\n630\t        std::lock_guard<std::mutex> lock(mutex_);\n631\t        summary.total_trades_today++;\n632\t        if (is_win) {\n633\t            summary.win_count_today++;\n634\t        } else {\n635\t            summary.loss_count_today++;\n636\t        }\n637\t        summary.realized_pnl_cents += pnl_cents;\n638\t        summary.last_updated_us = now_us;\n639\t        if (!is_win) {\n640\t            update_circuit_breaker_internal(true, now_us);\n641\t        }\n642\t    }\n643\t\n644\t    bool update_circuit_breaker(bool is_loss, TimestampUs now_us) {\n645\t        std::lock_guard<std::mutex> lock(mutex_);\n646\t        return update_circuit_breaker_internal(is_loss, now_us);\n647\t    }\n648\t\n649\t    void reset_circuit_breaker() {\n650\t        std::lock_guard<std::mutex> lock(mutex_);\n651\t        circuit_breaker_active_ = false;\n652\t        recent_losses_.clear();\n653\t        peak_total_pnl_cents_ = 0;\n654\t    }\n655\t\n656\t    double calculate_max_drawdown(RiskSummary& summary) {\n657\t        std::lock_guard<std::mutex> lock(mutex_);\n658\t        int64_t total_pnl = summary.realized_pnl_cents + summary.unrealized_pnl_cents;\n659\t        if (total_pnl > peak_total_pnl_cents_) {\n660\t            peak_total_pnl_cents_ = total_pnl;\n661\t        }\n662\t        int64_t peak_capital = static_cast<int64_t>(config::STARTING_CAPITAL_CENTS) + peak_total_pnl_cents_;\n663\t        int64_t current_capital = static_cast<int64_t>(config::STARTING_CAPITAL_CENTS) + total_pnl;\n664\t        if (peak_capital <= 0) {\n665\t            summary.max_drawdown_percent = 0.0;\n666\t            return 0.0;\n667\t        }\n668\t        if (current_capital >= peak_capital) {\n669\t            summary.max_drawdown_percent = 0.0;\n670\t            return 0.0;\n671\t        }\n672\t        summary.max_drawdown_percent = static_cast<double>(peak_capital - current_capital) / static_cast<double>(peak_capital) * 100.0;\n673\t        return summary.max_drawdown_percent;\n674\t    }\n675\t\n676\tprivate:\n677\t    mutable std::mutex mutex_;\n678\t    std::vector<TimestampUs> recent_losses_;\n679\t    bool circuit_breaker_active_;\n680\t    TimestampUs circuit_breaker_triggered_at_;\n681\t    int64_t peak_total_pnl_cents_{0};\n682\t\n683\t    bool update_circuit_breaker_internal(bool is_loss, TimestampUs now_us) {\n684\t        if (!is_loss) return false;\n685\t        recent_losses_.push_back(now_us);\n686\t        recent_losses_.erase(\n687\t            std::remove_if(recent_losses_.begin(), recent_losses_.end(),\n688\t                [now_us](TimestampUs ts) { return (now_us - ts) > config::CIRCUIT_BREAKER_WINDOW_US; }),\n689\t            recent_losses_.end());\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"527ba88f-f6e9-4321-9733-9a6e55be6ca8","uuid":"98d499dd-ebc4-4