emory_order_acquire);\n245\t        size_t t = tail_.load(std::memory_order_acquire);\n246\t        return (h >= t) ? (h - t) : (config::RING_BUFFER_SIZE - t + h);\n247\t    }\n248\t\n249\tprivate:\n250\t    MarketUpdate buffer_[config::RING_BUFFER_SIZE];\n251\t    alignas(64) std::atomic<size_t> head_;\n252\t    alignas(64) std::atomic<size_t> tail_;\n253\t};\n254\t\n255\t} // namespace queue\n256\t\n257\t// ============================================================================\n258\t// Order Book Cache\n259\t// ============================================================================\n260\t\n261\tnamespace cache {\n262\t\n263\tusing data::MarketPrice;\n264\tusing data::MarketUpdate;\n265\t\n266\tclass OrderBookCache {\n267\tpublic:\n268\t    OrderBookCache() = default;\n269\t    ~OrderBookCache() = default;\n270\t\n271\t    void update(const MarketUpdate& update) {\n272\t        std::unique_lock<std::shared_mutex> lock(mutex_);\n273\t        for (auto& price : prices_) {\n274\t            if (std::strcmp(price->ticker, update.ticker) == 0) {\n275\t                price->yes_bid = update.yes_bid;\n276\t                price->yes_ask = update.yes_ask;\n277\t                price->no_bid = update.no_bid;\n278\t                price->no_ask = update.no_ask;\n279\t                price->last_price = update.last_price;\n280\t                price->volume = update.volume;\n281\t                price->timestamp_us = update.timestamp_us;\n282\t                price->valid = true;\n283\t                return;\n284\t            }\n285\t        }\n286\t        auto mp = std::make_unique<MarketPrice>();\n287\t        std::strncpy(mp->ticker, update.ticker, sizeof(mp->ticker) - 1);\n288\t        mp->ticker[sizeof(mp->ticker) - 1] = '\\0';\n289\t        mp->yes_bid = update.yes_bid;\n290\t        mp->yes_ask = update.yes_ask;\n291\t        mp->no_bid = update.no_bid;\n292\t        mp->no_ask = update.no_ask;\n293\t        mp->last_price = update.last_price;\n294\t        mp->volume = update.volume;\n295\t        mp->timestamp_us = update.timestamp_us;\n296\t        mp->valid = true;\n297\t        prices_.push_back(std::move(mp));\n298\t    }\n299\t\n300\t    bool get_price(const char* ticker, MarketPrice& out) const {\n301\t        std::shared_lock<std::shared_mutex> lock(mutex_);\n302\t        for (const auto& price : prices_) {\n303\t            if (std::strcmp(price->ticker, ticker) == 0 && price->valid) {\n304\t                std::strncpy(out.ticker, price->ticker, sizeof(out.ticker));\n305\t                out.timestamp_us = price->timestamp_us;\n306\t                out.yes_bid = price->yes_bid;\n307\t                out.yes_ask = price->yes_ask;\n308\t                out.no_bid = price->no_bid;\n309\t                out.no_ask = price->no_ask;\n310\t                out.last_price = price->last_price;\n311\t                out.volume = price->volume;\n312\t                out.valid = true;\n313\t                return true;\n314\t            }\n315\t        }\n316\t        return false;\n317\t    }\n318\t\n319\t    bool all_valid(const std::vector<std::string>& tickers) const {\n320\t        std::shared_lock<std::shared_mutex> lock(mutex_);\n321\t        for (const auto& ticker : tickers) {\n322\t            bool found = false;\n323\t            for (const auto& price : prices_) {\n324\t                if (ticker == price->ticker && price->valid) {\n325\t                    found = true;\n326\t                    break;\n327\t                }\n328\t            }\n329\t            if (!found) return false;\n330\t        }\n331\t        return true;\n332\t    }\n333\t\n334\t    size_t market_count() const {\n335\t        std::shared_lock<std::shared_mutex> lock(mutex_);\n336\t        return prices_.size();\n337\t    }\n338\t\n339\t    void invalidate_stale(data::TimestampUs now_us, uint64_t max_age_us) {\n340\t        std::unique_lock<std::shared_mutex> lock(mutex_);\n341\t        for (auto& price : prices_) {\n342\t       