{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011MXucDAtLnUivKeUsk2W5M","type":"tool_result","content":"1\t/**\n2\t * Phase 4 C++ Execution Engine — Full Implementation (T351)\n3\t * Task: T351 — Sprint 10 Full Build\n4\t * Author: Dave (Full Stack Engineer)\n5\t * Date: 2026-04-03\n6\t *\n7\t * Production-ready Kalshi arbitrage execution engine.\n8\t * Compile: g++ -std=c++20 -pthread -O3 -o engine engine.cpp\n9\t */\n10\t\n11\t#include <atomic>\n12\t#include <chrono>\n13\t#include <cmath>\n14\t#include <cstdint>\n15\t#include <cstring>\n16\t#include <fstream>\n17\t#include <functional>\n18\t#include <iostream>\n19\t#include <memory>\n20\t#include <mutex>\n21\t#include <optional>\n22\t#include <shared_mutex>\n23\t#include <sstream>\n24\t#include <string>\n25\t#include <thread>\n26\t#include <vector>\n27\t\n28\t// ============================================================================\n29\t// Configuration & Constants\n30\t// ============================================================================\n31\t\n32\tnamespace config {\n33\t\n34\tconstexpr size_t RING_BUFFER_SIZE = 4096;\n35\tconstexpr size_t MAX_MARKETS = 256;\n36\tconstexpr size_t MAX_PAIRS = 16;\n37\tconstexpr size_t MAX_POSITIONS = 128;\n38\tconstexpr uint64_t WS_HEARTBEAT_INTERVAL_US = 30000000;\n39\tconstexpr uint64_t SIGNAL_COOLDOWN_US = 500000;\n40\tconstexpr uint64_t POSITION_MAX_HOLD_US = 300000000;\n41\tconstexpr uint64_t RISK_CHECK_INTERVAL_US = 100000;\n42\tconstexpr uint64_t ORDER_RETRY_DELAYS_US[3] = {10000, 50000, 250000};\n43\tconstexpr uint64_t ORDER_SUBMIT_TIMEOUT_US = 500000;\n44\tconstexpr uint64_t MAX_DAILY_LOSS_CENTS = 50000;\n45\tconstexpr uint64_t MAX_TOTAL_EXPOSURE_CENTS = 200000;\n46\tconstexpr uint64_t MAX_POSITION_SIZE = 1000;\n47\tconstexpr double SPREAD_DEVIATION_MIN_SIGMA = 0.5;\n48\tconstexpr double SPREAD_DEVIATION_MAX_SIGMA = 5.0;\n49\tconstexpr uint64_t CORRELATION_FRESHNESS_US = 3600000000;\n50\tconstexpr uint64_t PRICE_FRESHNESS_US = 1000000;\n51\tconstexpr uint8_t CIRCUIT_BREAKER_MAX_LOSSES = 3;\n52\tconstexpr uint64_t CIRCUIT_BREAKER_WINDOW_US = 60000000;\n53\t\n54\t} // namespace config\n55\t\n56\t// ============================================================================\n57\t// Core Data Structures\n58\t// ============================================================================\n59\t\n60\tnamespace data {\n61\t\n62\tusing Price = uint32_t;\n63\tusing TimestampUs = uint64_t;\n64\t\n65\tstruct MarketPrice {\n66\t    char ticker[32];\n67\t    TimestampUs timestamp_us{0};\n68\t    Price yes_bid{0};\n69\t    Price yes_ask{0};\n70\t    Price no_bid{0};\n71\t    Price no_ask{0};\n72\t    Price last_price{0};\n73\t    uint32_t volume{0};\n74\t    bool valid{false};\n75\t\n76\t    Price mid_price() const noexcept {\n77\t        if (yes_bid > 0 && yes_ask > 0) return (yes_bid + yes_ask) / 2;\n78\t        if (yes_bid > 0) return yes_bid;\n79\t        if (yes_ask > 0) return yes_ask;\n80\t        return last_price;\n81\t    }\n82\t};\n83\t\n84\tstruct MarketUpdate {\n85\t    TimestampUs timestamp_us;\n86\t    char ticker[32];\n87\t    Price yes_bid;\n88\t    Price yes_ask;\n89\t    Price no_bid;\n90\t    Price no_ask;\n91\t    Price last_price;\n92\t    uint32_t volume;\n93\t    bool is_snapshot;\n94\t};\n95\t\n96\tstruct CorrelationPair {\n97\t    char cluster[32];\n98\t    char market_a[32];\n99\t    char market_b[32];\n100\t    double pearson_correlation;\n101\t    double expected_spread;\n102\t    double spread_threshold;\n103\t    double arbitrage_confidence;\n104\t    uint32_t direction;\n105\t    bool is_arbitrage_opportunity;\n106\t};\n107\t\n108\tstruct ArbitrageSignal {\n109\t    TimestampUs timestamp_us;\n110\t    char market_a[32];\n111\t    char market_b[32];\n112\t    uint32_t direction;\n113\t    Price fair_value_a;\n114\t    Price fair_value_b;\n115\t    int32_t spread_deviation_bps;\n116\t    double confidence;\n117\t    double deviation_sigma;\n118\t    uint32_t suggested_contracts;\n119\t};\n120\t\n121\tstruct OrderLeg {\n122\t    char ticker[32];\n123\t    char side[4];\n124\t    uint32_t contracts;\n125\t    Price price;\n126\t    char client_order_id[64];\n127\t};\n128\t\n129\tstruct PairedOrder {\n130\t    char pair_id[64];\n131\t    OrderLeg leg_a;\n132\t    OrderLeg leg_b;\n133\t    TimestampUs created_at_us;\n134\t    TimestampUs deadline_us;\n135\t    uint8_t max_retries;\n136\t    uint8_t retry_count;\n137\t    ArbitrageSignal signal;\n138\t};\n139\t\n140\tstruct OrderResult {\n141\t    bool success;\n142\t    char order_id[64];\n143\t    char error[256];\n144\t    uint32_t filled_contracts;\n145\t    Price avg_fill_price;\n146\t    TimestampUs completed_at_us;\n147\t    uint8_t retry_count{0};\n148\t};\n149\t\n150\tstruct OpenPosition {\n151\t    char position_id[64];\n152\t    char pair_id[64];\n153\t    char market_a[32];\n154\t    char market_b[32];\n155\t    uint32_t contracts;\n156\t    Price entry_price_a;\n157\t    Price entry_price_b;\n158\t    Price current_price_a;\n159\t    Price current_price_b;\n160\t    int32_t entry_spread_bps;\n161\t    int32_t current_spread_bps;\n162\t    int32_t unrealized_pnl_cents;\n163\t    int32_t realized_pnl_cents;\n164\t    TimestampUs opened_at_us;\n165\t    TimestampUs last_update_us;\n166\t    bool auto_close_enabled;\n167\t    bool is_closing;\n168\t};\n169\t\n170\tstruct RiskSummary {\n171\t    uint64_t total_trades_today;\n172\t    uint64_t win_count_today;\n173\t    uint64_t loss_count_today;\n174\t    int64_t realized_pnl_cents;\n175\t    int64_t unrealized_pnl_cents;\n176\t    uint64_t total_exposure_cents;\n177\t    uint64_t open_position_count;\n178\t    bool circuit_breaker_triggered;\n179\t    TimestampUs last_updated_us;\n180\t};\n181\t\n182\tstruct RiskCheckResult {\n183\t    bool approved;\n184\t    char rejection_reason[256];\n185\t    double risk_score;\n186\t};\n187\t\n188\t} // namespace data\n189\t\n190\t// ==========================================================