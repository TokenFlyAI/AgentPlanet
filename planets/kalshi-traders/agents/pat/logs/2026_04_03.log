GN KEY (trade_id) REFERENCES trades(trade_id)\\n);\\n\\n-- Strategy comparison m
atrix (for cross-strategy analysis)\\nCREATE TABLE IF NOT EXISTS strategy_compar
ison (\\n    comparison_id INTEGER PRIMARY KEY AUTOINCREMENT,\\n    date TEXT NO
