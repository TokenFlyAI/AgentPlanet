_ratio REAL,\\n    sortino_ratio REAL,                         -- Sharpe but onl
y downside deviation\\n    calmar_ratio REAL,                          -- Return
/ max drawdown\\n    \\n    max_drawdown REAL DEFAULT 0,                -- Peak-
