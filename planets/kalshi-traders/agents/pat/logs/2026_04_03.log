============\\n\\nINSERT OR IGNORE INTO strategies (strategy_name, strategy_type
, description, max_position_size, target_sharpe_ratio) VALUES\\n(\'mean_reversio
n\', \'technical\', \'Z-score based mean reversion on price deviations\', 100, 1
.0),\\n(\'momentum\', \'technical\', \'Trend following based on recent price mov
ement\', 100, 1.0),\\n(\'crypto_edge\', \'fundamental\', \'Crypto-specific edge 
detection using on-chain metrics\', 50, 1.2),\\n(\'nfp_nowcast\', \'macro\', \'N
on-farm payroll prediction using alternative data\', 75, 0.8),\\n(\'econ_edge\',
\'macro\', \'Economic indicator edge detection\', 75, 0.9),\\n(\'arbitrage\', \'
arbitrage\', \'Cross-market arbitrage using correlation pairs\', 200, 1.5);\\n"}
