K (exit_price IS NULL OR (exit_price >= 1 AND exit_price <= 99)),\\n    contract
s INTEGER NOT NULL CHECK (contracts > 0),\\n    \\n    -- P&L calculations\\n   
realized_pnl REAL,                          -- Actual P&L on close\\n    unreali
zed_pnl REAL,                        -- Mark-to-market for open positions\\n    
pnl_percent REAL,                           -- Percentage return\\n    \\n    --
Trade metadata\\n    status TEXT NOT NULL DEFAULT \'open\' CHECK (status IN (\'o
pen\', \'closed\', \'expired\', \'cancelled\')),\\n    entry_timestamp TEXT NOT 
