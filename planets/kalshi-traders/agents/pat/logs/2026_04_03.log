TS v_strategy_current_performance AS\\nSELECT \\n    s.strategy_id,\\n    s.stra
tegy_name,\\n    s.strategy_type,\\n    s.is_active,\\n    COUNT(DISTINCT t.trad
e_id) as total_trades,\\n    SUM(CASE WHEN t.status = \'open\' THEN 1 ELSE 0 END
) as open_positions,\\n    SUM(CASE WHEN t.status = \'closed\' THEN 1 ELSE 0 END
) as closed_positions,\\n    SUM(CASE WHEN t.realized_pnl > 0 THEN 1 ELSE 0 END)
