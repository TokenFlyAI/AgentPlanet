\\n    min_confidence DECIMAL(3,2) DEFAULT 0.30,\\n    min_edge INTEGER DEFAULT 
2, -- minimum edge in cents\\n    \\n    -- Status\\n    status VARCHAR(20) NOT 
NULL DEFAULT \'active\', -- active, paused, disabled\\n    \\n    -- Performance
tracking (updated by PnL tracker)\\n    total_pnl INTEGER DEFAULT 0, -- in cents
\\n    total_trades INTEGER DEFAULT 0,\\n    winning_trades INTEGER DEFAULT 0,\\
n    losing_trades INTEGER DEFAULT 0,\\n    \\n    -- Timestamps\\n    created_a
t TIMESTAMP WITH TIME ZONE DEFAULT NOW(),\\n    updated_at TIMESTAMP WITH TIME Z
ONE DEFAULT NOW()\\n);\\n\\n-- Indexes for strategies\\nCREATE INDEX IF NOT EXIS
TS idx_strategies_status ON strategies(status);\\nCREATE INDEX IF NOT EXISTS idx
_strategies_type ON strategies(strategy_type);\\n\\n-- -------------------------
--------------------------------------------------\\n-- Strategy Signals Table\\
n-- Signals generated by strategies\\n-- ---------------------------------------
------------------------------------\\nCREATE TABLE IF NOT EXISTS strategy_signa
ls (\\n    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\\n    strategy_id UUI
D NOT NULL REFERENCES strategies(id) ON DELETE CASCADE,\\n    market_id UUID NOT
NULL REFERENCES markets(id),\\n    \\n    -- Signal details\\n    side VARCHAR(1
0) NOT NULL, -- \'yes\' or \'no\'\\n    signal_type VARCHAR(20) NOT NULL, -- \'e
ntry\', \'exit\', \'hold\'\\n    confidence DECIMAL(4,3) NOT NULL, -- 0.0 to 1.0
\\n    \\n    -- Pricing\\n    target_price INTEGER, -- suggested entry price in
cents\\n    current_price INTEGER, -- current market price in cents\\n    expect
ed_edge INTEGER, -- expected profit edge in cents\\n    \\n    -- Sizing (filled
by position sizer)\\n    recommended_contracts INTEGER,\\n    \\n    -- Status\\
n    status VARCHAR(20) DEFAULT \'pending\', -- pending, executed, expired, reje
cted\\n    \\n    -- Metadata\\n    reason TEXT,\\n    metadata JSONB DEFAULT \'
{}\',\\n    \\n    -- Timestamps\\n    generated_at TIMESTAMP WITH TIME ZONE DEF
AULT NOW(),\\n    executed_at TIMESTAMP WITH TIME ZONE,\\n    expires_at TIMESTA
MP WITH TIME ZONE\\n);\\n\\n-- Indexes for signals\\nCREATE INDEX IF NOT EXISTS 
idx_strategy_signals_strategy ON strategy_signals(strategy_id);\\nCREATE INDEX I
F NOT EXISTS idx_strategy_signals_market ON strategy_signals(market_id);\\nCREAT
E INDEX IF NOT EXISTS idx_strategy_signals_status ON strategy_signals(status);\\
nCREATE INDEX IF NOT EXISTS idx_strategy_signals_generated ON strategy_signals(g
enerated_at);\\n\\n-- ----------------------------------------------------------
-----------------\\n-- Strategy Positions Table\\n-- Links positions to strategi
es for attribution\\n-- --------------------------------------------------------
-------------------\\nCREATE TABLE IF NOT EXISTS strategy_positions (\\n    id U
UID PRIMARY KEY DEFAULT uuid_generate_v4(),\\n    strategy_id UUID NOT NULL REFE
RENCES strategies(id),\\n    position_id UUID NOT NULL REFERENCES positions(id),
\\n    market_id UUID NOT NULL REFERENCES markets(id),\\n    \\n    -- Attributi
on\\n    attribution_pct DECIMAL(5,2) DEFAULT 100.00, -- if multiple strategies 
share a position\\n    \\n    -- Strategy-specific P&L attribution\\n    attribu
ted_pnl INTEGER,\\n    \\n    -- Timestamps\\n    opened_at TIMESTAMP WITH TIME 
ZONE DEFAULT NOW(),\\n    closed_at TIMESTAMP WITH TIME ZONE\\n);\\n\\n-- Indexe
s for strategy positions\\nCREATE INDEX IF NOT EXISTS idx_strategy_positions_str
ategy ON strategy_positions(strategy_id);\\nCREATE INDEX IF NOT EXISTS idx_strat
egy_positions_position ON strategy_positions(position_id);\\n\\n-- -------------
--------------------------------------------------------------\\n-- Strategy Tra
des Table\\n-- Links trades to strategies for P&L tracking\\n-- ----------------
-----------------------------------------------------------\\nCREATE TABLE IF NO
T EXISTS strategy_trades (\\n    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
\\n    strategy_id UUID NOT NULL REFERENCES strategies(id),\\n    trade_id UUID 
NOT NULL REFERENCES trades(id),\\n    \\n    -- Attribution\\n    attributed_pnl
INTEGER, -- P&L attributed to this strategy\\n    \\n    -- Timestamps\\n    rec
orded_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()\\n);\\n\\n-- Indexes for strateg
y trades\\nCREATE INDEX IF NOT EXISTS idx_strategy_trades_strategy ON strategy_t
rades(strategy_id);\\nCREATE INDEX IF NOT EXISTS idx_strategy_trades_trade ON st
rategy_trades(trade_id);\\nCREATE INDEX IF NOT EXISTS idx_strategy_trades_record
ed ON strategy_trades(recorded_at);\\n\\n-- ------------------------------------
---------------------------------------\\n-- Strategy Performance Table\\n-- Tim
e-series performance data for strategies\\n-- ----------------------------------
-----------------------------------------\\nCREATE TABLE IF NOT EXISTS strategy_
performance (\\n    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\\n    strate
gy_id UUID NOT NULL REFERENCES strategies(id) ON DELETE CASCADE,\\n    \\n    --
Period\\n    period VARCHAR(20) NOT NULL, -- \'hourly\', \'daily\', \'weekly\', 
\'monthly\'\\n    period_start TIMESTAMP WITH TIME ZONE NOT NULL,\\n    \\n    -
- Metrics\\n    trades_count INTEGER DEFAULT 0,\\n    signals_count INTEGER DEFA
ULT 0,\\n    realized_pnl INTEGER DEFAULT 0,\\n    unrealized_pnl INTEGER DEFAUL
T 0,\\n    total_pnl INTEGER DEFAULT 0,\\n    win_rate DECIMAL(5,4), -- 0.0 to 1
.0\\n    max_exposure INTEGER, -- max position value during period\\n    cumulat
ive_pnl INTEGER DEFAULT 0, -- running total\\n    \\n    -- Unique constraint\\n
   UNIQUE(strategy_id, period, period_start)\\n);\\n\\n-- Indexes for performanc
e\\nCREATE INDEX IF NOT EXISTS idx_strategy_performance_strategy ON strategy_per
formance(strategy_id);\\nCREATE INDEX IF NOT EXISTS idx_strategy_performance_per
iod ON strategy_performance(period, period_start);\\n\\n-- ---------------------
------------------------------------------------------\\n-- Strategy Runs Table\
\n-- Log of strategy execution runs\\n-- ---------------------------------------
------------------------------------\\nCREATE TABLE IF NOT EXISTS strategy_runs 
(\\n    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\\n    strategy_id UUID R
EFERENCES strategies(id),\\n    \\n    -- Run details\\n    run_type VARCHAR(20)
NOT NULL, -- \'single\', \'batch\', \'backtest\'\\n    status VARCHAR(20) NOT NU
LL, -- \'running\', \'completed\', \'failed\'\\n    \\n    -- Results\\n    mark
ets_scanned INTEGER DEFAULT 0,\\n    signals_generated INTEGER DEFAULT 0,\\n    
signals_executed INTEGER DEFAULT 0,\\n    error_message TEXT,\\n    \\n    -- Ti
ming\\n    started_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),\\n    completed_at
TIMESTAMP WITH TIME ZONE\\n);\\n\\n-- Indexes for runs\\nCREATE INDEX IF NOT EXI
STS idx_strategy_runs_strategy ON strategy_runs(strategy_id);\\nCREATE INDEX IF 
NOT EXISTS idx_strategy_runs_status ON strategy_runs(status);\\nCREATE INDEX IF 
NOT EXISTS idx_strategy_runs_started ON strategy_runs(started_at);\\n\\n-- -----
----------------------------------------------------------------------\\n-- View
s for Strategy Framework\\n-- --------------------------------------------------
-------------------------\\n\\n-- Strategy positions with P&L view\\nCREATE OR R
EPLACE VIEW strategy_positions_view AS\\nSELECT \\n    sp.*,\\n    p.side,\\n   
p.contracts,\\n    p.avg_entry_price,\\n    p.status as position_status,\\n    m
.ticker,\\n    m.title as market_title,\\n    amp.calculated_unrealized_pnl\\nFR
OM strategy_positions sp\\nJOIN positions p ON sp.position_id = p.id\\nJOIN mark
ets m ON sp.market_id = m.id\\nLEFT JOIN open_positions_with_markets amp ON p.id
= amp.id;\\n\\n-- Active signals with market info\\nCREATE OR REPLACE VIEW activ
e_signals_view AS\\nSELECT \\n    ss.*,\\n    s.name as strategy_name,\\n    s.s
trategy_type,\\n    m.ticker,\\n    m.title as market_title,\\n    m.category\\n
FROM strategy_signals ss\\nJOIN strategies s ON ss.strategy_id = s.id\\nJOIN mar
kets m ON ss.market_id = m.id\\nWHERE ss.status = \'pending\'\\n  AND (ss.expire
s_at IS NULL OR ss.expires_at > NOW())\\nORDER BY ss.confidence DESC, ss.generat
ed_at DESC;\\n\\n-- Strategy summary view\\nCREATE OR REPLACE VIEW strategy_summ
ary_view AS\\nSELECT \\n    s.*,\\n    COALESCE(sp.recent_pnl, 0) as recent_pnl,
\\n    COALESCE(sp.recent_trades, 0) as recent_trades,\\n    CASE \\n        WHE
N s.total_trades > 0 THEN s.winning_trades::decimal / s.total_trades\\n        E
LSE 0\\n    END as calculated_win_rate\\nFROM strategies s\\nLEFT JOIN (\\n    S
ELECT \\n        strategy_id,\\n        SUM(total_pnl) as recent_pnl,\\n        
SUM(trades_count) as recent_trades\\n    FROM strategy_performance\\n    WHERE p
eriod = \'daily\'\\n      AND period_start >= CURRENT_DATE - INTERVAL \'7 days\'
\\n    GROUP BY strategy_id\\n) sp ON s.id = sp.strategy_id;\\n\\n-- -----------
----------------------------------------------------------------\\n-- Update tri
ggers for strategy tables\\n-- -------------------------------------------------
--------------------------\\nDROP TRIGGER IF EXISTS update_strategies_updated_at
ON strategies;\\nCREATE TRIGGER update_strategies_updated_at\\n    BEFORE UPDATE
ON strategies\\n    FOR EACH ROW\\n    EXECUTE FUNCTION update_updated_at_column
();\\n\\n-- --------------------------------------------------------------------
