----------\\n-- Strategies Table\\n-- Registered trading strategies\\n-- -------
--------------------------------------------------------------------\\nCREATE TA
BLE IF NOT EXISTS strategies (\\n    id UUID PRIMARY KEY DEFAULT uuid_generate_v
4(),\\n    name VARCHAR(100) NOT NULL UNIQUE,\\n    strategy_type VARCHAR(50) NO
T NULL, -- \'mean_reversion\', \'momentum\', \'arbitrage\', etc.\\n    descripti
on TEXT,\\n    \\n    -- Strategy configuration (JSON)\\n    config JSONB DEFAUL
T \'{}\',\\n    \\n    -- Risk parameters\\n    max_position_size INTEGER DEFAUL
