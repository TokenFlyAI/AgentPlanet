his strategy\n    \n    -- Timestamps\n    recorded_at TIMESTAMP WITH TIME ZONE 
DEFAULT NOW()\n);\n\n-- Indexes for strategy trades\nCREATE INDEX IF NOT EXISTS 
idx_strategy_trades_strategy ON strategy_trades(strategy_id);\nCREATE INDEX IF N
OT EXISTS idx_strategy_trades_trade ON strategy_trades(trade_id);\nCREATE INDEX 
IF NOT EXISTS idx_strategy_trades_recorded ON strategy_trades(recorded_at);\n\n-
- ---------------------------------------------------------------------------\n-
- Strategy Performance Table\n-- Time-series performance data for strategies\n--
---------------------------------------------------------------------------\nCRE
ATE TABLE IF NOT EXISTS strategy_performance (\n    id UUID PRIMARY KEY DEFAULT 
uuid_generate_v4(),\n    strategy_id UUID NOT NULL REFERENCES strategies(id) ON 
DELETE CASCADE,\n    \n    -- Period\n    period VARCHAR(20) NOT NULL, -- 'hourl
y', 'daily', 'weekly', 'monthly'\n    period_start TIMESTAMP WITH TIME ZONE NOT 
NULL,\n    \n    -- Metrics\n    trades_count INTEGER DEFAULT 0,\n    signals_co
unt INTEGER DEFAULT 0,\n    realized_pnl INTEGER DEFAULT 0,\n    unrealized_pnl 
INTEGER DEFAULT 0,\n    total_pnl INTEGER DEFAULT 0,\n    win_rate DECIMAL(5,4),
-- 0.0 to 1.0\n    max_exposure INTEGER, -- max position value during period\n  
 cumulative_pnl INTEGER DEFAULT 0, -- running total\n    \n    -- Unique constra
int\n    UNIQUE(strategy_id, period, period_start)\n);\n\n-- Indexes for perform
ance\nCREATE INDEX IF NOT EXISTS idx_strategy_performance_strategy ON strategy_p
erformance(strategy_id);\nCREATE INDEX IF NOT EXISTS idx_strategy_performance_pe
riod ON strategy_performance(period, period_start);\n\n-- ----------------------
-----------------------------------------------------\n-- Strategy Runs Table\n-
- Log of strategy execution runs\n-- -------------------------------------------
--------------------------------\nCREATE TABLE IF NOT EXISTS strategy_runs (\n  
 id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\n    strategy_id UUID REFERENCE
S strategies(id),\n    \n    -- Run details\n    run_type VARCHAR(20) NOT NULL, 
-- 'single', 'batch', 'backtest'\n    status VARCHAR(20) NOT NULL, -- 'running',
'completed', 'failed'\n    \n    -- Results\n    markets_scanned INTEGER DEFAULT
0,\n    signals_generated INTEGER DEFAULT 0,\n    signals_executed INTEGER DEFAU
LT 0,\n    error_message TEXT,\n    \n    -- Timing\n    started_at TIMESTAMP WI
TH TIME ZONE DEFAULT NOW(),\n    completed_at TIMESTAMP WITH TIME ZONE\n);\n\n--
Indexes for runs\nCREATE INDEX IF NOT EXISTS idx_strategy_runs_strategy ON strat
egy_runs(strategy_id);\nCREATE INDEX IF NOT EXISTS idx_strategy_runs_status ON s
trategy_runs(status);\nCREATE INDEX IF NOT EXISTS idx_strategy_runs_started ON s
trategy_runs(started_at);\n\n-- ------------------------------------------------
---------------------------\n-- Views for Strategy Framework\n-- ---------------
------------------------------------------------------------\n\n-- Strategy posi
tions with P&L view\nCREATE OR REPLACE VIEW strategy_positions_view AS\nSELECT \
n    sp.*,\n    p.side,\n    p.contracts,\n    p.avg_entry_price,\n    p.status 
as position_status,\n    m.ticker,\n    m.title as market_title,\n    amp.calcul
ated_unrealized_pnl\nFROM strategy_positions sp\nJOIN positions p ON sp.position
_id = p.id\nJOIN markets m ON sp.market_id = m.id\nLEFT JOIN open_positions_with
_markets amp ON p.id = amp.id;\n\n-- Active signals with market info\nCREATE OR 
REPLACE VIEW active_signals_view AS\nSELECT \n    ss.*,\n    s.name as strategy_
name,\n    s.strategy_type,\n    m.ticker,\n    m.title as market_title,\n    m.
category\nFROM strategy_signals ss\nJOIN strategies s ON ss.strategy_id = s.id\n
JOIN markets m ON ss.market_id = m.id\nWHERE ss.status = 'pending'\n  AND (ss.ex
pires_at IS NULL OR ss.expires_at > NOW())\nORDER BY ss.confidence DESC, ss.gene
rated_at DESC;\n\n-- Strategy summary view\nCREATE OR REPLACE VIEW strategy_summ
ary_view AS\nSELECT \n    s.*,\n    COALESCE(sp.recent_pnl, 0) as recent_pnl,\n 
  COALESCE(sp.recent_trades, 0) as recent_trades,\n    CASE \n        WHEN s.tot
al_trades > 0 THEN s.winning_trades::decimal / s.total_trades\n        ELSE 0\n 
  END as calculated_win_rate\nFROM strategies s\nLEFT JOIN (\n    SELECT \n     
  strategy_id,\n        SUM(total_pnl) as recent_pnl,\n        SUM(trades_count)
as recent_trades\n    FROM strategy_performance\n    WHERE period = 'daily'\n   
  AND period_start >= CURRENT_DATE - INTERVAL '7 days'\n    GROUP BY strategy_id
\n) sp ON s.id = sp.strategy_id;\n\n-- -----------------------------------------
----------------------------------\n-- Update triggers for strategy tables\n-- -
--------------------------------------------------------------------------\nDROP
TRIGGER IF EXISTS update_strategies_updated_at ON strategies;\nCREATE TRIGGER up
date_strategies_updated_at\n    BEFORE UPDATE ON strategies\n    FOR EACH ROW\n 
  EXECUTE FUNCTION update_updated_at_column();\n\n-- ---------------------------
------------------------------------------------\n-- Comments for strategy table
s\n-- --------------------------------------------------------------------------
-\nCOMMENT ON TABLE strategies IS 'Trading strategy definitions and configuratio
n';\nCOMMENT ON TABLE strategy_signals IS 'Trading signals generated by strategi
es';\nCOMMENT ON TABLE strategy_positions IS 'Position attribution to strategies
';\nCOMMENT ON TABLE strategy_trades IS 'Trade attribution to strategies for P&L
tracking';\nCOMMENT ON TABLE strategy_performance IS 'Time-series performance me
trics per strategy';\nCOMMENT ON TABLE strategy_runs IS 'Log of strategy executi
on runs';",
                old_start=395,
