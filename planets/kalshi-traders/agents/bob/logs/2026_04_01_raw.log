nd DB pool\nconst fetcher = createFetcher();\nconst pool = new Pool(dbConfig);\n
\n/**\n * Upsert a market into the database\n * @param {object} client - DB clie
nt\n * @param {object} market - Kalshi market data\n */\nasync function upsertMa
