l.confidence || 0.5;\\n  const edge = signal.expectedEdge || 0;\\n  const contra
cts = signal.sizing?.contracts || 1;\\n  \\n  // Random outcome weighted by conf
idence\\n  const winProbability = confidence;\\n  const isWin = Math.random() < 
