: "#!/usr/bin/env node\\n/**\\n * Pearson Correlation Detection — T345\\n * Iden
tifies arbitrage pairs using Pearson correlation coefficient\\n * Author: Bob (B
ackend Engineer)\\n * \\n * Reference: https://hudson-and-thames-arbitragelab.re
adthedocs-hosted.com/en/latest/distance_approach/pearson_approach.html\\n */\\n\
\n\\"use strict\\";\\n\\nconst fs = require(\\"fs\\");\\nconst path = require(\\
"path\\");\\n\\n// Configuration\\nconst CONFIG = {\\n  minCorrelation: 0.75,   
// Standard deviations for arbitrage signal\\n  minHistoryLength: 10,      // Mi
nimum price history length required\\n  lookbackWindow: 30,        // Periods fo
r calculating expected spread\\n};\\n\\n/**\\n * Calculate Pearson correlation c
oefficient between two price series\\n * @param {Array} x - First price series\\
n * @param {Array} y - Second price series\\n * @returns {number} Pearson correl
ation coefficient (-1 to 1)\\n */\\nfunction pearsonCorrelation(x, y) {\\n  cons
t n = Math.min(x.length, y.length);\\n  if (n < 2) return 0;\\n  \\n  // Use onl
y overlapping periods\\n  const xSlice = x.slice(-n);\\n  const ySlice = y.slice
(-n);\\n  \\n  const sumX = xSlice.reduce((a, b) => a + b, 0);\\n  const sumY = 
ySlice.reduce((a, b) => a + b, 0);\\n  \\n  const meanX = sumX / n;\\n  const me
anY = sumY / n;\\n  \\n  let numerator = 0;\\n  let denomX = 0;\\n  let denomY =
0;\\n  \\n  for (let i = 0; i < n; i++) {\\n    const diffX = xSlice[i] - meanX;
\\n    const diffY = ySlice[i] - meanY;\\n    numerator += diffX * diffY;\\n    
denomX += diffX * diffX;\\n    denomY += diffY * diffY;\\n  }\\n  \\n  const den
ominator = Math.sqrt(denomX * denomY);\\n  if (denominator === 0) return 0;\\n  
\\n  return numerator / denominator;\\n}\\n\\n/**\\n * Calculate historical spre
ad statistics between two price series\\n * @param {Array} x - First price serie
