rket_a, sig.market_b, now_us)) continue;\n            update_cooldown(sig.market
_a, sig.market_b, now_us);\n            result.push_back(sig);\n        }\n     
  prune_cooldowns(now_us);\n        return result;\n    }\n\n    bool is_cooldow
n(const char* market_a, const char* market_b, TimestampUs now_us) const {\n     
