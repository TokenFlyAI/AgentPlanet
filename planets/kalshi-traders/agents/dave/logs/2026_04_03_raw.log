{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A1NNFsrcp4SDyBi8SHyaaG","type":"tool_result","content":"420\t// Test 8: Full Engine Integration\n421\t// ============================================================================\n422\t\n423\tvoid test_full_engine(TestSuite& suite) {\n424\t    suite.test(\"Engine: initializes and starts/stops cleanly\", []() {\n425\t        engine::ExecutionEngine eng;\n426\t        router::KalshiApiConfig cfg{};\n427\t        assert(eng.initialize(\"/Users/chenyangcui/Documents/code/aicompany/agents/public/correlation_pairs.json\", cfg, \"ws://test\") == true);\n428\t        eng.start();\n429\t        std::this_thread::sleep_for(std::chrono::milliseconds(50));\n430\t        assert(eng.is_running() == true);\n431\t        eng.stop();\n432\t        assert(eng.is_running() == false);\n433\t    });\n434\t\n435\t    suite.test(\"Engine: strategy loop processes mock market data\", []() {\n436\t        engine::ExecutionEngine eng;\n437\t        router::KalshiApiConfig cfg{};\n438\t        assert(eng.initialize(\"/Users/chenyangcui/Documents/code/aicompany/agents/public/correlation_pairs.json\", cfg, \"ws://test\") == true);\n439\t        eng.start();\n440\t\n441\t        // Push mock updates for a known pair from correlation_pairs.json\n442\t        auto u = make_update(\"SP500-5000\", 5000, 5050);\n443\t        u.timestamp_us = now_us();\n444\t        eng.feed_handler()->push_mock_update(u);\n445\t\n446\t        auto v = make_update(\"NASDAQ-ALLTIME\", 4800, 4850);\n447\t        v.timestamp_us = now_us();\n448\t        eng.feed_handler()->push_mock_update(v);\n449\t\n450\t        std::this_thread::sleep_for(std::chrono::milliseconds(200));\n451\t        auto prices = eng.cache()->get_all_prices();\n452\t        assert(prices.size() >= 2);\n453\t        eng.stop();\n454\t    });\n455\t\n456\t    suite.test(\"Engine: risk summary updates after trades\", []() {\n457\t        engine::ExecutionEngine eng;\n458\t    