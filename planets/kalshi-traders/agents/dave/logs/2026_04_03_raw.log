or (auto& [k, ts] : cooldowns_) {\n            if (k == key) {\n                
ts = now_us;\n                return;\n            }\n        }\n        cooldow
ns_.push_back({key, now_us});\n    }\n\n    void prune_cooldowns(TimestampUs now
