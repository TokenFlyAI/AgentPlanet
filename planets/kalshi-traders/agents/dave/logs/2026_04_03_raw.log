{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PCTb8rqg3EvJDjNH3Ke9Qn","type":"tool_result","content":"1\t#!/usr/bin/env node\n2\t/**\n3\t * End-to-End Paper Trading Pipeline ŌĆö T542\n4\t * Single entry point that runs the full D004 pipeline:\n5\t *   Phase 1: Market Filter ŌåÆ markets_filtered.json\n6\t *   Phase 2: Clustering ŌåÆ market_clusters.json\n7\t *   Phase 3: Correlation ŌåÆ correlation_pairs.json\n8\t *   Phase 4: Paper Trade Simulation ŌåÆ trade_log.json + pnl_summary.json\n9\t * \n10\t * Usage: node run_pipeline.js [--paper]\n11\t * \n12\t * Following culture norms:\n13\t *   C6: Reference public/knowledge.md for technical facts\n14\t *   C8: Run and verify your code\n15\t *   D5: Trading system must be runnable end-to-end\n16\t */\n17\t\n18\t\"use strict\";\n19\t\n20\tconst fs = require(\"fs\");\n21\tconst path = require(\"path\");\n22\tconst { execSync } = require(\"child_process\");\n23\t\n24\t// ---------------------------------------------------------------------------\n25\t// Configuration\n26\t// ---------------------------------------------------------------------------\n27\tconst CONFIG = {\n28\t  // Output paths (relative to workspace root)\n29\t  outputDir: path.join(__dirname, \"../../../public\"),\n30\t  marketsFilteredPath: path.join(__dirname, \"../../../public/markets_filtered.json\"),\n31\t  marketClustersPath: path.join(__dirname, \"../../../public/market_clusters.json\"),\n32\t  correlationPairsPath: path.join(__dirname, \"../../../public/correlation_pairs.json\"),\n33\t  tradeLogPath: path.join(__dirname, \"../../../output/trade_log.json\"),\n34\t  pnlSummaryPath: path.join(__dirname, \"../../../output/pnl_summary.json\"),\n35\t  \n36\t  // Pipeline settings\n37\t  paperTrading: true,\n38\t  minMarkets: 3,\n39\t  minCorrelation: 0.60,\n40\t  spreadThreshold: 1.0,\n41\t};\n42\t\n43\t// Ensure output directories exist\n44\tfunction ensureDirectories() {\n45\t  const dirs = [\n46\t    path.dirname(CONFIG.marketsFilteredPath),\n47\t    path.dirname(CONFIG.tradeLogPath),\n48\t    path.join(__dirname, \"../../../output/bob\"),\n49\t  ];\n50\t  for (const dir of dirs) {\n51\t    if (!fs.existsSync(dir)) {\n52\t      fs.mkdirSync(dir, { recursive: true });\n53\t    }\n54\t  }\n55\t}\n56\t\n57\t// ---------------------------------------------------------------------------\n58\t// Phase 1: Market Filter\n59\t// ---------------------------------------------------------------------------\n60\tfunction runPhase1_MarketFilter() {\n61\t  console.log(\"\\n\" + \"=\".repeat(60));\n62\t  console.log(\"PHASE 1: Market Filtering\");\n63\t  console.log(\"=\".repeat(60));\n64\t  \n65\t  // Use the synthetic market generator to create realistic market data\n66\t  // This simulates Phase 1 output (markets_filtered.json)\n67\t  const markets = generateFilteredMarkets();\n68\t  \n69\t  const output = {\n70\t    generated_at: new Date().toISOString(),\n71\t    phase: 1,\n72\t    filter_criteria: {\n73\t      min_volume: 10000,\n74\t      yes_no_ratio_ranges: [\"15-30%\", \"70-85%\"],\n75\t      exclude_ranges: [\"0-15%\", \"40-60%\", \"85-100%\"],\n76\t    },\n77\t    qualifying_markets: markets.qualifying,\n78\t    excluded_markets: markets.excluded,\n79\t    summary: {\n80\t      total_markets: markets.qualifying.length + markets.excluded.length,\n81\t      qualifying: markets.qualifying.length,\n82\t      excluded: markets.excluded.length,\n83\t    },\n84\t  };\n85\t  \n86\t  fs.writeFileSync(CONFIG.marketsFilteredPath, JSON.stringify(output, null, 2));\n87\t  console.log(`Ō£ģ Phase 1 complete: ${markets.qualifying.length} qualifying markets`);\n88\t  console.log(`   Saved to: ${CONFIG.marketsFilteredPath}`);\n89\t\n90\t  if (markets.qualifying.length === 0) {\n91\t    console.warn(\"ŌÜĀ’ĖÅ  Phase 1 produced 0 qualifying markets ŌĆö downstream phases will have no data\");\n92\t  }\n93\t\n94\t  return output;\n95\t}\n96\t\n97\tfunction generateFilteredMarkets() {\n98\t  // Generate realistic Kalshi-style markets based on knowledge.md\n99\t  const allMarkets = [\n100\t    // Crypto markets (high volume, good for arbitrage)\n101\t    { ticker: \"BTCW-26-JUN30-80K\", title: \"Bitcoin >$80K by Jun 30\", category: \"Crypto\", volume: 720000, yes_price: 82, no_price: 18 },\n102\t    { ticker: \"BTCW-26-DEC31-120K\", title: \"Bitcoin >$120K by Dec 31\", category: \"Crypto\", volume: 890000, yes_price: 62, no_price: 38 },\n103\t    { ticker: \"ETHW-26-DEC31-5K\", title: \"Ethereum >$5K by Dec 31\", category: \"Crypto\", volume: 540000, yes_price: 28, no_price: 72 },\n104\t    { ticker: \"ETHW-26-JUN30-4K\", title: \"Ethereum >$4K by Jun 30\", category: \"Crypto\", volume: 420000, yes_price: 45, no_price: 55 },\n105\t    { ticker: \"SOLW-26-JUN30-300\", title: \"Solana >$300 by Jun 30\", category: \"Crypto\", volume: 180000, yes_price: 35, no_price: 65 },\n106\t    \n107\t    // Economics/Equity markets\n108\t    { ticker: \"INXW-26-DEC31-6000\", title: \"S&P 500 >6000 by Dec 31\", category: \"Economics\", volume: 250000, yes_price: 75, no_price: 25 },\n109\t    { ticker: \"INXW-26-DEC31-7000\", title: \"S&P 500 >7000 by Dec 31\", category: \"Economics\", volume: 180000, yes_price: 35, no_price: 65 },\n110\t    { ticker: \"GDPW-26-Q2-3PCT\", title: \"Q2 GDP >3%\", category: \"Economics\", volume: 95000, yes_price: 25, no_price: 75 },\n111\t    { ticker: \"CPIW-26-MAY-3PCT\", title: \"May CPI >3%\", category: \"Economics\", volume: 88000, yes_price: 72, no_price: 28 },\n112\t    \n113\t    // Financial/NFP markets\n114\t    { ticker: \"KXNF-20260501-T200000\", title: \"NFP >200K\", category: \"Financial\", volume: 150000, yes_price: 26, no_price: 74 },\n115\t    { ticker: \"KXNF-20260501-T250000\", title: \"NFP >250K\", category: \"Financial\", volume: 120000, yes_price: 12, no_price: 88 },\n116\t    \n117\t    // Rates markets\n118\t    { ticker: \"FEDW-26-JUN-CUT\", title: \"Fed cuts rates by June\", category: \"Rates\", volume: 320000, yes_price: 45, no_price: 55 },\n119\t    \n120\t    // Commodities\n121\t    { ticker: \"OILW-26-DEC31-100\", title: \"Oil >$100 by Dec 31\", category: \"Commodities\", volume: 75000, yes_price: 22, no_price: 78 },\n122\t  ];\n123\t  \n124\t  // Apply Phase 1 filters per knowledge.md\n125\t  const qualifying = [];\n126\t  const excluded = [];\n127\t  \n128\t  for (const m of allMarkets) {\n129\t    // Filter 1: Volume >= 10,000\n130\t    if (m.volume < 10000) {\n131\t      excluded.push({ ...m, reason: \"low_volume\" });\n132\t      continue;\n133\t    }\n134\t    \n135\t    // Filter 2: Yes/No ratio in target ranges (15-30% or 70-85%)\n136\t    const yesPct = m.yes_price;\n137\t    const inTargetRange = (yesPct >= 15 && yesPct <= 30) || (yesPct >= 70 && yesPct <= 85);\n138\t    const inMiddleRange = yesPct >= 40 && yesPct <= 60;\n139\t    const inExtremeRange = yesPct <= 15 || yesPct >= 85;\n140\t    \n141\t    if (inTargetRange) {\n142\t      qualifying.push(m);\n143\t    } else {\n144\t      let reason = \"price_ratio\";\n145\t      if (inMiddleRange) reason = \"price_ratio_middle\";\n146\t      if (inExtremeRange) reason = \"price_ratio_extreme\";\n147\t      excluded.push({ ...m, reason });\n148\t    }\n149\t  }\n150\t  \n151\t  return { qualifying, excluded };\n152\t}\n153\t\n154\t// ---------------------------------------------------------------------------\n155\t// Phase 2: Market Clustering\n156\t// ---------------------------------------------------------------------------\n157\tfunction runPhase2_Clustering(marketsFiltered) {\n158\t  console.log(\"\\n\" + \"=\".repeat(60));\n159\t  console.log(\"PHASE 2: Market Clustering\");\n160\t  console.log(\"=\".repeat(60));\n161\t  \n162\t  // Use Ivan's expanded clustering logic (T534)\n163\t  const clusters = generateClusters(marketsFiltered.qualifying_markets);\n164\t  \n165\t  const output = {\n166\t    generated_at: new Date().toISOString(),\n167\t    phase: 2,\n168\t    method: \"Economic domain knowledge + cross-category correlation rules\",\n169\t    input_markets: marketsFiltered.qualifying_markets.length,\n170\t    clusters: clusters.clusters,\n171\t    hidden_correlations: clusters.hidden_correlations,\n172\t    summary: {\n173\t      total_clusters: clusters.clusters.length,\n174\t      internal_clusters: clusters.clusters.filter(c => c.correlation_type === \"internal\").length,\n175\t      cross_category_clusters: clusters.clusters.filter(c => c.correlation_type === \"cross_category\").length,\n176\t      total_markets_clustered: clusters.totalMarkets,\n177\t      hidden_correlations_found: clusters.hidden_correlations.length,\n178\t    },\n179\t  };\n180\t  \n181\t  fs.writeFileSync(CONFIG.marketClustersPath, JSON.stringify(output, null, 2));\n182\t  console.log(`Ō£ģ Phase 2 complete: ${clusters.clusters.length} clusters found`);\n183\t  console.log(`   Internal: ${output.summary.internal_clusters}, Cross-category: ${output.summary.cross_category_clusters}`);\n184\t  console.log(`   Saved to: ${CONFIG.marketClustersPath}`);\n185\t\n186\t  if (clusters.clusters.length === 0) {\n187\t    console.warn(\"ŌÜĀ’ĖÅ  Phase 2 produced 0 clusters ŌĆö correlation detection will have no pairs to analyze\");\n188\t  }\n189\t\n190\t  return output;\n191\t}\n192\t\n193\tfunction generateClusters(qualifyingMarkets) {\n194\t  const tickers = qualifyingMarkets.map(m => m.ticker);\n195\t  const clusters = [];\n196\t  const hidden_correlations = [];\n197\t  \n198\t  // Cluster 1: Crypto Internal\n199\t  const cryptoMarkets = tickers.filter(t => t.includes(\"BTC\") || t.includes(\"ETH\") || t.includes(\"SOL\"));\n200\t  if (cryptoMarkets.length >= 2) {\n201\t    clusters.push({\n202\t      id: \"crypto_internal\",\n203\t      label: \"Crypto Markets\",\n204\t      markets: cryptoMarkets,\n205\t      correlation_strength: 0.95,\n206\t      description: \"Internal Crypto market correlations based on shared underlying drivers\",\n207\t      correlation_type: \"internal\",\n208\t    });\n209\t  }\n210\t  \n211\t  // Cluster 2: Economics Internal\n212\t  const econMarkets = tickers.filter(t => t.includes(\"INXW\") || t.includes(\"GDP\") || t.includes(\"CPI\"));\n213\t  if (econMarkets.length >= 2) {\n214\t    clusters.push({\n215\t      id: \"economics_internal\",\n216\t      label: \"Economics Markets\",\n217\t      markets: econMarkets,\n218\t      correlation_strength: 0.90,\n219\t      description: \"Internal Economics market correlations based on shared underlying drivers\",\n220\t      correlation_type: \"internal\",\n221\t    });\n222\t  }\n223\t  \n224\t  // Cluster 3: Rates-Macro Inverse\n225\t  if (tickers.includes(\"FEDW-26-JUN-CUT\") && econMarkets.length > 0) {\n226\t    clusters.push({\n227\t      id: \"rates_macro\",\n228\t      label: \"Rates-Macro Inverse Correlation\",\n229\t      markets: [\"FEDW-26-JUN-CUT\", ...econMarkets.slice(0, 2)],\n230\t      correlation_strength: 0.70,\n231\t      description: \"Fed rate cuts inversely correlate with strong NFP/GDP data\",\n232\t      correlation_type: \"cross_category\",\n233\t    });\n234\t  }\n235\t  \n236\t  // Cluster 4: Crypto-Macro\n237\t  if (cryptoMarkets.length > 0 && econMarkets.length > 0) {\n238\t    clusters.push({\n239\t      id: \"crypto_macro\",\n240\t      label: \"Crypto-Macro Correlation\",\n241\t      markets: [...cryptoMarkets.slice(0, 3), ...econMarkets.slice(0, 2)],\n242\t      correlation_strength: 0.65,\n243\t      description: \"Crypto assets inversely correlate with strong economic data (NFP/GDP) due to risk-off flows\",\n244\t      correlation_type: \"cross_category\",\n245\t    });\n246\t  }\n247\t\n248\t  // Cluster 5: Financial/NFP markets\n249\t  const nfpMarkets = tickers.filter(t => t.includes(\"KXNF\") || t.includes(\"NFP\"));\n250\t  if (nfpMarkets.length >= 2) {\n251\t    clusters.push({\n252\t      id: \"nfp_internal\",\n253\t      label: \"NFP Threshold Markets\",\n254\t      markets: nfpMarkets,\n255\t      correlation_strength: 0.88,\n256\t      description: \"Different NFP threshold markets are highly correlated\",\n257\t      correlation_type: \"internal\",\n258\t    });\n259\t  }\n260\t  \n261\t  // Generate hidden correlations\n262\t  for (const c of cryptoMarkets.slice(0, 2)) {\n263\t    for (const e of econMarkets.slice(0, 2)) {\n264\t      hidden_correlations.push({\n265\t        market_a: c,\n266\t        market_b: e,\n267\t        correlation_type: \"crypto_macro_inverse\",\n268\t        strength: 0.65,\n269\t        rationale: `${c} inversely correlates with ${e}: strong economic data ŌåÆ risk-off from crypto`,\n270\t      });\n271\t    }\n272\t  }\n273\t  \n274\t  // Count unique markets\n275\t  const allMarkets = new Set();\n276\t  for (const c of clusters) {\n277\t    for (const m of c.markets) allMarkets.add(m);\n278\t  }\n279\t  \n280\t  return { clusters, hidden_correlations, totalMarkets: allMarkets.size };\n281\t}\n282\t\n283\t// ---------------------------------------------------------------------------\n284\t// Phase 3: Pearson Correlation Detection\n285\t// ---------------------------------------------------------------------------\n286\tfunction runPhase3_Correlation(marketClusters) {\n287\t  console.log(\"\\n\" + \"=\".repeat(60));\n288\t  console.log(\"PHASE 3: Pearson Correlation Detection\");\n289\t  console.log(\"=\".repeat(60));\n290\t  \n291\t  const results = detectCorrelations(marketClusters);\n292\t  \n293\t  const output = {\n294\t    generated_at: new Date().toISOString(),\n295\t    phase: 3,\n296\t    config: {\n297\t      min_correlation: CONFIG.minCorrelation,\n298\t      spread_threshold: CONFIG.spreadThreshold,\n299\t      min_history_length: 10,\n300\t    },\n301\t    total_pairs_analyzed: results.pairs.length,\n302\t    arbitrage_opportunities: results.pairs.filter(p => p.is_arbitrage_opportunity).length,\n303\t    pairs: results.pairs,\n304\t  };\n305\t  \n306\t  fs.writeFileSync(CONFIG.correlationPairsPath, JSON.stringify(output, null, 2));\n307\t  console.log(`Ō£ģ Phase 3 complete: ${results.pairs.length} pairs analyzed`);\n308\t  console.log(`   Arbitrage opportunities: ${output.arbitrage_opportunities}`);\n309\t  console.log(`   Saved to: ${CONFIG.correlationPairsPath}`);\n310\t\n311\t  if (results.pairs.length === 0) {\n312\t    console.warn(\"ŌÜĀ’ĖÅ  Phase 3 produced 0 correlated pairs ŌĆö no trades will be generated\");\n313\t  } else if (output.arbitrage_opportunities === 0) {\n314\t    console.warn(\"ŌÜĀ’ĖÅ  Phase 3 found correlated pairs but 0 arbitrage opportunities ŌĆö spread threshold may be too strict\");\n315\t  }\n316\t\n317\t  return output;\n318\t}\n319\t\n320\tfunction detectCorrelations(clusters) {\n321\t  const pairs = [];\n322\t  \n323\t  // Process each cluster\n324\t  for (const cluster of clusters.clusters || []) {\n325\t    const markets = cluster.markets || [];\n326\t    \n327\t    // Generate synthetic price histories for correlation calculation\n328\t    const marketData = {};\n329\t    for (const ticker of markets) {\n330\t      marketData[ticker] = {\n331\t        ticker,\n332\t        prices: generatePriceHistory(ticker, 30),\n333\t        currentPrice: null, // Will be set after generation\n334\t      };\n335\t      marketData[ticker].currentPrice = marketData[ticker].prices[marketData[ticker].prices.length - 1];\n336\t    }\n337\t    \n338\t    // Compare all pairs within cluster\n339\t    for (let i = 0; i < markets.length; i++) {\n340\t      for (let j = i + 1; j < markets.length; j++) {\n341\t        const mA = marketData[markets[i]];\n342\t        const mB = marketData[markets[j]];\n343\t        \n344\t        const correlation = pearsonCorrelation(mA.prices, mB.prices);\n345\t        \n346\t        if (correlation >= CONFIG.minCorrelation) {\n347\t          const spreadStats = calculateSpreadStats(mA.prices, mB.prices);\n348\t          const currentSpread = calculateCurrentSpread(\n349\t            mA.currentPrice, mB.currentPrice,\n350\t            mA.prices[0], mB.prices[0]\n351\t          );\n352\t          const spreadDeviation = Math.abs(currentSpread - spreadStats.meanSpread) / spreadStats.stdSpread;\n353\t          const confidence = calculateArbitrageConfidence(correlation, spreadDeviation);\n354\t          \n355\t          pairs.push({\n356\t            cluster: cluster.id,\n357\t            market_a: mA.ticker,\n358\t            market_b: mB.ticker,\n359\t            pearson_correlation: parseFloat(correlation.toFixed(4)),\n360\t            expected_spread: parseFloat(spreadStats.meanSpread.toFixed(4)),\n361\t            current_spread: parseFloat(currentSpread.toFixed(4)),\n362\t            spread_deviation: parseFloat(spreadDeviation.toFixed(2)),\n363\t            arbitrage_confidence: parseFloat(confidence.toFixed(2)),\n364\t            direction: currentSpread > spreadStats.meanSpread ? \"sell_A_buy_B\" : \"buy_A_sell_B\",\n365\t            is_arbitrage_opportunity: spreadDeviation > CONFIG.spreadThreshold,\n366\t          });\n367\t        }\n368\t      }\n369\t    }\n370\t  }\n371\t  \n372\t  // Sort by confidence\n373\t  pairs.sort((a, b) => b.arbitrage_confidence - a.arbitrage_confidence);\n374\t  \n375\t  return { pairs };\n376\t}\n377\t\n378\tfunction pearsonCorrelation(x, y) {\n379\t  const n = Math.min(x.length, y.length);\n380\t  if (n < 2) return 0;\n381\t  \n382\t  const xSlice = x.slice(-n);\n383\t  const ySlice = y.slice(-n);\n384\t  \n385\t  const sumX = xSlice.reduce((a, b) => a + b, 0);\n386\t  const sumY = ySlice.reduce((a, b) => a + b, 0);\n387\t  const meanX = sumX / n;\n388\t  const meanY = sumY / n;\n389\t  \n390\t  let numerator = 0;\n391\t  let denomX = 0;\n392\t  let denomY = 0;\n393\t  \n394\t  for (let i = 0; i < n; i++) {\n395\t    const diffX = xSlice[i] - meanX;\n396\t    const diffY = ySlice[i] - meanY;\n397\t    numerator += diffX * diffY;\n398\t    denomX += diffX * diffX;\n399\t    denomY += diffY * diffY;\n400\t  }\n401\t  \n402\t  const denominator = Math.sqrt(denomX * denomY);\n403\t  if (denominator === 0) return 0;\n404\t  \n405\t  return numerator / denominator;\n406\t}\n407\t\n408\tfunction calculateSpreadStats(x, y) {\n409\t  const n = Math.min(x.length, y.length, 30);\n410\t  const xSlice = x.slice(-n);\n411\t  const ySlice = y.slice(-n);\n412\t  \n413\t  const spreads = [];\n414\t  const baseX = xSlice[0];\n415\t  const baseY = ySlice[0];\n416\t  \n417\t  for (let i = 0; i < n; i++) {\n418\t    const normX = (xSlice[i] - baseX) / baseX;\n419\t    const normY = (ySlice[i] - baseY) / baseY;\n420\t    spreads.push(normX - normY);\n421\t  }\n422\t  \n423\t  const meanSpread = spreads.reduce((a, b) => a + b, 0) / spreads.length;\n424\t  const variance = spreads.reduce((sum, s) => sum + Math.pow(s - meanSpread, 2), 0) / spreads.length;\n425\t  const stdSpread = Math.sqrt(variance) || 0.001;\n426\t  \n427\t  return { meanSpread, stdSpread };\n428\t}\n429\t\n430\tfunction calculateCurrentSpread(priceA, priceB, basePriceA, basePriceB) {\n431\t  const normA = (priceA - basePriceA) / basePriceA;\n432\t  const normB = (priceB - basePriceB) / basePriceB;\n433\t  return normA - normB;\n434\t}\n435\t\n436\tfunction calculateArbitrageConfidence(correlation, spreadDeviation) {\n437\t  const correlationScore = Math.max(0, correlation);\n438\t  const spreadScore = Math.min(spreadDeviation / CONFIG.spreadThreshold, 1);\n439\t  return correlationScore * 0.6 + spreadScore * 0.4;\n440\t}\n441\t\n442\t// Shared market factor series ŌĆö markets in the same sector share a common driver\n443\t// This produces realistic correlated price movement within clusters\n444\tconst _marketFactors = {};\n445\tfunction getMarketFactor(category, length) {\n446\t  if (_marketFactors[category]) return _marketFactors[category];\n447\t  const seed = category.split('').reduce((a, c) => a + c.charCodeAt(0), 0);\n448\t  const seededRandom = (n) => {\n449\t    const x = Math.sin(seed + n * 7.13) * 10000;\n450\t    return x - Math.floor(x);\n451\t  };\n452\t  const factors = [];\n453\t  for (let i = 0; i < length; i++) {\n454\t    factors.push((seededRandom(i) - 0.5) * 6);\n455\t  }\n456\t  _marketFactors[category] = factors;\n457\t  return factors;\n458\t}\n459\t\n460\tfunction generatePriceHistory(ticker, length) {\n461\t  const seed = ticker.split('').reduce((a, c) => a + c.charCodeAt(0), 0);\n462\t  const seededRandom = (n) => {\n463\t    const x = Math.sin(seed + n) * 10000;\n464\t    return x - Math.floor(x);\n465\t  };\n466\t\n467\t  // Determine category for shared factor\n468\t  let category = \"other\";\n469\t  let basePrice = 50;\n470\t  if (ticker.includes(\"BTC\") || ticker.includes(\"ETH\") || ticker.includes(\"SOL\")) {\n471\t    category = \"crypto\"; basePrice = ticker.includes(\"BTC\") ? 65 : ticker.includes(\"ETH\") ? 35 : 45;\n472\t  } else if (ticker.includes(\"INXW\") || ticker.includes(\"GDP\") || ticker.includes(\"CPI\")) {\n473\t    category = \"economics\"; basePrice = ticker.includes(\"INXW\") ? 75 : 25;\n474\t  } else if (ticker.includes(\"KXNF\") || ticker.includes(\"NFP\")) {\n475\t    category = \"nfp\"; basePrice = 26;\n476\t  } else if (ticker.includes(\"FED\")) {\n477\t    category = \"rates\"; basePrice = 45;\n478\t  } else if (ticker.includes(\"OIL\")) {\n479\t    category = \"commodities\"; basePrice = 22;\n480\t  }\n481\t\n482\t  // Mix shared factor (70%) + idiosyncratic noise (30%) to create correlated series\n483\t  const sharedFactor = getMarketFactor(category, length);\n484\t  const prices = [basePrice];\n485\t  for (let i = 1; i < length; i++) {\n486\t    const shared = sharedFactor[i] * 0.7;\n487\t    const noise = (seededRandom(i) - 0.5) * 4 * 0.3;\n488\t    const change = shared + noise;\n489\t    const newPrice = Math.max(5, Math.min(95, prices[i-1] + change));\n490\t    prices.push(Math.round(newPrice));\n491\t  }\n492\t\n493\t  return prices;\n494\t}\n495\t\n496\t// ---------------------------------------------------------------------------\n497\t// Phase 4: Paper Trade Simulation\n498\t// ---------------------------------------------------------------------------\n499\tfunction runPhase4_PaperTrading(correlationPairs) {\n500\t  console.log(\"\\n\" + \"=\".repeat(60));\n501\t  console.log(\"PHASE 4: Paper Trading Simulation\");\n502\t  console.log(\"=\".repeat(60));\n503\t  \n504\t  const trades = generatePaperTrades(correlationPairs);\n505\t  const pnlSummary = calculatePnLSummary(trades);\n506\t  \n507\t  // Write trade log\n508\t  const tradeLog = {\n509\t    generated_at: new Date().toISOString(),\n510\t    phase: 4,\n511\t    mode: \"paper_trading\",\n512\t    total_trades: trades.length,\n513\t    trades: trades,\n514\t  };\n515\t  fs.writeFileSync(CONFIG.tradeLogPath, JSON.stringify(tradeLog, null, 2));\n516\t  \n517\t  // Write P&L summary\n518\t  const summary = {\n519\t    generated_at: new Date().toISOString(),\n520\t    phase: 4,\n521\t    mode: \"paper_trading\",\n522\t    ...pnlSummary,\n523\t  };\n524\t  fs.writeFileSync(CONFIG.pnlSummaryPath, JSON.stringify(summary, null, 2));\n525\t  \n526\t  console.log(`Ō£ģ Phase 4 complete: ${trades.length} paper trades simulated`);\n527\t  console.log(`   Win rate: ${(pnlSummary.win_rate * 100).toFixed(1)}%`);\n528\t  console.log(`   Total P&L: $${pnlSummary.total_pnl.toFixed(2)}`);\n529\t  console.log(`   Trade log: ${CONFIG.tradeLogPath}`);\n530\t  console.log(`   P&L summary: ${CONFIG.pnlSummaryPath}`);\n531\t  \n532\t  return { tradeLog, pnlSummary };\n533\t}\n534\t\n535\tfunction generatePaperTrades(correlationPairs) {\n536\t  const trades = [];\n537\t  const arbPairs = correlationPairs.pairs.filter(p => p.is_arbitrage_opportunity);\n538\t  \n539\t  // Generate 1-2 trades per arbitrage opportunity\n540\t  for (const pair of arbPairs.slice(0, 6)) { // Limit to top 6\n541\t    const numTrades = 1 + Math.floor(Math.random() * 2); // 1-2 trades per pair\n542\t    \n543\t    for (let i = 0; i < numTrades; i++) {\n544\t      const isWin = Math.random() < pair.arbitrage_confidence;\n545\t      const contracts = 1 + Math.floor(Math.random() * 4); // 1-4 contracts\n546\t      const entryPrice = 50 + Math.floor(Math.random() * 30); // 50-80 cents\n547\t      \n548\t      // P&L calculation\n549\t      const avgWin = 15; // cents\n550\t      const avgLoss = -10; // cents\n551\t      const pnl = isWin ? avgWin * contracts : avgLoss * contracts;\n552\t      \n553\t      trades.push({\n554\t        id: `trade_${trades.length + 1}`,\n555\t        timestamp: new Date(Date.now() - Math.floor(Math.random() * 86400000 * 7)).toISOString(), // Within last 7 days\n556\t        market_a: pair.market_a,\n557\t        market_b: pair.market_b,\n558\t        cluster: pair.cluster,\n559\t        correlation: pair.pearson_correlation,\n560\t        direction: pair.direction,\n561\t        contracts: contracts,\n562\t        entry_price: entryPrice,\n563\t        confidence: pair.arbitrage_confidence,\n564\t        outcome: isWin ? \"win\" : \"loss\",\n565\t        pnl_cents: pnl,\n566\t        pnl_dollars: pnl / 100,\n567\t      });\n568\t    }\n569\t  }\n570\t  \n571\t  return trades;\n572\t}\n573\t\n574\tfunction calculatePnLSummary(trades) {\n575\t  if (trades.length === 0) {\n576\t    return {\n577\t      total_trades: 0,\n578\t      wins: 0,\n579\t      losses: 0,\n580\t      win_rate: 0,\n581\t      total_pnl: 0,\n582\t      avg_pnl_per_trade: 0,\n583\t      total_contracts: 0,\n584\t    };\n585\t  }\n586\t  \n587\t  const wins = trades.filter(t => t.outcome === \"win\").length;\n588\t  const losses = trades.filter(t => t.outcome === \"loss\").length;\n589\t  const totalPnL = trades.reduce((sum, t) => sum + t.pnl_dollars, 0);\n590\t  const totalContracts = trades.reduce((sum, t) => sum + t.contracts, 0);\n591\t  \n592\t  return {\n593\t    total_trades: trades.length,\n594\t    wins,\n595\t    losses,\n596\t    win_rate: wins / trades.length,\n597\t    total_pnl: totalPnL,\n598\t    avg_pnl_per_trade: totalPnL / trades.length,\n599\t    total_contracts: totalContracts,\n600\t  };\n601\t}\n602\t\n603\t// ---------------------------------------------------------------------------\n604\t// Main Pipeline\n605\t// ---------------------------------------------------------------------------\n606\tasync function main() {\n607\t  console.log(\"\\n\" + \"=\".repeat(60));\n608\t  console.log(\"D004 END-TO-END PAPER TRADING PIPELINE\");\n609\t  console.log(\"Task T542 ŌĆö Following culture norms C6, C8, D5\");\n610\t  console.log(\"=\".repeat(60));\n611\t  console.log(`Started at: ${new Date().toISOString()}`);\n612\t  \n613\t  const startTime = Date.now();\n614\t  \n615\t  // Reset cached market factors for fresh generation\n616\t  for (const k of Object.keys(_marketFactors)) delete _marketFactors[k];\n617\t\n618\t  // Ensure directories exist\n619\t  ensureDirectories();\n620\t  \n621\t  // Phase 1: Market Filter\n622\t  const phase1Result = runPhase1_MarketFilter();\n623\t  \n624\t  // Phase 2: Clustering\n625\t  const phase2Result = runPhase2_Clustering(phase1Result);\n626\t  \n627\t  // Phase 3: Correlation\n628\t  const phase3Result = runPhase3_Correlation(phase2Result);\n629\t  \n630\t  // Phase 4: Paper Trading\n631\t  const phase4Result = runPhase4_PaperTrading(phase3Result);\n632\t  \n633\t  // Final summary\n634\t  const duration = Date.now() - startTime;\n635\t  \n636\t  console.log(\"\\n\" + \"=\".repeat(60));\n637\t  console.log(\"PIPELINE COMPLETE\");\n638\t  console.log(\"=\".repeat(60));\n639\t  console.log(`Duration: ${duration}ms`);\n640\t  console.log(`\\nPhase 1: ${phase1Result.summary.qualifying} qualifying markets`);\n641\t  console.log(`Phase 2: ${phase2Result.summary.total_clusters} clusters (${phase2Result.summary.cross_category_clusters} cross-category)`);\n642\t  console.log(`Phase 3: ${phase3Result.total_pairs_analyzed} pairs, ${phase3Result.arbitrage_opportunities} arbitrage opportunities`);\n643\t  console.log(`Phase 4: ${phase4Result.pnlSummary.total_trades} trades, $${phase4Result.pnlSummary.total_pnl.toFixed(2)} P&L, ${(phase4Result.pnlSummary.win_rate * 100).toFixed(1)}% win rate`);\n644\t  \n645\t  console.log(\"\\n­¤ōü Output Files:\");\n646\t  console.log(`   ${CONFIG.marketsFilteredPath}`);\n647\t  console.log(`   ${CONFIG.marketClustersPath}`);\n648\t  console.log(`   ${CONFIG.correlationPairsPath}`);\n649\t  console.log(`   ${CONFIG.tradeLogPath}`);\n650\t  console.log(`   ${CONFIG.pnlSummaryPath}`);\n651\t  \n652\t  console.log(\"\\nŌ£ģ Pipeline executed successfully!\");\n653\t  console.log(\"Following C8: All outputs verified and written to disk.\");\n654\t  \n655\t  return {\n656\t    phase1: phase1Result,\n657\t    phase2: phase2Result,\n658\t    phase3: phase3Result,\n659\t    phase4: phase4Result,\n660\t    duration,\n661\t  };\n662\t}\n663\t\n664\t// Run if called directly\n665\tif (require.main === module) {\n666\t  main().catch(err => {\n667\t    console.error(\"\\nŌØī Pipeline failed:\", err.message);\n668\t    console.error(err.stack);\n669\t    process.exit(1);\n670\t  });\n671\t}\n672\t\n673\tmodule.exports = { main, runPhase1_MarketFilter, runPhase2_Clustering, runPhase3_Correlation, runPhase4_PaperTrading };\n674\t"}]},"parent_tool_use_id":null,"session_id":"f18c7a99-8d48-45ab-a98d-720c3d01377f","uuid":"c87aad12-492e-4bc1-b6b0-22c451d95a23","timestamp":"2026-04-04T06:53:10.559Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/chenyangcui/Documents/code/aicompany/planets/kalshi-traders/output/bob/run_pipeline.js","content":"#!/usr/bin/env node\n/**\n * End-to-End Paper Trading Pipeline ŌĆö T542\n * Single entry point that runs the full D004 pipeline:\n *   Phase 1: Market Filter ŌåÆ markets_filtered.json\n *   Phase 2: Clustering ŌåÆ market_clusters.json\n *   Phase 3: Correlation ŌåÆ correlation_pairs.json\n *   Phase 4: Paper Trade Simulation ŌåÆ trade_log.json + pnl_summary.json\n * \n * Usage: node run_pipeline.js [--paper]\n * \n * Following culture norms:\n *   C6: Reference public/knowledge.md for technical facts\n *   C8: Run and verify your code\n *   D5: Trading system must be runnable end-to-end\n */\n\n\"use strict\";\n\nconst fs = require(\"fs\");\nconst path = require(\"path\");\nconst { execSync } = require(\"child_process\");\n\n// ---------------------------------------------------------------------------\n// Configuration\n// ---------------------------------------------------------------------------\nconst CONFIG = {\n  // Output paths (relative to workspace root)\n  outputDir: path.join(__dirname, \"../../../public\"),\n  marketsFilteredPath: path.join(__dirname, \"../../../public/markets_filtered.json\"),\n  marketClustersPath: path.join(__dirname, \"../../../public/market_clusters.json\"),\n  correlationPairsPath: path.join(__dirname, \"../../../public/correlation_pairs.json\"),\n  tradeLogPath: path.join(__dirname, \"../../../output/trade_log.json\"),\n  pnlSummaryPath: path.join(__dirname, \"../../../output/pnl_summary.json\"),\n  \n  // Pipeline settings\n  paperTrading: true,\n  minMarkets: 3,\n  minCorrelation: 0.60,\n  spreadThreshold: 1.0,\n};\n\n// Ensure output directories exist\nfunction ensureDirectories() {\n  const dirs = [\n    path.dirname(CONFIG.marketsFilteredPath),\n    path.dirname(CONFIG.tradeLogPath),\n    path.join(__dirname, \"../../../output/bob\"),\n  ];\n  for (const dir of dirs) {\n    if (!fs.existsSync(dir)) {\n      fs.mkdirSync(dir, { recursive: true });\n    }\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Phase 1: Market Filter\n// ---------------------------------------------------------------------------\nfunction runPhase1_MarketFilter() {\n  console.log(\"\\n\" + \"=\".repeat(60));\n  console.log(\"PHASE 1: Market Filtering\");\n  console.log(\"=\".repeat(60));\n  \n  // Use the synthetic market generator to create realistic market data\n  // This simulates Phase 1 output (markets_filtered.json)\n  const markets = generateFilteredMarkets();\n  \n  const output = {\n    generated_at: new Date().toISOString(),\n    phase: 1,\n    filter_criteria: {\n      min_volume: 10000,\n      yes_no_ratio_ranges: [\"15-30%\", \"70-85%\"],\n      exclude_ranges: [\"0-15%\", \"40-60%\", \"85-100%\"],\n    },\n    qualifying_markets: markets.qualifying,\n    excluded_markets: markets.excluded,\n    summary: {\n      total_markets: markets.qualifying.length + markets.excluded.length,\n      qualifying: markets.qualifying.length,\n      excluded: markets.excluded.length,\n    },\n  };\n  \n  fs.writeFileSync(CONFIG.marketsFilteredPath, JSON.stringify(output, null, 2));\n  console.log(`Ō£ģ Phase 1 complete: ${markets.qualifying.length} qualifying markets`);\n  console.log(`   Saved to: ${CONFIG.marketsFilteredPath}`);\n\n  if (markets.qualifying.length === 0) {\n    console.warn(\"ŌÜĀ’ĖÅ  Phase 1 produced 0 qualifying markets ŌĆö downstream phases will have no data\");\n  }\n\n  return output;\n}\n\nfunction generateFilteredMarkets() {\n  // Generate realistic Kalshi-style markets based on knowledge.md\n  const allMarkets = [\n    // Crypto markets (high volume, good for arbitrage)\n    { ticker: \"BTCW-26-JUN30-80K\", title: \"Bitcoin >$80K by Jun 30\", category: \"Crypto\", volume: 720000, yes_price: 82, no_price: 18 },\n    { ticker: \"BTCW-26-DEC31-120K\", title: \"Bitcoin >$120K by Dec 31\", category: \"Crypto\", volume: 890000, yes_price: 62, no_price: 38 },\n    { ticker: \"ETHW-26-DEC31-5K\", title: \"Ethereum >$5K by Dec 31\", category: \"Crypto\", volume: 540000, yes_price: 28, no_price: 72 },\n    { ticker: \"ETHW-26-JUN30-4K\", title: \"Ethereum >$4K by Jun 30\", category: \"Crypto\", volume: 420000, yes_price: 45, no_price: 55 },\n    { ticker: \"SOLW-26-JUN30-300\", title: \"Solana >$300 by Jun 30\", category: \"Crypto\", volume: 180000, yes_price: 35, no_price: 65 },\n    \n    // Economics/Equity markets\n    { ticker: \"INXW-26-DEC31-6000\", title: \"S&P 500 >6000 by Dec 31\", category: \"Economics\", volume: 250000, yes_price: 75, no_price: 25 },\n    { ticker: \"INXW-26-DEC31-7000\", title: \"S&P 500 >7000 by Dec 31\", category: \"Economics\", volume: 180000, yes_price: 35, no_price: 65 },\n    { ticker: \"GDPW-26-Q2-3PCT\", title: \"Q2 GDP >3%\", category: \"Economics\", volume: 95000, yes_price: 25, no_price: 75 },\n    { ticker: \"CPIW-26-MAY-3PCT\", title: \"May CPI >3%\", category: \"Economics\", volume: 88000, yes_price: 72, no_price: 28 },\n    \n    // Financial/NFP markets\n    { ticker: \"KXNF-20260501-T200000\", title: \"NFP >200K\", category: \"Financial\", volume: 150000, yes_price: 26, no_price: 74 },\n    { ticker: \"KXNF-20260501-T250000\", title: \"NFP >250K\", category: \"Financial\", volume: 120000, yes_price: 12, no_price: 88 },\n    \n    // Rates markets\n    { ticker: \"FEDW-26-JUN-CUT\", title: \"Fed cuts rates by June\", category: \"Rates\", volume: 320000, yes_price: 45, no_price: 55 },\n    \n    // Commodities\n    { ticker: \"OILW-26-DEC31-100\", title: \"Oil >$100 by Dec 31\", category: \"Commodities\", volume: 75000, yes_price: 22, no_price: 78 },\n  ];\n  \n  // Apply Phase 1 filters per knowledge.md\n  const qualifying = [];\n  const excluded = [];\n  \n  for (const m of allMarkets) {\n    // Filter 1: Volume >= 10,000\n    if (m.volume < 10000) {\n      excluded.push({ ...m, reason: \"low_volume\" });\n      continue;\n    }\n    \n    // Filter 2: Yes/No ratio in target ranges (15-30% or 70-85%)\n    const yesPct = m.yes_price;\n    const inTargetRange = (yesPct >= 15 && yesPct <= 30) || (yesPct >= 70 && yesPct <= 85);\n    const inMiddleRange = yesPct >= 40 && yesPct <= 60;\n    const inExtremeRange = yesPct <= 15 || yesPct >= 85;\n    \n    if (inTargetRange) {\n      qualifying.push(m);\n    } else {\n      let reason = \"price_ratio\";\n      if (inMiddleRange) reason = \"price_ratio_middle\";\n      if (inExtremeRange) reason = \"price_ratio_extreme\";\n      excluded.push({ ...m, reason });\n    }\n  }\n  \n  return { qualifying, excluded };\n}\n\n// ---------------------------------------------------------------------------\n// Phase 2: Market Clustering\n// ---------------------------------------------------------------------------\nfunction runPhase2_Clustering(marketsFiltered) {\n  console.log(\"\\n\" + \"=\".repeat(60));\n  console.log(\"PHASE 2: Market Clustering\");\n  console.log(\"=\".repeat(60));\n  \n  // Use Ivan's expanded clustering logic (T534)\n  const clusters = generateClusters(marketsFiltered.qualifying_markets);\n  \n  const output = {\n    generated_at: new Date().toISOString(),\n    phase: 2,\n    method: \"Economic domain knowledge + cross-category correlation rules\",\n    input_markets: marketsFiltered.qualifying_markets.length,\n    clusters: clusters.clusters,\n    hidden_correlations: clusters.hidden_correlations,\n    summary: {\n      total_clusters: clusters.clusters.length,\n      internal_clusters: clusters.clusters.filter(c => c.correlation_type === \"internal\").length,\n      cross_category_clusters: clusters.clusters.filter(c => c.correlation_type === \"cross_category\").length,\n      total_markets_clustered: clusters.totalMarkets,\n      hidden_correlations_found: clusters.hidden_correlations.length,\n    },\n  };\n  \n  fs.writeFileSync(CONFIG.marketClustersPath, JSON.stringify(output, null, 2));\n  console.log(`Ō£ģ Phase 2 complete: ${clusters.clusters.length} clusters found`);\n  console.log(`   Internal: ${output.summary.internal_clusters}, Cross-category: ${output.summary.cross_category_clusters}`);\n  console.log(`   Saved to: ${CONFIG.marketClustersPath}`);\n\n  if (clusters.clusters.length === 0) {\n    console.warn(\"ŌÜĀ’ĖÅ  Phase 2 produced 0 clusters ŌĆö correlation detection will have no pairs to analyze\");\n  }\n\n  return output;\n}\n\nfunction generateClusters(qualifyingMarkets) {\n  const tickers = qualifyingMarkets.map(m => m.ticker);\n  const clusters = [];\n  const hidden_correlations = [];\n  \n  // Cluster 1: Crypto Internal\n  const cryptoMarkets = tickers.filter(t => t.includes(\"BTC\") || t.includes(\"ETH\") || t.includes(\"SOL\"));\n  if (cryptoMarkets.length >= 2) {\n    clusters.push({\n      id: \"crypto_internal\",\n      label: \"Crypto Markets\",\n      markets: cryptoMarkets,\n      correlation_strength: 0.95,\n      description: \"Internal Crypto market correlations based on shared underlying drivers\",\n      correlation_type: \"internal\",\n    });\n  }\n  \n  // Cluster 2: Economics Internal\n  const econMarkets = tickers.filter(t => t.includes(\"INXW\") || t.includes(\"GDP\") || t.includes(\"CPI\"));\n  if (econMarkets.length >= 2) {\n    clusters.push({\n      id: \"economics_internal\",\n      label: \"Economics Markets\",\n      markets: econMarkets,\n      correlation_strength: 0.90,\n      description: \"Internal Economics market correlations based on shared underlying drivers\",\n      correlation_type: \"internal\",\n    });\n  }\n  \n  // Cluster 3: Rates-Macro Inverse\n  if (tickers.includes(\"FEDW-26-JUN-CUT\") && econMarkets.length > 0) {\n    clusters.push({\n      id: \"rates_macro\",\n      label: \"Rates-Macro Inverse Correlation\",\n      markets: [\"FEDW-26-JUN-CUT\", ...econMarkets.slice(0, 2)],\n      correlation_strength: 0.70,\n      description: \"Fed rate cuts inversely correlate with strong NFP/GDP data\",\n      correlation_type: \"cross_category\",\n    });\n  }\n  \n  // Cluster 4: Crypto-Macro\n  if (cryptoMarkets.length > 0 && econMarkets.length > 0) {\n    clusters.push({\n      id: \"crypto_macro\",\n      label: \"Crypto-Macro Correlation\",\n      markets: [...cryptoMarkets.slice(0, 3), ...econMarkets.slice(0, 2)],\n      correlation_strength: 0.65,\n      description: \"Crypto assets inversely correlate with strong economic data (NFP/GDP) due to risk-off flows\",\n      correlation_type: \"cross_category\",\n    });\n  }\n\n  // Cluster 5: Financial/NFP markets\n  const nfpMarkets = tickers.filter(t => t.includes(\"KXNF\") || t.includes(\"NFP\"));\n  if (nfpMarkets.length >= 2) {\n    clusters.push({\n      id: \"nfp_internal\",\n      label: \"NFP Threshold Markets\",\n      markets: nfpMarkets,\n      correlation_strength: 0.88,\n      description: \"Different NFP threshold markets are highly correlated\",\n      correlation_type: \"internal\",\n    });\n  }\n  \n  // Generate hidden correlations\n  for (const c of cryptoMarkets.slice(0, 2)) {\n    for (const e of econMarkets.slice(0, 2)) {\n      hidden_correlations.push({\n        market_a: c,\n        market_b: e,\n        correlation_type: \"crypto_macro_inverse\",\n        strength: 0.65,\n        rationale: `${c} inversely correlates with ${e}: strong economic data ŌåÆ risk-off from crypto`,\n      });\n    }\n  }\n  \n  // Count unique markets\n  const allMarkets = new Set();\n  for (const c of clusters) {\n    for (const m of c.markets) allMarkets.add(m);\n  }\n  \n  return { clusters, hidden_correlations, totalMarkets: allMarkets.size };\n}\n\n// ---------------------------------------------------------------------------\n// Phase 3: Pearson Correlation Detection\n// ---------------------------------------------------------------------------\nfunction runPhase3_Correlation(marketClusters) {\n  console.log(\"\\n\" + \"=\".repeat(60));\n  console.log(\"PHASE 3: Pearson Correlation Detection\");\n  console.log(\"=\".repeat(60));\n  \n  const results = detectCorrelations(marketClusters);\n  \n  const output = {\n    generated_at: new Date().toISOString(),\n    phase: 3,\n    config: {\n      min_correlation: CONFIG.minCorrelation,\n      spread_threshold: CONFIG.spreadThreshold,\n      min_history_length: 10,\n    },\n    total_pairs_analyzed: results.pairs.length,\n    arbitrage_opportunities: results.pairs.filter(p => p.is_arbitrage_opportunity).length,\n    pairs: results.pairs,\n  };\n  \n  fs.writeFileSync(CONFIG.correlationPairsPath, JSON.stringify(output, null, 2));\n  console.log(`Ō£ģ Phase 3 complete: ${results.pairs.length} pairs analyzed`);\n  console.log(`   Arbitrage opportunities: ${output.arbitrage_opportunities}`);\n  console.log(`   Saved to: ${CONFIG.correlationPairsPath}`);\n\n  if (results.pairs.length === 0) {\n    console.warn(\"ŌÜĀ’ĖÅ  Phase 3 produced 0 correlated pairs ŌĆö no trades will be generated\");\n  } else if (output.arbitrage_opportunities === 0) {\n    console.warn(\"ŌÜĀ’ĖÅ  Phase 3 found correlated pairs but 0 arbitrage opportunities ŌĆö spread threshold may be too strict\");\n  }\n\n  return output;\n}\n\nfunction detectCorrelations(clusters) {\n  const pairs = [];\n  \n  // Process each cluster\n  for (const cluster of clusters.clusters || []) {\n    const markets = cluster.markets || [];\n    \n    // Generate synthetic price histories for correlation calculation\n    const marketData = {};\n    for (const ticker of markets) {\n      marketData[ticker] = {\n        ticker,\n        prices: generatePriceHistory(ticker, 30),\n        currentPrice: null, // Will be set after generation\n      };\n      marketData[ticker].currentPrice = marketData[ticker].prices[marketData[ticker].prices.length - 1];\n    }\n    \n    // Compare all pairs within cluster\n    for (let i = 0; i < markets.length; i++) {\n      for (let j = i + 1; j < markets.length; j++) {\n        const mA = marketData[markets[i]];\n        const mB = marketData[markets[j]];\n        \n        const correlation = pearsonCorrelation(mA.prices, mB.prices);\n        \n        if (correlation >= CONFIG.minCorrelation) {\n          const spreadStats = calculateSpreadStats(mA.prices, mB.prices);\n          const currentSpread = calculateCurrentSpread(\n            mA.currentPrice, mB.currentPrice,\n            mA.prices[0], mB.prices[0]\n          );\n          const spreadDeviation = Math.abs(currentSpread - spreadStats.meanSpread) / spreadStats.stdSpread;\n          const confidence = calculateArbitrageConfidence(correlation, spreadDeviation);\n          \n          pairs.push({\n            cluster: cluster.id,\n            market_a: mA.ticker,\n            market_b: mB.ticker,\n            pearson_correlation: parseFloat(correlation.toFixed(4)),\n            expected_spread: parseFloat(spreadStats.meanSpread.toFixed(4)),\n            current_spread: parseFloat(currentSpread.toFixed(4)),\n            spread_deviation: parseFloat(spreadDeviation.toFixed(2)),\n            arbitrage_confidence: parseFloat(confidence.toFixed(2)),\n            direction: currentSpread > spreadStats.meanSpread ? \"sell_A_buy_B\" : \"buy_A_sell_B\",\n            is_arbitrage_opportunity: spreadDeviation > CONFIG.spreadThreshold,\n          });\n        }\n      }\n    }\n  }\n  \n  // Sort by confidence\n  pairs.sort((a, b) => b.arbitrage_confidence - a.arbitrage_confidence);\n  \n  return { pairs };\n}\n\nfunction pearsonCorrelation(x, y) {\n  const n = Math.min(x.length, y.length);\n  if (n < 2) return 0;\n  \n  const xSlice = x.slice(-n);\n  const ySlice = y.slice(-n);\n  \n  const sumX = xSlice.reduce((a, b) => a + b, 0);\n  const sumY = ySlice.reduce((a, b) => a + b, 0);\n  const meanX = sumX / n;\n  const meanY = sumY / n;\n  \n  let numerator = 0;\n  let denomX = 0;\n  let denomY = 0;\n  \n  for (let i = 0; i < n; i++) {\n    const diffX = xSlice[i] - meanX;\n    const diffY = ySlice[i] - meanY;\n    numerator += diffX * diffY;\n    denomX += diffX * diffX;\n    denomY += diffY * diffY;\n  }\n  \n  const denominator = Math.sqrt(denomX * denomY);\n  if (denominator === 0) return 0;\n  \n  return numerator / denominator;\n}\n\nfunction calculateSpreadStats(x, y) {\n  const n = Math.min(x.length, y.length, 30);\n  const xSlice = x.slice(-n);\n  const ySlice = y.slice(-n);\n  \n  const spreads = [];\n  const baseX = xSlice[0];\n  const baseY = ySlice[0];\n  \n  for (let i = 0; i < n; i++) {\n    const normX = (xSlice[i] - baseX) / baseX;\n    const normY = (ySlice[i] - baseY) / baseY;\n    spreads.push(normX - normY);\n  }\n  \n  const meanSpread = spreads.reduce((a, b) => a + b, 0) / spreads.length;\n  const variance = spreads.reduce((sum, s) => sum + Math.pow(s - meanSpread, 2), 0) / spreads.length;\n  const stdSpread = Math.sqrt(variance) || 0.001;\n  \n  return { meanSpread, stdSpread };\n}\n\nfunction calculateCurrentSpread(priceA, priceB, basePriceA, basePriceB) {\n  const normA = (priceA - basePriceA) / basePriceA;\n  const normB = (priceB - basePriceB) / basePriceB;\n  return normA - normB;\n}\n\nfunction calculateArbitrageConfidence(correlation, spreadDeviation) {\n  const correlationScore = Math.max(0, correlation);\n  const spreadScore = Math.min(spreadDeviation / CONFIG.spreadThreshold, 1);\n  return correlationScore * 0.6 + spreadScore * 0.4;\n}\n\n// Shared market factor series ŌĆö markets in the same sector share a common driver\n// This produces realistic correlated price movement within clusters\nconst _marketFactors = {};\nfunction getMarketFactor(category, length) {\n  if (_marketFactors[category]) return _marketFactors[category];\n  const seed = category.split('').reduce((a, c) => a + c.charCodeAt(0), 0);\n  const seededRandom = (n) => {\n    const x = Math.sin(seed + n * 7.13) * 10000;\n    return x - Math.floor(x);\n  };\n  const factors = [];\n  for (let i = 0; i < length; i++) {\n    factors.push((seededRandom(i) - 0.5) * 6);\n  }\n  _marketFactors[category] = factors;\n  return factors;\n}\n\nfunction generatePriceHistory(ticker, length) {\n  const seed = ticker.split('').reduce((a, c) => a + c.charCodeAt(0), 0);\n  const seededRandom = (n) => {\n    const x = Math.sin(seed + n) * 10000;\n    return x - Math.floor(x);\n  };\n\n  // Determine category for shared factor\n  let category = \"other\";\n  let basePrice = 50;\n  if (ticker.includes(\"BTC\") || ticker.includes(\"ETH\") || ticker.includes(\"SOL\")) {\n    category = \"crypto\"; basePrice = ticker.includes(\"BTC\") ? 65 : ticker.includes(\"ETH\") ? 35 : 45;\n  } else if (ticker.includes(\"INXW\") || ticker.includes(\"GDP\") || ticker.includes(\"CPI\")) {\n    category = \"economics\"; basePrice = ticker.includes(\"INXW\") ? 75 : 25;\n  } else if (ticker.includes(\"KXNF\") || ticker.includes(\"NFP\")) {\n    category = \"nfp\"; basePrice = 26;\n  } else if (ticker.includes(\"FED\")) {\n    category = \"rates\"; basePrice = 45;\n  } else if (ticker.includes(\"OIL\")) {\n    category = \"commodities\"; basePrice = 22;\n  }\n\n  // Mix shared factor (70%) + idiosyncratic noise (30%) to create correlated series\n  const sharedFactor = getMarketFactor(category, length);\n  const prices = [basePrice];\n  for (let i = 1; i < length; i++) {\n    const shared = sharedFactor[i] * 0.7;\n    const noise = (seededRandom(i) - 0.5) * 4 * 0.3;\n    const change = shared + noise;\n    const newPrice = Math.max(5, Math.min(95, prices[i-1] + change));\n    prices.push(Math.round(newPrice));\n  }\n\n  return prices;\n}\n\n// ---------------------------------------------------------------------------\n// Phase 4: Paper Trade Simulation\n// ---------------------------------------------------------------------------\nfunction runPhase4_PaperTrading(correlationPairs) {\n  console.log(\"\\n\" + \"=\".repeat(60));\n  console.log(\"PHASE 4: Paper Trading Simulation\");\n  console.log(\"=\".repeat(60));\n  \n  const trades = generatePaperTrades(correlationPairs);\n  const pnlSummary = calculatePnLSummary(trades);\n  \n  // Write trade log\n  const tradeLog = {\n    generated_at: new Date().toISOString(),\n    phase: 4,\n    mode: \"paper_trading\",\n    total_trades: trades.length,\n    trades: trades,\n  };\n  fs.writeFileSync(CONFIG.tradeLogPath, JSON.stringify(tradeLog, null, 2));\n  \n  // Write P&L summary\n  const summary = {\n    generated_at: new Date().toISOString(),\n    phase: 4,\n    mode: \"paper_trading\",\n    ...pnlSummary,\n  };\n  fs.writeFileSync(CONFIG.pnlSummaryPath, JSON.stringify(summary, null, 2));\n  \n  console.log(`Ō£ģ Phase 4 complete: ${trades.length} paper trades simulated`);\n  console.log(`   Win rate: ${(pnlSummary.win_rate * 100).toFixed(1)}%`);\n  console.log(`   Total P&L: $${pnlSummary.total_pnl.toFixed(2)}`);\n  console.log(`   Trade log: ${CONFIG.tradeLogPath}`);\n  console.log(`   P&L summary: ${CONFIG.pnlSummaryPath}`);\n  \n  return { tradeLog, pnlSummary };\n}\n\nfunction generatePaperTrades(correlationPairs) {\n  const trades = [];\n  const arbPairs = correlationPairs.pairs.filter(p => p.is_arbitrage_opportunity);\n  \n  // Generate 1-2 trades per arbitrage opportunity\n  for (const pair of arbPairs.slice(0, 6)) { // Limit to top 6\n    const numTrades = 1 + Math.floor(Math.random() * 2); // 1-2 trades per pair\n    \n    for (let i = 0; i < numTrades; i++) {\n      const isWin = Math.random() < pair.arbitrage_confidence;\n      const contracts = 1 + Math.floor(Math.random() * 4); // 1-4 contracts\n      const entryPrice = 50 + Math.floor(Math.random() * 30); // 50-80 cents\n      \n      // P&L calculation\n      const avgWin = 15; // cents\n      const avgLoss = -10; // cents\n      const pnl = isWin ? avgWin * contracts : avgLoss * contracts;\n      \n      trades.push({\n        id: `trade_${trades.length + 1}`,\n        timestamp: new Date(Date.now() - Math.floor(Math.random() * 86400000 * 7)).toISOString(), // Within last 7 days\n        market_a: pair.market_a,\n        market_b: pair.market_b,\n        cluster: pair.cluster,\n        correlation: pair.pearson_correlation,\n        direction: pair.direction,\n        contracts: contracts,\n        entry_price: entryPrice,\n        confidence: pair.arbitrage_confidence,\n        outcome: isWin ? \"win\" : \"loss\",\n        pnl_cents: pnl,\n        pnl_dollars: pnl / 100,\n      });\n    }\n  }\n  \n  return trades;\n}\n\nfunction calculatePnLSummary(trades) {\n  if (trades.length === 0) {\n    return {\n      total_trades: 0,\n      wins: 0,\n      losses: 0,\n      win_rate: 0,\n      total_pnl: 0,\n      avg_pnl_per_trade: 0,\n      total_contracts: 0,\n    };\n  }\n  \n  const wins = trades.filter(t => t.outcome === \"win\").length;\n  const losses = trades.filter(t => t.outcome === \"loss\").length;\n  const totalPnL = trades.reduce((sum, t) => sum + t.pnl_dollars, 0);\n  const totalContracts = trades.reduce((sum, t) => sum + t.contracts, 0);\n  \n  return {\n    total_trades: trades.length,\n    wins,\n    losses,\n    win_rate: wins / trades.length,\n    total_pnl: totalPnL,\n    avg_pnl_per_trade: totalPnL / trades.length,\n    total_contracts: totalContracts,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Main Pipeline\n// ---------------------------------------------------------------------------\nasync function main() {\n  console.log(\"\\n\" + \"=\".repeat(60));\n  console.log(\"D004 END-TO-END PAPER TRADING PIPELINE\");\n  console.log(\"Task T542 ŌĆö Following culture norms C6, C8, D5\");\n  console.log(\"=\".repeat(60));\n  console.log(`Started at: ${new Date().toISOString()}`);\n  \n  const startTime = Date.now();\n  \n  // Reset cached market factors for fresh generation\n  for (const k of Object.keys(_marketFactors)) delete _marketFactors[k];\n\n  // Ensure directories exist\n  ensureDirectories();\n  \n  // Phase 1: Market Filter\n  const phase1Result = runPhase1_MarketFilter();\n  \n  // Phase 2: Clustering\n  const phase2Result = runPhase2_Clustering(phase1Result);\n  \n  // Phase 3: Correlation\n  const phase3Result = runPhase3_Correlation(phase2Result);\n  \n  // Phase 4: Paper Trading\n  const phase4Result = runPhase4_PaperTrading(phase3Result);\n  \n  // Final summary\n  const duration = Date.now() - startTime;\n  \n  console.log(\"\\n\" + \"=\".repeat(60));\n  console.log(\"PIPELINE COMPLETE\");\n  console.log(\"=\".repeat(60));\n  console.log(`Duration: ${duration}ms`);\n  console.log(`\\nPhase 1: ${phase1Result.summary.qualifying} qualifying markets`);\n  console.log(`Phase 2: ${phase2Result.summary.total_clusters} clusters (${phase2Result.summary.cross_category_clusters} cross-category)`);\n  console.log(`Phase 3: ${phase3Result.total_pairs_analyzed} pairs, ${phase3Result.arbitrage_opportunities} arbitrage opportunities`);\n  console.log(`Phase 4: ${phase4Result.pnlSummary.total_trades} trades, $${phase4Result.pnlSummary.total_pnl.toFixed(2)} P&L, ${(phase4Result.pnlSummary.win_rate * 100).toFixed(1)}% win rate`);\n  \n  console.log(\"\\n­¤ōü Output Files:\");\n  console.log(`   ${CONFIG.marketsFilteredPath}`);\n  console.log(`   ${CONFIG.marketClustersPath}`);\n  console.log(`   ${CONFIG.correlationPairsPath}`);\n  console.log(`   ${CONFIG.tradeLogPath}`);\n  console.log(`   ${CONFIG.pnlSummaryPath}`);\n  \n  console.log(\"\\nŌ£ģ Pipeline executed successfully!\");\n  console.log(\"Following C8: All outputs verified and written to disk.\");\n  \n  return {\n    phase1: phase1Result,\n    phase2: phase2Result,\n    phase3: phase3Result,\n    phase4: phase4Result,\n    duration,\n  };\n}\n\n// Run if called directly\nif (require.main === module) {\n  main().catch(err => {\n    console.error(\"\\nŌØī Pipeline failed:\", err.message);\n    console.error(err.stack);\n    process.exit(1);\n  });\n}\n\nmodule.exports = { main, runPhase1_MarketFilter, runPhase2_Clustering, runPhase3_Correlation, runPhase4_PaperTrading };\n","numLines":674,"startLine":1,"totalLines":674}}}
