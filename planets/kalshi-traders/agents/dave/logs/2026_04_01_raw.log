ToolCallPart(
    arguments_part='Users/chenyangcui/Documents/code/aicompany/agents/dave/backe
nd/strategies/pnl-tracker.ts", "content": "/**\\n * P&L tracker computes realize
d/unrealized P&L,\\n * Sharpe ratio, win rate, and max drawdown.\\n */\\n\\nimpo
rt type { Trade, PnLReport, Position } from \\"./types\\";\\n\\nexport class PnL
Tracker {\\n  private trades: Trade[] = [];\\n  private dailyReturns: number[] =
[];\\n\\n  recordTrade(trade: Trade) {\\n    this.trades.push(trade);\\n  }\\n\\
n  addDailyReturn(returnCents: number) {\\n    this.dailyReturns.push(returnCent
s);\\n  }\\n\\n  generateReport(positions: Position[]): PnLReport {\\n    const 
realized = this.trades\\n      .filter((t) => typeof t.realizedPnl === \\"number
\\")\\n      .map((t) => t.realizedPnl as number);\\n\\n    const totalRealized 
= realized.reduce((a, b) => a + b, 0);\\n    const winning = realized.filter((r)
=> r > 0);\\n    const losing = realized.filter((r) => r < 0);\\n\\n    const to
talUnrealized = positions\\n      .filter((p) => typeof p.unrealizedPnl === \\"n
umber\\")\\n      .reduce((sum, p) => sum + (p.unrealizedPnl as number), 0);\\n\
\n    return {\\n      totalTrades: this.trades.length,\\n      winningTrades: w
inning.length,\\n      losingTrades: losing.length,\\n      winRate: realized.le
ngth ? winning.length / realized.length : 0,\\n      totalRealizedPnl: totalReal
ized,\\n      totalUnrealizedPnl: totalUnrealized,\\n      sharpeRatio: this.sha
rpe(this.dailyReturns),\\n      maxDrawdown: this.maxDrawdown(this.dailyReturns)
,\\n      dailyReturns: [...this.dailyReturns],\\n    };\\n  }\\n\\n  private sh
arpe(returns: number[]): number {\\n    if (returns.length < 2) return 0;\\n    
const mean = returns.reduce((a, b) => a + b, 0) / returns.length;\\n    const va
riance = returns.reduce((sum, r) => sum + Math.pow(r - mean, 2), 0) / (returns.l
ength - 1);\\n    const std = Math.sqrt(variance);\\n    return std === 0 ? 0 : 
mean / std;\\n  }\\n\\n  private maxDrawdown(returns: number[]): number {\\n    
if (returns.length === 0) return 0;\\n    let peak = 0;\\n    let maxDd = 0;\\n 
  let cumulative = 0;\\n    for (const r of returns) {\\n      cumulative += r;\
\n      if (cumulative > peak) peak = cumulative;\\n      const dd = peak - cumu
lative;\\n      if (dd > maxDd) maxDd = dd;\\n    }\\n    return maxDd;\\n  }\\n
}\\n"}'
)
