id,\n      side,\n      signalType: "entry",\n      confidence,\n      targetPri
ce,\n      currentPrice: targetPrice,\n      expectedEdge: Math.round(edge),\n  
   recommendedContracts: 10,\n      reason: `Mean reversion: z-score=${zScore.to
