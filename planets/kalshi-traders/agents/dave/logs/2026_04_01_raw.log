ckend/strategies/pnl-tracker.ts',
                old_text='',
                new_text='/**\n * P&L tracker computes realized/unrealized P&L,\
n * Sharpe ratio, win rate, and max drawdown.\n */\n\nimport type { Trade, PnLRe
port, Position } from "./types";\n\nexport class PnLTracker {\n  private trades:
Trade[] = [];\n  private dailyReturns: number[] = [];\n\n  recordTrade(trade: Tr
ade) {\n    this.trades.push(trade);\n  }\n\n  addDailyReturn(returnCents: numbe
r) {\n    this.dailyReturns.push(returnCents);\n  }\n\n  generateReport(position
s: Position[]): PnLReport {\n    const realized = this.trades\n      .filter((t)
=> typeof t.realizedPnl === "number")\n      .map((t) => t.realizedPnl as number
);\n\n    const totalRealized = realized.reduce((a, b) => a + b, 0);\n    const 
winning = realized.filter((r) => r > 0);\n    const losing = realized.filter((r)
=> r < 0);\n\n    const totalUnrealized = positions\n      .filter((p) => typeof
p.unrealizedPnl === "number")\n      .reduce((sum, p) => sum + (p.unrealizedPnl 
as number), 0);\n\n    return {\n      totalTrades: this.trades.length,\n      w
inningTrades: winning.length,\n      losingTrades: losing.length,\n      winRate
: realized.length ? winning.length / realized.length : 0,\n      totalRealizedPn
l: totalRealized,\n      totalUnrealizedPnl: totalUnrealized,\n      sharpeRatio
: this.sharpe(this.dailyReturns),\n      maxDrawdown: this.maxDrawdown(this.dail
yReturns),\n      dailyReturns: [...this.dailyReturns],\n    };\n  }\n\n  privat
e sharpe(returns: number[]): number {\n    if (returns.length < 2) return 0;\n  
 const mean = returns.reduce((a, b) => a + b, 0) / returns.length;\n    const va
riance = returns.reduce((sum, r) => sum + Math.pow(r - mean, 2), 0) / (returns.l
ength - 1);\n    const std = Math.sqrt(variance);\n    return std === 0 ? 0 : me
an / std;\n  }\n\n  private maxDrawdown(returns: number[]): number {\n    if (re
turns.length === 0) return 0;\n    let peak = 0;\n    let maxDd = 0;\n    let cu
mulative = 0;\n    for (const r of returns) {\n      cumulative += r;\n      if 
(cumulative > peak) peak = cumulative;\n      const dd = peak - cumulative;\n   
  if (dd > maxDd) maxDd = dd;\n    }\n    return maxDd;\n  }\n}',
                old_start=1,
                new_start=1,
                is_summary=False
            )
        ],
        extras=None
    )
)
