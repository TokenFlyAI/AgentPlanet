.\\n * Supports fixed-fraction and Kelly criterion sizing.\\n */\\n\\nimport typ
e { Signal, Portfolio, StrategyConfig } from \\"./types\\";\\n\\nexport class Po
sitionSizer {\\n  constructor(private config: StrategyConfig) {}\\n\\n  /**\\n  
* Calculate contracts to trade for a signal.\\n   * Uses fixed-fraction by defau
lt; can be overridden for Kelly.\\n   */\\n  calculate(signal: Signal, portfolio
: Portfolio): number {\\n    const method = (signal.metadata?.sizingMethod as st
ring) || \\"fixed-fraction\\";\\n\\n    let contracts: number;\\n    if (method 
=== \\"kelly\\") {\\n      contracts = this.kelly(signal, portfolio);\\n    } el
se {\\n      contracts = this.fixedFraction(signal, portfolio);\\n    }\\n\\n   
// Apply hard caps\\n    const maxByPortfolio = Math.floor(\\n      (portfolio.t
otalValue * this.config.maxPositionPercent) / this.getPriceCents(signal)\\n    )
;\\n    contracts = Math.min(contracts, this.config.maxPositionContracts, maxByP
ortfolio);\\n    contracts = Math.max(0, contracts);\\n\\n    return Math.floor(
contracts);\\n  }\\n\\n  private fixedFraction(_signal: Signal, portfolio: Portf
olio): number {\\n    const allocation = portfolio.totalValue * this.config.defa
ultFraction;\\n    const price = this.getPriceCents(_signal);\\n    if (price <=
0) return 0;\\n    return Math.floor(allocation / price);\\n  }\\n\\n  private k
elly(signal: Signal, portfolio: Portfolio): number {\\n    // Kelly fraction: f*
= edge / (1 - impliedProbability)\\n    // impliedProbability = our confidence\\
n    const edge = signal.edge;\\n    const p = signal.confidence;\\n    if (edge
<= 0 || p >= 1) return 0;\\n    const kellyFraction = edge / (1 - p);\\n    cons
t allocation = portfolio.totalValue * Math.min(kellyFraction, 0.25); // Half-Kel
ly cap at 25%\\n    const price = this.getPriceCents(signal);\\n    if (price <=
0) return 0;\\n    return Math.floor(allocation / price);\\n  }\\n\\n  private g
etPriceCents(signal: Signal): number {\\n    // Use a placeholder price of 50 ce
nts if unavailable.\\n    // Runner should inject actual market price into metad
ata.\\n    const price = signal.metadata?.marketPrice as number | undefined;\\n 
  return typeof price === \\"number\\" && price > 0 ? price : 50;\\n  }\\n}\\n"}
'
