.\n */\n\nconst { BaseStrategy } = require("./index");\n\nclass MeanReversionStr
ategy extends BaseStrategy {\n  constructor(config = {}) {\n    super("MeanRever
sion", config);\n    this.upperThreshold = config.upperThreshold || 0.80;\n    t
his.lowerThreshold = config.lowerThreshold || 0.20;\n    this.target = 0.50;\n  
}\n\n  generateSignals(marketData) {\n    const signals = [];\n    const markets
= marketData.markets || [];\n\n    for (const market of markets) {\n      const 
prob =\n        market.implied_probability ??\n        (market.yes_mid ? market.
yes_mid / 100 : null);\n\n      if (prob === null) continue;\n\n      if (prob >
this.upperThreshold) {\n        const edge = prob - this.target;\n        const 
confidence = Math.min(0.5 + edge, 0.95);\n        signals.push({\n          mark
etId: market.ticker,\n          direction: "sell_yes", // equivalent to buying N
O\n          confidence,\n          edge: edge * 100, // convert to cents for fr
amework consistency\n          price: market.yes_mid || Math.round(prob * 100),\
n          strategy: this.name,\n          timestamp: new Date(),\n          met
adata: {\n            impliedProbability: prob,\n            target: this.target
,\n          },\n        });\n      } else if (prob < this.lowerThreshold) {\n  
     const edge = this.target - prob;\n        const confidence = Math.min(0.5 +
edge, 0.95);\n        signals.push({\n          marketId: market.ticker,\n      
   direction: "buy_yes",\n          confidence,\n          edge: edge * 100,\n  
       price: market.yes_mid || Math.round(prob * 100),\n          strategy: thi
s.name,\n          timestamp: new Date(),\n          metadata: {\n            im
pliedProbability: prob,\n            target: this.target,\n          },\n       
});\n      }\n    }\n\n    return signals;\n  }\n}\n\nmodule.exports = { MeanRev
ersionStrategy };\n',
