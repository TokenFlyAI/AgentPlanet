21\t      this.minContracts,\n   122\t      Math.min(contracts, this.maxContract
s)\n   123\t    );\n   124\t    \n   125\t    return {\n   126\t      contracts:
finalContracts,\n   127\t      kellyFull,\n   128\t      kellyAdjusted,\n   129\
