Probability of win\n    99\t    const q = 1 - p;                // Probability o
f loss\n   100\t    const b = (100 - price) / price; // Odds received (profit/ri
sk)\n   101\t    \n   102\t    // Full Kelly fraction\n   103\t    const kellyFu
ll = (b * p - q) / b;\n   104\t    \n   105\t    // Apply Kelly fraction (quarte
