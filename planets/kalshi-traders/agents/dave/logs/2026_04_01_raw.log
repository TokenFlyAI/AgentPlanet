lTracker.updatePositionPrice(marketId, price);\\n  }\\n\\n  /**\\n   * Get strat
egy performance\\n   * @returns {StrategyPerformance}\\n   */\\n  getPerformance
() {\\n    const metrics = this.pnlTracker.getPerformanceMetrics();\\n    return
{\\n      strategyName: this.name,\\n      ...metrics,\\n    };\\n  }\\n\\n  /**
