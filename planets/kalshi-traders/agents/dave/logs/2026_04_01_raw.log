osedPositions: this.closedPositions.length,\\n    };\\n  }\\n\\n  /**\\n   * Get
all open positions\\n   * @returns {Array} Open positions\\n   */\\n  getOpenPos
itions() {\\n    const open = [];\\n    for (const positions of this.positions.v
