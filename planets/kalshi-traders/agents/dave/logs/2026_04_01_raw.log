\n  }\\n\\n  /**\\n   * Get current portfolio summary\\n   * @returns {Object} P
ortfolio summary\\n   */\\n  getPortfolioSummary() {\\n    let unrealizedPnl = 0
;\\n    let totalExposure = 0;\\n    \\n    for (const positions of this.positio
ns.values()) {\\n      for (const pos of positions) {\\n        if (pos.status =
