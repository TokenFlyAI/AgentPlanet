{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HTvCM3pmG7iP1iPKx45ise","type":"tool_result","content":"690\t\n691\t/**\n692\t * POST /api/notifications/register\n693\t * Register device token for push notifications\n694\t * Body: { userId, token, platform: \"apns\"|\"fcm\" }\n695\t */\n696\tapp.post(\"/api/notifications/register\", (req, res) => {\n697\t  const { userId, token, platform } = req.body;\n698\t  \n699\t  // Validation\n700\t  if (!userId || !token || !platform) {\n701\t    return sendError(res, 400, 'MISSING_FIELDS', 'Missing required fields: userId, token, platform');\n702\t  }\n703\t  \n704\t  if (![\"apns\", \"fcm\"].includes(platform)) {\n705\t    return sendError(res, 400, 'INVALID_PLATFORM', \"Invalid platform. Must be 'apns' or 'fcm'\");\n706\t  }\n707\t  \n708\t  // Store token\n709\t  const key = `${userId}:${platform}`;\n710\t  deviceTokens.set(key, {\n711\t    userId,\n712\t    token,\n713\t    platform,\n714\t    registeredAt: new Date().toISOString(),\n715\t  });\n716\t  \n717\t  res.json({\n718\t    success: true,\n719\t    message: \"Device token registered\",\n720\t    userId,\n721\t    platform,\n722\t    timestamp: new Date().toISOString(),\n723\t  });\n724\t});\n725\t\n726\t/**\n727\t * GET /api/notifications/tokens\n728\t * List registered tokens (admin/debug endpoint)\n729\t */\n730\tapp.get(\"/api/notifications/tokens\", (req, res) => {\n731\t  const tokens = Array.from(deviceTokens.values());\n732\t  res.json({\n733\t    success: true,\n734\t    count: tokens.length,\n735\t    tokens: tokens.map(t => ({ ...t, token: t.token.substring(0, 10) + \"...\" })),\n736\t  });\n737\t});\n738\t\n739\t// ---------------------------------------------------------------------------\n740\t// Live Kalshi API Connection (Task 242)\n741\t// ---------------------------------------------------------------------------\n742\t\n743\t/**\n744\t * GET /api/kalshi/status\n745\t * Check Kalshi API credentials and connectivity\n746