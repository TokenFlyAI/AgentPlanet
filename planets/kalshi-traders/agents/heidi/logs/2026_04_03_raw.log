{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01NUr85YDDpNKeAKLnXqNWD1","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AvkebCqRm53p7XHPEm8gyC","name":"Read","input":{"file_path":"/Users/chenyangcui/Documents/code/aicompany/planets/kalshi-traders/output/shared/codebase/backend/kalshi_client.js"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":24519,"cache_read_input_tokens":36500,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":24519},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"13869bcc-5a8c-4ff8-8624-290e2bdca9d1","uuid":"2f7f46ab-85a5-4178-bc22-c711850657a2"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AvkebCqRm53p7XHPEm8gyC","type":"tool_result","content":"1\t/**\n2\t * Kalshi API Client — Agent Planet Trading Infrastructure\n3\t * Author: Bob (Backend Engineer)\n4\t * Task: #219 — Build Kalshi API client to fetch live market data and prices\n5\t *\n6\t * Provides:\n7\t *   - Authentication (API key-based)\n8\t *   - Market data fetching (markets, prices, orderbook)\n9\t *   - Account information\n10\t *   - Order management\n11\t *   - Built-in rate limiting\n12\t *\n13\t * API Docs: https://trading-api.readme.io/reference/getting-started\n14\t */\n15\t\n16\t\"use strict\";\n17\t\n18\tconst https = require(\"https\");\n19\tconst { URL } = require(\"url\");\n20\t\n21\t// Kalshi API configuration\n22\tconst KALSHI_API_BASE = \"https://trading-api.kalshi.com/v1\";\n23\tconst KALSHI_DEMO_BASE = \"https://demo-api.kalshi.com/v1\";\n24\t\n25\t// Rate limiting: Kalshi allows 100 requests per 10 seconds per API key\n26\tconst DEFAULT_RATE_LIMIT = {\n27\t  maxRequests: 100,\n28\t  windowMs: 10_000,\n29\t};\n30\t\n31\t// ---------------------------------------------------------------------------\n32\t// Simple In-Memory Rate Limiter (Sliding Window)\n33\t// ---------------------------------------------------------------------------\n34\tclass SimpleRateLimiter {\n35\t  constructor(opts = {}) {\n36\t    this.maxRequests = opts.maxRequests || DEFAULT_RATE_LIMIT.maxRequests;\n37\t    this.windowMs = opts.windowMs || DEFAULT_RATE_LIMIT.windowMs;\n38\t    this.requests = [];\n39\t  }\n40\t\n41\t  /**\n42\t   * Check if a request can be made, wait if necessary\n43\t   * @returns {Promise<void>}\n44\t   */\n45\t  async acquire() {\n46\t    const now = Date.now();\n47\t    const windowStart = now - this.windowMs;\n48\t\n49\t    // Remove old requests outside the window\n50\t    this.requests = this.requests.filter((t) => t >= windowStart);\n51\t\n52\t    if (this.requests.length < this.maxRequests) {\n53\t      this.requests.push(now);\n54\t      return;\n55\t    }\n56\t\n57\t    // Need to wait\n58\t    const oldestRequest = this.requests[0];\n59\t    const waitTime = oldestRequest + this.windowMs - now + 10; // +10ms buffer\n60\t\n61\t    if (waitTime > 0) {\n62\t      await sleep(waitTime);\n63\t    }\n64\t\n65\t    // Recursively try again\n66\t    return this.acquire();\n67\t  }\n68\t\n69\t  get remaining() {\n70\t    const windowStart = Date.now() - this.windowMs;\n71\t    this.requests = this.requests.filter((t) => t >= windowStart);\n72\t    return Math.max(0, this.maxRequests - this.requests.length);\n73\t  }\n74\t}\n75\t\n76\tfunction sleep(ms) {\n77\t  return new Promise((resolve) => setTimeout(resolve, ms));\n78\t}\n79\t\n80\t// ---------------------------------------------------------------------------\n81\t// Kalshi API Client\n82\t// ---------------------------------------------------------------------------\n83\tclass KalshiClient {\n84\t  /**\n85\t   * Create a new Kalshi API client\n86\t   * @param {object} opts\n87\t   * @param {string} opts.apiKey - Kalshi API key\n88\t   * @param {boolean} opts.demo - Use demo/sandbox environment (default: true)\n89\t   * @param {object} opts.rateLimit - Rate limit options\n90\t   * @param {number} opts.timeout - Request timeout in ms (default: 30000)\n91\t   */\n92\t  constructor(opts = {}) {\n93\t    this.apiKey = opts.apiKey || process.env.KALSHI_API_KEY;\n94\t    this.demo = opts.demo !== false; // Default to demo mode\n95\t    this.baseUrl = this.demo ? KALSHI_DEMO_BASE : KALSHI_API_BASE;\n96\t    this.timeout = opts.timeout || 30000;\n97\t\n98\t    if (!this.apiKey) {\n99\t      throw new Error(\n100\t        \"Kalshi API key required. Set KALSHI_API_KEY env var or pass apiKey option.\"\n101\t      );\n102\t    }\n103\t\n104\t    this.rateLimiter = new SimpleRateLimiter(opts.rateLimit);\n105\t  }\n106\t\n107\t  /**\n108\t   * Make an authenticated request to the Kalshi API\n109\t   * @param {string} method - HTTP method\n110\t   * @param {string} path - API path (without base URL)\n111\t   * @param {object} opts - Request options\n112\t   * @returns {Promise<object>}\n113\t   */\n114\t  async request(method, path, opts = {}) {\n115\t    // Acquire rate limit slot\n116\t    await this.rateLimiter.acquire();\n117\t\n118\t    const url = new URL(path, this.baseUrl);\n119\t\n120\t    // Add query params\n121\t    if (opts.params) {\n122\t      Object.entries(opts.params).forEach(([key, value]) => {\n123\t        if (value !== undefined && value !== null) {\n124\t          url.searchParams.append(key, String(value));\n125\t        }\n126\t      });\n127\t    }\n128\t\n129\t    const headers = {\n130\t      Authorization: `Bearer ${this.apiKey}`,\n131\t      Accept: \"application/json\",\n132\t      \"Content-Type\": \"application/json\",\n133\t      ...(opts.headers || {}),\n134\t    };\n135\t\n136\t    return new Promise((resolve, reject) => {\n137\t      const req = https.request(\n138\t        url,\n139\t        {\n140\t          method,\n141\t          headers,\n142\t          timeout: this.timeout,\n143\t        },\n144\t        (res) => {\n145\t          let data = \"\";\n146\t          res.on(\"data\", (chunk) => (data += chunk));\n147\t          res.on(\"end\", () => {\n148\t            try {\n149\t              const body = data ? JSON.parse(data) : null;\n150\t\n151\t              if (res.statusCode >= 200 && res.statusCode < 300) {\n152\t                resolve({\n153\t                  status: res.statusCode,\n154\t                  headers: res.headers,\n155\t                  data: body,\n156\t                });\n157\t              } else {\n158\t                const error = new Error(\n159\t                  body?.error?.message ||\n160\t                    `HTTP ${res.statusCode}: ${res.statusMessage}`\n161\t                );\n162\t                error.status = res.statusCode;\n163\t                error.response = body;\n164\t                reject(error);\n165\t              }\n166\t            } catch (e) {\n167\t              reject(new Error(`Failed to parse response: ${e.message}`));\n168\t            }\n169\t          });\n170\t        }\n171\t      );\n172\t\n173\t      req.on(\"error\", reject);\n174\t      req.on(\"timeout\", () => {\n175\t        req.destroy();\n176\t        reject(new Error(\"Request timeout\"));\n177\t      });\n178\t\n179\t      if (opts.body) {\n180\t        req.write(JSON.stringify(opts.body));\n181\t      }\n182\t\n183\t      req.end();\n184\t    });\n185\t  }\n186\t\n187\t  // -------------------------------------------------------------------------\n188\t  // Account Endpoints\n189\t  // -------------------------------------------------------------------------\n190\t\n191\t  /**\n192\t   * Get account balance and information\n193\t   * @returns {Promise<object>}\n194\t   */\n195\t  async getAccount() {\n196\t    return this.request(\"GET\", \"/account\");\n197\t  }\n198\t\n199\t  /**\n200\t   * Get account balance\n201\t   * @returns {Promise<object>}\n202\t   */\n203\t  async getBalance() {\n204\t    return this.request(\"GET\", \"/account/balance\");\n205\t  }\n206\t\n207\t  // -------------------------------------------------------------------------\n208\t  // Market Endpoints\n209\t  // -------------------------------------------------------------------------\n210\t\n211\t  /**\n212\t   * Get all markets with optional filters\n213\t   * @param {object} filters\n214\t   * @param {string} filters.status - Market status (active, closed, etc.)\n215\t   * @param {string} filters.category - Market category\n216\t   * @param {string} filters.series_ticker - Series ticker\n217\t   * @param {number} filters.limit - Max results (default: 100)\n218\t   * @param {string} filters.cursor - Pagination cursor\n219\t   * @returns {Promise<object>}\n220\t   */\n221\t  async getMarkets(filters = {}) {\n222\t    const params = {\n223\t      limit: filters.limit || 100,\n224\t      ...(filters.status && { status: filters.status }),\n225\t      ...(filters.category && { category: filters.category }),\n226\t      ...(filters.series_ticker && { series_ticker: filters.series_ticker }),\n227\t      ...(filters.cursor && { cursor: filters.cursor }),\n228\t    };\n229\t\n230\t    return this.request(\"GET\", \"/markets\", { params });\n231\t  }\n232\t\n233\t  /**\n234\t   * Get a specific market by ticker\n235\t   * @param {string} ticker - Market ticker symbol\n236\t   * @returns {Promise<object>}\n237\t   */\n238\t  async getMarket(ticker) {\n239\t    return this.request(\"GET\", `/markets/${ticker}`);\n240\t  }\n241\t\n242\t  /**\n243\t   * Get market orderbook\n244\t   * @param {string} ticker - Market ticker symbol\n245\t   * @param {number} depth - Orderbook depth (default: 10)\n246\t   * @returns {Promise<object>}\n247\t   */\n248\t  async getOrderbook(ticker, depth = 10) {\n249\t    return this.request(\"GET\", `/markets/${ticker}/orderbook`, {\n250\t      params: { depth },\n251\t    });\n252\t  }\n253\t\n254\t  /**\n255\t   * Get market candle data (price history)\n256\t   * @param {string} ticker - Market ticker symbol\n257\t   * @param {object} opts\n258\t   * @param {string} opts.resolution - Candle resolution (1m, 5m, 15m, 1h, 1d)\n259\t   * @param {number} opts.from - Start timestamp (ms)\n260\t   * @param {number} opts.to - End timestamp (ms)\n261\t   * @returns {Promise<object>}\n262\t   */\n263\t  async getCandles(ticker, opts = {}) {\n264\t    const params = {\n265\t      resolution: opts.resolution || \"1d\",\n266\t      ...(opts.from && { from: opts.from }),\n267\t      ...(opts.to && { to: opts.to }),\n268\t    };\n269\t\n270\t    return this.request(\"GET\", `/markets/${ticker}/candles`, { params });\n271\t  }\n272\t\n273\t  /**\n274\t   * Get market history (trades)\n275\t   * @param {string} ticker - Market ticker symbol\n276\t   * @param {object} opts\n277\t   * @param {number} opts.limit - Max results\n278\t   * @param {string} opts.cursor - Pagination cursor\n279\t   * @returns {Promise<object>}\n280\t   */\n281\t  async getMarketHistory(ticker, opts = {}) {\n282\t    const params = {\n283\t      limit: opts.limit || 100,\n284\t      ...(opts.cursor && { cursor: opts.cursor }),\n285\t    };\n286\t\n287\t    return this.request(\"GET\", `/markets/${ticker}/history`, { params });\n288\t  }\n289\t\n290\t  // -------------------------------------------------------------------------\n291\t  // Series Endpoints\n292\t  // -------------------------------------------------------------------------\n293\t\n294\t  /**\n295\t   * Get all series\n296\t   * @param {object} opts\n297\t   * @param {number} opts.limit - Max results\n298\t   * @param {string} opts.cursor - Pagination cursor\n299\t   * @returns {Promise<object>}\n300\t   */\n301\t  async getSeries(opts = {}) {\n302\t    const params = {\n303\t      limit: opts.limit || 100,\n304\t      ...(opts.cursor && { cursor: opts.cursor }),\n305\t    };\n306\t\n307\t    return this.request(\"GET\", \"/series\", { params });\n308\t  }\n309\t\n310\t  /**\n311\t   * Get a specific series\n312\t   * @param {string} ticker - Series ticker\n313\t   * @returns {Promise<object>}\n314\t   */\n315\t  async getSeriesByTicker(ticker) {\n316\t    return this.request(\"GET\", `/series/${ticker}`);\n317\t  }\n318\t\n319\t  // -------------------------------------------------------------------------\n320\t  // Event Endpoints\n321\t  // -------------------------------------------------------------------------\n322\t\n323\t  /**\n324\t   * Get all events\n325\t   * @param {object} opts\n326\t   * @param {number} opts.limit - Max results\n327\t   * @param {string} opts.cursor - Pagination cursor\n328\t   * @returns {Promise<object>}\n329\t   */\n330\t  async getEvents(opts = {}) {\n331\t    const params = {\n332\t      limit: opts.limit || 100,\n333\t      ...(opts.cursor && { cursor: opts.cursor }),\n334\t    };\n335\t\n336\t    return this.request(\"GET\", \"/events\", { params });\n337\t  }\n338\t\n339\t  /**\n340\t   * Get a specific event\n341\t   * @param {string} eventTicker - Event ticker\n342\t   * @returns {Promise<object>}\n343\t   */\n344\t  async getEvent(eventTicker) {\n345\t    return this.request(\"GET\", `/events/${eventTicker}`);\n346\t  }\n347\t\n348\t  // -------------------------------------------------------------------------\n349\t  // Order Endpoints\n350\t  // -------------------------------------------------------------------------\n351\t\n352\t  /**\n353\t   * Get all orders\n354\t   * @param {object} opts\n355\t   * @param {string} opts.status - Order status\n356\t   * @param {number} opts.limit - Max results\n357\t   * @param {string} opts.cursor - Pagination cursor\n358\t   * @returns {Promise<object>}\n359\t   */\n360\t  async getOrders(opts = {}) {\n361\t    const params = {\n362\t      limit: opts.limit || 100,\n363\t      ...(opts.status && { status: opts.status }),\n364\t      ...(opts.cursor && { cursor: opts.cursor }),\n365\t    };\n366\t\n367\t    return this.request(\"GET\", \"/orders\", { params });\n368\t  }\n369\t\n370\t  /**\n371\t   * Get a specific order\n372\t   * @param {string} orderId - Order ID\n373\t   * @returns {Promise<object>}\n374\t   */\n375\t  async getOrder(orderId) {\n376\t    return this.request(\"GET\", `/orders/${orderId}`);\n377\t  }\n378\t\n379\t  /**\n380\t   * Create a new order\n381\t   * @param {object} order\n382\t   * @param {string} order.ticker - Market ticker\n383\t   * @param {string} order.side - Order side (yes/no)\n384\t   * @param {number} order.count - Number of contracts\n385\t   * @param {number} order.price - Price in cents (0-100)\n386\t   * @param {string} order.client_order_id - Client order ID (optional)\n387\t   * @returns {Promise<object>}\n388\t   */\n389\t  async createOrder(order) {\n390\t    return this.request(\"POST\", \"/orders\", { body: order });\n391\t  }\n392\t\n393\t  /**\n394\t   * Cancel an order\n395\t   * @param {string} orderId - Order ID\n396\t   * @returns {Promise<object>}\n397\t   */\n398\t  async cancelOrder(orderId) {\n399\t    return this.request(\"DELETE\", `/orders/${orderId}`);\n400\t  }\n401\t\n402\t  /**\n403\t   * Cancel all orders\n404\t   * @returns {Promise<object>}\n405\t   */\n406\t  async cancelAllOrders() {\n407\t    return this.request(\"DELETE\", \"/orders\");\n408\t  }\n409\t\n410\t  // -------------------------------------------------------------------------\n411\t  // Position Endpoints\n412\t  // -------------------------------------------------------------------------\n413\t\n414\t  /**\n415\t   * Get all positions\n416\t   * @param {object} opts\n417\t   * @param {number} opts.limit - Max results\n418\t   * @param {string} opts.cursor - Pagination cursor\n419\t   * @returns {Promise<object>}\n420\t   */\n421\t  async getPositions(opts = {}) {\n422\t    const params = {\n423\t      limit: opts.limit || 100,\n424\t      ...(opts.cursor && { cursor: opts.cursor }),\n425\t    };\n426\t\n427\t    return this.request(\"GET\", \"/positions\", { params });\n428\t  }\n429\t\n430\t  /**\n431\t   * Get a specific position\n432\t   * @param {string} ticker - Market ticker\n433\t   * @returns {Promise<object>}\n434\t   */\n435\t  async getPosition(ticker) {\n436\t    return this.request(\"GET\", `/positions/${ticker}`);\n437\t  }\n438\t\n439\t  // -------------------------------------------------------------------------\n440\t  // Portfolio Endpoints\n441\t  // -------------------------------------------------------------------------\n442\t\n443\t  /**\n444\t   * Get portfolio statistics\n445\t   * @returns {Promise<object>}\n446\t   */\n447\t  async getPortfolio() {\n448\t    return this.request(\"GET\", \"/portfolio\");\n449\t  }\n450\t\n451\t  /**\n452\t   * Get portfolio history\n453\t   * @param {object} opts\n454\t   * @param {string} opts.lookback - Lookback period (1d, 7d, 30d, etc.)\n455\t   * @returns {Promise<object>}\n456\t   */\n457\t  async getPortfolioHistory(opts = {}) {\n458\t    const params = {\n459\t      ...(opts.lookback && { lookback: opts.lookback }),\n460\t    };\n461\t\n462\t    return this.request(\"GET\", \"/portfolio/history\", { params });\n463\t  }\n464\t\n465\t  // -------------------------------------------------------------------------\n466\t  // Utility Methods\n467\t  // -------------------------------------------------------------------------\n468\t\n469\t  /**\n470\t   * Get current rate limit status\n471\t   * @returns {object}\n472\t   */\n473\t  getRateLimitStatus() {\n474\t    return {\n475\t      remaining: this.rateLimiter.remaining,\n476\t      limit: this.rateLimiter.maxRequests,\n477\t      windowMs: this.rateLimiter.windowMs,\n478\t    };\n479\t  }\n480\t}\n481\t\n482\t// ---------------------------------------------------------------------------\n483\t// Convenience Functions\n484\t// ---------------------------------------------------------------------------\n485\t\n486\t/**\n487\t * Create a new Kalshi client from environment variables\n488\t * @returns {KalshiClient}\n489\t */\n490\tfunction createClient() {\n491\t  return new KalshiClient({\n492\t    apiKey: process.env.KALSHI_API_KEY,\n493\t    demo: process.env.KALSHI_DEMO !== \"false\",\n494\t  });\n495\t}\n496\t\n497\t// ---------------------------------------------------------------------------\n498\t// Exports\n499\t// ---------------------------------------------------------------------------\n500\tmodule.exports = {\n501\t  KalshiClient,\n502\t  SimpleRateLimiter,\n503\t  createClient,\n504\t};\n505\t\n506\t// ---------------------------------------------------------------------------\n507\t// Standalone test\n508\t// ---------------------------------------------------------------------------\n509\tif (require.main === module) {\n510\t  console.log(\"Kalshi Client Module - Self Test\\n\");\n511\t\n512\t  // Test rate limiter\n513\t  console.log(\"1. Testing SimpleRateLimiter:\");\n514\t  const rl = new SimpleRateLimiter({ maxRequests: 3, windowMs: 1000 });\n515\t\n516\t  async function testRateLimiter() {\n517\t    for (let i = 1; i <= 5; i++) {\n518\t      const start = Date.now();\n519\t      await rl.acquire();\n520\t      console.log(`  Request ${i}: acquired after ${Date.now() - start}ms`);\n521\t    }\n522\t  }\n523\t\n524\t  testRateLimiter()\n525\t    .then(() => {\n526\t      console.log(\"\\n2. Testing KalshiClient instantiation:\");\n527\t\n528\t      // Test without API key (should throw)\n529\t      try {\n530\t        const client = new KalshiClient({});\n531\t        console.log(\"  ERROR: Should have thrown without API key\");\n532\t      } catch (e) {\n533\t        console.log(`  ✓ Correctly throws: ${e.message}`);\n534\t      }\n535\t\n536\t      // Test with API key\n537\t      const client = new KalshiClient({\n538\t        apiKey: \"test_key_123\",\n539\t        demo: true,\n540\t      });\n541\t      console.log(`  ✓ Client created (demo mode: ${client.demo})`);\n542\t      console.log(`  ✓ Base URL: ${client.baseUrl}`);\n543\t\n544\t      // Test rate limit status\n545\t      const status = client.getRateLimitStatus();\n546\t      console.log(`  ✓ Rate limit: ${status.remaining}/${status.limit}`);\n547\t\n548\t      console.log(\"\\n✅ All tests completed\");\n549\t    })\n550\t    .catch((e) => {\n551\t      console.error(\"\\n❌ Test failed:\", e.message);\n552\t      process.exit(1);\n553\t    });\n554\t}\n555\t"}]},"parent_tool_use_id":null,"session_id":"13869bcc-5a8c-4ff8-8624-290e2bdca9d1","uuid":"5acc2eb2-787e-4459-bded-c5176d50ec78","timestamp":"2026-04-04T05:42:22.615Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/chenyangcui/Documents/code/aicompany/planets/kalshi-traders/output/shared/codebase/backend/kalshi_client.js","content":"/**\n * Kalshi API Client — Agent Planet Trading Infrastructure\n * Author: Bob (Backend Engineer)\n * Task: #219 — Build Kalshi API client to fetch live market data and prices\n *\n * Provides:\n *   - Authentication (API key-based)\n *   - Market data fetching (markets, prices, orderbook)\n *   - Account information\n *   - Order management\n *   - Built-in rate limiting\n *\n * API Docs: https://trading-api.readme.io/reference/getting-started\n */\n\n\"use strict\";\n\nconst https = require(\"https\");\nconst { URL } = require(\"url\");\n\n// Kalshi API configuration\nconst KALSHI_API_BASE = \"https://trading-api.kalshi.com/v1\";\nconst KALSHI_DEMO_BASE = \"https://demo-api.kalshi.com/v1\";\n\n// Rate limiting: Kalshi allows 100 requests per 10 seconds per API key\nconst DEFAULT_RATE_LIMIT = {\n  maxRequests: 100,\n  windowMs: 10_000,\n};\n\n// ---------------------------------------------------------------------------\n// Simple In-Memory Rate Limiter (Sliding Window)\n// ---------------------------------------------------------------------------\nclass SimpleRateLimiter {\n  constructor(opts = {}) {\n    this.maxRequests = opts.maxRequests || DEFAULT_RATE_LIMIT.maxRequests;\n    this.windowMs = opts.windowMs || DEFAULT_RATE_LIMIT.windowMs;\n    this.requests = [];\n  }\n\n  /**\n   * Check if a request can be made, wait if necessary\n   * @returns {Promise<void>}\n   */\n  async acquire() {\n    const now = Date.now();\n    const windowStart = now - this.windowMs;\n\n    // Remove old requests outside the window\n    this.requests = this.requests.filter((t) => t >= windowStart);\n\n    if (this.requests.length < this.maxRequests) {\n      this.requests.push(now);\n      return;\n    }\n\n    // Need to wait\n    const oldestRequest = this.requests[0];\n    const waitTime = oldestRequest + this.windowMs - now + 10; // +10ms buffer\n\n    if (waitTime > 0) {\n      await sleep(waitTime);\n    }\n\n    // Recursively try again\n    return this.acquire();\n  }\n\n  get remaining() {\n    const windowStart = Date.now() - this.windowMs;\n    this.requests = this.requests.filter((t) => t >= windowStart);\n    return Math.max(0, this.maxRequests - this.requests.length);\n  }\n}\n\nfunction sleep(ms) {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\n// ---------------------------------------------------------------------------\n// Kalshi API Client\n// ---------------------------------------------------------------------------\nclass KalshiClient {\n  /**\n   * Create a new Kalshi API client\n   * @param {object} opts\n   * @param {string} opts.apiKey - Kalshi API key\n   * @param {boolean} opts.demo - Use demo/sandbox environment (default: true)\n   * @param {object} opts.rateLimit - Rate limit options\n   * @param {number} opts.timeout - Request timeout in ms (default: 30000)\n   */\n  constructor(opts = {}) {\n    this.apiKey = opts.apiKey || process.env.KALSHI_API_KEY;\n    this.demo = opts.demo !== false; // Default to demo mode\n    this.baseUrl = this.demo ? KALSHI_DEMO_BASE : KALSHI_API_BASE;\n    this.timeout = opts.timeout || 30000;\n\n    if (!this.apiKey) {\n      throw new Error(\n        \"Kalshi API key required. Set KALSHI_API_KEY env var or pass apiKey option.\"\n      );\n    }\n\n    this.rateLimiter = new SimpleRateLimiter(opts.rateLimit);\n  }\n\n  /**\n   * Make an authenticated request to the Kalshi API\n   * @param {string} method - HTTP method\n   * @param {string} path - API path (without base URL)\n   * @param {object} opts - Request options\n   * @returns {Promise<object>}\n   */\n  async request(method, path, opts = {}) {\n    // Acquire rate limit slot\n    await this.rateLimiter.acquire();\n\n    const url = new URL(path, this.baseUrl);\n\n    // Add query params\n    if (opts.params) {\n      Object.entries(opts.params).forEach(([key, value]) => {\n        if (value !== undefined && value !== null) {\n          url.searchParams.append(key, String(value));\n        }\n      });\n    }\n\n    const headers = {\n      Authorization: `Bearer ${this.apiKey}`,\n      Accept: \"application/json\",\n      \"Content-Type\": \"application/json\",\n      ...(opts.headers || {}),\n    };\n\n    return new Promise((resolve, reject) => {\n      const req = https.request(\n        url,\n        {\n          method,\n          headers,\n          timeout: this.timeout,\n        },\n        (res) => {\n          let data = \"\";\n          res.on(\"data\", (chunk) => (data += chunk));\n          res.on(\"end\", () => {\n            try {\n              const body = data ? JSON.parse(data) : null;\n\n              if (res.statusCode >= 200 && res.statusCode < 300) {\n                resolve({\n                  status: res.statusCode,\n                  headers: res.headers,\n                  data: body,\n                });\n              } else {\n                const error = new Error(\n                  body?.error?.message ||\n                    `HTTP ${res.statusCode}: ${res.statusMessage}`\n                );\n                error.status = res.statusCode;\n                error.response = body;\n                reject(error);\n              }\n            } catch (e) {\n              reject(new Error(`Failed to parse response: ${e.message}`));\n            }\n          });\n        }\n      );\n\n      req.on(\"error\", reject);\n      req.on(\"timeout\", () => {\n        req.destroy();\n        reject(new Error(\"Request timeout\"));\n      });\n\n      if (opts.body) {\n        req.write(JSON.stringify(opts.body));\n      }\n\n      req.end();\n    });\n  }\n\n  // -------------------------------------------------------------------------\n  // Account Endpoints\n  // -------------------------------------------------------------------------\n\n  /**\n   * Get account balance and information\n   * @returns {Promise<object>}\n   */\n  async getAccount() {\n    return this.request(\"GET\", \"/account\");\n  }\n\n  /**\n   * Get account balance\n   * @returns {Promise<object>}\n   */\n  async getBalance() {\n    return this.request(\"GET\", \"/account/balance\");\n  }\n\n  // -------------------------------------------------------------------------\n  // Market Endpoints\n  // -------------------------------------------------------------------------\n\n  /**\n   * Get all markets with optional filters\n   * @param {object} filters\n   * @param {string} filters.status - Market status (active, closed, etc.)\n   * @param {string} filters.category - Market category\n   * @param {string} filters.series_ticker - Series ticker\n   * @param {number} filters.limit - Max results (default: 100)\n   * @param {string} filters.cursor - Pagination cursor\n   * @returns {Promise<object>}\n   */\n  async getMarkets(filters = {}) {\n    const params = {\n      limit: filters.limit || 100,\n      ...(filters.status && { status: filters.status }),\n      ...(filters.category && { category: filters.category }),\n      ...(filters.series_ticker && { series_ticker: filters.series_ticker }),\n      ...(filters.cursor && { cursor: filters.cursor }),\n    };\n\n    return this.request(\"GET\", \"/markets\", { params });\n  }\n\n  /**\n   * Get a specific market by ticker\n   * @param {string} ticker - Market ticker symbol\n   * @returns {Promise<object>}\n   */\n  async getMarket(ticker) {\n    return this.request(\"GET\", `/markets/${ticker}`);\n  }\n\n  /**\n   * Get market orderbook\n   * @param {string} ticker - Market ticker symbol\n   * @param {number} depth - Orderbook depth (default: 10)\n   * @returns {Promise<object>}\n   */\n  async getOrderbook(ticker, depth = 10) {\n    return this.request(\"GET\", `/markets/${ticker}/orderbook`, {\n      params: { depth },\n    });\n  }\n\n  /**\n   * Get market candle data (price history)\n   * @param {string} ticker - Market ticker symbol\n   * @param {object} opts\n   * @param {string} opts.resolution - Candle resolution (1m, 5m, 15m, 1h, 1d)\n   * @param {number} opts.from - Start timestamp (ms)\n   * @param {number} opts.to - End timestamp (ms)\n   * @returns {Promise<object>}\n   */\n  async getCandles(ticker, opts = {}) {\n    const params = {\n      resolution: opts.resolution || \"1d\",\n      ...(opts.from && { from: opts.from }),\n      ...(opts.to && { to: opts.to }),\n    };\n\n    return this.request(\"GET\", `/markets/${ticker}/candles`, { params });\n  }\n\n  /**\n   * Get market history (trades)\n   * @param {string} ticker - Market ticker symbol\n   * @param {object} opts\n   * @param {number} opts.limit - Max results\n   * @param {string} opts.cursor - Pagination cursor\n   * @returns {Promise<object>}\n   */\n  async getMarketHistory(ticker, opts = {}) {\n    const params = {\n      limit: opts.limit || 100,\n      ...(opts.cursor && { cursor: opts.cursor }),\n    };\n\n    return this.request(\"GET\", `/markets/${ticker}/history`, { params });\n  }\n\n  // -------------------------------------------------------------------------\n  // Series Endpoints\n  // -------------------------------------------------------------------------\n\n  /**\n   * Get all series\n   * @param {object} opts\n   * @param {number} opts.limit - Max results\n   * @param {string} opts.cursor - Pagination cursor\n   * @returns {Promise<object>}\n   */\n  async getSeries(opts = {}) {\n    const params = {\n      limit: opts.limit || 100,\n      ...(opts.cursor && { cursor: opts.cursor }),\n    };\n\n    return this.request(\"GET\", \"/series\", { params });\n  }\n\n  /**\n   * Get a specific series\n   * @param {string} ticker - Series ticker\n   * @returns {Promise<object>}\n   */\n  async getSeriesByTicker(ticker) {\n    return this.request(\"GET\", `/series/${ticker}`);\n  }\n\n  // -------------------------------------------------------------------------\n  // Event Endpoints\n  // -------------------------------------------------------------------------\n\n  /**\n   * Get all events\n   * @param {object} opts\n   * @param {number} opts.limit - Max results\n   * @param {string} opts.cursor - Pagination cursor\n   * @returns {Promise<object>}\n   */\n  async getEvents(opts = {}) {\n    const params = {\n      limit: opts.limit || 100,\n      ...(opts.cursor && { cursor: opts.cursor }),\n    };\n\n    return this.request(\"GET\", \"/events\", { params });\n  }\n\n  /**\n   * Get a specific event\n   * @param {string} eventTicker - Event ticker\n   * @returns {Promise<object>}\n   */\n  async getEvent(eventTicker) {\n    return this.request(\"GET\", `/events/${eventTicker}`);\n  }\n\n  // -------------------------------------------------------------------------\n  // Order Endpoints\n  // -------------------------------------------------------------------------\n\n  /**\n   * Get all orders\n   * @param {object} opts\n   * @param {string} opts.status - Order status\n   * @param {number} opts.limit - Max results\n   * @param {string} opts.cursor - Pagination cursor\n   * @returns {Promise<object>}\n   */\n  async getOrders(opts = {}) {\n    const params = {\n      limit: opts.limit || 100,\n      ...(opts.status && { status: opts.status }),\n      ...(opts.cursor && { cursor: opts.cursor }),\n    };\n\n    return this.request(\"GET\", \"/orders\", { params });\n  }\n\n  /**\n   * Get a specific order\n   * @param {string} orderId - Order ID\n   * @returns {Promise<object>}\n   */\n  async getOrder(orderId) {\n    return this.request(\"GET\", `/orders/${orderId}`);\n  }\n\n  /**\n   * Create a new order\n   * @param {object} order\n   * @param {string} order.ticker - Market ticker\n   * @param {string} order.side - Order side (yes/no)\n   * @param {number} order.count - Number of contracts\n   * @param {number} order.price - Price in cents (0-100)\n   * @param {string} order.client_order_id - Client order ID (optional)\n   * @returns {Promise<object>}\n   */\n  async createOrder(order) {\n    return this.request(\"POST\", \"/orders\", { body: order });\n  }\n\n  /**\n   * Cancel an order\n   * @param {string} orderId - Order ID\n   * @returns {Promise<object>}\n   */\n  async cancelOrder(orderId) {\n    return this.request(\"DELETE\", `/orders/${orderId}`);\n  }\n\n  /**\n   * Cancel all orders\n   * @returns {Promise<object>}\n   */\n  async cancelAllOrders() {\n    return this.request(\"DELETE\", \"/orders\");\n  }\n\n  // -------------------------------------------------------------------------\n  // Position Endpoints\n  // -------------------------------------------------------------------------\n\n  /**\n   * Get all positions\n   * @param {object} opts\n   * @param {number} opts.limit - Max results\n   * @param {string} opts.cursor - Pagination cursor\n   * @returns {Promise<object>}\n   */\n  async getPositions(opts = {}) {\n    const params = {\n      limit: opts.limit || 100,\n      ...(opts.cursor && { cursor: opts.cursor }),\n    };\n\n    return this.request(\"GET\", \"/positions\", { params });\n  }\n\n  /**\n   * Get a specific position\n   * @param {string} ticker - Market ticker\n   * @returns {Promise<object>}\n   */\n  async getPosition(ticker) {\n    return this.request(\"GET\", `/positions/${ticker}`);\n  }\n\n  // -------------------------------------------------------------------------\n  // Portfolio Endpoints\n  // -------------------------------------------------------------------------\n\n  /**\n   * Get portfolio statistics\n   * @returns {Promise<object>}\n   */\n  async getPortfolio() {\n    return this.request(\"GET\", \"/portfolio\");\n  }\n\n  /**\n   * Get portfolio history\n   * @param {object} opts\n   * @param {string} opts.lookback - Lookback period (1d, 7d, 30d, etc.)\n   * @returns {Promise<object>}\n   */\n  async getPortfolioHistory(opts = {}) {\n    const params = {\n      ...(opts.lookback && { lookback: opts.lookback }),\n    };\n\n    return this.request(\"GET\", \"/portfolio/history\", { params });\n  }\n\n  // -------------------------------------------------------------------------\n  // Utility Methods\n  // -------------------------------------------------------------------------\n\n  /**\n   * Get current rate limit status\n   * @returns {object}\n   */\n  getRateLimitStatus() {\n    return {\n      remaining: this.rateLimiter.remaining,\n      limit: this.rateLimiter.maxRequests,\n      windowMs: this.rateLimiter.windowMs,\n    };\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Convenience Functions\n// ---------------------------------------------------------------------------\n\n/**\n * Create a new Kalshi client from environment variables\n * @returns {KalshiClient}\n */\nfunction createClient() {\n  return new KalshiClient({\n    apiKey: process.env.KALSHI_API_KEY,\n    demo: process.env.KALSHI_DEMO !== \"false\",\n  });\n}\n\n// ---------------------------------------------------------------------------\n// Exports\n// ---------------------------------------------------------------------------\nmodule.exports = {\n  KalshiClient,\n  SimpleRateLimiter,\n  createClient,\n};\n\n// ---------------------------------------------------------------------------\n// Standalone test\n// ---------------------------------------------------------------------------\nif (require.main === module) {\n  console.log(\"Kalshi Client Module - Self Test\\n\");\n\n  // Test rate limiter\n  console.log(\"1. Testing SimpleRateLimiter:\");\n  const rl = new SimpleRateLimiter({ maxRequests: 3, windowMs: 1000 });\n\n  async function testRateLimiter() {\n    for (let i = 1; i <= 5; i++) {\n      const start = Date.now();\n      await rl.acquire();\n      console.log(`  Request ${i}: acquired after ${Date.now() - start}ms`);\n    }\n  }\n\n  testRateLimiter()\n    .then(() => {\n      console.log(\"\\n2. Testing KalshiClient instantiation:\");\n\n      // Test without API key (should throw)\n      try {\n        const client = new KalshiClient({});\n        console.log(\"  ERROR: Should have thrown without API key\");\n      } catch (e) {\n        console.log(`  ✓ Correctly throws: ${e.message}`);\n      }\n\n      // Test with API key\n      const client = new KalshiClient({\n        apiKey: \"test_key_123\",\n        demo: true,\n      });\n      console.log(`  ✓ Client created (demo mode: ${client.demo})`);\n      console.log(`  ✓ Base URL: ${client.baseUrl}`);\n\n      // Test rate limit status\n      const status = client.getRateLimitStatus();\n      console.log(`  ✓ Rate limit: ${status.remaining}/${status.limit}`);\n\n      console.log(\"\\n✅ All tests completed\");\n    })\n    .catch((e) => {\n      console.error(\"\\n❌ Test failed:\", e.message);\n      process.exit(1);\n    });\n}\n","numLines":555,"startLine":1,"totalLines":555}}}
