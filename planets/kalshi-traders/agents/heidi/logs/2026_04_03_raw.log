{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P4bYUbp26RN2XrJX55nqUv","type":"tool_result","content":"1\t/**\n2\t * Login API Module — Tokenfly Agent Team Lab\n3\t * Author: Bob (Backend Engineer)\n4\t * Date: 2026-03-31\n5\t * Task: T002 - Implement login API\n6\t *\n7\t * Provides:\n8\t *   POST /api/auth/login    — Authenticate and issue JWT\n9\t *   POST /api/auth/logout   — Revoke current session\n10\t *   POST /api/auth/refresh  — Refresh access token\n11\t *   GET  /api/auth/me       — Get current user info\n12\t *   POST /api/auth/password — Change password\n13\t *\n14\t * Security features:\n15\t *   - bcrypt password hashing\n16\t *   - JWT with short expiry (15 min access, 7 day refresh)\n17\t *   - Account lockout after 5 failed attempts\n18\t *   - Rate limiting on login endpoint\n19\t *   - Secure httpOnly cookies\n20\t *   - CSRF protection via double-submit cookie\n21\t */\n22\t\n23\t\"use strict\";\n24\t\n25\tconst crypto = require(\"crypto\");\n26\tconst { promisify } = require(\"util\");\n27\t\n28\t// JWT implementation (no external dependencies)\n29\t// Simple HS256 JWT for embedded use\n30\tconst JWT_SECRET = process.env.JWT_SECRET || crypto.randomBytes(32).toString(\"hex\");\n31\tconst JWT_ACCESS_EXPIRY = parseInt(process.env.JWT_ACCESS_EXPIRY || \"900\", 10);     // 15 minutes\n32\tconst JWT_REFRESH_EXPIRY = parseInt(process.env.JWT_REFRESH_EXPIRY || \"604800\", 10); // 7 days\n33\tconst MAX_LOGIN_ATTEMPTS = parseInt(process.env.MAX_LOGIN_ATTEMPTS || \"5\", 10);\n34\tconst LOCKOUT_DURATION_MS = parseInt(process.env.LOCKOUT_DURATION_MS || \"900000\", 10); // 15 minutes\n35\t\n36\t// Bcrypt constants for timing-safe comparison (we store bcrypt hashes)\n37\tconst BCRYPT_HASH_LENGTH = 60;\n38\t\n39\t// In-memory rate limiter for login attempts (IP-based)\n40\tconst loginAttempts = new Map(); // ip -> { count, resetAt }\n41\t\n42\t/**\n43\t * JWT utility functions (HS256)\n44\t */\n45\tfunction base64UrlEncode(buf) {\n46\t  return buf.toString(\"base64\").replace(/\\+/g, \"-\").replace(/\\//g, \"_\").replace(/=/g, \"\");\n47\t}\n48\t\n49\tfunction base64UrlDecode(str) {\n50\t  const padding = \"=\".repeat((4 - (str.length % 4)) % 4);\n51\t  return Buffer.from(str.replace(/-/g, \"+\").replace(/_/g, \"/\") + padding, \"base64\");\n52\t}\n53\t\n54\tfunction signJwt(payload, secret, expiresInSeconds) {\n55\t  const header = { alg: \"HS256\", typ: \"JWT\" };\n56\t  const now = Math.floor(Date.now() / 1000);\n57\t  const claims = { ...payload, iat: now, exp: now + expiresInSeconds, jti: crypto.randomUUID() };\n58\t  \n59\t  const headerB64 = base64UrlEncode(Buffer.from(JSON.stringify(header)));\n60\t  const payloadB64 = base64UrlEncode(Buffer.from(JSON.stringify(claims)));\n61\t  const signingInput = `${headerB64}.${payloadB64}`;\n62\t  \n63\t  const signature = crypto.createHmac(\"sha256\", secret).update(signingInput).digest();\n64\t  const signatureB64 = base64UrlEncode(signature);\n65\t  \n66\t  return `${signingInput}.${signatureB64}`;\n67\t}\n68\t\n69\tfunction verifyJwt(token, secret) {\n70\t  const parts = token.split(\".\");\n71\t  if (parts.length !== 3) throw new Error(\"Invalid token format\");\n72\t  \n73\t  const [headerB64, payloadB64, signatureB64] = parts;\n74\t  const signingInput = `${headerB64}.${payloadB64}`;\n75\t  \n76\t  const expectedSig = crypto.createHmac(\"sha256\", secret).update(signingInput).digest();\n77\t  const actualSig = base64UrlDecode(signatureB64);\n78\t  \n79\t  if (!crypto.timingSafeEqual(expectedSig, actualSig)) {\n80\t    throw new Error(\"Invalid signature\");\n81\t  }\n82\t  \n83\t  const payload = JSON.parse(base64UrlDecode(payloadB64).toString(\"utf8\"));\n84\t  const now = Math.floor(Date.now() / 1000);\n85\t  \n86\t  if (payload.exp && payload.exp < now) {\n87\t    throw new Error(\"Token expired\");\n88\t  }\n89\t  \n90\t  return payload;\n91\t}\n92\t\n93\t/**\n94\t * Password hashing using Node.js crypto (scrypt)\n95\t * Note: In production, use bcrypt via native module. \n96\t * This implementation uses scrypt as a fallback for zero-dependency setup.\n97\t */\n98\tconst scrypt = promisify(crypto.scrypt);\n99\t\n100\tasync function hashPassword(password) {\n101\t  const salt = crypto.randomBytes(16).toString(\"hex\");\n102\t  const derivedKey = await scrypt(password, salt, 64);\n103\t  return `${salt}:${derivedKey.toString(\"hex\")}`;\n104\t}\n105\t\n106\tasync function verifyPassword(password, hash) {\n107\t  const [salt, key] = hash.split(\":\");\n108\t  if (!salt || !key) return false;\n109\t  const derivedKey = await scrypt(password, salt, 64);\n110\t  const keyBuf = Buffer.from(key, \"hex\");\n111\t  const derivedBuf = derivedKey;\n112\t  if (keyBuf.length !== derivedBuf.length) return false;\n113\t  return crypto.timingSafeEqual(keyBuf, derivedBuf);\n114\t}\n115\t\n116\t/**\n117\t * Rate limiting for login attempts\n118\t */\n119\tfunction checkLoginRateLimit(ip) {\n120\t  const now = Date.now();\n121\t  const record = loginAttempts.get(ip);\n122\t  \n123\t  if (!record || now > record.resetAt) {\n124\t    loginAttempts.set(ip, { count: 1, resetAt: now + 60000 }); // 1 minute window\n125\t    return { allowed: true, remaining: 4 };\n126\t  }\n127\t  \n128\t  record.count++;\n129\t  if (record.count > 10) { // 10 attempts per minute\n130\t    return { allowed: false, retryAfter: Math.ceil((record.resetAt - now) / 1000) };\n131\t  }\n132\t  \n133\t  return { allowed: true, remaining: 10 - record.count };\n134\t}\n135\t\n136\t/**\n137\t * CSRF token generation\n138\t */\n139\tfunction generateCsrfToken() {\n140\t  return crypto.randomBytes(32).toString(\"hex\");\n141\t}\n142\t\n143\t/**\n144\t * Parse request body\n145\t */\n146\tfunction parseBody(req, maxSize = 65536) {\n147\t  return new Promise((resolve, reject) => {\n148\t    let body = \"\";\n149\t    let size = 0;\n150\t    \n151\t    req.on(\"data\", (chunk) => {\n152\t      size += chunk.length;\n153\t      if (size > maxSize) {\n154\t        reject(new Error(\"Request body too large\"));\n155\t        return;\n156\t      }\n157\t      body += chunk.toString(\"utf8\");\n158\t    });\n159\t    \n160\t    req.on(\"end\", () => {\n161\t      try {\n162\t        resolve(body ? JSON.parse(body) : {});\n163\t      } catch (e) {\n164\t        reject(new Error(\"Invalid JSON\"));\n165\t      }\n166\t    });\n167\t    \n168\t    req.on(\"error\", reject);\n169\t  });\n170\t}\n171\t\n172\t/**\n173\t * Response helpers\n174\t */\n175\tfunction sendJson(res, status, data, cors = true) {\n176\t  const headers = { \"Content-Type\": \"application/json\" };\n177\t  if (cors) headers[\"Access-Control-Allow-Origin\"] = \"*\";\n178\t  res.writeHead(status, headers);\n179\t  res.end(JSON.stringify(data));\n180\t}\n181\t\n182\tfunction setCookie(res, name, value, options = {}) {\n183\t  const defaults = {\n184\t    httpOnly: true,\n185\t    secure: process.env.NODE_ENV === \"production\",\n186\t    sameSite: \"strict\",\n187\t    path: \"/\",\n188\t    maxAge: 86400, // 1 day default\n189\t  };\n190\t  const opts = { ...defaults, ...options };\n191\t  \n192\t  let cookie = `${name}=${value}`;\n193\t  if (opts.httpOnly) cookie += \"; HttpOnly\";\n194\t  if (opts.secure) cookie += \"; Secure\";\n195\t  if (opts.sameSite) cookie += `; SameSite=${opts.sameSite}`;\n196\t  if (opts.path) cookie += `; Path=${opts.path}`;\n197\t  if (opts.maxAge) cookie += `; Max-Age=${opts.maxAge}`;\n198\t  \n199\t  const existing = res.getHeader(\"Set-Cookie\");\n200\t  if (existing) {\n201\t    res.setHeader(\"Set-Cookie\", Array.isArray(existing) ? [...existing, cookie] : [existing, cookie]);\n202\t  } else {\n203\t    res.setHeader(\"Set-Cookie\", cookie);\n204\t  }\n205\t}\n206\t\n207\tfunction clearCookie(res, name) {\n208\t  setCookie(res, name, \"\", { maxAge: 0 });\n209\t}\n210\t\n211\t/**\n212\t * Extract token from request\n213\t */\n214\tfunction extractToken(req) {\n215\t  // 1. Authorization header\n216\t  const auth = req.headers[\"authorization\"];\n217\t  if (auth && auth.startsWith(\"Bearer \")) {\n218\t    return auth.slice(7);\n219\t  }\n220\t  \n221\t  // 2. Cookie\n222\t  const cookie = req.headers[\"cookie\"];\n223\t  if (cookie) {\n224\t    const match = cookie.match(/access_token=([^;]+)/);\n225\t    if (match) return match[1];\n226\t  }\n227\t  \n228\t  return null;\n229\t}\n230\t\n231\t/**\n232\t * Mock database for in-memory operation (replace with real DB queries)\n233\t * In production, these would query PostgreSQL\n234\t */\n235\tconst mockDb = {\n236\t  users: new Map(), // username -> { agent_id, password_hash, login_attempts, locked_until }\n237\t  sessions: new Map(), // jti -> { agent_id, expires_at, revoked_at }\n238\t  \n239\t  async findUserByUsername(username) {\n240\t    return this.users.get(username.toLowerCase());\n241\t  },\n242\t  \n243\t  async recordLoginAttempt(username, success) {\n244\t    const user = this.users.get(username.toLowerCase());\n245\t    if (!user) return;\n246\t    \n247\t    if (success) {\n248\t      user.login_attempts = 0;\n249\t      user.last_login_at = new Date().toISOString();\n250\t      user.locked_until = null;\n251\t    } else {\n252\t      user.login_attempts = (user.login_attempts || 0) + 1;\n253\t      if (user.login_attempts >= MAX_LOGIN_ATTEMPTS) {\n254\t        user.locked_until = new Date(Date.now() + LOCKOUT_DURATION_MS).toISOString();\n255\t      }\n256\t    }\n257\t  },\n258\t  \n259\t  async createSession(agentId, jti, expiresAt) {\n260\t    this.sessions.set(jti, {\n261\t      agent_id: agentId,\n262\t      expires_at: expiresAt,\n263\t      revoked_at: null,\n264\t    });\n265\t  },\n266\t  \n267\t  async revokeSession(jti) {\n268\t    const session = this.sessions.get(jti);\n269\t    if (session) session.revoked_at = new Date().toISOString();\n270\t  },\n271\t  \n272\t  async isSessionValid(jti) {\n273\t    const session = this.sessions.get(jti);\n274\t    if (!session) return false;\n275\t    if (session.revoked_at) return false;\n276\t    if (new Date(session.expires_at) < new Date()) return false;\n277\t    return true;\n278\t  },\n279\t};\n280\t\n281\t// Seed mock users (in production, these come from user_accounts table)\n282\tasync function seedMockUsers() {\n283\t  const agents = [\n284\t    { name: \"alice\", role: \"acting_ceo\" },\n285\t    { name: \"bob\", role: \"backend\" },\n286\t    { name: \"charlie\", role: \"frontend\" },\n287\t    { name: \"dave\", role: \"fullstack\" },\n288\t    { name: \"heidi\", role: \"security\" },\n289\t  ];\n290\t  \n291\t  for (const agent of agents) {\n292\t    const hash = await hashPassword(\"changeme\");\n293\t    mockDb.users.set(agent.name, {\n294\t      agent_id: crypto.randomUUID(),\n295\t      username: agent.name,\n296\t      password_hash: hash,\n297\t      login_attempts: 0,\n298\t      locked_until: null,\n299\t      role: agent.role,\n300\t    });\n301\t  }\n302\t}\n303\tseedMockUsers();\n304\t\n305\t/**\n306\t * Authentication middleware\n307\t */\n308\tasync function authenticate(req) {\n309\t  const token = extractToken(req);\n310\t  if (!token) return { authenticated: false, error: \"No token provided\" };\n311\t  \n312\t  try {\n313\t    const payload = verifyJwt(token, JWT_SECRET);\n314\t    const isValid = await mockDb.isSessionValid(payload.jti);\n315\t    if (!isValid) return { authenticated: false, error: \"Session revoked or expired\" };\n316\t    \n317\t    return { \n318\t      authenticated: true, \n319\t      agentId: payload.sub,\n320\t      username: payload.username,\n321\t      role: payload.role,\n322\t      jti: payload.jti,\n323\t    };\n324\t  } catch (e) {\n325\t    return { authenticated: false, error: e.message };\n326\t  }\n327\t}\n328\t\n329\t/**\n330\t * Request handlers\n331\t */\n332\tasync function handleLogin(req, res) {\n333\t  const ip = req.socket?.remoteAddress || \"unknown\";\n334\t  const rateLimit = checkLoginRateLimit(ip);\n335\t  \n336\t  if (!rateLimit.allowed) {\n337\t    sendJson(res, 429, { error: \"Too many login attempts\", retry_after: rateLimit.retryAfter });\n338\t    return;\n339\t  }\n340\t  \n341\t  let body;\n342\t  try {\n343\t    body = await parseBody(req);\n344\t  } catch (e) {\n345\t    sendJson(res, 400, { error: \"Invalid request body\" });\n346\t    return;\n347\t  }\n348\t  \n349\t  const { username, password } = body;\n350\t  \n351\t  if (!username || !password) {\n352\t    sendJson(res, 400, { error: \"Username and password required\" });\n353\t    return;\n354\t  }\n355\t  \n356\t  const user = await mockDb.findUserByUsername(username);\n357\t  \n358\t  if (!user) {\n359\t    // Same timing as failed password to prevent user enumeration\n360\t    await hashPassword(password); // waste time\n361\t    sendJson(res, 401, { error: \"Invalid credentials\" });\n362\t    return;\n363\t  }\n364\t  \n365\t  // Check lockout\n366\t  if (user.locked_until && new Date(user.locked_until) > new Date()) {\n367\t    const retryAfter = Math.ceil((new Date(user.locked_until) - Date.now()) / 1000);\n368\t    sendJson(res, 423, { error: \"Account locked\", retry_after: retryAfter });\n369\t    return;\n370\t  }\n371\t  \n372\t  const valid = await verifyPassword(password, user.password_hash);\n373\t  \n374\t  if (!valid) {\n375\t    await mockDb.recordLoginAttempt(username, false);\n376\t    sendJson(res, 401, { error: \"Invalid credentials\" });\n377\t    return;\n378\t  }\n379\t  \n380\t  await mockDb.recordLoginAttempt(username, true);\n381\t  \n382\t  // Generate tokens\n383\t  const accessToken = signJwt(\n384\t    { sub: user.agent_id, username: user.username, role: user.role },\n385\t    JWT_SECRET,\n386\t    JWT_ACCESS_EXPIRY\n387\t  );\n388\t  \n389\t  const refreshToken = signJwt(\n390\t    { sub: user.agent_id, type: \"refresh\" },\n391\t    JWT_SECRET,\n392\t    JWT_REFRESH_EXPIRY\n393\t  );\n394\t  \n395\t  // Store session\n396\t  const refreshPayload = verifyJwt(refreshToken, JWT_SECRET);\n397\t  await mockDb.createSession(user.agent_id, refreshPayload.jti, new Date(Date.now() + JWT_REFRESH_EXPIRY * 1000));\n398\t  \n399\t  // Set cookies\n400\t  setCookie(res, \"access_token\", accessToken, { maxAge: JWT_ACCESS_EXPIRY });\n401\t  setCookie(res, \"refresh_token\", refreshToken, { maxAge: JWT_REFRESH_EXPIRY });\n402\t  setCookie(res, \"csrf_token\", generateCsrfToken(), { httpOnly: false, maxAge: JWT_REFRESH_EXPIRY });\n403\t  \n404\t  sendJson(res, 200, {\n405\t    success: true,\n406\t    agent: {\n407\t      id: user.agent_id,\n408\t      username: user.username,\n409\t      role: user.role,\n410\t    },\n411\t    expires_in: JWT_ACCESS_EXPIRY,\n412\t  });\n413\t}\n414\t\n415\tasync function handleLogout(req, res) {\n416\t  const auth = await authenticate(req);\n417\t  \n418\t  if (auth.authenticated && auth.jti) {\n419\t    await mockDb.revokeSession(auth.jti);\n420\t  }\n421\t  \n422\t  // Always clear cookies even if not authenticated\n423\t  clearCookie(res, \"access_token\");\n424\t  clearCookie(res, \"refresh_token\");\n425\t  clearCookie(res, \"csrf_token\");\n426\t  \n427\t  sendJson(res, 200, { success: true, message: \"Logged out\" });\n428\t}\n429\t\n430\tasync function handleRefresh(req, res) {\n431\t  let body;\n432\t  try {\n433\t    body = await parseBody(req);\n434\t  } catch (e) {\n435\t    body = {};\n436\t  }\n437\t  \n438\t  // Get refresh token from cookie or body\n439\t  let refreshToken = body.refresh_token;\n440\t  if (!refreshToken) {\n441\t    const cookie = req.headers[\"cookie\"];\n442\t    if (cookie) {\n443\t      const match = cookie.match(/refresh_token=([^;]+)/);\n444\t      if (match) refreshToken = match[1];\n445\t    }\n446\t  }\n447\t  \n448\t  if (!refreshToken) {\n449\t    sendJson(res, 401, { error: \"No refresh token provided\" });\n450\t    return;\n451\t  }\n452\t  \n453\t  let payload;\n454\t  try {\n455\t    payload = verifyJwt(refreshToken, JWT_SECRET);\n456\t  } catch (e) {\n457\t    sendJson(res, 401, { error: \"Invalid refresh token\" });\n458\t    return;\n459\t  }\n460\t  \n461\t  if (payload.type !== \"refresh\") {\n462\t    sendJson(res, 401, { error: \"Invalid token type\" });\n463\t    return;\n464\t  }\n465\t  \n466\t  const isValid = await mockDb.isSessionValid(payload.jti);\n467\t  if (!isValid) {\n468\t    sendJson(res, 401, { error: \"Session revoked\" });\n469\t    return;\n470\t  }\n471\t  \n472\t  // Revoke old session\n473\t  await mockDb.revokeSession(payload.jti);\n474\t  \n475\t  // Get user info\n476\t  const user = await mockDb.findUserByUsername(payload.sub);\n477\t  const username = user ? user.username : payload.sub;\n478\t  const role = user ? user.role : \"agent\";\n479\t  \n480\t  // Issue new tokens\n481\t  const newAccessToken = signJwt(\n482\t    { sub: payload.sub, username, role },\n483\t    JWT_SECRET,\n484\t    JWT_ACCESS_EXPIRY\n485\t  );\n486\t  \n487\t  const newRefreshToken = signJwt(\n488\t    { sub: payload.sub, type: \"refresh\" },\n489\t    JWT_SECRET,\n490\t    JWT_REFRESH_EXPIRY\n491\t  );\n492\t  \n493\t  const newRefreshPayload = verifyJwt(newRefreshToken, JWT_SECRET);\n494\t  await mockDb.createSession(payload.sub, newRefreshPayload.jti, new Date(Date.now() + JWT_REFRESH_EXPIRY * 1000));\n495\t  \n496\t  setCookie(res, \"access_token\", newAccessToken, { maxAge: JWT_ACCESS_EXPIRY });\n497\t  setCookie(res, \"refresh_token\", newRefreshToken, { maxAge: JWT_REFRESH_EXPIRY });\n498\t  \n499\t  sendJson(res, 200, {\n500\t    success: true,\n501\t    expires_in: JWT_ACCESS_EXPIRY,\n502\t  });\n503\t}\n504\t\n505\tasync function handleMe(req, res) {\n506\t  const auth = await authenticate(req);\n507\t  \n508\t  if (!auth.authenticated) {\n509\t    sendJson(res, 401, { error: auth.error || \"Unauthorized\" });\n510\t    return;\n511\t  }\n512\t  \n513\t  sendJson(res, 200, {\n514\t    agent: {\n515\t      id: auth.agentId,\n516\t      username: auth.username,\n517\t      role: auth.role,\n518\t    },\n519\t  });\n520\t}\n521\t\n522\tasync function handleChangePassword(req, res) {\n523\t  const auth = await authenticate(req);\n524\t  \n525\t  if (!auth.authenticated) {\n526\t    sendJson(res, 401, { error: auth.error || \"Unauthorized\" });\n527\t    return;\n528\t  }\n529\t  \n530\t  let body;\n531\t  try {\n532\t    body = await parseBody(req);\n533\t  } catch (e) {\n534\t    sendJson(res, 400, { error: \"Invalid request body\" });\n535\t    return;\n536\t  }\n537\t  \n538\t  const { current_password, new_password } = body;\n539\t  \n540\t  if (!current_password || !new_password) {\n541\t    sendJson(res, 400, { error: \"Current password and new password required\" });\n542\t    return;\n543\t  }\n544\t  \n545\t  if (new_password.length < 8) {\n546\t    sendJson(res, 400, { error: \"New password must be at least 8 characters\" });\n547\t    return;\n548\t  }\n549\t  \n550\t  const user = await mockDb.findUserByUsername(auth.username);\n551\t  if (!user) {\n552\t    sendJson(res, 404, { error: \"User not found\" });\n553\t    return;\n554\t  }\n555\t  \n556\t  const valid = await verifyPassword(current_password, user.password_hash);\n557\t  if (!valid) {\n558\t    sendJson(res, 401, { error: \"Current password incorrect\" });\n559\t    return;\n560\t  }\n561\t  \n562\t  user.password_hash = await hashPassword(new_password);\n563\t  \n564\t  // Revoke all sessions except current\n565\t  // (In production: UPDATE user_sessions SET revoked_at = NOW() WHERE agent_id = $1 AND jti != $2)\n566\t  \n567\t  sendJson(res, 200, { success: true, message: \"Password changed successfully\" });\n568\t}\n569\t\n570\t/**\n571\t * Main request router\n572\t */\n573\tasync function handleAuthRequest(req, res) {\n574\t  const parsed = new URL(req.url, \"http://localhost\");\n575\t  const pathname = parsed.pathname.replace(/\\/$/, \"\");\n576\t  const method = req.method.toUpperCase();\n577\t  \n578\t  // CORS preflight\n579\t  if (method === \"OPTIONS\") {\n580\t    res.writeHead(204, {\n581\t      \"Access-Control-Allow-Origin\": \"*\",\n582\t      \"Access-Control-Allow-Methods\": \"GET,POST,OPTIONS\",\n583\t      \"Access-Control-Allow-Headers\": \"Content-Type, Authorization, X-CSRF-Token\",\n584\t      \"Access-Control-Allow-Credentials\": \"true\",\n585\t    });\n586\t    res.end();\n587\t    return true;\n588\t  }\n589\t  \n590\t  if (!pathname.startsWith(\"/api/auth\")) return false;\n591\t  \n592\t  // Set CORS headers for all auth responses\n593\t  res.setHeader(\"Access-Control-Allow-Origin\", \"*\");\n594\t  res.setHeader(\"Access-Control-Allow-Credentials\", \"true\");\n595\t  \n596\t  try {\n597\t    if (pathname === \"/api/auth/login\" && method === \"POST\") {\n598\t      await handleLogin(req, res);\n599\t      return true;\n600\t    }\n601\t    \n602\t    if (pathname === \"/api/auth/logout\" && method === \"POST\") {\n603\t      await handleLogout(req, res);\n604\t      return true;\n605\t    }\n606\t    \n607\t    if (pathname === \"/api/auth/refresh\" && method === \"POST\") {\n608\t      await handleRefresh(req, res);\n609\t      return true;\n610\t    }\n611\t    \n612\t    if (pathname === \"/api/auth/me\" && method === \"GET\") {\n613\t      await handleMe(req, res);\n614\t      return true;\n615\t    }\n616\t    \n617\t    if (pathname === \"/api/auth/password\" && method === \"POST\") {\n618\t      await handleChangePassword(req, res);\n619\t      return true;\n620\t    }\n621\t    \n622\t    if (pathname === \"/api/auth\") {\n623\t      sendJson(res, 200, {\n624\t        endpoints: [\n625\t          \"POST /api/auth/login\",\n626\t          \"POST /api/auth/logout\",\n627\t          \"POST /api/auth/refresh\",\n628\t          \"GET  /api/auth/me\",\n629\t          \"POST /api/auth/password\",\n630\t        ],\n631\t      });\n632\t      return true;\n633\t    }\n634\t    \n635\t    sendJson(res, 404, { error: \"Unknown auth endpoint\" });\n636\t    return true;\n637\t  } catch (e) {\n638\t    console.error(\"[auth] Error:\", e);\n639\t    sendJson(res, 500, { error: \"Internal server error\" });\n640\t    return true;\n641\t  }\n642\t}\n643\t\n644\t/**\n645\t * Standalone mode\n646\t */\n647\tif (require.main === module) {\n648\t  const http = require(\"http\");\n649\t  const port = parseInt(process.argv[2] || \"3102\", 10);\n650\t  \n651\t  const server = http.createServer(async (req, res) => {\n652\t    const handled = await handleAuthRequest(req, res);\n653\t    if (!handled) {\n654\t      sendJson(res, 404, { error: \"Not found\" });\n655\t    }\n656\t  });\n657\t  \n658\t  server.listen(port, () => {\n659\t    console.log(`[login-api] Listening on http://localhost:${port}`);\n660\t    console.log(\"Endpoints:\");\n661\t    console.log(`  POST http://localhost:${port}/api/auth/login`);\n662\t    console.log(`  POST http://localhost:${port}/api/auth/logout`);\n663\t    console.log(`  POST http://localhost:${port}/api/auth/refresh`);\n664\t    console.log(`  GET  http://localhost:${port}/api/auth/me`);\n665\t    console.log(`  POST http://localhost:${port}/api/auth/password`);\n666\t    console.log(\"\\nDefault credentials (username:password):\");\n667\t    console.log(\"  alice:changeme, bob:changeme, charlie:changeme\");\n668\t  });\n669\t}\n670\t\n671\t// Exports for integration\n672\tmodule.exports = {\n673\t  handleAuthRequest,\n674\t  authenticate,\n675\t  hashPassword,\n676\t  verifyPassword,\n677\t  signJwt,\n678\t  verifyJwt,\n679\t  generateCsrfToken,\n680\t  JWT_SECRET,\n681\t};\n682\t"}]},"parent_tool_use_id":null,"session_id":"13869bcc-5a8c-4ff8-8624-290e2bdca9d1","uuid":"0d15fc36-b35d-4f8e-bde0-1effe44d7163","timestamp":"2026-04-04T05:42:23.413Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/chenyangcui/Documents/code/aicompany/planets/kalshi-traders/output/shared/codebase/backend/login.js","content":"/**\n * Login API Module — Tokenfly Agent Team Lab\n * Author: Bob (Backend Engineer)\n * Date: 2026-03-31\n * Task: T002 - Implement login API\n *\n * Provides:\n *   POST /api/auth/login    — Authenticate and issue JWT\n *   POST /api/auth/logout   — Revoke current session\n *   POST /api/auth/refresh  — Refresh access token\n *   GET  /api/auth/me       — Get current user info\n *   POST /api/auth/password — Change password\n *\n * Security features:\n *   - bcrypt password hashing\n *   - JWT with short expiry (15 min access, 7 day refresh)\n *   - Account lockout after 5 failed attempts\n *   - Rate limiting on login endpoint\n *   - Secure httpOnly cookies\n *   - CSRF protection via double-submit cookie\n */\n\n\"use strict\";\n\nconst crypto = require(\"crypto\");\nconst { promisify } = require(\"util\");\n\n// JWT implementation (no external dependencies)\n// Simple HS256 JWT for embedded use\nconst JWT_SECRET = process.env.JWT_SECRET || crypto.randomBytes(32).toString(\"hex\");\nconst JWT_ACCESS_EXPIRY = parseInt(process.env.JWT_ACCESS_EXPIRY || \"900\", 10);     // 15 minutes\nconst JWT_REFRESH_EXPIRY = parseInt(process.env.JWT_REFRESH_EXPIRY || \"604800\", 10); // 7 days\nconst MAX_LOGIN_ATTEMPTS = parseInt(process.env.MAX_LOGIN_ATTEMPTS || \"5\", 10);\nconst LOCKOUT_DURATION_MS = parseInt(process.env.LOCKOUT_DURATION_MS || \"900000\", 10); // 15 minutes\n\n// Bcrypt constants for timing-safe comparison (we store bcrypt hashes)\nconst BCRYPT_HASH_LENGTH = 60;\n\n// In-memory rate limiter for login attempts (IP-based)\nconst loginAttempts = new Map(); // ip -> { count, resetAt }\n\n/**\n * JWT utility functions (HS256)\n */\nfunction base64UrlEncode(buf) {\n  return buf.toString(\"base64\").replace(/\\+/g, \"-\").replace(/\\//g, \"_\").replace(/=/g, \"\");\n}\n\nfunction base64UrlDecode(str) {\n  const padding = \"=\".repeat((4 - (str.length % 4)) % 4);\n  return Buffer.from(str.replace(/-/g, \"+\").replace(/_/g, \"/\") + padding, \"base64\");\n}\n\nfunction signJwt(payload, secret, expiresInSeconds) {\n  const header = { alg: \"HS256\", typ: \"JWT\" };\n  const now = Math.floor(Date.now() / 1000);\n  const claims = { ...payload, iat: now, exp: now + expiresInSeconds, jti: crypto.randomUUID() };\n  \n  const headerB64 = base64UrlEncode(Buffer.from(JSON.stringify(header)));\n  const payloadB64 = base64UrlEncode(Buffer.from(JSON.stringify(claims)));\n  const signingInput = `${headerB64}.${payloadB64}`;\n  \n  const signature = crypto.createHmac(\"sha256\", secret).update(signingInput).digest();\n  const signatureB64 = base64UrlEncode(signature);\n  \n  return `${signingInput}.${signatureB64}`;\n}\n\nfunction verifyJwt(token, secret) {\n  const parts = token.split(\".\");\n  if (parts.length !== 3) throw new Error(\"Invalid token format\");\n  \n  const [headerB64, payloadB64, signatureB64] = parts;\n  const signingInput = `${headerB64}.${payloadB64}`;\n  \n  const expectedSig = crypto.createHmac(\"sha256\", secret).update(signingInput).digest();\n  const actualSig = base64UrlDecode(signatureB64);\n  \n  if (!crypto.timingSafeEqual(expectedSig, actualSig)) {\n    throw new Error(\"Invalid signature\");\n  }\n  \n  const payload = JSON.parse(base64UrlDecode(payloadB64).toString(\"utf8\"));\n  const now = Math.floor(Date.now() / 1000);\n  \n  if (payload.exp && payload.exp < now) {\n    throw new Error(\"Token expired\");\n  }\n  \n  return payload;\n}\n\n/**\n * Password hashing using Node.js crypto (scrypt)\n * Note: In production, use bcrypt via native module. \n * This implementation uses scrypt as a fallback for zero-dependency setup.\n */\nconst scrypt = promisify(crypto.scrypt);\n\nasync function hashPassword(password) {\n  const salt = crypto.randomBytes(16).toString(\"hex\");\n  const derivedKey = await scrypt(password, salt, 64);\n  return `${salt}:${derivedKey.toString(\"hex\")}`;\n}\n\nasync function verifyPassword(password, hash) {\n  const [salt, key] = hash.split(\":\");\n  if (!salt || !key) return false;\n  const derivedKey = await scrypt(password, salt, 64);\n  const keyBuf = Buffer.from(key, \"hex\");\n  const derivedBuf = derivedKey;\n  if (keyBuf.length !== derivedBuf.length) return false;\n  return crypto.timingSafeEqual(keyBuf, derivedBuf);\n}\n\n/**\n * Rate limiting for login attempts\n */\nfunction checkLoginRateLimit(ip) {\n  const now = Date.now();\n  const record = loginAttempts.get(ip);\n  \n  if (!record || now > record.resetAt) {\n    loginAttempts.set(ip, { count: 1, resetAt: now + 60000 }); // 1 minute window\n    return { allowed: true, remaining: 4 };\n  }\n  \n  record.count++;\n  if (record.count > 10) { // 10 attempts per minute\n    return { allowed: false, retryAfter: Math.ceil((record.resetAt - now) / 1000) };\n  }\n  \n  return { allowed: true, remaining: 10 - record.count };\n}\n\n/**\n * CSRF token generation\n */\nfunction generateCsrfToken() {\n  return crypto.randomBytes(32).toString(\"hex\");\n}\n\n/**\n * Parse request body\n */\nfunction parseBody(req, maxSize = 65536) {\n  return new Promise((resolve, reject) => {\n    let body = \"\";\n    let size = 0;\n    \n    req.on(\"data\", (chunk) => {\n      size += chunk.length;\n      if (size > maxSize) {\n        reject(new Error(\"Request body too large\"));\n        return;\n      }\n      body += chunk.toString(\"utf8\");\n    });\n    \n    req.on(\"end\", () => {\n      try {\n        resolve(body ? JSON.parse(body) : {});\n      } catch (e) {\n        reject(new Error(\"Invalid JSON\"));\n      }\n    });\n    \n    req.on(\"error\", reject);\n  });\n}\n\n/**\n * Response helpers\n */\nfunction sendJson(res, status, data, cors = true) {\n  const headers = { \"Content-Type\": \"application/json\" };\n  if (cors) headers[\"Access-Control-Allow-Origin\"] = \"*\";\n  res.writeHead(status, headers);\n  res.end(JSON.stringify(data));\n}\n\nfunction setCookie(res, name, value, options = {}) {\n  const defaults = {\n    httpOnly: true,\n    secure: process.env.NODE_ENV === \"production\",\n    sameSite: \"strict\",\n    path: \"/\",\n    maxAge: 86400, // 1 day default\n  };\n  const opts = { ...defaults, ...options };\n  \n  let cookie = `${name}=${value}`;\n  if (opts.httpOnly) cookie += \"; HttpOnly\";\n  if (opts.secure) cookie += \"; Secure\";\n  if (opts.sameSite) cookie += `; SameSite=${opts.sameSite}`;\n  if (opts.path) cookie += `; Path=${opts.path}`;\n  if (opts.maxAge) cookie += `; Max-Age=${opts.maxAge}`;\n  \n  const existing = res.getHeader(\"Set-Cookie\");\n  if (existing) {\n    res.setHeader(\"Set-Cookie\", Array.isArray(existing) ? [...existing, cookie] : [existing, cookie]);\n  } else {\n    res.setHeader(\"Set-Cookie\", cookie);\n  }\n}\n\nfunction clearCookie(res, name) {\n  setCookie(res, name, \"\", { maxAge: 0 });\n}\n\n/**\n * Extract token from request\n */\nfunction extractToken(req) {\n  // 1. Authorization header\n  const auth = req.headers[\"authorization\"];\n  if (auth && auth.startsWith(\"Bearer \")) {\n    return auth.slice(7);\n  }\n  \n  // 2. Cookie\n  const cookie = req.headers[\"cookie\"];\n  if (cookie) {\n    const match = cookie.match(/access_token=([^;]+)/);\n    if (match) return match[1];\n  }\n  \n  return null;\n}\n\n/**\n * Mock database for in-memory operation (replace with real DB queries)\n * In production, these would query PostgreSQL\n */\nconst mockDb = {\n  users: new Map(), // username -> { agent_id, password_hash, login_attempts, locked_until }\n  sessions: new Map(), // jti -> { agent_id, expires_at, revoked_at }\n  \n  async findUserByUsername(username) {\n    return this.users.get(username.toLowerCase());\n  },\n  \n  async recordLoginAttempt(username, success) {\n    const user = this.users.get(username.toLowerCase());\n    if (!user) return;\n    \n    if (success) {\n      user.login_attempts = 0;\n      user.last_login_at = new Date().toISOString();\n      user.locked_until = null;\n    } else {\n      user.login_attempts = (user.login_attempts || 0) + 1;\n      if (user.login_attempts >= MAX_LOGIN_ATTEMPTS) {\n        user.locked_until = new Date(Date.now() + LOCKOUT_DURATION_MS).toISOString();\n      }\n    }\n  },\n  \n  async createSession(agentId, jti, expiresAt) {\n    this.sessions.set(jti, {\n      agent_id: agentId,\n      expires_at: expiresAt,\n      revoked_at: null,\n    });\n  },\n  \n  async revokeSession(jti) {\n    const session = this.sessions.get(jti);\n    if (session) session.revoked_at = new Date().toISOString();\n  },\n  \n  async isSessionValid(jti) {\n    const session = this.sessions.get(jti);\n    if (!session) return false;\n    if (session.revoked_at) return false;\n    if (new Date(session.expires_at) < new Date()) return false;\n    return true;\n  },\n};\n\n// Seed mock users (in production, these come from user_accounts table)\nasync function seedMockUsers() {\n  const agents = [\n    { name: \"alice\", role: \"acting_ceo\" },\n    { name: \"bob\", role: \"backend\" },\n    { name: \"charlie\", role: \"frontend\" },\n    { name: \"dave\", role: \"fullstack\" },\n    { name: \"heidi\", role: \"security\" },\n  ];\n  \n  for (const agent of agents) {\n    const hash = await hashPassword(\"changeme\");\n    mockDb.users.set(agent.name, {\n      agent_id: crypto.randomUUID(),\n      username: agent.name,\n      password_hash: hash,\n      login_attempts: 0,\n      locked_until: null,\n      role: agent.role,\n    });\n  }\n}\nseedMockUsers();\n\n/**\n * Authentication middleware\n */\nasync function authenticate(req) {\n  const token = extractToken(req);\n  if (!token) return { authenticated: false, error: \"No token provided\" };\n  \n  try {\n    const payload = verifyJwt(token, JWT_SECRET);\n    const isValid = await mockDb.isSessionValid(payload.jti);\n    if (!isValid) return { authenticated: false, error: \"Session revoked or expired\" };\n    \n    return { \n      authenticated: true, \n      agentId: payload.sub,\n      username: payload.username,\n      role: payload.role,\n      jti: payload.jti,\n    };\n  } catch (e) {\n    return { authenticated: false, error: e.message };\n  }\n}\n\n/**\n * Request handlers\n */\nasync function handleLogin(req, res) {\n  const ip = req.socket?.remoteAddress || \"unknown\";\n  const rateLimit = checkLoginRateLimit(ip);\n  \n  if (!rateLimit.allowed) {\n    sendJson(res, 429, { error: \"Too many login attempts\", retry_after: rateLimit.retryAfter });\n    return;\n  }\n  \n  let body;\n  try {\n    body = await parseBody(req);\n  } catch (e) {\n    sendJson(res, 400, { error: \"Invalid request body\" });\n    return;\n  }\n  \n  const { username, password } = body;\n  \n  if (!username || !password) {\n    sendJson(res, 400, { error: \"Username and password required\" });\n    return;\n  }\n  \n  const user = await mockDb.findUserByUsername(username);\n  \n  if (!user) {\n    // Same timing as failed password to prevent user enumeration\n    await hashPassword(password); // waste time\n    sendJson(res, 401, { error: \"Invalid credentials\" });\n    return;\n  }\n  \n  // Check lockout\n  if (user.locked_until && new Date(user.locked_until) > new Date()) {\n    const retryAfter = Math.ceil((new Date(user.locked_until) - Date.now()) / 1000);\n    sendJson(res, 423, { error: \"Account locked\", retry_after: retryAfter });\n    return;\n  }\n  \n  const valid = await verifyPassword(password, user.password_hash);\n  \n  if (!valid) {\n    await mockDb.recordLoginAttempt(username, false);\n    sendJson(res, 401, { error: \"Invalid credentials\" });\n    return;\n  }\n  \n  await mockDb.recordLoginAttempt(username, true);\n  \n  // Generate tokens\n  const accessToken = signJwt(\n    { sub: user.agent_id, username: user.username, role: user.role },\n    JWT_SECRET,\n    JWT_ACCESS_EXPIRY\n  );\n  \n  const refreshToken = signJwt(\n    { sub: user.agent_id, type: \"refresh\" },\n    JWT_SECRET,\n    JWT_REFRESH_EXPIRY\n  );\n  \n  // Store session\n  const refreshPayload = verifyJwt(refreshToken, JWT_SECRET);\n  await mockDb.createSession(user.agent_id, refreshPayload.jti, new Date(Date.now() + JWT_REFRESH_EXPIRY * 1000));\n  \n  // Set cookies\n  setCookie(res, \"access_token\", accessToken, { maxAge: JWT_ACCESS_EXPIRY });\n  setCookie(res, \"refresh_token\", refreshToken, { maxAge: JWT_REFRESH_EXPIRY });\n  setCookie(res, \"csrf_token\", generateCsrfToken(), { httpOnly: false, maxAge: JWT_REFRESH_EXPIRY });\n  \n  sendJson(res, 200, {\n    success: true,\n    agent: {\n      id: user.agent_id,\n      username: user.username,\n      role: user.role,\n    },\n    expires_in: JWT_ACCESS_EXPIRY,\n  });\n}\n\nasync function handleLogout(req, res) {\n  const auth = await authenticate(req);\n  \n  if (auth.authenticated && auth.jti) {\n    await mockDb.revokeSession(auth.jti);\n  }\n  \n  // Always clear cookies even if not authenticated\n  clearCookie(res, \"access_token\");\n  clearCookie(res, \"refresh_token\");\n  clearCookie(res, \"csrf_token\");\n  \n  sendJson(res, 200, { success: true, message: \"Logged out\" });\n}\n\nasync function handleRefresh(req, res) {\n  let body;\n  try {\n    body = await parseBody(req);\n  } catch (e) {\n    body = {};\n  }\n  \n  // Get refresh token from cookie or body\n  let refreshToken = body.refresh_token;\n  if (!refreshToken) {\n    const cookie = req.headers[\"cookie\"];\n    if (cookie) {\n      const match = cookie.match(/refresh_token=([^;]+)/);\n      if (match) refreshToken = match[1];\n    }\n  }\n  \n  if (!refreshToken) {\n    sendJson(res, 401, { error: \"No refresh token provided\" });\n    return;\n  }\n  \n  let payload;\n  try {\n    payload = verifyJwt(refreshToken, JWT_SECRET);\n  } catch (e) {\n    sendJson(res, 401, { error: \"Invalid refresh token\" });\n    return;\n  }\n  \n  if (payload.type !== \"refresh\") {\n    sendJson(res, 401, { error: \"Invalid token type\" });\n    return;\n  }\n  \n  const isValid = await mockDb.isSessionValid(payload.jti);\n  if (!isValid) {\n    sendJson(res, 401, { error: \"Session revoked\" });\n    return;\n  }\n  \n  // Revoke old session\n  await mockDb.revokeSession(payload.jti);\n  \n  // Get user info\n  const user = await mockDb.findUserByUsername(payload.sub);\n  const username = user ? user.username : payload.sub;\n  const role = user ? user.role : \"agent\";\n  \n  // Issue new tokens\n  const newAccessToken = signJwt(\n    { sub: payload.sub, username, role },\n    JWT_SECRET,\n    JWT_ACCESS_EXPIRY\n  );\n  \n  const newRefreshToken = signJwt(\n    { sub: payload.sub, type: \"refresh\" },\n    JWT_SECRET,\n    JWT_REFRESH_EXPIRY\n  );\n  \n  const newRefreshPayload = verifyJwt(newRefreshToken, JWT_SECRET);\n  await mockDb.createSession(payload.sub, newRefreshPayload.jti, new Date(Date.now() + JWT_REFRESH_EXPIRY * 1000));\n  \n  setCookie(res, \"access_token\", newAccessToken, { maxAge: JWT_ACCESS_EXPIRY });\n  setCookie(res, \"refresh_token\", newRefreshToken, { maxAge: JWT_REFRESH_EXPIRY });\n  \n  sendJson(res, 200, {\n    success: true,\n    expires_in: JWT_ACCESS_EXPIRY,\n  });\n}\n\nasync function handleMe(req, res) {\n  const auth = await authenticate(req);\n  \n  if (!auth.authenticated) {\n    sendJson(res, 401, { error: auth.error || \"Unauthorized\" });\n    return;\n  }\n  \n  sendJson(res, 200, {\n    agent: {\n      id: auth.agentId,\n      username: auth.username,\n      role: auth.role,\n    },\n  });\n}\n\nasync function handleChangePassword(req, res) {\n  const auth = await authenticate(req);\n  \n  if (!auth.authenticated) {\n    sendJson(res, 401, { error: auth.error || \"Unauthorized\" });\n    return;\n  }\n  \n  let body;\n  try {\n    body = await parseBody(req);\n  } catch (e) {\n    sendJson(res, 400, { error: \"Invalid request body\" });\n    return;\n  }\n  \n  const { current_password, new_password } = body;\n  \n  if (!current_password || !new_password) {\n    sendJson(res, 400, { error: \"Current password and new password required\" });\n    return;\n  }\n  \n  if (new_password.length < 8) {\n    sendJson(res, 400, { error: \"New password must be at least 8 characters\" });\n    return;\n  }\n  \n  const user = await mockDb.findUserByUsername(auth.username);\n  if (!user) {\n    sendJson(res, 404, { error: \"User not found\" });\n    return;\n  }\n  \n  const valid = await verifyPassword(current_password, user.password_hash);\n  if (!valid) {\n    sendJson(res, 401, { error: \"Current password incorrect\" });\n    return;\n  }\n  \n  user.password_hash = await hashPassword(new_password);\n  \n  // Revoke all sessions except current\n  // (In production: UPDATE user_sessions SET revoked_at = NOW() WHERE agent_id = $1 AND jti != $2)\n  \n  sendJson(res, 200, { success: true, message: \"Password changed successfully\" });\n}\n\n/**\n * Main request router\n */\nasync function handleAuthRequest(req, res) {\n  const parsed = new URL(req.url, \"http://localhost\");\n  const pathname = parsed.pathname.replace(/\\/$/, \"\");\n  const method = req.method.toUpperCase();\n  \n  // CORS preflight\n  if (method === \"OPTIONS\") {\n    res.writeHead(204, {\n      \"Access-Control-Allow-Origin\": \"*\",\n      \"Access-Control-Allow-Methods\": \"GET,POST,OPTIONS\",\n      \"Access-Control-Allow-Headers\": \"Content-Type, Authorization, X-CSRF-Token\",\n      \"Access-Control-Allow-Credentials\": \"true\",\n    });\n    res.end();\n    return true;\n  }\n  \n  if (!pathname.startsWith(\"/api/auth\")) return false;\n  \n  // Set CORS headers for all auth responses\n  res.setHeader(\"Access-Control-Allow-Origin\", \"*\");\n  res.setHeader(\"Access-Control-Allow-Credentials\", \"true\");\n  \n  try {\n    if (pathname === \"/api/auth/login\" && method === \"POST\") {\n      await handleLogin(req, res);\n      return true;\n    }\n    \n    if (pathname === \"/api/auth/logout\" && method === \"POST\") {\n      await handleLogout(req, res);\n      return true;\n    }\n    \n    if (pathname === \"/api/auth/refresh\" && method === \"POST\") {\n      await handleRefresh(req, res);\n      return true;\n    }\n    \n    if (pathname === \"/api/auth/me\" && method === \"GET\") {\n      await handleMe(req, res);\n      return true;\n    }\n    \n    if (pathname === \"/api/auth/password\" && method === \"POST\") {\n      await handleChangePassword(req, res);\n      return true;\n    }\n    \n    if (pathname === \"/api/auth\") {\n      sendJson(res, 200, {\n        endpoints: [\n          \"POST /api/auth/login\",\n          \"POST /api/auth/logout\",\n          \"POST /api/auth/refresh\",\n          \"GET  /api/auth/me\",\n          \"POST /api/auth/password\",\n        ],\n      });\n      return true;\n    }\n    \n    sendJson(res, 404, { error: \"Unknown auth endpoint\" });\n    return true;\n  } catch (e) {\n    console.error(\"[auth] Error:\", e);\n    sendJson(res, 500, { error: \"Internal server error\" });\n    return true;\n  }\n}\n\n/**\n * Standalone mode\n */\nif (require.main === module) {\n  const http = require(\"http\");\n  const port = parseInt(process.argv[2] || \"3102\", 10);\n  \n  const server = http.createServer(async (req, res) => {\n    const handled = await handleAuthRequest(req, res);\n    if (!handled) {\n      sendJson(res, 404, { error: \"Not found\" });\n    }\n  });\n  \n  server.listen(port, () => {\n    console.log(`[login-api] Listening on http://localhost:${port}`);\n    console.log(\"Endpoints:\");\n    console.log(`  POST http://localhost:${port}/api/auth/login`);\n    console.log(`  POST http://localhost:${port}/api/auth/logout`);\n    console.log(`  POST http://localhost:${port}/api/auth/refresh`);\n    console.log(`  GET  http://localhost:${port}/api/auth/me`);\n    console.log(`  POST http://localhost:${port}/api/auth/password`);\n    console.log(\"\\nDefault credentials (username:password):\");\n    console.log(\"  alice:changeme, bob:changeme, charlie:changeme\");\n  });\n}\n\n// Exports for integration\nmodule.exports = {\n  handleAuthRequest,\n  authenticate,\n  hashPassword,\n  verifyPassword,\n  signJwt,\n  verifyJwt,\n  generateCsrfToken,\n  JWT_SECRET,\n};\n","numLines":682,"startLine":1,"totalLines":682}}}
