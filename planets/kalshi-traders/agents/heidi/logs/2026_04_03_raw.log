{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019BLgkV9GbPcbjzuXXG7T2n","type":"tool_result","content":"1\t#!/bin/bash\n2\t#\n3\t# Live Trading Prep Script — Task 335\n4\t# Automated gate before live trading authorization\n5\t# \n6\t# Usage: bash live_trading_prep.sh [KALSHI_API_KEY]\n7\t# \n8\t# Exit codes:\n9\t#   0 = GO (all gates passed)\n10\t#   1 = NO-GO (one or more gates failed)\n11\t#   2 = ERROR (script failure)\n12\t\n13\tset -euo pipefail\n14\t\n15\t# Colors for output\n16\tRED='\\033[0;31m'\n17\tGREEN='\\033[0;32m'\n18\tYELLOW='\\033[1;33m'\n19\tBLUE='\\033[0;34m'\n20\tNC='\\033[0m' # No Color\n21\t\n22\t# Configuration\n23\tMIN_WIN_RATE=0.40          # 40% minimum win rate\n24\tMIN_PAPER_TRADES=10        # At least 10 paper trades\n25\tMAX_DRAWDOWN=5000          # $50 max drawdown in cents\n26\tAPI_TEST_TIMEOUT=30        # Seconds to wait for API test\n27\tREPORT_FILE=\"output/live_trading_prep_report.md\"\n28\tLOG_FILE=\"logs/live_trading_prep.log\"\n29\t\n30\t# Track results\n31\tGATES_PASSED=0\n32\tGATES_FAILED=0\n33\tERRORS=()\n34\tWARNINGS=()\n35\t\n36\t# Logging function\n37\tlog() {\n38\t    local level=\"$1\"\n39\t    shift\n40\t    local message=\"$*\"\n41\t    local timestamp=$(date -u +\"%Y-%m-%dT%H:%M:%SZ\")\n42\t    echo \"[$timestamp] [$level] $message\" | tee -a \"$LOG_FILE\"\n43\t}\n44\t\n45\t# Print section header\n46\tsection() {\n47\t    echo -e \"\\n${BLUE}=== $1 ===${NC}\"\n48\t    log \"INFO\" \"Starting: $1\"\n49\t}\n50\t\n51\t# Print success\n52\tpass() {\n53\t    echo -e \"${GREEN}✓ PASS:${NC} $1\"\n54\t    log \"PASS\" \"$1\"\n55\t    ((GATES_PASSED++)) || true\n56\t}\n57\t\n58\t# Print failure\n59\tfail() {\n60\t    echo -e \"${RED}✗ FAIL:${NC} $1\"\n61\t    log \"FAIL\" \"$1\"\n62\t    ((GATES_FAILED++)) || true\n63\t    ERRORS+=(\"$1\")\n64\t}\n65\t\n66\t# Print warning\n67\twarn() {\n68\t    echo -e \"${YELLOW}⚠ WARNING:${NC} $1\"\n69\t    log \"WARN\" \"$1\"\n70\t    WARNINGS+=(\"$1\")\n71\t}\n72\t\n73\t# Initialize\n74\tmkdir -p logs output\n75\t> \"$LOG_FILE\"\n76\t\n77\techo -e \"${BLUE}\"\n78\techo \"╔══════════════════════════════════════════════════════════════╗\"\n79\techo \"║           LIVE TRADING PREP — AUTOMATED GATE                 ║\"\n80\techo \"║                    Task 335 — Sprint 7                       ║\"\n81\techo \"╚══════════════════════════════════════════════════════════════╝\"\n82\techo -e \"${NC}\"\n83\t\n84\tlog \"INFO\" \"Live Trading Prep started\"\n85\tlog \"INFO\" \"Configuration: MIN_WIN_RATE=$MIN_WIN_RATE, MIN_PAPER_TRADES=$MIN_PAPER_TRADES, MAX_DRAWDOWN=$MAX_DRAWDOWN\"\n86\t\n87\t# ============================================================================\n88\t# GATE 1: Environment & Dependencies\n89\t# ============================================================================\n90\tsection \"GATE 1: Environment & Dependencies\"\n91\t\n92\t# Check Node.js version\n93\tif command -v node &> /dev/null; then\n94\t    NODE_VERSION=$(node --version | cut -d'v' -f2)\n95\t    pass \"Node.js installed: v$NODE_VERSION\"\n96\telse\n97\t    fail \"Node.js not found\"\n98\tfi\n99\t\n100\t# Check required files exist\n101\tREQUIRED_FILES=(\n102\t    \"backend/strategies/live_runner.js\"\n103\t    \"backend/strategies/signal_engine.js\"\n104\t    \"backend/kalshi_client.js\"\n105\t    \"backend/paper_trades_db.js\"\n106\t)\n107\t\n108\tfor file in \"${REQUIRED_FILES[@]}\"; do\n109\t    if [[ -f \"$file\" ]]; then\n110\t        pass \"Required file exists: $file\"\n111\t    else\n112\t        fail \"Missing required file: $file\"\n113\t    fi\n114\tdone\n115\t\n116\t# Check npm packages installed\n117\tif [[ -d \"node_modules\" ]]; then\n118\t    pass \"Node modules installed\"\n119\telse\n120\t    fail \"Node modules not installed (run: npm install)\"\n121\tfi\n122\t\n123\t# ============================================================================\n124\t# GATE 2: Kalshi API Credentials\n125\t# ============================================================================\n126\tsection \"GATE 2: Kalshi API Credentials\"\n127\t\n128\tKALSHI_API_KEY=\"${1:-${KALSHI_API_KEY:-}}\"\n129\t\n130\tif [[ -z \"$KALSHI_API_KEY\" ]]; then\n131\t    fail \"KALSHI_API_KEY not provided (pass as argument or set env var)\"\n132\telse\n133\t    # Mask key for logging\n134\t    MASKED_KEY=\"${KALSHI_API_KEY:0:4}****${KALSHI_API_KEY: -4}\"\n135\t    pass \"KALSHI_API_KEY provided: $MASKED_KEY\"\n136\tfi\n137\t\n138\t# Test API connectivity\n139\techo \"Testing Kalshi API connectivity...\"\n140\texport KALSHI_API_KEY\n141\texport KALSHI_DEMO=\"true\"  # Always use demo mode for testing\n142\t\n143\tAPI_TEST_OUTPUT=$(node -e \"\n144\tconst { KalshiClient } = require('./backend/kalshi_client');\n145\tconst client = new KalshiClient({ apiKey: process.env.KALSHI_API_KEY, demo: true });\n146\tclient.getMarkets({ limit: 1 })\n147\t  .then(r => { console.log('SUCCESS:', JSON.stringify(r.data ? 'connected' : 'no data')); process.exit(0); })\n148\t  .catch(e => { console.log('ERROR:', e.message); process.exit(1); });\n149\t\" 2>&1) || true\n150\t\n151\tif echo \"$API_TEST_OUTPUT\" | grep -q \"SUCCESS\"; then\n152\t    pass \"Kalshi API connection successful\"\n153\telse\n154\t    fail \"Kalshi API connection failed: $API_TEST_OUTPUT\"\n155\tfi\n156\t\n157\t# ============================================================================\n158\t# GATE 3: Strategy Configuration Validation\n159\t# ============================================================================\n160\tsection \"GATE 3: Strategy Configuration Validation\"\n161\t\n162\t# Check mean_reversion parameters match backtest\n163\tCONFIG_CHECK=$(node -e \"\n164\tconst fs = require('fs');\n165\tconst content = fs.readFileSync('backend/strategies/live_runner.js', 'utf8');\n166\t\n167\t// Extract key parameters\n168\tconst zScoreMatch = content.match(/zScoreThreshold:\\s*([0-9.]+)/);\n169\tconst minVolumeMatch = content.match(/minVolume:\\s*([0-9]+)/);\n170\tconst candleDaysMatch = content.match(/CANDLE_DAYS\\s*=\\s*([0-9]+)/);\n171\t\n172\tconst zScore = zScoreMatch ? zScoreMatch[1] : 'NOT_FOUND';\n173\tconst minVolume = minVolumeMatch ? minVolumeMatch[1] : 'NOT_FOUND';\n174\tconst candleDays = candleDaysMatch ? candleDaysMatch[1] : 'NOT_FOUND';\n175\t\n176\tconsole.log('zScoreThreshold:', zScore);\n177\tconsole.log('minVolume:', minVolume);\n178\tconsole.log('CANDLE_DAYS:', candleDays);\n179\t\n180\t// Validate against backtest baseline\n181\tconst errors = [];\n182\tif (zScore !== '1.5') errors.push('zScoreThreshold should be 1.5, got ' + zScore);\n183\tif (minVolume !== '10000') errors.push('minVolume should be 10000, got ' + minVolume);\n184\tif (candleDays !== '30') errors.push('CANDLE_DAYS should be 30, got ' + candleDays);\n185\t\n186\tif (errors.length > 0) {\n187\t    console.log('ERRORS:', errors.join('; '));\n188\t    process.exit(1);\n189\t} else {\n190\t    console.log('STATUS: OK');\n191\t    process.exit(0);\n192\t}\n193\t\" 2>&1)\n194\t\n195\tif echo \"$CONFIG_CHECK\" | grep -q \"STATUS: OK\"; then\n196\t    pass \"Strategy parameters aligned with backtest\"\n197\t    echo \"$CONFIG_CHECK\" | grep -E \"zScoreThreshold|minVolume|CANDLE_DAYS\" | sed 's/^/  /'\n198\telse\n199\t    fail \"Strategy parameter mismatch:\"\n200\t    echo \"$CONFIG_CHECK\" | grep \"ERRORS:\" | sed 's/ERRORS://' | sed 's/^/  /'\n201\tfi\n202\t\n203\t# Check momentum/crypto_edge are disabled\n204\tDISABLED_CHECK=$(node -e \"\n205\tconst fs = require('fs');\n206\tconst content = fs.readFileSync('backend/strategies/live_runner.js', 'utf8');\n207\t\n208\t// Check that momentum and crypto_edge are commented out or disabled\n209\tconst momentumActive = content.match(/const\\s+momentum\\s*=\\s*new\\s+MomentumStrategy/) && \n210\t                       !content.match(/\\/\\/\\s*DISABLED.*momentum/);\n211\tconst cryptoActive = content.match(/const\\s+cryptoEdge\\s*=\\s*new\\s+CryptoEdgeStrategy/) &&\n212\t                     !content.match(/\\/\\/\\s*DISABLED.*crypto/);\n213\t\n214\tif (momentumActive || cryptoActive) {\n215\t    console.log('DISABLED: false');\n216\t    if (momentumActive) console.log('ERROR: momentum is active');\n217\t    if (cryptoActive) console.log('ERROR: crypto_edge is active');\n218\t    process.exit(1);\n219\t} else {\n220\t    console.log('DISABLED: true');\n221\t    process.exit(0);\n222\t}\n223\t\" 2>&1)\n224\t\n225\tif echo \"$DISABLED_CHECK\" | grep -q \"DISABLED: true\"; then\n226\t    pass \"momentum and crypto_edge strategies are disabled\"\n227\telse\n228\t    fail \"Contaminating strategies detected:\"\n229\t    echo \"$DISABLED_CHECK\" | grep \"ERROR:\" | sed 's/ERROR://' | sed 's/^/  /'\n230\tfi\n231\t\n232\t# ============================================================================\n233\t# GATE 4: Paper Trading with Real Data\n234\t# ============================================================================\n235\tsection \"GATE 4: Paper Trading with Real Data\"\n236\t\n237\techo \"Running paper trades with real Kalshi API data...\"\n238\techo \"This will execute $MIN_PAPER_TRADES paper trades.\"\n239\techo \"\"\n240\t\n241\t# Clear previous paper trade data for clean test\n242\tif [[ -f \"output/paper_trades.db\" ]]; then\n243\t    mv \"output/paper_trades.db\" \"output/paper_trades.db.backup.$(date +%s)\"\n244\t    log \"INFO\" \"Backed up previous paper_trades.db\"\n245\tfi\n246\t\n247\t# Run paper trades\n248\tTRADE_COUNT=0\n249\tMAX_ATTEMPTS=20\n250\tATTEMPT=0\n251\t\n252\twhile [[ $TRADE_COUNT -lt $MIN_PAPER_TRADES && $ATTEMPT -lt $MAX_ATTEMPTS ]]; do\n253\t    ((ATTEMPT++)) || true\n254\t    echo \"  Attempt $ATTEMPT: Running live_runner.js...\"\n255\t    \n256\t    RUNNER_OUTPUT=$(node backend/strategies/live_runner.js --execute 2>&1) || true\n257\t    echo \"$RUNNER_OUTPUT\" | tee -a \"$LOG_FILE\"\n258\t    \n259\t    # Check if trades were generated\n260\t    NEW_TRADES=$(echo \"$RUNNER_OUTPUT\" | grep -oP 'Logged \\K[0-9]+' | head -1 || echo \"0\")\n261\t    TRADE_COUNT=$((TRADE_COUNT + NEW_TRADES))\n262\t    \n263\t    echo \"  Trades this run: $NEW_TRADES, Total: $TRADE_COUNT\"\n264\t    \n265\t    # Wait between runs\n266\t    if [[ $TRADE_COUNT -lt $MIN_PAPER_TRADES ]]; then\n267\t        sleep 5\n268\t    fi\n269\tdone\n270\t\n271\tif [[ $TRADE_COUNT -ge $MIN_PAPER_TRADES ]]; then\n272\t    pass \"Generated $TRADE_COUNT paper trades (target: $MIN_PAPER_TRADES)\"\n273\telse\n274\t    fail \"Only generated $TRADE_COUNT paper trades (target: $MIN_PAPER_TRADES)\"\n275\t    warn \"This may indicate no signals are being generated with real data\"\n276\tfi\n277\t\n278\t# ============================================================================\n279\t# GATE 5: Win Rate Verification\n280\t# ============================================================================\n281\tsection \"GATE 5: Win Rate Verification\"\n282\t\n283\t# Get paper trade summary\n284\tSUMMARY=$(node -e \"\n285\tconst fs = require('fs');\n286\tconst path = 'output/paper_trades.db';\n287\tif (!fs.existsSync(path)) {\n288\t    console.log('NO_DATA');\n289\t    process.exit(1);\n290\t}\n291\tconst data = JSON.parse(fs.readFileSync(path, 'utf8'));\n292\tconst closed = data.filter(t => t.status === 'CLOSED');\n293\tconst wins = closed.filter(t => t.outcome === 'WIN');\n294\tconst losses = closed.filter(t => t.outcome === 'LOSS');\n295\tconst totalPnl = closed.reduce((sum, t) => sum + (t.pnl || 0), 0);\n296\t\n297\tconsole.log('TOTAL:', data.length);\n298\tconsole.log('CLOSED:', closed.length);\n299\tconsole.log('WINS:', wins.length);\n300\tconsole.log('LOSSES:', losses.length);\n301\tconsole.log('WIN_RATE:', closed.length > 0 ? (wins.length / closed.length).toFixed(4) : '0');\n302\tconsole.log('TOTAL_PNL:', totalPnl);\n303\t\" 2>&1)\n304\t\n305\tif echo \"$SUMMARY\" | grep -q \"NO_DATA\"; then\n306\t    fail \"No paper trade data available\"\n307\telse\n308\t    TOTAL_TRADES=$(echo \"$SUMMARY\" | grep \"TOTAL:\" | cut -d: -f2 | tr -d ' ')\n309\t    CLOSED_TRADES=$(echo \"$SUMMARY\" | grep \"CLOSED:\" | cut -d: -f2 | tr -d ' ')\n310\t    WINS=$(echo \"$SUMMARY\" | grep \"WINS:\" | cut -d: -f2 | tr -d ' ')\n311\t    LOSSES=$(echo \"$SUMMARY\" | grep \"LOSSES:\" | cut -d: -f2 | tr -d ' ')\n312\t    WIN_RATE=$(echo \"$SUMMARY\" | grep \"WIN_RATE:\" | cut -d: -f2 | tr -d ' ')\n313\t    TOTAL_PNL=$(echo \"$SUMMARY\" | grep \"TOTAL_PNL:\" | cut -d: -f2 | tr -d ' ')\n314\t    \n315\t    echo \"  Total trades: $TOTAL_TRADES\"\n316\t    echo \"  Closed trades: $CLOSED_TRADES\"\n317\t    echo \"  Wins: $WINS, Losses: $LOSSES\"\n318\t    echo \"  Win rate: $(echo \"$WIN_RATE * 100\" | bc -l | xargs printf \"%.1f%%\")\"\n319\t    echo \"  Total P&L: $(echo \"$TOTAL_PNL / 100\" | bc -l | xargs printf \"\\$%.2f\")\"\n320\t    \n321\t    # Check win rate threshold\n322\t    WIN_RATE_OK=$(echo \"$WIN_RATE >= $MIN_WIN_RATE\" | bc -l)\n323\t    if [[ $WIN_RATE_OK -eq 1 ]]; then\n324\t        pass \"Win rate $(echo \"$WIN_RATE * 100\" | bc -l | xargs printf \"%.1f%%\") >= $(echo \"$MIN_WIN_RATE * 100\" | bc -l)%\"\n325\t    else\n326\t        fail \"Win rate $(echo \"$WIN_RATE * 100\" | bc -l | xargs printf \"%.1f%%\") < $(echo \"$MIN_WIN_RATE * 100\" | bc -l)%\"\n327\t    fi\n328\t    \n329\t    # Check drawdown\n330\t    DRAWDOWN_OK=$(echo \"${TOTAL_PNL#-} <= $MAX_DRAWDOWN\" | bc -l)\n331\t    if [[ $DRAWDOWN_OK -eq 1 ]]; then\n332\t        pass \"Drawdown within limit: $(echo \"${TOTAL_PNL#-} / 100\" | bc -l | xargs printf \"\\$%.2f\")\"\n333\t    else\n334\t        fail \"Drawdown exceeds limit: $(echo \"${TOTAL_PNL#-} / 100\" | bc -l | xargs printf \"\\$%.2f\")\"\n335\t    fi\n336\tfi\n337\t\n338\t# ============================================================================\n339\t# GATE 6: Security Review\n340\t# ============================================================================\n341\tsection \"GATE 6: Security Review\"\n342\t\n343\t# Check PAPER_TRADING flag is set\n344\tif grep -q \"PAPER_TRADING.*!==*.*false\" backend/strategies/live_runner.js; then\n345\t    pass \"PAPER_TRADING safeguard is active\"\n346\telse\n347\t    warn \"Could not verify PAPER_TRADING safeguard\"\n348\tfi\n349\t\n350\t# Check for hardcoded credentials\n351\tif grep -r \"apiKey.*=.*[\\\"'][^\\\"']\\{10,\\}[\\\"']\" backend/ --include=\"*.js\" 2>/dev/null | grep -v \"\\.test\\.\" | head -1; then\n352\t    fail \"Potential hardcoded API key found\"\n353\telse\n354\t    pass \"No hardcoded credentials detected\"\n355\tfi\n356\t\n357\t# Check file permissions\n358\tif [[ -f \"backend/strategies/live_runner.js\" && -r \"backend/strategies/live_runner.js\" ]]; then\n359\t    pass \"Strategy files have appropriate permissions\"\n360\tfi\n361\t\n362\t# ============================================================================\n363\t# GATE 7: Monitoring Setup\n364\t# ============================================================================\n365\tsection \"GATE 7: Monitoring Setup\"\n366\t\n367\t# Check dashboard API is accessible\n368\tDASHBOARD_TEST=$(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3200/api/health 2>/dev/null || echo \"000\")\n369\tif [[ \"$DASHBOARD_TEST\" == \"200\" ]]; then\n370\t    pass \"Dashboard API is accessible\"\n371\telse\n372\t    warn \"Dashboard API not accessible (HTTP $DASHBOARD_TEST)\"\n373\tfi\n374\t\n375\t# Check PnL endpoint\n376\tPNL_TEST=$(curl -s http://localhost:3200/api/pnl/live 2>/dev/null | head -1 || echo \"FAIL\")\n377\tif echo \"$PNL_TEST\" | grep -q \"win_rate\\|total_pnl\"; then\n378\t    pass \"PnL monitoring endpoint is functional\"\n379\telse\n380\t    warn \"PnL endpoint not responding correctly\"\n381\tfi\n382\t\n383\t# ============================================================================\n384\t# FINAL DECISION\n385\t# ============================================================================\n386\tsection \"FINAL DECISION\"\n387\t\n388\techo \"\"\n389\techo \"═══════════════════════════════════════════════════════════════\"\n390\techo \"                    GATE SUMMARY\"\n391\techo \"═══════════════════════════════════════════════════════════════\"\n392\techo \"  Gates Passed: $GATES_PASSED\"\n393\techo \"  Gates Failed: $GATES_FAILED\"\n394\techo \"  Warnings: ${#WARNINGS[@]}\"\n395\techo \"\"\n396\t\n397\tif [[ $GATES_FAILED -eq 0 ]]; then\n398\t    DECISION=\"GO\"\n399\t    DECISION_COLOR=\"$GREEN\"\n400\t    EXIT_CODE=0\n401\telif [[ $GATES_FAILED -le 2 && ${#WARNINGS[@]} -eq 0 ]]; then\n402\t    DECISION=\"GO WITH CAUTION\"\n403\t    DECISION_COLOR=\"$YELLOW\"\n404\t    EXIT_CODE=0\n405\telse\n406\t    DECISION=\"NO-GO\"\n407\t    DECISION_COLOR=\"$RED\"\n408\t    EXIT_CODE=1\n409\tfi\n410\t\n411\techo -e \"${DECISION_COLOR}\"\n412\techo \"  ██████╗ ███████╗ ██████╗██╗███████╗██╗ ██████╗ ███╗   ██╗\"\n413\techo \"  ██╔══██╗██╔════╝██╔════╝██║██╔════╝██║██╔═══██╗████╗  ██║\"\n414\techo \"  ██║  ██║█████╗  ██║     ██║███████╗██║██║   ██║██╔██╗ ██║\"\n415\techo \"  ██║  ██║██╔══╝  ██║     ██║╚════██║██║██║   ██║██║╚██╗██║\"\n416\techo \"  ██████╔╝███████╗╚██████╗██║███████║██║╚██████╔╝██║ ╚████║\"\n417\techo \"  ╚═════╝ ╚══════╝ ╚═════╝╚═╝╚══════╝╚═╝ ╚═════╝ ╚═╝  ╚═══╝\"\n418\techo \"\"\n419\techo \"                    $DECISION\"\n420\techo -e \"${NC}\"\n421\t\n422\t# Generate report\n423\tcat > \"$REPORT_FILE\" << EOF\n424\t# Live Trading Prep Report\n425\t\n426\t**Generated:** $(date -u +\"%Y-%m-%dT%H:%M:%SZ\")  \n427\t**Decision:** $DECISION  \n428\t**Exit Code:** $EXIT_CODE\n429\t\n430\t## Summary\n431\t\n432\t| Metric | Value |\n433\t|--------|-------|\n434\t| Gates Passed | $GATES_PASSED |\n435\t| Gates Failed | $GATES_FAILED |\n436\t| Warnings | ${#WARNINGS[@]} |\n437\t\n438\t## Gate Results\n439\t\n440\t### GATE 1: Environment & Dependencies\n441\t$(if command -v node &> /dev/null; then echo \"- ✓ Node.js installed\"; else echo \"- ✗ Node.js not found\"; fi)\n442\t\n443\t### GATE 2: Kalshi API Credentials\n444\t$(if [[ -n \"$KALSHI_API_KEY\" ]]; then echo \"- ✓ API key provided\"; else echo \"- ✗ API key missing\"; fi)\n445\t\n446\t### GATE 3: Strategy Configuration\n447\t$(echo \"$CONFIG_CHECK\" | grep -E \"zScoreThreshold|minVolume|CANDLE_DAYS\" | sed 's/^/- /')\n448\t\n449\t### GATE 4: Paper Trading\n450\t- Total trades: ${TOTAL_TRADES:-N/A}\n451\t- Target: $MIN_PAPER_TRADES\n452\t\n453\t### GATE 5: Win Rate\n454\t- Win rate: ${WIN_RATE:-N/A}\n455\t- Target: $MIN_WIN_RATE\n456\t- Total P&L: ${TOTAL_PNL:-N/A}¢\n457\t\n458\t## Errors\n459\t\n460\t$(if [[ ${#ERRORS[@]} -eq 0 ]]; then echo \"None\"; else printf '%s\\n' \"${ERRORS[@]}\" | sed 's/^/- /'; fi)\n461\t\n462\t## Warnings\n463\t\n464\t$(if [[ ${#WARNINGS[@]} -eq 0 ]]; then echo \"None\"; else printf '%s\\n' \"${WARNINGS[@]}\" | sed 's/^/- /'; fi)\n465\t\n466\t## Next Steps\n467\t\n468\t$(if [[ $EXIT_CODE -eq 0 ]]; then echo \"System is ready for live trading authorization. Escalate to Founder for final approval.\"; else echo \"Address failed gates before proceeding to live trading.\"; fi)\n469\tEOF\n470\t\n471\techo \"Report written to: $REPORT_FILE\"\n472\tlog \"INFO\" \"Live Trading Prep completed with decision: $DECISION\"\n473\t\n474\texit $EXIT_CODE\n475\t"}]},"parent_tool_use_id":null,"session_id":"13869bcc-5a8c-4ff8-8624-290e2bdca9d1","uuid":"18ce972f-1b76-4404-91f9-233f4741a30c","timestamp":"2026-04-04T05:42:16.783Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/chenyangcui/Documents/code/aicompany/planets/kalshi-traders/output/shared/codebase/backend/scripts/live_trading_prep.sh","content":"#!/bin/bash\n#\n# Live Trading Prep Script — Task 335\n# Automated gate before live trading authorization\n# \n# Usage: bash live_trading_prep.sh [KALSHI_API_KEY]\n# \n# Exit codes:\n#   0 = GO (all gates passed)\n#   1 = NO-GO (one or more gates failed)\n#   2 = ERROR (script failure)\n\nset -euo pipefail\n\n# Colors for output\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nYELLOW='\\033[1;33m'\nBLUE='\\033[0;34m'\nNC='\\033[0m' # No Color\n\n# Configuration\nMIN_WIN_RATE=0.40          # 40% minimum win rate\nMIN_PAPER_TRADES=10        # At least 10 paper trades\nMAX_DRAWDOWN=5000          # $50 max drawdown in cents\nAPI_TEST_TIMEOUT=30        # Seconds to wait for API test\nREPORT_FILE=\"output/live_trading_prep_report.md\"\nLOG_FILE=\"logs/live_trading_prep.log\"\n\n# Track results\nGATES_PASSED=0\nGATES_FAILED=0\nERRORS=()\nWARNINGS=()\n\n# Logging function\nlog() {\n    local level=\"$1\"\n    shift\n    local message=\"$*\"\n    local timestamp=$(date -u +\"%Y-%m-%dT%H:%M:%SZ\")\n    echo \"[$timestamp] [$level] $message\" | tee -a \"$LOG_FILE\"\n}\n\n# Print section header\nsection() {\n    echo -e \"\\n${BLUE}=== $1 ===${NC}\"\n    log \"INFO\" \"Starting: $1\"\n}\n\n# Print success\npass() {\n    echo -e \"${GREEN}✓ PASS:${NC} $1\"\n    log \"PASS\" \"$1\"\n    ((GATES_PASSED++)) || true\n}\n\n# Print failure\nfail() {\n    echo -e \"${RED}✗ FAIL:${NC} $1\"\n    log \"FAIL\" \"$1\"\n    ((GATES_FAILED++)) || true\n    ERRORS+=(\"$1\")\n}\n\n# Print warning\nwarn() {\n    echo -e \"${YELLOW}⚠ WARNING:${NC} $1\"\n    log \"WARN\" \"$1\"\n    WARNINGS+=(\"$1\")\n}\n\n# Initialize\nmkdir -p logs output\n> \"$LOG_FILE\"\n\necho -e \"${BLUE}\"\necho \"╔══════════════════════════════════════════════════════════════╗\"\necho \"║           LIVE TRADING PREP — AUTOMATED GATE                 ║\"\necho \"║                    Task 335 — Sprint 7                       ║\"\necho \"╚══════════════════════════════════════════════════════════════╝\"\necho -e \"${NC}\"\n\nlog \"INFO\" \"Live Trading Prep started\"\nlog \"INFO\" \"Configuration: MIN_WIN_RATE=$MIN_WIN_RATE, MIN_PAPER_TRADES=$MIN_PAPER_TRADES, MAX_DRAWDOWN=$MAX_DRAWDOWN\"\n\n# ============================================================================\n# GATE 1: Environment & Dependencies\n# ============================================================================\nsection \"GATE 1: Environment & Dependencies\"\n\n# Check Node.js version\nif command -v node &> /dev/null; then\n    NODE_VERSION=$(node --version | cut -d'v' -f2)\n    pass \"Node.js installed: v$NODE_VERSION\"\nelse\n    fail \"Node.js not found\"\nfi\n\n# Check required files exist\nREQUIRED_FILES=(\n    \"backend/strategies/live_runner.js\"\n    \"backend/strategies/signal_engine.js\"\n    \"backend/kalshi_client.js\"\n    \"backend/paper_trades_db.js\"\n)\n\nfor file in \"${REQUIRED_FILES[@]}\"; do\n    if [[ -f \"$file\" ]]; then\n        pass \"Required file exists: $file\"\n    else\n        fail \"Missing required file: $file\"\n    fi\ndone\n\n# Check npm packages installed\nif [[ -d \"node_modules\" ]]; then\n    pass \"Node modules installed\"\nelse\n    fail \"Node modules not installed (run: npm install)\"\nfi\n\n# ============================================================================\n# GATE 2: Kalshi API Credentials\n# ============================================================================\nsection \"GATE 2: Kalshi API Credentials\"\n\nKALSHI_API_KEY=\"${1:-${KALSHI_API_KEY:-}}\"\n\nif [[ -z \"$KALSHI_API_KEY\" ]]; then\n    fail \"KALSHI_API_KEY not provided (pass as argument or set env var)\"\nelse\n    # Mask key for logging\n    MASKED_KEY=\"${KALSHI_API_KEY:0:4}****${KALSHI_API_KEY: -4}\"\n    pass \"KALSHI_API_KEY provided: $MASKED_KEY\"\nfi\n\n# Test API connectivity\necho \"Testing Kalshi API connectivity...\"\nexport KALSHI_API_KEY\nexport KALSHI_DEMO=\"true\"  # Always use demo mode for testing\n\nAPI_TEST_OUTPUT=$(node -e \"\nconst { KalshiClient } = require('./backend/kalshi_client');\nconst client = new KalshiClient({ apiKey: process.env.KALSHI_API_KEY, demo: true });\nclient.getMarkets({ limit: 1 })\n  .then(r => { console.log('SUCCESS:', JSON.stringify(r.data ? 'connected' : 'no data')); process.exit(0); })\n  .catch(e => { console.log('ERROR:', e.message); process.exit(1); });\n\" 2>&1) || true\n\nif echo \"$API_TEST_OUTPUT\" | grep -q \"SUCCESS\"; then\n    pass \"Kalshi API connection successful\"\nelse\n    fail \"Kalshi API connection failed: $API_TEST_OUTPUT\"\nfi\n\n# ============================================================================\n# GATE 3: Strategy Configuration Validation\n# ============================================================================\nsection \"GATE 3: Strategy Configuration Validation\"\n\n# Check mean_reversion parameters match backtest\nCONFIG_CHECK=$(node -e \"\nconst fs = require('fs');\nconst content = fs.readFileSync('backend/strategies/live_runner.js', 'utf8');\n\n// Extract key parameters\nconst zScoreMatch = content.match(/zScoreThreshold:\\s*([0-9.]+)/);\nconst minVolumeMatch = content.match(/minVolume:\\s*([0-9]+)/);\nconst candleDaysMatch = content.match(/CANDLE_DAYS\\s*=\\s*([0-9]+)/);\n\nconst zScore = zScoreMatch ? zScoreMatch[1] : 'NOT_FOUND';\nconst minVolume = minVolumeMatch ? minVolumeMatch[1] : 'NOT_FOUND';\nconst candleDays = candleDaysMatch ? candleDaysMatch[1] : 'NOT_FOUND';\n\nconsole.log('zScoreThreshold:', zScore);\nconsole.log('minVolume:', minVolume);\nconsole.log('CANDLE_DAYS:', candleDays);\n\n// Validate against backtest baseline\nconst errors = [];\nif (zScore !== '1.5') errors.push('zScoreThreshold should be 1.5, got ' + zScore);\nif (minVolume !== '10000') errors.push('minVolume should be 10000, got ' + minVolume);\nif (candleDays !== '30') errors.push('CANDLE_DAYS should be 30, got ' + candleDays);\n\nif (errors.length > 0) {\n    console.log('ERRORS:', errors.join('; '));\n    process.exit(1);\n} else {\n    console.log('STATUS: OK');\n    process.exit(0);\n}\n\" 2>&1)\n\nif echo \"$CONFIG_CHECK\" | grep -q \"STATUS: OK\"; then\n    pass \"Strategy parameters aligned with backtest\"\n    echo \"$CONFIG_CHECK\" | grep -E \"zScoreThreshold|minVolume|CANDLE_DAYS\" | sed 's/^/  /'\nelse\n    fail \"Strategy parameter mismatch:\"\n    echo \"$CONFIG_CHECK\" | grep \"ERRORS:\" | sed 's/ERRORS://' | sed 's/^/  /'\nfi\n\n# Check momentum/crypto_edge are disabled\nDISABLED_CHECK=$(node -e \"\nconst fs = require('fs');\nconst content = fs.readFileSync('backend/strategies/live_runner.js', 'utf8');\n\n// Check that momentum and crypto_edge are commented out or disabled\nconst momentumActive = content.match(/const\\s+momentum\\s*=\\s*new\\s+MomentumStrategy/) && \n                       !content.match(/\\/\\/\\s*DISABLED.*momentum/);\nconst cryptoActive = content.match(/const\\s+cryptoEdge\\s*=\\s*new\\s+CryptoEdgeStrategy/) &&\n                     !content.match(/\\/\\/\\s*DISABLED.*crypto/);\n\nif (momentumActive || cryptoActive) {\n    console.log('DISABLED: false');\n    if (momentumActive) console.log('ERROR: momentum is active');\n    if (cryptoActive) console.log('ERROR: crypto_edge is active');\n    process.exit(1);\n} else {\n    console.log('DISABLED: true');\n    process.exit(0);\n}\n\" 2>&1)\n\nif echo \"$DISABLED_CHECK\" | grep -q \"DISABLED: true\"; then\n    pass \"momentum and crypto_edge strategies are disabled\"\nelse\n    fail \"Contaminating strategies detected:\"\n    echo \"$DISABLED_CHECK\" | grep \"ERROR:\" | sed 's/ERROR://' | sed 's/^/  /'\nfi\n\n# ============================================================================\n# GATE 4: Paper Trading with Real Data\n# ============================================================================\nsection \"GATE 4: Paper Trading with Real Data\"\n\necho \"Running paper trades with real Kalshi API data...\"\necho \"This will execute $MIN_PAPER_TRADES paper trades.\"\necho \"\"\n\n# Clear previous paper trade data for clean test\nif [[ -f \"output/paper_trades.db\" ]]; then\n    mv \"output/paper_trades.db\" \"output/paper_trades.db.backup.$(date +%s)\"\n    log \"INFO\" \"Backed up previous paper_trades.db\"\nfi\n\n# Run paper trades\nTRADE_COUNT=0\nMAX_ATTEMPTS=20\nATTEMPT=0\n\nwhile [[ $TRADE_COUNT -lt $MIN_PAPER_TRADES && $ATTEMPT -lt $MAX_ATTEMPTS ]]; do\n    ((ATTEMPT++)) || true\n    echo \"  Attempt $ATTEMPT: Running live_runner.js...\"\n    \n    RUNNER_OUTPUT=$(node backend/strategies/live_runner.js --execute 2>&1) || true\n    echo \"$RUNNER_OUTPUT\" | tee -a \"$LOG_FILE\"\n    \n    # Check if trades were generated\n    NEW_TRADES=$(echo \"$RUNNER_OUTPUT\" | grep -oP 'Logged \\K[0-9]+' | head -1 || echo \"0\")\n    TRADE_COUNT=$((TRADE_COUNT + NEW_TRADES))\n    \n    echo \"  Trades this run: $NEW_TRADES, Total: $TRADE_COUNT\"\n    \n    # Wait between runs\n    if [[ $TRADE_COUNT -lt $MIN_PAPER_TRADES ]]; then\n        sleep 5\n    fi\ndone\n\nif [[ $TRADE_COUNT -ge $MIN_PAPER_TRADES ]]; then\n    pass \"Generated $TRADE_COUNT paper trades (target: $MIN_PAPER_TRADES)\"\nelse\n    fail \"Only generated $TRADE_COUNT paper trades (target: $MIN_PAPER_TRADES)\"\n    warn \"This may indicate no signals are being generated with real data\"\nfi\n\n# ============================================================================\n# GATE 5: Win Rate Verification\n# ============================================================================\nsection \"GATE 5: Win Rate Verification\"\n\n# Get paper trade summary\nSUMMARY=$(node -e \"\nconst fs = require('fs');\nconst path = 'output/paper_trades.db';\nif (!fs.existsSync(path)) {\n    console.log('NO_DATA');\n    process.exit(1);\n}\nconst data = JSON.parse(fs.readFileSync(path, 'utf8'));\nconst closed = data.filter(t => t.status === 'CLOSED');\nconst wins = closed.filter(t => t.outcome === 'WIN');\nconst losses = closed.filter(t => t.outcome === 'LOSS');\nconst totalPnl = closed.reduce((sum, t) => sum + (t.pnl || 0), 0);\n\nconsole.log('TOTAL:', data.length);\nconsole.log('CLOSED:', closed.length);\nconsole.log('WINS:', wins.length);\nconsole.log('LOSSES:', losses.length);\nconsole.log('WIN_RATE:', closed.length > 0 ? (wins.length / closed.length).toFixed(4) : '0');\nconsole.log('TOTAL_PNL:', totalPnl);\n\" 2>&1)\n\nif echo \"$SUMMARY\" | grep -q \"NO_DATA\"; then\n    fail \"No paper trade data available\"\nelse\n    TOTAL_TRADES=$(echo \"$SUMMARY\" | grep \"TOTAL:\" | cut -d: -f2 | tr -d ' ')\n    CLOSED_TRADES=$(echo \"$SUMMARY\" | grep \"CLOSED:\" | cut -d: -f2 | tr -d ' ')\n    WINS=$(echo \"$SUMMARY\" | grep \"WINS:\" | cut -d: -f2 | tr -d ' ')\n    LOSSES=$(echo \"$SUMMARY\" | grep \"LOSSES:\" | cut -d: -f2 | tr -d ' ')\n    WIN_RATE=$(echo \"$SUMMARY\" | grep \"WIN_RATE:\" | cut -d: -f2 | tr -d ' ')\n    TOTAL_PNL=$(echo \"$SUMMARY\" | grep \"TOTAL_PNL:\" | cut -d: -f2 | tr -d ' ')\n    \n    echo \"  Total trades: $TOTAL_TRADES\"\n    echo \"  Closed trades: $CLOSED_TRADES\"\n    echo \"  Wins: $WINS, Losses: $LOSSES\"\n    echo \"  Win rate: $(echo \"$WIN_RATE * 100\" | bc -l | xargs printf \"%.1f%%\")\"\n    echo \"  Total P&L: $(echo \"$TOTAL_PNL / 100\" | bc -l | xargs printf \"\\$%.2f\")\"\n    \n    # Check win rate threshold\n    WIN_RATE_OK=$(echo \"$WIN_RATE >= $MIN_WIN_RATE\" | bc -l)\n    if [[ $WIN_RATE_OK -eq 1 ]]; then\n        pass \"Win rate $(echo \"$WIN_RATE * 100\" | bc -l | xargs printf \"%.1f%%\") >= $(echo \"$MIN_WIN_RATE * 100\" | bc -l)%\"\n    else\n        fail \"Win rate $(echo \"$WIN_RATE * 100\" | bc -l | xargs printf \"%.1f%%\") < $(echo \"$MIN_WIN_RATE * 100\" | bc -l)%\"\n    fi\n    \n    # Check drawdown\n    DRAWDOWN_OK=$(echo \"${TOTAL_PNL#-} <= $MAX_DRAWDOWN\" | bc -l)\n    if [[ $DRAWDOWN_OK -eq 1 ]]; then\n        pass \"Drawdown within limit: $(echo \"${TOTAL_PNL#-} / 100\" | bc -l | xargs printf \"\\$%.2f\")\"\n    else\n        fail \"Drawdown exceeds limit: $(echo \"${TOTAL_PNL#-} / 100\" | bc -l | xargs printf \"\\$%.2f\")\"\n    fi\nfi\n\n# ============================================================================\n# GATE 6: Security Review\n# ============================================================================\nsection \"GATE 6: Security Review\"\n\n# Check PAPER_TRADING flag is set\nif grep -q \"PAPER_TRADING.*!==*.*false\" backend/strategies/live_runner.js; then\n    pass \"PAPER_TRADING safeguard is active\"\nelse\n    warn \"Could not verify PAPER_TRADING safeguard\"\nfi\n\n# Check for hardcoded credentials\nif grep -r \"apiKey.*=.*[\\\"'][^\\\"']\\{10,\\}[\\\"']\" backend/ --include=\"*.js\" 2>/dev/null | grep -v \"\\.test\\.\" | head -1; then\n    fail \"Potential hardcoded API key found\"\nelse\n    pass \"No hardcoded credentials detected\"\nfi\n\n# Check file permissions\nif [[ -f \"backend/strategies/live_runner.js\" && -r \"backend/strategies/live_runner.js\" ]]; then\n    pass \"Strategy files have appropriate permissions\"\nfi\n\n# ============================================================================\n# GATE 7: Monitoring Setup\n# ============================================================================\nsection \"GATE 7: Monitoring Setup\"\n\n# Check dashboard API is accessible\nDASHBOARD_TEST=$(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3200/api/health 2>/dev/null || echo \"000\")\nif [[ \"$DASHBOARD_TEST\" == \"200\" ]]; then\n    pass \"Dashboard API is accessible\"\nelse\n    warn \"Dashboard API not accessible (HTTP $DASHBOARD_TEST)\"\nfi\n\n# Check PnL endpoint\nPNL_TEST=$(curl -s http://localhost:3200/api/pnl/live 2>/dev/null | head -1 || echo \"FAIL\")\nif echo \"$PNL_TEST\" | grep -q \"win_rate\\|total_pnl\"; then\n    pass \"PnL monitoring endpoint is functional\"\nelse\n    warn \"PnL endpoint not responding correctly\"\nfi\n\n# ============================================================================\n# FINAL DECISION\n# ============================================================================\nsection \"FINAL DECISION\"\n\necho \"\"\necho \"═══════════════════════════════════════════════════════════════\"\necho \"                    GATE SUMMARY\"\necho \"═══════════════════════════════════════════════════════════════\"\necho \"  Gates Passed: $GATES_PASSED\"\necho \"  Gates Failed: $GATES_FAILED\"\necho \"  Warnings: ${#WARNINGS[@]}\"\necho \"\"\n\nif [[ $GATES_FAILED -eq 0 ]]; then\n    DECISION=\"GO\"\n    DECISION_COLOR=\"$GREEN\"\n    EXIT_CODE=0\nelif [[ $GATES_FAILED -le 2 && ${#WARNINGS[@]} -eq 0 ]]; then\n    DECISION=\"GO WITH CAUTION\"\n    DECISION_COLOR=\"$YELLOW\"\n    EXIT_CODE=0\nelse\n    DECISION=\"NO-GO\"\n    DECISION_COLOR=\"$RED\"\n    EXIT_CODE=1\nfi\n\necho -e \"${DECISION_COLOR}\"\necho \"  ██████╗ ███████╗ ██████╗██╗███████╗██╗ ██████╗ ███╗   ██╗\"\necho \"  ██╔══██╗██╔════╝██╔════╝██║██╔════╝██║██╔═══██╗████╗  ██║\"\necho \"  ██║  ██║█████╗  ██║     ██║███████╗██║██║   ██║██╔██╗ ██║\"\necho \"  ██║  ██║██╔══╝  ██║     ██║╚════██║██║██║   ██║██║╚██╗██║\"\necho \"  ██████╔╝███████╗╚██████╗██║███████║██║╚██████╔╝██║ ╚████║\"\necho \"  ╚═════╝ ╚══════╝ ╚═════╝╚═╝╚══════╝╚═╝ ╚═════╝ ╚═╝  ╚═══╝\"\necho \"\"\necho \"                    $DECISION\"\necho -e \"${NC}\"\n\n# Generate report\ncat > \"$REPORT_FILE\" << EOF\n# Live Trading Prep Report\n\n**Generated:** $(date -u +\"%Y-%m-%dT%H:%M:%SZ\")  \n**Decision:** $DECISION  \n**Exit Code:** $EXIT_CODE\n\n## Summary\n\n| Metric | Value |\n|--------|-------|\n| Gates Passed | $GATES_PASSED |\n| Gates Failed | $GATES_FAILED |\n| Warnings | ${#WARNINGS[@]} |\n\n## Gate Results\n\n### GATE 1: Environment & Dependencies\n$(if command -v node &> /dev/null; then echo \"- ✓ Node.js installed\"; else echo \"- ✗ Node.js not found\"; fi)\n\n### GATE 2: Kalshi API Credentials\n$(if [[ -n \"$KALSHI_API_KEY\" ]]; then echo \"- ✓ API key provided\"; else echo \"- ✗ API key missing\"; fi)\n\n### GATE 3: Strategy Configuration\n$(echo \"$CONFIG_CHECK\" | grep -E \"zScoreThreshold|minVolume|CANDLE_DAYS\" | sed 's/^/- /')\n\n### GATE 4: Paper Trading\n- Total trades: ${TOTAL_TRADES:-N/A}\n- Target: $MIN_PAPER_TRADES\n\n### GATE 5: Win Rate\n- Win rate: ${WIN_RATE:-N/A}\n- Target: $MIN_WIN_RATE\n- Total P&L: ${TOTAL_PNL:-N/A}¢\n\n## Errors\n\n$(if [[ ${#ERRORS[@]} -eq 0 ]]; then echo \"None\"; else printf '%s\\n' \"${ERRORS[@]}\" | sed 's/^/- /'; fi)\n\n## Warnings\n\n$(if [[ ${#WARNINGS[@]} -eq 0 ]]; then echo \"None\"; else printf '%s\\n' \"${WARNINGS[@]}\" | sed 's/^/- /'; fi)\n\n## Next Steps\n\n$(if [[ $EXIT_CODE -eq 0 ]]; then echo \"System is ready for live trading authorization. Escalate to Founder for final approval.\"; else echo \"Address failed gates before proceeding to live trading.\"; fi)\nEOF\n\necho \"Report written to: $REPORT_FILE\"\nlog \"INFO\" \"Live Trading Prep completed with decision: $DECISION\"\n\nexit $EXIT_CODE\n","numLines":475,"startLine":1,"totalLines":475}}}
