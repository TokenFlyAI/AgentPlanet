timal position sizes based on risk management rules.\n     4\t * Author: Bob (Ba
ckend Engineer)\n     5\t * Task: #220\n     6\t */\n     7\t\n     8\t"use stri
ct";\n     9\t\n    10\tclass PositionSizer {\n    11\t  constructor(options = {
}) {\n    12\t    // Account-level constraints\n    13\t    this.accountBalance 
= options.accountBalance || 500000; // cents ($5,000 default)\n    14\t    this.
maxRiskPerTrade = options.maxRiskPerTrade || 0.02; // 2% max risk per trade\n   
15\t    this.maxPositionPct = options.maxPositionPct || 0.20; // 20% max in sing
le position\n    16\t    this.minContracts = options.minContracts || 1;\n    17\
t    this.maxContracts = options.maxContracts || 1000;\n    18\t\n    19\t    //
Kelly criterion settings\n    20\t    this.useKelly = options.useKelly || false;
\n    21\t    this.kellyFraction = options.kellyFraction || 0.25; // fractional 
Kelly (quarter Kelly)\n    22\t  }\n    23\t\n    24\t  /**\n    25\t   * Calcul
ate position size for a signal.\n    26\t   * @param {Object} signal - signal wi
th confidence, expectedEdge, currentPrice, side\n    27\t   * @param {Object} ma
rket - market data with volume, openInterest\n    28\t   * @returns {Object} siz
ing result: { contracts, riskAmount, reason }\n    29\t   */\n    30\t  sizePosi
tion(signal, market = {}) {\n    31\t    const price = signal.currentPrice || 50
;\n    32\t    const edge = signal.expectedEdge || 0;\n    33\t    const confide
nce = signal.confidence || 0;\n    34\t\n    35\t    // Base risk amount: fixed 
fractional\n    36\t    const maxRiskAmount = Math.floor(this.accountBalance * t
his.maxRiskPerTrade);\n    37\t\n    38\t    // Risk per contract: if buying at 
price, max loss is price (goes to 0)\n    39\t    const riskPerContract = price;
// in cents\n    40\t\n    41\t    let contracts = 0;\n    42\t    if (riskPerCo
ntract > 0) {\n    43\t      contracts = Math.floor(maxRiskAmount / riskPerContr
act);\n    44\t    }\n    45\t\n    46\t    // Apply Kelly criterion if enabled\
n    47\t    if (this.useKelly && edge > 0 && price > 0) {\n    48\t      // Sim
plified Kelly: f* = edge / odds\n    49\t      // For binary markets, odds = pri
ce / (100 - price)\n    50\t      const winProb = confidence;\n    51\t      con
st lossProb = 1 - winProb;\n    52\t      const winAmount = 100 - price;\n    53
\t      const lossAmount = price;\n    54\t      const kelly =\n    55\t        
winProb > 0 && lossAmount > 0\n    56\t          ? (winProb / lossAmount) - (los
sProb / winAmount)\n    57\t          : 0;\n    58\t      const fractionalKelly 
= kelly * this.kellyFraction;\n    59\t      const kellyContracts = Math.floor(\
n    60\t        (this.accountBalance * fractionalKelly) / price\n    61\t      
}\n    64\t\n    65\t    // Apply confidence scaling\n    66\t    contracts = Ma
th.floor(contracts * confidence);\n    67\t\n    68\t    // Apply market liquidi
ty constraint: max 1% of daily volume\n    69\t    const volume = market.volume 
