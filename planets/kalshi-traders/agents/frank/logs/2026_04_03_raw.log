{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RX5tW4gjE8YMTfRRQGGWq5","type":"tool_result","content":"500\t    const historyMap = { m1: [{ yes_close: 50 }, { yes_close: 55 }] }; // only 2 points\n501\t    const signals = engine.detectMeanReversion(markets, historyMap);\n502\t    assert.strictEqual(signals.length, 0, \"Should skip short history\");\n503\t  });\n504\t}\n505\t\n506\t// ============================================================================\n507\t// TEST SUITE 6: PositionSizer\n508\t// ============================================================================\n509\tconsole.log(\"\\n📦 Suite 6: PositionSizer\");\n510\t\n511\tif (positionSizerModule) {\n512\t  const { PositionSizer } = positionSizerModule;\n513\t\n514\t  test(\"PositionSizer constructor sets defaults\", () => {\n515\t    const sizer = new PositionSizer();\n516\t    assert.strictEqual(sizer.accountBalance, 500000);\n517\t    assert.strictEqual(sizer.maxRiskPerTrade, 0.02);\n518\t    assert.strictEqual(sizer.minContracts, 1);\n519\t  });\n520\t\n521\t  test(\"PositionSizer.sizePosition returns valid sizing\", () => {\n522\t    const sizer = new PositionSizer({ accountBalance: 100000 });\n523\t    const signal = { currentPrice: 50, expectedEdge: 5, confidence: 0.8 };\n524\t    const result = sizer.sizePosition(signal);\n525\t    assert.ok(result.contracts >= 1, \"Should have at least 1 contract\");\n526\t    assert.ok(result.contracts <= 1000, \"Should not exceed maxContracts\");\n527\t    assert.ok(result.riskAmount > 0, \"Risk amount should be positive\");\n528\t    assert.ok(result.reason, \"Should include reason\");\n529\t  });\n530\t\n531\t  test(\"PositionSizer scales by confidence\", () => {\n532\t    const sizer = new PositionSizer({ accountBalance: 100000 });\n533\t    const highConf = sizer.sizePosition({ currentPrice: 50, expectedEdge: 5, confidence: 0.9 });\n534\t    const lowConf = sizer.sizePosition({ currentPrice: 50, expectedEdge: 5, confidence: 0.3 });\n535\t    assert.ok(highConf.contracts >= lowConf.contracts, \"Higher confidence should give more contracts\");\n536\t  });\n537\t\n538\t  test(\"PositionSizer respects liquidity cap\", () => {\n539\t    const sizer = new PositionSizer({ accountBalance: 10000000 }); // large account\n540\t    const signal = { currentPrice: 10, expectedEdge: 5, confidence: 0.9 };\n541\t    const market = { volume: 100 }; // very low volume\n542\t    const result = sizer.sizePosition(signal, market);\n543\t    // 1% of 100 volume = 1 contract cap\n544\t    assert.ok(result.contracts <= 1, `Contracts ${result.contracts} should respect liquidity cap`);\n545\t  });\n546\t\n547\t  test(\"PositionSizer.sizeSignals adds sizing to all signals\", () => {\n548\t    const sizer = new PositionSizer({ accountBalance: 100000 });\n549\t    const signals = [\n550\t      { marketId: \"m1\", currentPrice: 50, expectedEdge: 5, confidence: 0.8 },\n551\t      { marketId: \"m2\", currentPrice: 30, expectedEdge: 10, confidence: 0.6 },\n552\t    ];\n553\t    const result = sizer.sizeSignals(signals);\n554\t    assert.strictEqual(result.length, 2);\n555\t    assert.ok(result[0].sizing, \"First signal missing sizing\");\n556\t    assert.ok(result[1].sizing, \"Second signal missing sizing\");\n557\t    assert.ok(result[0].sizing.contracts >= 1);\n558\t    assert.ok(result[1].sizing.contracts >= 1);\n559\t  });\n560\t\n561\t  test(\"PositionSizer.setAccountBalance updates balance\", () => {\n562\t    const sizer = new PositionSizer({ accountBalance: 100000 });\n563\t    sizer.setAccountBalance(200000);\n564\t    assert.strictEqual(sizer.accountBalance, 200000);\n565\t  });\n566\t\n567\t  test(\"PositionSizer enforces minContracts\", () => {\n568\t    const sizer = new PositionSizer({ accountBalance: 100, minContracts: 5 });\n569\t    const signal = { currentPrice: 99, expectedEdge: 1, confidence: 0.01 }; // tiny position\n570\t    const result = sizer.sizePosition(signal);\n571\t    assert.ok(result.contracts >= 5, \"Should enforce minContracts\");\n572\t  });\n573\t}\n574\t\n575\t// ============================================================================\n576\t// TEST SUITE 7: MeanReversionStrategy\n577\t// ============================================================================\n578\tconsole.log(\"\\n📦 Suite 7: MeanReversionStrategy\");\n579\t\n580\tif (meanReversionModule) {\n581\t  const { MeanReversionStrategy } = meanReversionModule;\n582\t\n583\t  test(\"MeanReversionStrategy constructor sets defaults\", () => {\n584\t    const strat = new MeanReversionStrategy();\n585\t    assert.strictEqual(strat.zScoreThreshold, 1.5);\n586\t    assert.strictEqual(strat.minVolume, 10000);\n587\t  });\n588\t\n589\t  test(\"MeanReversionStrategy generates signal for high z-score\", () => {\n590\t    const strat = new MeanReversionStrategy({ zScoreThreshold: 1.2 });\n591\t    const market = {\n592\t      id: \"m1\", yes_mid: 80, no_mid: 20, volume: 50000,\n593\t      price_history_mean: 50, price_history_stddev: 10,\n594\t    };\n595\t    const signal = strat.generateSignal(market);\n596\t    assert.ok(signal, \"Should generate signal\");\n597\t    assert.strictEqual(signal.side, \"no\", \"High z-score → sell (revert down)\");\n598\t    assert.ok(signal.confidence > 0 && signal.confidence <= 0.95, \"Confidence in range\");\n599\t  });\n600\t\n601\t  test(\"MeanReversionStrategy generates signal for low z-score\", () => {\n602\t    const strat = new MeanReversionStrategy({ zScoreThreshold: 1.2 });\n603\t    const market = {\n604\t      id: \"m1\", yes_mid: 20, no_mid: 80, volume: 50000,\n605\t      price_history_mean: 50, price_history_stddev: 10,\n606\t    };\n607\t    const signal = strat.generateSignal(market);\n608\t    assert.ok(signal, \"Should generate signal\");\n609\t    assert.strictEqual(signal.side, \"yes\", \"Low z-score → buy (revert up)\");\n610\t  });\n611\t\n612\t  test(\"MeanReversionStrategy returns null for normal z-score\", () => {\n613\t    const strat = new MeanReversionStrategy({ zScoreThreshold: 1.5 });\n614\t    const market = {\n615\t      id: \"m1\", yes_mid: 52, no_mid: 48, volume: 50000,\n616\t      price_history_mean: 50, price_history_stddev: 10,\n617\t    };\n618\t    const signal = strat.generateSignal(market);\n619\t    assert.strictEqual(signal, null, \"Should not generate signal for normal z-score\");\n620\t  });\n621\t\n622\t  test(\"MeanReversionStrategy returns null for low volume\", () => {\n623\t    const strat = new MeanReversionStrategy({ minVolume: 10000 });\n624\t    const market = {\n625\t      id: \"m1\", yes_mid: 80, no_mid: 20, volume: 500,\n626\t      price_history_mean: 50, price_history_stddev: 10,\n627\t    };\n628\t    const signal = strat.generateSignal(market);\n629\t    assert.strictEqual(signal, null, \"Should skip low-volume markets\");\n630\t  });\n631\t\n632\t  test(\"MeanReversionStrategy uses fallback stddev=10 when stddev is 0 (falsy)\", () => {\n633\t    // stddev=0 is falsy, so `|| 10` fallback applies → signal may still generate\n634\t    const strat = new MeanReversionStrategy({ zScoreThreshold: 1.2 });\n635\t    const market = {\n636\t      id: \"m1\", yes_mid: 80, no_mid: 20, volume: 50000,\n637\t      price_history_mean: 50, price_history_stddev: 0,\n638\t    };\n639\t    const signal = strat.generateSignal(market);\n640\t    // With fallback stddev=10, z-score = (80-50)/10 = 3.0 → signal generated\n641\t    assert.ok(signal, \"Should generate signal using fallback stddev\");\n642\t  });\n643\t\n644\t  test(\"MeanReversionStrategy confidence is capped at 0.95\", () => {\n645\t    const strat = new MeanReversionStrategy({ zScoreThreshold: 0.1 });\n646\t    const market = {\n647\t      id: \"m1\", yes_mid: 99, no_mid: 1, volume: 50000,\n648\t      price_history_mean: 50, price_history_stddev: 5,\n649\t    };\n650\t    const signal = strat.generateSignal(market);\n651\t    assert.ok(signal, \"Should generate signal\");\n652\t    assert.ok(signal.confidence <= 0.95, `Confidence ${signal.confidence} exceeds 0.95 cap`);\n653\t  });\n654\t}\n655\t\n656\t// ============================================================================\n657\t// TEST SUITE 8: RiskManager (no DB)\n658\t// ============================================================================\n659\tconsole.log(\"\\n📦 Suite 8: RiskManager (in-memory mode)\");\n660\t\n661\tif (riskManagerModule) {\n662\t  const { RiskManager, validateTrade, RISK_LIMITS } = riskManagerModule;\n663\t\n664\t  test(\"RISK_LIMITS has expected default values\", () => {\n665\t    assert.ok(RISK_LIMITS.maxDailyLoss > 0, \"maxDailyLoss should be positive\");\n666\t    assert.ok(RISK_LIMITS.maxPositionSize > 0, \"maxPositionSize should be positive\");\n667\t    assert.ok(RISK_LIMITS.maxTotalExposure > 0, \"maxTotalExposure should be positive\");\n668\t    assert.ok(RISK_LIMITS.maxDrawdown > 0 && RISK_LIMITS.maxDrawdown <= 1, \"maxDrawdown range\");\n669\t  });\n670\t\n671\t  testAsync(\"validateTrade approves valid small trade (no DB = daily PnL check uses undefined)\", async () => {\n672\t    const trade = {\n673\t      marketTicker: \"TEST-MKT\",\n674\t      side: \"YES\",\n675\t      quantity: 5,\n676\t      price: 50,\n677\t    };\n678\t    const result = await validateTrade(trade);\n679\t    // NOTE: Without DB, getTodayPnL returns { realized: 0, unrealized: 0 } (no .total),\n680\t    // so pnl.total is undefined, and `undefined > -50000` is false → daily loss check fails.\n681\t    // This is a known limitation when running without Postgres.\n682\t    // We verify the structure is correct regardless:\n683\t    assert.ok(typeof result.approved === \"boolean\", \"approved should be boolean\");\n684\t    assert.ok(Array.isArray(result.reasons), \"reasons should be array\");\n685\t    assert.ok(typeof result.riskScore === \"number\", \"riskScore should be number\");\n686\t    assert.ok(result.checks.length >= 3, \"Should have at least 3 risk checks\");\n687\t  });\n688\t\n689\t  testAsync(\"validateTrade rejects oversized position\", async () => {\n690\t    const trade = {\n691\t      marketTicker: \"TEST-MKT\",\n692\t      side: \"YES\",\n693\t      quantity: RISK_LIMITS.maxPositionSize + 100,\n694\t      price: 50,\n695\t    };\n696\t    const result = await validateTrade(trade);\n697\t    assert.strictEqual(result.approved, false, \"Should reject oversized position\");\n698\t    assert.ok(result.reasons.some((r) => r.includes(\"Position size\")), \"Should cite position size\");\n699\t  });\n700\t\n701\t  testAsync(\"RiskManager.filterSignals returns approved and rejected arrays\", async () => {\n702\t    const rm = new RiskManager();\n703\t    const signals = [\n704\t      { marketId: \"m1\", side: \"yes\", currentPrice: 50, recommendedContracts: 5, confidence: 0.8 },\n705\t      { marketId: \"m2\", side: \"no\", currentPrice: 30, recommendedContracts: 3, confidence: 0.6 },\n706\t    ];\n707\t    const result = await rm.filterSignals(signals);\n708\t    assert.ok(Array.isArray(result.approved), \"Missing approved array\");\n709\t    assert.ok(Array.isArray(result.rejected), \"Missing rejected array\");\n710\t    assert.ok(result.context, \"Missing context object\");\n711\t    assert.strictEqual(\n712\t      result.approved.length + result.rejected.length,\n713\t      signals.length,\n714\t      \"All signals should be accounted for\"\n715\t    );\n716\t  });\n717\t}\n718\t\n719\t// ============================================================================\n720\t// TEST SUITE 9: End-to-End Pipeline\n721\t// ============================================================================\n722\tconsole.log(\"\\n📦 Suite 9: End-to-End Pipeline Integration\");\n723\t\n724\tif (pipeline) {\n725\t  testAsync(\"Full pipeline runs end-to-end without errors\", async () => {\n726\t    const result = await pipeline.main();\n727\t    assert.ok(result.phase1, \"Missing phase1 result\");\n728\t    assert.ok(result.phase2, \"Missing phase2 result\");\n729\t    assert.ok(result.phase3, \"Missing phase3 result\");\n730\t    assert.ok(result.phase4, \"Missing phase4 result\");\n731\t    assert.ok(result.duration >= 0, \"Duration should be non-negative\");\n732\t  });\n733\t\n734\t  testAsync(\"Full pipeline produces output files\", async () => {\n735\t    await pipeline.main();\n736\t    // Check that output files were written (they use relative paths from bob/output)\n737\t    const publicDir = path.join(BOB_OUTPUT, \"../../../public\");\n738\t    const outputDir = path.join(BOB_OUTPUT, \"../../../output\");\n739\t\n740\t    const marketsFile = path.join(publicDir, \"markets_filtered.json\");\n741\t    const clustersFile = path.join(publicDir, \"market_clusters.json\");\n742\t    const correlationFile = path.join(publicDir, \"correlation_pairs.json\");\n743\t\n744\t    assert.ok(fs.existsSync(marketsFile), \"markets_filtered.json not written\");\n745\t    assert.ok(fs.existsSync(clustersFile), \"market_clusters.json not written\");\n746\t    assert.ok(fs.existsSync(correlationFile), \"correlation_pairs.json not written\");\n747\t\n748\t    // Validate JSON is parseable\n749\t    const markets = JSON.parse(fs.readFileSync(marketsFile, \"utf8\"));\n750\t    assert.ok(markets.phase === 1, \"markets_filtered.json should be phase 1\");\n751\t\n752\t    const clusters = JSON.parse(fs.readFileSync(clustersFile, \"utf8\"));\n753\t    assert.ok(clusters.phase === 2, \"market_clusters.json should be phase 2\");\n754\t\n755\t    const corr = JSON.parse(fs.readFileSync(correlationFile, \"utf8\"));\n756\t    assert.ok(corr.phase === 3, \"correlation_pairs.json should be phase 3\");\n757\t  });\n758\t\n759\t  test(\"Pipeline phases are deterministic (same output on repeated runs)\", () => {\n760\t    const run1 = pipeline.runPhase1_MarketFilter();\n761\t    const run2 = pipeline.runPhase1_MarketFilter();\n762\t    assert.strictEqual(run1.qualifying_markets.length, run2.qualifying_markets.length, \"Phase 1 not deterministic\");\n763\t\n764\t    const p2a = pipeline.runPhase2_Clustering(run1);\n765\t    const p2b = pipeline.runPhase2_Clustering(run2);\n766\t    assert.strictEqual(p2a.clusters.length, p2b.clusters.length, \"Phase 2 not deterministic\");\n767\t  });\n768\t}\n769\t\n770\t// ============================================================================\n771\t// Run all async tests and report\n772\t// ============================================================================\n773\tasync function runAll() {\n774\t  // Wait for any pending async tests\n775\t  await new Promise((resolve) => setTimeout(resolve, 500));\n776\t\n777\t  console.log(\"\\n\" + \"=\".repeat(60));\n778\t  console.log(`TEST RESULTS: ${passedTests}/${totalTests} passed, ${failedTests} failed`);\n779\t  console.log(\"=\".repeat(60));\n780\t\n781\t  if (failures.length > 0) {\n782\t    console.log(\"\\nFailed tests:\");\n783\t    for (const f of failures) {\n784\t      console.log(`  ❌ ${f.name}: ${f.error}`);\n785\t    }\n786\t  }\n787\t\n788\t  // Write results to output file\n789\t  const resultFile = path.join(__dirname, \"d004_test_results.json\");\n790\t  const results = {\n791\t    generated_at: new Date().toISOString(),\n792\t    task: \"T548\",\n793\t    author: \"frank\",\n794\t    total: totalTests,\n795\t    passed: passedTests,\n796\t    failed: failedTests,\n797\t    failures,\n798\t  };\n799\t  fs.writeFileSync(resultFile, JSON.stringify(results, null, 2));\n800\t  console.log(`\\nResults saved to: ${resultFile}`);\n801\t\n802\t  if (failedTests > 0) {\n803\t    process.exit(1);\n804\t  }\n805\t}\n806\t\n807\trunAll();\n808\t"}]},"parent_tool_use_id":null,"session_id":"855ad91b-f6c8-4ef0-b5d0-8e5805f4c92a","uuid":"3bf7d506-4877-47f1-8947-f5361940d669","timestamp":"2026-04-04T06:10:09.877Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/chenyangcui/Documents/code/aicompany/planets/kalshi-traders/agents/frank/output/d004_pipeline_tests.js","content":"    const historyMap = { m1: [{ yes_close: 50 }, { yes_close: 55 }] }; // only 2 points\n    const signals = engine.detectMeanReversion(markets, historyMap);\n    assert.strictEqual(signals.length, 0, \"Should skip short history\");\n  });\n}\n\n// ============================================================================\n// TEST SUITE 6: PositionSizer\n// ============================================================================\nconsole.log(\"\\n📦 Suite 6: PositionSizer\");\n\nif (positionSizerModule) {\n  const { PositionSizer } = positionSizerModule;\n\n  test(\"PositionSizer constructor sets defaults\", () => {\n    const sizer = new PositionSizer();\n    assert.strictEqual(sizer.accountBalance, 500000);\n    assert.strictEqual(sizer.maxRiskPerTrade, 0.02);\n    assert.strictEqual(sizer.minContracts, 1);\n  });\n\n  test(\"PositionSizer.sizePosition returns valid sizing\", () => {\n    const sizer = new PositionSizer({ accountBalance: 100000 });\n    const signal = { currentPrice: 50, expectedEdge: 5, confidence: 0.8 };\n    const result = sizer.sizePosition(signal);\n    assert.ok(result.contracts >= 1, \"Should have at least 1 contract\");\n    assert.ok(result.contracts <= 1000, \"Should not exceed maxContracts\");\n    assert.ok(result.riskAmount > 0, \"Risk amount should be positive\");\n    assert.ok(result.reason, \"Should include reason\");\n  });\n\n  test(\"PositionSizer scales by confidence\", () => {\n    const sizer = new PositionSizer({ accountBalance: 100000 });\n    const highConf = sizer.sizePosition({ currentPrice: 50, expectedEdge: 5, confidence: 0.9 });\n    const lowConf = sizer.sizePosition({ currentPrice: 50, expectedEdge: 5, confidence: 0.3 });\n    assert.ok(highConf.contracts >= lowConf.contracts, \"Higher confidence should give more contracts\");\n  });\n\n  test(\"PositionSizer respects liquidity cap\", () => {\n    const sizer = new PositionSizer({ accountBalance: 10000000 }); // large account\n    const signal = { currentPrice: 10, expectedEdge: 5, confidence: 0.9 };\n    const market = { volume: 100 }; // very low volume\n    const result = sizer.sizePosition(signal, market);\n    // 1% of 100 volume = 1 contract cap\n    assert.ok(result.contracts <= 1, `Contracts ${result.contracts} should respect liquidity cap`);\n  });\n\n  test(\"PositionSizer.sizeSignals adds sizing to all signals\", () => {\n    const sizer = new PositionSizer({ accountBalance: 100000 });\n    const signals = [\n      { marketId: \"m1\", currentPrice: 50, expectedEdge: 5, confidence: 0.8 },\n      { marketId: \"m2\", currentPrice: 30, expectedEdge: 10, confidence: 0.6 },\n    ];\n    const result = sizer.sizeSignals(signals);\n    assert.strictEqual(result.length, 2);\n    assert.ok(result[0].sizing, \"First signal missing sizing\");\n    assert.ok(result[1].sizing, \"Second signal missing sizing\");\n    assert.ok(result[0].sizing.contracts >= 1);\n    assert.ok(result[1].sizing.contracts >= 1);\n  });\n\n  test(\"PositionSizer.setAccountBalance updates balance\", () => {\n    const sizer = new PositionSizer({ accountBalance: 100000 });\n    sizer.setAccountBalance(200000);\n    assert.strictEqual(sizer.accountBalance, 200000);\n  });\n\n  test(\"PositionSizer enforces minContracts\", () => {\n    const sizer = new PositionSizer({ accountBalance: 100, minContracts: 5 });\n    const signal = { currentPrice: 99, expectedEdge: 1, confidence: 0.01 }; // tiny position\n    const result = sizer.sizePosition(signal);\n    assert.ok(result.contracts >= 5, \"Should enforce minContracts\");\n  });\n}\n\n// ============================================================================\n// TEST SUITE 7: MeanReversionStrategy\n// ============================================================================\nconsole.log(\"\\n📦 Suite 7: MeanReversionStrategy\");\n\nif (meanReversionModule) {\n  const { MeanReversionStrategy } = meanReversionModule;\n\n  test(\"MeanReversionStrategy constructor sets defaults\", () => {\n    const strat = new MeanReversionStrategy();\n    assert.strictEqual(strat.zScoreThreshold, 1.5);\n    assert.strictEqual(strat.minVolume, 10000);\n  });\n\n  test(\"MeanReversionStrategy generates signal for high z-score\", () => {\n    const strat = new MeanReversionStrategy({ zScoreThreshold: 1.2 });\n    const market = {\n      id: \"m1\", yes_mid: 80, no_mid: 20, volume: 50000,\n      price_history_mean: 50, price_history_stddev: 10,\n    };\n    const signal = strat.generateSignal(market);\n    assert.ok(signal, \"Should generate signal\");\n    assert.strictEqual(signal.side, \"no\", \"High z-score → sell (revert down)\");\n    assert.ok(signal.confidence > 0 && signal.confidence <= 0.95, \"Confidence in range\");\n  });\n\n  test(\"MeanReversionStrategy generates signal for low z-score\", () => {\n    const strat = new MeanReversionStrategy({ zScoreThreshold: 1.2 });\n    const market = {\n      id: \"m1\", yes_mid: 20, no_mid: 80, volume: 50000,\n      price_history_mean: 50, price_history_stddev: 10,\n    };\n    const signal = strat.generateSignal(market);\n    assert.ok(signal, \"Should generate signal\");\n    assert.strictEqual(signal.side, \"yes\", \"Low z-score → buy (revert up)\");\n  });\n\n  test(\"MeanReversionStrategy returns null for normal z-score\", () => {\n    const strat = new MeanReversionStrategy({ zScoreThreshold: 1.5 });\n    const market = {\n      id: \"m1\", yes_mid: 52, no_mid: 48, volume: 50000,\n      price_history_mean: 50, price_history_stddev: 10,\n    };\n    const signal = strat.generateSignal(market);\n    assert.strictEqual(signal, null, \"Should not generate signal for normal z-score\");\n  });\n\n  test(\"MeanReversionStrategy returns null for low volume\", () => {\n    const strat = new MeanReversionStrategy({ minVolume: 10000 });\n    const market = {\n      id: \"m1\", yes_mid: 80, no_mid: 20, volume: 500,\n      price_history_mean: 50, price_history_stddev: 10,\n    };\n    const signal = strat.generateSignal(market);\n    assert.strictEqual(signal, null, \"Should skip low-volume markets\");\n  });\n\n  test(\"MeanReversionStrategy uses fallback stddev=10 when stddev is 0 (falsy)\", () => {\n    // stddev=0 is falsy, so `|| 10` fallback applies → signal may still generate\n    const strat = new MeanReversionStrategy({ zScoreThreshold: 1.2 });\n    const market = {\n      id: \"m1\", yes_mid: 80, no_mid: 20, volume: 50000,\n      price_history_mean: 50, price_history_stddev: 0,\n    };\n    const signal = strat.generateSignal(market);\n    // With fallback stddev=10, z-score = (80-50)/10 = 3.0 → signal generated\n    assert.ok(signal, \"Should generate signal using fallback stddev\");\n  });\n\n  test(\"MeanReversionStrategy confidence is capped at 0.95\", () => {\n    const strat = new MeanReversionStrategy({ zScoreThreshold: 0.1 });\n    const market = {\n      id: \"m1\", yes_mid: 99, no_mid: 1, volume: 50000,\n      price_history_mean: 50, price_history_stddev: 5,\n    };\n    const signal = strat.generateSignal(market);\n    assert.ok(signal, \"Should generate signal\");\n    assert.ok(signal.confidence <= 0.95, `Confidence ${signal.confidence} exceeds 0.95 cap`);\n  });\n}\n\n// ============================================================================\n// TEST SUITE 8: RiskManager (no DB)\n// ============================================================================\nconsole.log(\"\\n📦 Suite 8: RiskManager (in-memory mode)\");\n\nif (riskManagerModule) {\n  const { RiskManager, validateTrade, RISK_LIMITS } = riskManagerModule;\n\n  test(\"RISK_LIMITS has expected default values\", () => {\n    assert.ok(RISK_LIMITS.maxDailyLoss > 0, \"maxDailyLoss should be positive\");\n    assert.ok(RISK_LIMITS.maxPositionSize > 0, \"maxPositionSize should be positive\");\n    assert.ok(RISK_LIMITS.maxTotalExposure > 0, \"maxTotalExposure should be positive\");\n    assert.ok(RISK_LIMITS.maxDrawdown > 0 && RISK_LIMITS.maxDrawdown <= 1, \"maxDrawdown range\");\n  });\n\n  testAsync(\"validateTrade approves valid small trade (no DB = daily PnL check uses undefined)\", async () => {\n    const trade = {\n      marketTicker: \"TEST-MKT\",\n      side: \"YES\",\n      quantity: 5,\n      price: 50,\n    };\n    const result = await validateTrade(trade);\n    // NOTE: Without DB, getTodayPnL returns { realized: 0, unrealized: 0 } (no .total),\n    // so pnl.total is undefined, and `undefined > -50000` is false → daily loss check fails.\n    // This is a known limitation when running without Postgres.\n    // We verify the structure is correct regardless:\n    assert.ok(typeof result.approved === \"boolean\", \"approved should be boolean\");\n    assert.ok(Array.isArray(result.reasons), \"reasons should be array\");\n    assert.ok(typeof result.riskScore === \"number\", \"riskScore should be number\");\n    assert.ok(result.checks.length >= 3, \"Should have at least 3 risk checks\");\n  });\n\n  testAsync(\"validateTrade rejects oversized position\", async () => {\n    const trade = {\n      marketTicker: \"TEST-MKT\",\n      side: \"YES\",\n      quantity: RISK_LIMITS.maxPositionSize + 100,\n      price: 50,\n    };\n    const result = await validateTrade(trade);\n    assert.strictEqual(result.approved, false, \"Should reject oversized position\");\n    assert.ok(result.reasons.some((r) => r.includes(\"Position size\")), \"Should cite position size\");\n  });\n\n  testAsync(\"RiskManager.filterSignals returns approved and rejected arrays\", async () => {\n    const rm = new RiskManager();\n    const signals = [\n      { marketId: \"m1\", side: \"yes\", currentPrice: 50, recommendedContracts: 5, confidence: 0.8 },\n      { marketId: \"m2\", side: \"no\", currentPrice: 30, recommendedContracts: 3, confidence: 0.6 },\n    ];\n    const result = await rm.filterSignals(signals);\n    assert.ok(Array.isArray(result.approved), \"Missing approved array\");\n    assert.ok(Array.isArray(result.rejected), \"Missing rejected array\");\n    assert.ok(result.context, \"Missing context object\");\n    assert.strictEqual(\n      result.approved.length + result.rejected.length,\n      signals.length,\n      \"All signals should be accounted for\"\n    );\n  });\n}\n\n// ============================================================================\n// TEST SUITE 9: End-to-End Pipeline\n// ============================================================================\nconsole.log(\"\\n📦 Suite 9: End-to-End Pipeline Integration\");\n\nif (pipeline) {\n  testAsync(\"Full pipeline runs end-to-end without errors\", async () => {\n    const result = await pipeline.main();\n    assert.ok(result.phase1, \"Missing phase1 result\");\n    assert.ok(result.phase2, \"Missing phase2 result\");\n    assert.ok(result.phase3, \"Missing phase3 result\");\n    assert.ok(result.phase4, \"Missing phase4 result\");\n    assert.ok(result.duration >= 0, \"Duration should be non-negative\");\n  });\n\n  testAsync(\"Full pipeline produces output files\", async () => {\n    await pipeline.main();\n    // Check that output files were written (they use relative paths from bob/output)\n    const publicDir = path.join(BOB_OUTPUT, \"../../../public\");\n    const outputDir = path.join(BOB_OUTPUT, \"../../../output\");\n\n    const marketsFile = path.join(publicDir, \"markets_filtered.json\");\n    const clustersFile = path.join(publicDir, \"market_clusters.json\");\n    const correlationFile = path.join(publicDir, \"correlation_pairs.json\");\n\n    assert.ok(fs.existsSync(marketsFile), \"markets_filtered.json not written\");\n    assert.ok(fs.existsSync(clustersFile), \"market_clusters.json not written\");\n    assert.ok(fs.existsSync(correlationFile), \"correlation_pairs.json not written\");\n\n    // Validate JSON is parseable\n    const markets = JSON.parse(fs.readFileSync(marketsFile, \"utf8\"));\n    assert.ok(markets.phase === 1, \"markets_filtered.json should be phase 1\");\n\n    const clusters = JSON.parse(fs.readFileSync(clustersFile, \"utf8\"));\n    assert.ok(clusters.phase === 2, \"market_clusters.json should be phase 2\");\n\n    const corr = JSON.parse(fs.readFileSync(correlationFile, \"utf8\"));\n    assert.ok(corr.phase === 3, \"correlation_pairs.json should be phase 3\");\n  });\n\n  test(\"Pipeline phases are deterministic (same output on repeated runs)\", () => {\n    const run1 = pipeline.runPhase1_MarketFilter();\n    const run2 = pipeline.runPhase1_MarketFilter();\n    assert.strictEqual(run1.qualifying_markets.length, run2.qualifying_markets.length, \"Phase 1 not deterministic\");\n\n    const p2a = pipeline.runPhase2_Clustering(run1);\n    const p2b = pipeline.runPhase2_Clustering(run2);\n    assert.strictEqual(p2a.clusters.length, p2b.clusters.length, \"Phase 2 not deterministic\");\n  });\n}\n\n// ============================================================================\n// Run all async tests and report\n// ============================================================================\nasync function runAll() {\n  // Wait for any pending async tests\n  await new Promise((resolve) => setTimeout(resolve, 500));\n\n  console.log(\"\\n\" + \"=\".repeat(60));\n  console.log(`TEST RESULTS: ${passedTests}/${totalTests} passed, ${failedTests} failed`);\n  console.log(\"=\".repeat(60));\n\n  if (failures.length > 0) {\n    console.log(\"\\nFailed tests:\");\n    for (const f of failures) {\n      console.log(`  ❌ ${f.name}: ${f.error}`);\n    }\n  }\n\n  // Write results to output file\n  const resultFile = path.join(__dirname, \"d004_test_results.json\");\n  const results = {\n    generated_at: new Date().toISOString(),\n    task: \"T548\",\n    author: \"frank\",\n    total: totalTests,\n    passed: passedTests,\n    failed: failedTests,\n    failures,\n  };\n  fs.writeFileSync(resultFile, JSON.stringify(results, null, 2));\n  console.log(`\\nResults saved to: ${resultFile}`);\n\n  if (failedTests > 0) {\n    process.exit(1);\n  }\n}\n\nrunAll();\n","numLines":309,"startLine":500,"totalLines":808}}}
