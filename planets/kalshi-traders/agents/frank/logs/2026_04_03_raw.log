{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V5QjyQP5JiLFdkgof7UVNj","type":"tool_result","content":"1\t/**\n2\t * Unit Tests — MeanReversionStrategy\n3\t * Task: #279\n4\t * Author: Frank (QA Engineer)\n5\t * Coverage: z-score calculation, signal generation, confidence threshold enforcement\n6\t *\n7\t * Run: node agents/frank/output/mean_reversion_test.js\n8\t */\n9\t\n10\t\"use strict\";\n11\t\n12\tconst { MeanReversionStrategy } = require(\"../../bob/backend/strategies/strategies/mean_reversion\");\n13\t\n14\tlet passed = 0;\n15\tlet failed = 0;\n16\t\n17\tfunction assert(description, condition) {\n18\t  if (condition) {\n19\t    console.log(`  ✓ ${description}`);\n20\t    passed++;\n21\t  } else {\n22\t    console.error(`  ✗ FAIL: ${description}`);\n23\t    failed++;\n24\t  }\n25\t}\n26\t\n27\tfunction assertClose(description, actual, expected, tolerance = 0.001) {\n28\t  const ok = Math.abs(actual - expected) <= tolerance;\n29\t  if (ok) {\n30\t    console.log(`  ✓ ${description} (${actual.toFixed(4)})`);\n31\t    passed++;\n32\t  } else {\n33\t    console.error(`  ✗ FAIL: ${description} — expected ${expected}, got ${actual}`);\n34\t    failed++;\n35\t  }\n36\t}\n37\t\n38\t// ---------------------------------------------------------------------------\n39\t// Helpers\n40\t// ---------------------------------------------------------------------------\n41\t\n42\tfunction makeMarket(overrides = {}) {\n43\t  return Object.assign(\n44\t    {\n45\t      id: \"mkt-1\",\n46\t      yes_mid: 50,\n47\t      no_mid: 50,\n48\t      volume: 20000,\n49\t      price_history_mean: 50,\n50\t      price_history_stddev: 10,\n51\t    },\n52\t    overrides\n53\t  );\n54\t}\n55\t\n56\t// ---------------------------------------------------------------------------\n57\t// Suite 1: Constructor defaults\n58\t// ---------------------------------------------------------------------------\n59\tconsole.log(\"\\n=== Suite 1: Constructor defaults ===\");\n60\t{\n61\t  const s = new MeanReversionStrategy();\n62\t  assert(\"default lookbackPeriods = 10\", s.lookbackPeriods === 10);\n63\t  assert(\"default zScoreThreshold = 1.5\", s.zScoreThreshold === 1.5);\n64\t  assert(\"default minVolume = 10000\", s.minVolume === 10000);\n65\t\n66\t  const custom = new MeanReversionStrategy({ lookbackPeriods: 20, zScoreThreshold: 2.0, minVolume: 5000 });\n67\t  assert(\"custom lookbackPeriods = 20\", custom.lookbackPeriods === 20);\n68\t  assert(\"custom zScoreThreshold = 2.0\", custom.zScoreThreshold === 2.0);\n69\t  assert(\"custom minVolume = 5000\", custom.minVolume === 5000);\n70\t}\n71\t\n72\t// ---------------------------------------------------------------------------\n73\t// Suite 2: Volume filter\n74\t// ---------------------------------------------------------------------------\n75\tconsole.log(\"\\n=== Suite 2: Volume filter ===\");\n76\t{\n77\t  const s = new MeanReversionStrategy();\n78\t\n79\t  const mktLowVol = makeMarket({ yes_mid: 75, volume: 5000 }); // z = (75-50)/10 = 2.5, but vol < 10000\n80\t  assert(\"returns null when volume < minVolume\", s.generateSignal(mktLowVol) === null);\n81\t\n82\t  const mktZeroVol = makeMarket({ yes_mid: 80, volume: 0 });\n83\t  assert(\"returns null when volume = 0\", s.generateSignal(mktZeroVol) === null);\n84\t\n85\t  const mktExactVol = makeMarket({ yes_mid: 75, volume: 10000 }); // exactly at threshold → should pass\n86\t  assert(\"generates signal when volume == minVolume\", s.generateSignal(mktExactVol) !== null);\n87\t}\n88\t\n89\t// ---------------------------------------------------------------------------\n90\t// Suite 3: z-score threshold gate\n91\t// ---------------------------------------------------------------------------\n92\tconsole.log(\"\\n=== Suite 3: z-score threshold gate ===\");\n93\t{\n94\t  const s = new MeanReversionStrategy(); // threshold = 1.5\n95\t\n96\t  // z = (65 - 50) / 10 = 1.5 — exactly at threshold → signal IS generated (gate is strict <, so == passes)\n97\t  const mktAtThreshold = makeMarket({ yes_mid: 65 });\n98\t  assert(\"generates signal when |z-score| == threshold (gate is strict <)\", s.generateSignal(mktAtThreshold) !== null);\n99\t\n100\t  // z = (65.1 - 50) / 10 = 1.51 — just above threshold\n101\t  const mktJustAbove = makeMarket({ yes_mid: 65.1 });\n102\t  assert(\"generates signal when |z-score| just above threshold\", s.generateSignal(mktJustAbove) !== null);\n103\t\n104\t  // z = (40 - 50) / 10 = -1.0 — below threshold\n105\t  const mktBelow = makeMarket({ yes_mid: 40 });\n106\t  assert(\"returns null when |z-score| < threshold (negative side)\", s.generateSignal(mktBelow) === null);\n107\t\n108\t  // zero stddev guard\n109\t  const mktZeroStd = makeMarket({ price_history_stddev: 0 });\n110\t  assert(\"returns null when stddev = 0 (division guard)\", s.generateSignal(mktZeroStd) === null);\n111\t\n112\t  // negative stddev guard\n113\t  const mktNegStd = makeMarket({ price_history_stddev: -5 });\n114\t  assert(\"returns null when stddev < 0\", s.generateSignal(mktNegStd) === null);\n115\t}\n116\t\n117\t// ---------------------------------------------------------------------------\n118\t// Suite 4: z-score calculation correctness\n119\t// ---------------------------------------------------------------------------\n120\tconsole.log(\"\\n=== Suite 4: z-score calculation ===\");\n121\t{\n122\t  const s = new MeanReversionStrategy();\n123\t\n124\t  // Overbought: yesPrice=80, mean=50, std=10 → z = 3.0\n125\t  const mktHigh = makeMarket({ yes_mid: 80, price_history_mean: 50, price_history_stddev: 10 });\n126\t  const sigHigh = s.generateSignal(mktHigh);\n127\t  assert(\"signal generated for overbought market (z=3)\", sigHigh !== null);\n128\t  assert(\"z=3 reason string contains z-score=3.00\", sigHigh.reason.includes(\"z-score=3.00\"));\n129\t\n130\t  // Oversold: yesPrice=20, mean=50, std=10 → z = -3.0\n131\t  const mktLow = makeMarket({ yes_mid: 20 });\n132\t  const sigLow = s.generateSignal(mktLow);\n133\t  assert(\"signal generated for oversold market (z=-3)\", sigLow !== null);\n134\t  assert(\"z=-3 reason string contains z-score=-3.00\", sigLow.reason.includes(\"z-score=-3.00\"));\n135\t\n136\t  // Mean in reason string\n137\t  assert(\"reason contains mean=50.0\", sigHigh.reason.includes(\"mean=50.0\"));\n138\t  assert(\"reason contains volume\", sigHigh.reason.includes(\"vol=20000\"));\n139\t}\n140\t\n141\t// ---------------------------------------------------------------------------\n142\t// Suite 5: Signal direction (side)\n143\t// ---------------------------------------------------------------------------\n144\tconsole.log(\"\\n=== Suite 5: Signal direction ===\");\n145\t{\n146\t  const s = new MeanReversionStrategy();\n147\t\n148\t  // Overbought → expect mean reversion down → bet NO\n149\t  const mktOver = makeMarket({ yes_mid: 80 }); // z = 3\n150\t  const sigOver = s.generateSignal(mktOver);\n151\t  assert(\"overbought market → side='no'\", sigOver.side === \"no\");\n152\t\n153\t  // Oversold → expect mean reversion up → bet YES\n154\t  const mktUnder = makeMarket({ yes_mid: 20 }); // z = -3\n155\t  const sigUnder = s.generateSignal(mktUnder);\n156\t  assert(\"oversold market → side='yes'\", sigUnder.side === \"yes\");\n157\t}\n158\t\n159\t// ---------------------------------------------------------------------------\n160\t// Suite 6: Confidence threshold enforcement\n161\t// ---------------------------------------------------------------------------\n162\tconsole.log(\"\\n=== Suite 6: Confidence threshold enforcement ===\");\n163\t{\n164\t  const s = new MeanReversionStrategy();\n165\t\n166\t  // confidence = min(|z| / 3, 0.95)\n167\t  // z = 3 → confidence = 3/3 = 1.0, capped at 0.95\n168\t  const mktZ3 = makeMarket({ yes_mid: 80 });\n169\t  const sigZ3 = s.generateSignal(mktZ3);\n170\t  assertClose(\"z=3 confidence capped at 0.95\", sigZ3.confidence, 0.95);\n171\t\n172\t  // z = 4.5 → confidence = 4.5/3 = 1.5, capped at 0.95\n173\t  const mktZ4 = makeMarket({ yes_mid: 95 }); // z = (95-50)/10 = 4.5\n174\t  const sigZ4 = s.generateSignal(mktZ4);\n175\t  assertClose(\"z=4.5 confidence capped at 0.95\", sigZ4.confidence, 0.95);\n176\t\n177\t  // z = 2.25 → confidence = 2.25/3 = 0.75 (below cap)\n178\t  const mktZ2 = makeMarket({ yes_mid: 72.5 }); // z = (72.5-50)/10 = 2.25\n179\t  const sigZ2 = s.generateSignal(mktZ2);\n180\t  assertClose(\"z=2.25 confidence = 0.75 (uncapped)\", sigZ2.confidence, 0.75);\n181\t\n182\t  // confidence always in [0, 0.95]\n183\t  for (const yesPrice of [30, 40, 60, 70, 80, 90]) {\n184\t    const sig = s.generateSignal(makeMarket({ yes_mid: yesPrice }));\n185\t    if (sig) {\n186\t      assert(`confidence in [0,0.95] for yesPrice=${yesPrice}`, sig.confidence >= 0 && sig.confidence <= 0.95);\n187\t    }\n188\t  }\n189\t}\n190\t\n191\t// ---------------------------------------------------------------------------\n192\t// Suite 7: Signal structure / required fields\n193\t// ---------------------------------------------------------------------------\n194\tconsole.log(\"\\n=== Suite 7: Signal structure ===\");\n195\t{\n196\t  const s = new MeanReversionStrategy();\n197\t  const mkt = makeMarket({ id: \"test-mkt\", yes_mid: 80 });\n198\t  const sig = s.generateSignal(mkt);\n199\t\n200\t  assert(\"signal has marketId\", sig.marketId === \"test-mkt\");\n201\t  assert(\"signal has side\", typeof sig.side === \"string\");\n202\t  assert(\"signal has signalType='entry'\", sig.signalType === \"entry\");\n203\t  assert(\"signal has confidence (number)\", typeof sig.confidence === \"number\");\n204\t  assert(\"signal has targetPrice (number)\", typeof sig.targetPrice === \"number\");\n205\t  assert(\"signal has currentPrice (number)\", typeof sig.currentPrice === \"number\");\n206\t  assert(\"signal has expectedEdge (number)\", typeof sig.expectedEdge === \"number\");\n207\t  assert(\"signal has recommendedContracts = 10\", sig.recommendedContracts === 10);\n208\t  assert(\"signal has reason (string)\", typeof sig.reason === \"string\");\n209\t}\n210\t\n211\t// ---------------------------------------------------------------------------\n212\t// Suite 8: Price field fallbacks\n213\t// ---------------------------------------------------------------------------\n214\tconsole.log(\"\\n=== Suite 8: Price field fallbacks ===\");\n215\t{\n216\t  const s = new MeanReversionStrategy();\n217\t\n218\t  // Falls back to yes_price when yes_mid absent\n219\t  const mktNoMid = { id: \"x\", yes_price: 80, volume: 20000, price_history_mean: 50, price_history_stddev: 10 };\n220\t  const sigNoMid = s.generateSignal(mktNoMid);\n221\t  assert(\"falls back to yes_price when yes_mid absent\", sigNoMid !== null);\n222\t\n223\t  // Falls back to default price 50 when neither field present\n224\t  const mktNoPrices = { id: \"x\", volume: 20000, price_history_mean: 50, price_history_stddev: 10 };\n225\t  // yesPrice = 50 = mean → z = 0 → null\n226\t  const sigNoPrices = s.generateSignal(mktNoPrices);\n227\t  assert(\"defaults to price=50, z=0 → null signal\", sigNoPrices === null);\n228\t\n229\t  // Falls back to mean=50, std=10 when history absent\n230\t  const mktNoHistory = { id: \"x\", yes_mid: 80, volume: 20000 };\n231\t  const sigNoHistory = s.generateSignal(mktNoHistory);\n232\t  assert(\"generates signal using default mean=50 std=10\", sigNoHistory !== null);\n233\t}\n234\t\n235\t// ---------------------------------------------------------------------------\n236\t// Suite 9: Custom threshold configuration\n237\t// ---------------------------------------------------------------------------\n238\tconsole.log(\"\\n=== Suite 9: Custom zScoreThreshold configuration ===\");\n239\t{\n240\t  const strict = new MeanReversionStrategy({ zScoreThreshold: 3.0 });\n241\t\n242\t  // z = 2.5 — would fire at default 1.5 but not at 3.0\n243\t  const mkt = makeMarket({ yes_mid: 75 }); // z = 2.5\n244\t  assert(\"z=2.5 no signal with threshold=3.0\", strict.generateSignal(mkt) === null);\n245\t\n246\t  // z = 3.5 — fires at 3.0\n247\t  const mktHigh = makeMarket({ yes_mid: 85 }); // z = 3.5\n248\t  assert(\"z=3.5 generates signal with threshold=3.0\", strict.generateSignal(mktHigh) !== null);\n249\t\n250\t  const lenient = new MeanReversionStrategy({ zScoreThreshold: 0.5 });\n251\t  const mktMild = makeMarket({ yes_mid: 58 }); // z = 0.8\n252\t  assert(\"z=0.8 generates signal with threshold=0.5\", lenient.generateSignal(mktMild) !== null);\n253\t}\n254\t\n255\t// ---------------------------------------------------------------------------\n256\t// Summary\n257\t// ---------------------------------------------------------------------------\n258\tconsole.log(`\\n${\"=\".repeat(50)}`);\n259\tconsole.log(`Results: ${passed} passed, ${failed} failed`);\n260\tif (failed > 0) {\n261\t  console.error(\"SOME TESTS FAILED\");\n262\t  process.exit(1);\n263\t} else {\n264\t  console.log(\"ALL TESTS PASSED\");\n265\t}\n266\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"7d2d5ab6-12de-4b32-a887-54043fa57ae7","uuid":"b9847091-13d3-4248-831a-6890b383b420","timestamp":"2026-04-03T19:20:44.553Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/chenyangcui/Documents/code/aicompany/agents/frank/output/mean_reversion_test.js","content":"/**\n * Unit Tests — MeanReversionStrategy\n * Task: #279\n * Author: Frank (QA Engineer)\n * Coverage: z-score calculation, signal generation, confidence threshold enforcement\n *\n * Run: node agents/frank/output/mean_reversion_test.js\n */\n\n\"use strict\";\n\nconst { MeanReversionStrategy } = require(\"../../bob/backend/strategies/strategies/mean_reversion\");\n\nlet passed = 0;\nlet failed = 0;\n\nfunction assert(description, condition) {\n  if (condition) {\n    console.log(`  ✓ ${description}`);\n    passed++;\n  } else {\n    console.error(`  ✗ FAIL: ${description}`);\n    failed++;\n  }\n}\n\nfunction assertClose(description, actual, expected, tolerance = 0.001) {\n  const ok = Math.abs(actual - expected) <= tolerance;\n  if (ok) {\n    console.log(`  ✓ ${description} (${actual.toFixed(4)})`);\n    passed++;\n  } else {\n    console.error(`  ✗ FAIL: ${description} — expected ${expected}, got ${actual}`);\n    failed++;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\nfunction makeMarket(overrides = {}) {\n  return Object.assign(\n    {\n      id: \"mkt-1\",\n      yes_mid: 50,\n      no_mid: 50,\n      volume: 20000,\n      price_history_mean: 50,\n      price_history_stddev: 10,\n    },\n    overrides\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Suite 1: Constructor defaults\n// ---------------------------------------------------------------------------\nconsole.log(\"\\n=== Suite 1: Constructor defaults ===\");\n{\n  const s = new MeanReversionStrategy();\n  assert(\"default lookbackPeriods = 10\", s.lookbackPeriods === 10);\n  assert(\"default zScoreThreshold = 1.5\", s.zScoreThreshold === 1.5);\n  assert(\"default minVolume = 10000\", s.minVolume === 10000);\n\n  const custom = new MeanReversionStrategy({ lookbackPeriods: 20, zScoreThreshold: 2.0, minVolume: 5000 });\n  assert(\"custom lookbackPeriods = 20\", custom.lookbackPeriods === 20);\n  assert(\"custom zScoreThreshold = 2.0\", custom.zScoreThreshold === 2.0);\n  assert(\"custom minVolume = 5000\", custom.minVolume === 5000);\n}\n\n// ---------------------------------------------------------------------------\n// Suite 2: Volume filter\n// ---------------------------------------------------------------------------\nconsole.log(\"\\n=== Suite 2: Volume filter ===\");\n{\n  const s = new MeanReversionStrategy();\n\n  const mktLowVol = makeMarket({ yes_mid: 75, volume: 5000 }); // z = (75-50)/10 = 2.5, but vol < 10000\n  assert(\"returns null when volume < minVolume\", s.generateSignal(mktLowVol) === null);\n\n  const mktZeroVol = makeMarket({ yes_mid: 80, volume: 0 });\n  assert(\"returns null when volume = 0\", s.generateSignal(mktZeroVol) === null);\n\n  const mktExactVol = makeMarket({ yes_mid: 75, volume: 10000 }); // exactly at threshold → should pass\n  assert(\"generates signal when volume == minVolume\", s.generateSignal(mktExactVol) !== null);\n}\n\n// ---------------------------------------------------------------------------\n// Suite 3: z-score threshold gate\n// ---------------------------------------------------------------------------\nconsole.log(\"\\n=== Suite 3: z-score threshold gate ===\");\n{\n  const s = new MeanReversionStrategy(); // threshold = 1.5\n\n  // z = (65 - 50) / 10 = 1.5 — exactly at threshold → signal IS generated (gate is strict <, so == passes)\n  const mktAtThreshold = makeMarket({ yes_mid: 65 });\n  assert(\"generates signal when |z-score| == threshold (gate is strict <)\", s.generateSignal(mktAtThreshold) !== null);\n\n  // z = (65.1 - 50) / 10 = 1.51 — just above threshold\n  const mktJustAbove = makeMarket({ yes_mid: 65.1 });\n  assert(\"generates signal when |z-score| just above threshold\", s.generateSignal(mktJustAbove) !== null);\n\n  // z = (40 - 50) / 10 = -1.0 — below threshold\n  const mktBelow = makeMarket({ yes_mid: 40 });\n  assert(\"returns null when |z-score| < threshold (negative side)\", s.generateSignal(mktBelow) === null);\n\n  // zero stddev guard\n  const mktZeroStd = makeMarket({ price_history_stddev: 0 });\n  assert(\"returns null when stddev = 0 (division guard)\", s.generateSignal(mktZeroStd) === null);\n\n  // negative stddev guard\n  const mktNegStd = makeMarket({ price_history_stddev: -5 });\n  assert(\"returns null when stddev < 0\", s.generateSignal(mktNegStd) === null);\n}\n\n// ---------------------------------------------------------------------------\n// Suite 4: z-score calculation correctness\n// ---------------------------------------------------------------------------\nconsole.log(\"\\n=== Suite 4: z-score calculation ===\");\n{\n  const s = new MeanReversionStrategy();\n\n  // Overbought: yesPrice=80, mean=50, std=10 → z = 3.0\n  const mktHigh = makeMarket({ yes_mid: 80, price_history_mean: 50, price_history_stddev: 10 });\n  const sigHigh = s.generateSignal(mktHigh);\n  assert(\"signal generated for overbought market (z=3)\", sigHigh !== null);\n  assert(\"z=3 reason string contains z-score=3.00\", sigHigh.reason.includes(\"z-score=3.00\"));\n\n  // Oversold: yesPrice=20, mean=50, std=10 → z = -3.0\n  const mktLow = makeMarket({ yes_mid: 20 });\n  const sigLow = s.generateSignal(mktLow);\n  assert(\"signal generated for oversold market (z=-3)\", sigLow !== null);\n  assert(\"z=-3 reason string contains z-score=-3.00\", sigLow.reason.includes(\"z-score=-3.00\"));\n\n  // Mean in reason string\n  assert(\"reason contains mean=50.0\", sigHigh.reason.includes(\"mean=50.0\"));\n  assert(\"reason contains volume\", sigHigh.reason.includes(\"vol=20000\"));\n}\n\n// ---------------------------------------------------------------------------\n// Suite 5: Signal direction (side)\n// ---------------------------------------------------------------------------\nconsole.log(\"\\n=== Suite 5: Signal direction ===\");\n{\n  const s = new MeanReversionStrategy();\n\n  // Overbought → expect mean reversion down → bet NO\n  const mktOver = makeMarket({ yes_mid: 80 }); // z = 3\n  const sigOver = s.generateSignal(mktOver);\n  assert(\"overbought market → side='no'\", sigOver.side === \"no\");\n\n  // Oversold → expect mean reversion up → bet YES\n  const mktUnder = makeMarket({ yes_mid: 20 }); // z = -3\n  const sigUnder = s.generateSignal(mktUnder);\n  assert(\"oversold market → side='yes'\", sigUnder.side === \"yes\");\n}\n\n// ---------------------------------------------------------------------------\n// Suite 6: Confidence threshold enforcement\n// ---------------------------------------------------------------------------\nconsole.log(\"\\n=== Suite 6: Confidence threshold enforcement ===\");\n{\n  const s = new MeanReversionStrategy();\n\n  // confidence = min(|z| / 3, 0.95)\n  // z = 3 → confidence = 3/3 = 1.0, capped at 0.95\n  const mktZ3 = makeMarket({ yes_mid: 80 });\n  const sigZ3 = s.generateSignal(mktZ3);\n  assertClose(\"z=3 confidence capped at 0.95\", sigZ3.confidence, 0.95);\n\n  // z = 4.5 → confidence = 4.5/3 = 1.5, capped at 0.95\n  const mktZ4 = makeMarket({ yes_mid: 95 }); // z = (95-50)/10 = 4.5\n  const sigZ4 = s.generateSignal(mktZ4);\n  assertClose(\"z=4.5 confidence capped at 0.95\", sigZ4.confidence, 0.95);\n\n  // z = 2.25 → confidence = 2.25/3 = 0.75 (below cap)\n  const mktZ2 = makeMarket({ yes_mid: 72.5 }); // z = (72.5-50)/10 = 2.25\n  const sigZ2 = s.generateSignal(mktZ2);\n  assertClose(\"z=2.25 confidence = 0.75 (uncapped)\", sigZ2.confidence, 0.75);\n\n  // confidence always in [0, 0.95]\n  for (const yesPrice of [30, 40, 60, 70, 80, 90]) {\n    const sig = s.generateSignal(makeMarket({ yes_mid: yesPrice }));\n    if (sig) {\n      assert(`confidence in [0,0.95] for yesPrice=${yesPrice}`, sig.confidence >= 0 && sig.confidence <= 0.95);\n    }\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Suite 7: Signal structure / required fields\n// ---------------------------------------------------------------------------\nconsole.log(\"\\n=== Suite 7: Signal structure ===\");\n{\n  const s = new MeanReversionStrategy();\n  const mkt = makeMarket({ id: \"test-mkt\", yes_mid: 80 });\n  const sig = s.generateSignal(mkt);\n\n  assert(\"signal has marketId\", sig.marketId === \"test-mkt\");\n  assert(\"signal has side\", typeof sig.side === \"string\");\n  assert(\"signal has signalType='entry'\", sig.signalType === \"entry\");\n  assert(\"signal has confidence (number)\", typeof sig.confidence === \"number\");\n  assert(\"signal has targetPrice (number)\", typeof sig.targetPrice === \"number\");\n  assert(\"signal has currentPrice (number)\", typeof sig.currentPrice === \"number\");\n  assert(\"signal has expectedEdge (number)\", typeof sig.expectedEdge === \"number\");\n  assert(\"signal has recommendedContracts = 10\", sig.recommendedContracts === 10);\n  assert(\"signal has reason (string)\", typeof sig.reason === \"string\");\n}\n\n// ---------------------------------------------------------------------------\n// Suite 8: Price field fallbacks\n// ---------------------------------------------------------------------------\nconsole.log(\"\\n=== Suite 8: Price field fallbacks ===\");\n{\n  const s = new MeanReversionStrategy();\n\n  // Falls back to yes_price when yes_mid absent\n  const mktNoMid = { id: \"x\", yes_price: 80, volume: 20000, price_history_mean: 50, price_history_stddev: 10 };\n  const sigNoMid = s.generateSignal(mktNoMid);\n  assert(\"falls back to yes_price when yes_mid absent\", sigNoMid !== null);\n\n  // Falls back to default price 50 when neither field present\n  const mktNoPrices = { id: \"x\", volume: 20000, price_history_mean: 50, price_history_stddev: 10 };\n  // yesPrice = 50 = mean → z = 0 → null\n  const sigNoPrices = s.generateSignal(mktNoPrices);\n  assert(\"defaults to price=50, z=0 → null signal\", sigNoPrices === null);\n\n  // Falls back to mean=50, std=10 when history absent\n  const mktNoHistory = { id: \"x\", yes_mid: 80, volume: 20000 };\n  const sigNoHistory = s.generateSignal(mktNoHistory);\n  assert(\"generates signal using default mean=50 std=10\", sigNoHistory !== null);\n}\n\n// ---------------------------------------------------------------------------\n// Suite 9: Custom threshold configuration\n// ---------------------------------------------------------------------------\nconsole.log(\"\\n=== Suite 9: Custom zScoreThreshold configuration ===\");\n{\n  const strict = new MeanReversionStrategy({ zScoreThreshold: 3.0 });\n\n  // z = 2.5 — would fire at default 1.5 but not at 3.0\n  const mkt = makeMarket({ yes_mid: 75 }); // z = 2.5\n  assert(\"z=2.5 no signal with threshold=3.0\", strict.generateSignal(mkt) === null);\n\n  // z = 3.5 — fires at 3.0\n  const mktHigh = makeMarket({ yes_mid: 85 }); // z = 3.5\n  assert(\"z=3.5 generates signal with threshold=3.0\", strict.generateSignal(mktHigh) !== null);\n\n  const lenient = new MeanReversionStrategy({ zScoreThreshold: 0.5 });\n  const mktMild = makeMarket({ yes_mid: 58 }); // z = 0.8\n  assert(\"z=0.8 generates signal with threshold=0.5\", lenient.generateSignal(mktMild) !== null);\n}\n\n// ---------------------------------------------------------------------------\n// Summary\n// ---------------------------------------------------------------------------\nconsole.log(`\\n${\"=\".repeat(50)}`);\nconsole.log(`Results: ${passed} passed, ${failed} failed`);\nif (failed > 0) {\n  console.error(\"SOME TESTS FAILED\");\n  process.exit(1);\n} else {\n  console.log(\"ALL TESTS PASSED\");\n}\n","numLines":266,"startLine":1,"totalLines":266}}}
