{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ThxV4c3YcxPjRwhmDaW37H","type":"tool_result","content":"1\t/**\n2\t * Position Sizer\n3\t * Calculates optimal position sizes based on risk management rules.\n4\t * Author: Bob (Backend Engineer)\n5\t * Task: #220\n6\t */\n7\t\n8\t\"use strict\";\n9\t\n10\tclass PositionSizer {\n11\t  constructor(options = {}) {\n12\t    // Account-level constraints\n13\t    this.accountBalance = options.accountBalance || 500000; // cents ($5,000 default)\n14\t    this.maxRiskPerTrade = options.maxRiskPerTrade || 0.02; // 2% max risk per trade\n15\t    this.maxPositionPct = options.maxPositionPct || 0.20; // 20% max in single position\n16\t    this.minContracts = options.minContracts || 1;\n17\t    this.maxContracts = options.maxContracts || 1000;\n18\t\n19\t    // Kelly criterion settings\n20\t    this.useKelly = options.useKelly || false;\n21\t    this.kellyFraction = options.kellyFraction || 0.25; // fractional Kelly (quarter Kelly)\n22\t  }\n23\t\n24\t  /**\n25\t   * Calculate position size for a signal.\n26\t   * @param {Object} signal - signal with confidence, expectedEdge, currentPrice, side\n27\t   * @param {Object} market - market data with volume, openInterest\n28\t   * @returns {Object} sizing result: { contracts, riskAmount, reason }\n29\t   */\n30\t  sizePosition(signal, market = {}) {\n31\t    const price = signal.currentPrice || 50;\n32\t    const edge = signal.expectedEdge || 0;\n33\t    const confidence = signal.confidence || 0;\n34\t\n35\t    // Base risk amount: fixed fractional\n36\t    const maxRiskAmount = Math.floor(this.accountBalance * this.maxRiskPerTrade);\n37\t\n38\t    // Risk per contract: if buying at price, max loss is price (goes to 0)\n39\t    const riskPerContract = price; // in cents\n40\t\n41\t    let contracts = 0;\n42\t    if (riskPerContract > 0) {\n43\t      contracts = Math.floor(maxRiskAmount / riskPerContract);\n44\t    }\n45\t\n46\t    // Apply Kelly criterion if enabled\n47\t    if (this.useKelly && edge > 0 && price > 0) {\n48\t      // Simplified Kelly: f* = edge / odds\n49\t      // For binary markets, odds = price / (100 - price)\n50\t      const winProb = confidence;\n51\t      const lossProb = 1 - winProb;\n52\t      const winAmount = 100 - price;\n53\t      const lossAmount = price;\n54\t      const kelly =\n55\t        winProb > 0 && lossAmount > 0\n56\t          ? (winProb / lossAmount) - (lossProb / winAmount)\n57\t          : 0;\n58\t      const fractionalKelly = kelly * this.kellyFraction;\n59\t      const kellyContracts = Math.floor(\n60\t        (this.accountBalance * fractionalKelly) / price\n61\t      );\n62\t      contracts = Math.min(contracts, kellyContracts);\n63\t    }\n64\t\n65\t    // Apply confidence scaling\n66\t    contracts = Math.floor(contracts * confidence);\n67\t\n68\t    // Apply market liquidity constraint: max 1% of daily volume\n69\t    const volume = market.volume || market.volume24h || 0;\n70\t    if (volume > 0) {\n71\t      const liquidityCap = Math.floor(volume * 0.01);\n72\t      contracts = Math.min(contracts, liquidityCap);\n73\t    }\n74\t\n75\t    // Apply max position size constraint\n76\t    const maxPositionValue = Math.floor(this.accountBalance * this.maxPositionPct);\n77\t    const maxByPosition = Math.floor(maxPositionValue / price);\n78\t    contracts = Math.min(contracts, maxByPosition);\n79\t\n80\t    // Hard limits\n81\t    contracts = Math.max(contracts, this.minContracts);\n82\t    contracts = Math.min(contracts, this.maxContracts);\n83\t\n84\t    const riskAmount = contracts * riskPerContract;\n85\t    const positionValue = contracts * price;\n86\t\n87\t    return {\n88\t      contracts,\n89\t      riskAmount,\n90\t      positionValue,\n91\t      riskPctOfAccount: (riskAmount / this.accountBalance).toFixed(4),\n92\t      positionPctOfAccount: (positionValue / this.accountBalance).toFixed(4),\n93\t      reason: `Fixed fractional sizing: ${this.maxRiskPerTrade * 100}% risk, ` +\n94\t        `confidence=${(confidence * 100).toFixed(1)}%, ` +\n95\t        `price=${price}c, edge=${edge}c`,\n96\t    };\n97\t  }\n98\t\n99\t  /**\n100\t   * Update account balance.\n101\t   * @param {number} balance - new balance in cents\n102\t   */\n103\t  setAccountBalance(balance) {\n104\t    this.accountBalance = balance;\n105\t  }\n106\t\n107\t  /**\n108\t   * Batch size multiple signals.\n109\t   * @param {Array} signals - array of signals\n110\t   * @param {Object} marketMap - map of marketId -> market data\n111\t   * @returns {Array} signals with sizing appended\n112\t   */\n113\t  sizeSignals(signals, marketMap = {}) {\n114\t    return signals.map((signal) => {\n115\t      const market = marketMap[signal.marketId] || {};\n116\t      const sizing = this.sizePosition(signal, market);\n117\t      return { ...signal, sizing };\n118\t    });\n119\t  }\n120\t}\n121\t\n122\tmodule.exports = { PositionSizer };\n123\t"}]},"parent_tool_use_id":null,"session_id":"855ad91b-f6c8-4ef0-b5d0-8e5805f4c92a","uuid":"e4c67e05-890a-40c8-9329-e39292b16583","timestamp":"2026-04-04T05:04:50.196Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/chenyangcui/Documents/code/aicompany/planets/kalshi-traders/output/bob/backend/strategies/position_sizer.js","content":"/**\n * Position Sizer\n * Calculates optimal position sizes based on risk management rules.\n * Author: Bob (Backend Engineer)\n * Task: #220\n */\n\n\"use strict\";\n\nclass PositionSizer {\n  constructor(options = {}) {\n    // Account-level constraints\n    this.accountBalance = options.accountBalance || 500000; // cents ($5,000 default)\n    this.maxRiskPerTrade = options.maxRiskPerTrade || 0.02; // 2% max risk per trade\n    this.maxPositionPct = options.maxPositionPct || 0.20; // 20% max in single position\n    this.minContracts = options.minContracts || 1;\n    this.maxContracts = options.maxContracts || 1000;\n\n    // Kelly criterion settings\n    this.useKelly = options.useKelly || false;\n    this.kellyFraction = options.kellyFraction || 0.25; // fractional Kelly (quarter Kelly)\n  }\n\n  /**\n   * Calculate position size for a signal.\n   * @param {Object} signal - signal with confidence, expectedEdge, currentPrice, side\n   * @param {Object} market - market data with volume, openInterest\n   * @returns {Object} sizing result: { contracts, riskAmount, reason }\n   */\n  sizePosition(signal, market = {}) {\n    const price = signal.currentPrice || 50;\n    const edge = signal.expectedEdge || 0;\n    const confidence = signal.confidence || 0;\n\n    // Base risk amount: fixed fractional\n    const maxRiskAmount = Math.floor(this.accountBalance * this.maxRiskPerTrade);\n\n    // Risk per contract: if buying at price, max loss is price (goes to 0)\n    const riskPerContract = price; // in cents\n\n    let contracts = 0;\n    if (riskPerContract > 0) {\n      contracts = Math.floor(maxRiskAmount / riskPerContract);\n    }\n\n    // Apply Kelly criterion if enabled\n    if (this.useKelly && edge > 0 && price > 0) {\n      // Simplified Kelly: f* = edge / odds\n      // For binary markets, odds = price / (100 - price)\n      const winProb = confidence;\n      const lossProb = 1 - winProb;\n      const winAmount = 100 - price;\n      const lossAmount = price;\n      const kelly =\n        winProb > 0 && lossAmount > 0\n          ? (winProb / lossAmount) - (lossProb / winAmount)\n          : 0;\n      const fractionalKelly = kelly * this.kellyFraction;\n      const kellyContracts = Math.floor(\n        (this.accountBalance * fractionalKelly) / price\n      );\n      contracts = Math.min(contracts, kellyContracts);\n    }\n\n    // Apply confidence scaling\n    contracts = Math.floor(contracts * confidence);\n\n    // Apply market liquidity constraint: max 1% of daily volume\n    const volume = market.volume || market.volume24h || 0;\n    if (volume > 0) {\n      const liquidityCap = Math.floor(volume * 0.01);\n      contracts = Math.min(contracts, liquidityCap);\n    }\n\n    // Apply max position size constraint\n    const maxPositionValue = Math.floor(this.accountBalance * this.maxPositionPct);\n    const maxByPosition = Math.floor(maxPositionValue / price);\n    contracts = Math.min(contracts, maxByPosition);\n\n    // Hard limits\n    contracts = Math.max(contracts, this.minContracts);\n    contracts = Math.min(contracts, this.maxContracts);\n\n    const riskAmount = contracts * riskPerContract;\n    const positionValue = contracts * price;\n\n    return {\n      contracts,\n      riskAmount,\n      positionValue,\n      riskPctOfAccount: (riskAmount / this.accountBalance).toFixed(4),\n      positionPctOfAccount: (positionValue / this.accountBalance).toFixed(4),\n      reason: `Fixed fractional sizing: ${this.maxRiskPerTrade * 100}% risk, ` +\n        `confidence=${(confidence * 100).toFixed(1)}%, ` +\n        `price=${price}c, edge=${edge}c`,\n    };\n  }\n\n  /**\n   * Update account balance.\n   * @param {number} balance - new balance in cents\n   */\n  setAccountBalance(balance) {\n    this.accountBalance = balance;\n  }\n\n  /**\n   * Batch size multiple signals.\n   * @param {Array} signals - array of signals\n   * @param {Object} marketMap - map of marketId -> market data\n   * @returns {Array} signals with sizing appended\n   */\n  sizeSignals(signals, marketMap = {}) {\n    return signals.map((signal) => {\n      const market = marketMap[signal.marketId] || {};\n      const sizing = this.sizePosition(signal, market);\n      return { ...signal, sizing };\n    });\n  }\n}\n\nmodule.exports = { PositionSizer };\n","numLines":123,"startLine":1,"totalLines":123}}}
