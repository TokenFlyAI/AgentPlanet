{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0189XqrjiNQR7e5nT9VDbHiB","type":"tool_result","content":"1\t#!/usr/bin/env node\n2\t/**\n3\t * Risk Manager for Live Trading Pipeline\n4\t * Author: Bob (Backend Engineer)\n5\t * Task: #244 — Integrate risk management into live trading\n6\t *\n7\t * Validates trades against risk limits before execution.\n8\t */\n9\t\n10\t\"use strict\";\n11\t\n12\tconst { Pool } = require(\"pg\");\n13\t\n14\t// Database configuration\n15\tconst dbConfig = {\n16\t  host: process.env.DB_HOST || \"localhost\",\n17\t  port: parseInt(process.env.DB_PORT || \"5432\"),\n18\t  database: process.env.DB_NAME || \"kalshi_trading\",\n19\t  user: process.env.DB_USER || \"trader\",\n20\t  password: process.env.DB_PASSWORD,\n21\t};\n22\t\n23\tlet pool = null;\n24\t\n25\ttry {\n26\t  pool = new Pool(dbConfig);\n27\t} catch (e) {\n28\t  console.warn(\"[RiskManager] Database not available, using in-memory risk tracking\");\n29\t}\n30\t\n31\t// Risk limits (configurable via env vars)\n32\tconst RISK_LIMITS = {\n33\t  maxDailyLoss: parseInt(process.env.MAX_DAILY_LOSS || \"50000\"), // cents ($500)\n34\t  maxPositionSize: parseInt(process.env.MAX_POSITION_SIZE || \"1000\"), // contracts\n35\t  maxTotalExposure: parseInt(process.env.MAX_TOTAL_EXPOSURE || \"200000\"), // cents ($2000)\n36\t  maxConcentration: parseFloat(process.env.MAX_CONCENTRATION || \"0.25\"), // 25% in single market\n37\t  maxDrawdown: parseFloat(process.env.MAX_DRAWDOWN || \"0.10\"), // 10% max drawdown\n38\t};\n39\t\n40\t/**\n41\t * Get current positions from database\n42\t */\n43\tasync function getCurrentPositions() {\n44\t  if (!pool) return [];\n45\t  let client;\n46\t  try {\n47\t    client = await pool.connect();\n48\t  } catch (e) {\n49\t    console.warn(\"[RiskManager] DB connection failed, returning empty positions\");\n50\t    return [];\n51\t  }\n52\t  try {\n53\t    const result = await client.query(`\n54\t      SELECT \n55\t        market_ticker,\n56\t        side,\n57\t        SUM(CASE WHEN side = 'YES' THEN quantity ELSE -quantity END) as net_position,\n58\t        SUM(quantity * avg_entry_price) as notional_value\n59\t      FROM positions\n60\t      WHERE status = 'open'\n61\t      GROUP BY market_ticker, side\n62\t    `);\n63\t    return result.rows;\n64\t  } finally {\n65\t    client.release();\n66\t  }\n67\t}\n68\t\n69\t/**\n70\t * Get today's P&L\n71\t */\n72\tasync function getTodayPnL() {\n73\t  if (!pool) return { realized: 0, unrealized: 0 };\n74\t  try {\n75\t    const client = await pool.connect();\n76\t    try {\n77\t      const result = await client.query(`\n78\t        SELECT \n79\t          COALESCE(SUM(realized_pnl), 0) as realized_pnl,\n80\t          COALESCE(SUM(unrealized_pnl), 0) as unrealized_pnl\n81\t        FROM trades\n82\t        WHERE DATE(created_at) = CURRENT_DATE\n83\t      `);\n84\t      return {\n85\t        realized: parseInt(result.rows[0].realized_pnl) || 0,\n86\t        unrealized: parseInt(result.rows[0].unrealized_pnl) || 0,\n87\t        total: parseInt(result.rows[0].realized_pnl) + parseInt(result.rows[0].unrealized_pnl),\n88\t      };\n89\t    } finally {\n90\t      client.release();\n91\t    }\n92\t  } catch (e) {\n93\t    console.log(\"[RiskManager] DB unavailable, using fallback P&L data\");\n94\t    return { realized: 0, unrealized: 0, total: 0 };\n95\t  }\n96\t}\n97\t\n98\t/**\n99\t * Calculate total exposure across all positions\n100\t */\n101\tasync function getTotalExposure() {\n102\t  try {\n103\t    const client = await pool.connect();\n104\t    try {\n105\t      const result = await client.query(`\n106\t        SELECT COALESCE(SUM(ABS(quantity) * avg_entry_price), 0) as total_exposure\n107\t        FROM positions\n108\t        WHERE status = 'open'\n109\t      `);\n110\t      return parseInt(result.rows[0].total_exposure) || 0;\n111\t    } finally {\n112\t      client.release();\n113\t    }\n114\t  } catch (e) {\n115\t    return 0;\n116\t  }\n117\t}\n118\t\n119\t/**\n120\t * Validate a proposed trade against risk limits\n121\t * @param {Object} trade - Proposed trade\n122\t * @param {string} trade.marketTicker - Market ticker\n123\t * @param {string} trade.side - 'YES' or 'NO'\n124\t * @param {number} trade.quantity - Number of contracts\n125\t * @param {number} trade.price - Price per contract (cents)\n126\t * @returns {Object} - { approved: boolean, reasons: string[], riskScore: number }\n127\t */\n128\tasync function validateTrade(trade) {\n129\t  const reasons = [];\n130\t  const checks = [];\n131\t\n132\t  // Get current state\n133\t  const [positions, pnl, exposure] = await Promise.all([\n134\t    getCurrentPositions(),\n135\t    getTodayPnL(),\n136\t    getTotalExposure(),\n137\t  ]);\n138\t\n139\t  const tradeValue = trade.quantity * trade.price;\n140\t  const newExposure = exposure + tradeValue;\n141\t\n142\t  // Check 1: Daily loss limit\n143\t  const dailyLossCheck = pnl.total > -RISK_LIMITS.maxDailyLoss;\n144\t  checks.push({ name: \"daily_loss\", passed: dailyLossCheck, value: pnl.total });\n145\t  if (!dailyLossCheck) {\n146\t    reasons.push(`Daily loss limit exceeded: ${pnl.total}¢ lost (max: ${RISK_LIMITS.maxDailyLoss}¢)`);\n147\t  }\n148\t\n149\t  // Check 2: Position size limit\n150\t  const positionSizeCheck = trade.quantity <= RISK_LIMITS.maxPositionSize;\n151\t  checks.push({ name: \"position_size\", passed: positionSizeCheck, value: trade.quantity });\n152\t  if (!positionSizeCheck) {\n153\t    reasons.push(`Position size too large: ${trade.quantity} contracts (max: ${RISK_LIMITS.maxPositionSize})`);\n154\t  }\n155\t\n156\t  // Check 3: Total exposure limit\n157\t  const exposureCheck = newExposure <= RISK_LIMITS.maxTotalExposure;\n158\t  checks.push({ name: \"total_exposure\", passed: exposureCheck, value: newExposure });\n159\t  if (!exposureCheck) {\n160\t    reasons.push(`Total exposure would exceed limit: ${newExposure}¢ (max: ${RISK_LIMITS.maxTotalExposure}¢)`);\n161\t  }\n162\t\n163\t  // Check 4: Concentration limit (max % in single market)\n164\t  // Skip concentration check if this is the first trade (exposure = 0)\n165\t  const existingPosition = positions.find(p => p.market_ticker === trade.marketTicker);\n166\t  const existingValue = existingPosition ? parseInt(existingPosition.notional_value) : 0;\n167\t  const newMarketValue = existingValue + tradeValue;\n168\t  const concentration = newExposure > 0 ? newMarketValue / newExposure : 0;\n169\t  // Allow first trade (when exposure is 0) or check concentration\n170\t  const concentrationCheck = exposure === 0 || concentration <= RISK_LIMITS.maxConcentration;\n171\t  checks.push({ name: \"concentration\", passed: concentrationCheck, value: concentration });\n172\t  if (!concentrationCheck) {\n173\t    reasons.push(`Concentration too high: ${(concentration * 100).toFixed(1)}% in ${trade.marketTicker} (max: ${(RISK_LIMITS.maxConcentration * 100).toFixed(0)}%)`);\n174\t  }\n175\t\n176\t  // Calculate risk score (0-100, lower is better)\n177\t  const failedChecks = checks.filter(c => !c.passed).length;\n178\t  const riskScore = Math.min(100, (failedChecks / checks.length) * 100 + (newExposure / RISK_LIMITS.maxTotalExposure) * 50);\n179\t\n180\t  return {\n181\t    approved: reasons.length === 0,\n182\t    reasons,\n183\t    riskScore: Math.round(riskScore),\n184\t    checks,\n185\t    currentState: {\n186\t      dailyPnL: pnl,\n187\t      totalExposure: exposure,\n188\t      newExposure,\n189\t      concentration,\n190\t    },\n191\t  };\n192\t}\n193\t\n194\t/**\n195\t * Record risk check in database\n196\t */\n197\tasync function logRiskCheck(trade, validationResult) {\n198\t  const client = await pool.connect();\n199\t  try {\n200\t    await client.query(`\n201\t      INSERT INTO risk_checks (\n202\t        market_ticker, side, quantity, price, \n203\t        approved, risk_score, reasons, created_at\n204\t      ) VALUES ($1, $2, $3, $4, $5, $6, $7, NOW())\n205\t    `, [\n206\t      trade.marketTicker,\n207\t      trade.side,\n208\t      trade.quantity,\n209\t      trade.price,\n210\t      validationResult.approved,\n211\t      validationResult.riskScore,\n212\t      JSON.stringify(validationResult.reasons),\n213\t    ]);\n214\t  } finally {\n215\t    client.release();\n216\t  }\n217\t}\n218\t\n219\t/**\n220\t * Get risk summary for dashboard\n221\t */\n222\tasync function getRiskSummary() {\n223\t  const [positions, pnl, exposure] = await Promise.all([\n224\t    getCurrentPositions(),\n225\t    getTodayPnL(),\n226\t    getTotalExposure(),\n227\t  ]);\n228\t\n229\t  return {\n230\t    limits: RISK_LIMITS,\n231\t    current: {\n232\t      dailyPnL: pnl,\n233\t      totalExposure: exposure,\n234\t      openPositions: positions.length,\n235\t    },\n236\t    utilization: {\n237\t      dailyLoss: Math.abs(pnl.total) / RISK_LIMITS.maxDailyLoss,\n238\t      exposure: exposure / RISK_LIMITS.maxTotalExposure,\n239\t    },\n240\t    status: pnl.total < -RISK_LIMITS.maxDailyLoss || exposure > RISK_LIMITS.maxTotalExposure ? \"AT_RISK\" : \"OK\",\n241\t  };\n242\t}\n243\t\n244\t// RiskManager class for live_runner.js integration\n245\tclass RiskManager {\n246\t  async filterSignals(signals) {\n247\t    const approved = [];\n248\t    const rejected = [];\n249\t    let context = null;\n250\t\n251\t    try {\n252\t      const summary = await getRiskSummary();\n253\t      context = {\n254\t        dailyPnl: summary.current.dailyPnL.total || 0,\n255\t        openExposure: summary.current.totalExposure || 0,\n256\t        openPositionsCount: summary.current.openPositions || 0,\n257\t        drawdown: summary.utilization.exposure || 0,\n258\t      };\n259\t    } catch (dbErr) {\n260\t      // Database not available — run without DB-backed risk checks\n261\t      context = {\n262\t        dailyPnl: 0,\n263\t        openExposure: 0,\n264\t        openPositionsCount: 0,\n265\t        drawdown: 0,\n266\t      };\n267\t    }\n268\t\n269\t    for (const signal of signals) {\n270\t      const trade = {\n271\t        marketTicker: signal.ticker || signal.marketId,\n272\t        side: signal.side ? signal.side.toUpperCase() : \"YES\",\n273\t        quantity: signal.recommendedContracts || signal.positionSize || 1,\n274\t        price: Math.round((signal.currentPrice || signal.targetPrice || 50) * 100),\n275\t      };\n276\t\n277\t      try {\n278\t        const result = await validateTrade(trade);\n279\t        if (result.approved) {\n280\t          approved.push(signal);\n281\t        } else {\n282\t          rejected.push({ signal, reason: result.reasons.join(\"; \") });\n283\t        }\n284\t      } catch (err) {\n285\t        // If DB is down, approve signal with a warning\n286\t        approved.push(signal);\n287\t      }\n288\t    }\n289\t\n290\t    return { approved, rejected, context };\n291\t  }\n292\t}\n293\t\n294\tmodule.exports = {\n295\t  RiskManager,\n296\t  validateTrade,\n297\t  logRiskCheck,\n298\t  getRiskSummary,\n299\t  getCurrentPositions,\n300\t  getTodayPnL,\n301\t  RISK_LIMITS,\n302\t};\n303\t\n304\t// CLI for testing\n305\tif (require.main === module) {\n306\t  async function main() {\n307\t    const args = process.argv.slice(2);\n308\t    \n309\t    if (args[0] === \"summary\") {\n310\t      const summary = await getRiskSummary();\n311\t      console.log(JSON.stringify(summary, null, 2));\n312\t    } else if (args[0] === \"check\") {\n313\t      const trade = {\n314\t        marketTicker: args[1] || \"TEST-MARKET\",\n315\t        side: args[2] || \"YES\",\n316\t        quantity: parseInt(args[3]) || 10,\n317\t        price: parseInt(args[4]) || 50,\n318\t      };\n319\t      const result = await validateTrade(trade);\n320\t      console.log(JSON.stringify(result, null, 2));\n321\t    } else {\n322\t      console.log(`\n323\tRisk Manager CLI\n324\t\n325\tUsage:\n326\t  node risk_manager.js summary           Show risk summary\n327\t  node risk_manager.js check <ticker> <side> <qty> <price>   Validate a trade\n328\t\n329\tExamples:\n330\t  node risk_manager.js summary\n331\t  node risk_manager.js check BTCW-26-JUN30-100K YES 10 65\n332\t`);\n333\t    }\n334\t    process.exit(0);\n335\t  }\n336\t\n337\t  main().catch(e => {\n338\t    console.error(\"Error:\", e);\n339\t    process.exit(1);\n340\t  });\n341\t}\n342\t"}]},"parent_tool_use_id":null,"session_id":"855ad91b-f6c8-4ef0-b5d0-8e5805f4c92a","uuid":"df6e63ff-ce9a-46ec-94f1-778f531ab8fd","timestamp":"2026-04-04T05:04:38.782Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/chenyangcui/Documents/code/aicompany/planets/kalshi-traders/output/bob/backend/strategies/risk_manager.js","content":"#!/usr/bin/env node\n/**\n * Risk Manager for Live Trading Pipeline\n * Author: Bob (Backend Engineer)\n * Task: #244 — Integrate risk management into live trading\n *\n * Validates trades against risk limits before execution.\n */\n\n\"use strict\";\n\nconst { Pool } = require(\"pg\");\n\n// Database configuration\nconst dbConfig = {\n  host: process.env.DB_HOST || \"localhost\",\n  port: parseInt(process.env.DB_PORT || \"5432\"),\n  database: process.env.DB_NAME || \"kalshi_trading\",\n  user: process.env.DB_USER || \"trader\",\n  password: process.env.DB_PASSWORD,\n};\n\nlet pool = null;\n\ntry {\n  pool = new Pool(dbConfig);\n} catch (e) {\n  console.warn(\"[RiskManager] Database not available, using in-memory risk tracking\");\n}\n\n// Risk limits (configurable via env vars)\nconst RISK_LIMITS = {\n  maxDailyLoss: parseInt(process.env.MAX_DAILY_LOSS || \"50000\"), // cents ($500)\n  maxPositionSize: parseInt(process.env.MAX_POSITION_SIZE || \"1000\"), // contracts\n  maxTotalExposure: parseInt(process.env.MAX_TOTAL_EXPOSURE || \"200000\"), // cents ($2000)\n  maxConcentration: parseFloat(process.env.MAX_CONCENTRATION || \"0.25\"), // 25% in single market\n  maxDrawdown: parseFloat(process.env.MAX_DRAWDOWN || \"0.10\"), // 10% max drawdown\n};\n\n/**\n * Get current positions from database\n */\nasync function getCurrentPositions() {\n  if (!pool) return [];\n  let client;\n  try {\n    client = await pool.connect();\n  } catch (e) {\n    console.warn(\"[RiskManager] DB connection failed, returning empty positions\");\n    return [];\n  }\n  try {\n    const result = await client.query(`\n      SELECT \n        market_ticker,\n        side,\n        SUM(CASE WHEN side = 'YES' THEN quantity ELSE -quantity END) as net_position,\n        SUM(quantity * avg_entry_price) as notional_value\n      FROM positions\n      WHERE status = 'open'\n      GROUP BY market_ticker, side\n    `);\n    return result.rows;\n  } finally {\n    client.release();\n  }\n}\n\n/**\n * Get today's P&L\n */\nasync function getTodayPnL() {\n  if (!pool) return { realized: 0, unrealized: 0 };\n  try {\n    const client = await pool.connect();\n    try {\n      const result = await client.query(`\n        SELECT \n          COALESCE(SUM(realized_pnl), 0) as realized_pnl,\n          COALESCE(SUM(unrealized_pnl), 0) as unrealized_pnl\n        FROM trades\n        WHERE DATE(created_at) = CURRENT_DATE\n      `);\n      return {\n        realized: parseInt(result.rows[0].realized_pnl) || 0,\n        unrealized: parseInt(result.rows[0].unrealized_pnl) || 0,\n        total: parseInt(result.rows[0].realized_pnl) + parseInt(result.rows[0].unrealized_pnl),\n      };\n    } finally {\n      client.release();\n    }\n  } catch (e) {\n    console.log(\"[RiskManager] DB unavailable, using fallback P&L data\");\n    return { realized: 0, unrealized: 0, total: 0 };\n  }\n}\n\n/**\n * Calculate total exposure across all positions\n */\nasync function getTotalExposure() {\n  try {\n    const client = await pool.connect();\n    try {\n      const result = await client.query(`\n        SELECT COALESCE(SUM(ABS(quantity) * avg_entry_price), 0) as total_exposure\n        FROM positions\n        WHERE status = 'open'\n      `);\n      return parseInt(result.rows[0].total_exposure) || 0;\n    } finally {\n      client.release();\n    }\n  } catch (e) {\n    return 0;\n  }\n}\n\n/**\n * Validate a proposed trade against risk limits\n * @param {Object} trade - Proposed trade\n * @param {string} trade.marketTicker - Market ticker\n * @param {string} trade.side - 'YES' or 'NO'\n * @param {number} trade.quantity - Number of contracts\n * @param {number} trade.price - Price per contract (cents)\n * @returns {Object} - { approved: boolean, reasons: string[], riskScore: number }\n */\nasync function validateTrade(trade) {\n  const reasons = [];\n  const checks = [];\n\n  // Get current state\n  const [positions, pnl, exposure] = await Promise.all([\n    getCurrentPositions(),\n    getTodayPnL(),\n    getTotalExposure(),\n  ]);\n\n  const tradeValue = trade.quantity * trade.price;\n  const newExposure = exposure + tradeValue;\n\n  // Check 1: Daily loss limit\n  const dailyLossCheck = pnl.total > -RISK_LIMITS.maxDailyLoss;\n  checks.push({ name: \"daily_loss\", passed: dailyLossCheck, value: pnl.total });\n  if (!dailyLossCheck) {\n    reasons.push(`Daily loss limit exceeded: ${pnl.total}¢ lost (max: ${RISK_LIMITS.maxDailyLoss}¢)`);\n  }\n\n  // Check 2: Position size limit\n  const positionSizeCheck = trade.quantity <= RISK_LIMITS.maxPositionSize;\n  checks.push({ name: \"position_size\", passed: positionSizeCheck, value: trade.quantity });\n  if (!positionSizeCheck) {\n    reasons.push(`Position size too large: ${trade.quantity} contracts (max: ${RISK_LIMITS.maxPositionSize})`);\n  }\n\n  // Check 3: Total exposure limit\n  const exposureCheck = newExposure <= RISK_LIMITS.maxTotalExposure;\n  checks.push({ name: \"total_exposure\", passed: exposureCheck, value: newExposure });\n  if (!exposureCheck) {\n    reasons.push(`Total exposure would exceed limit: ${newExposure}¢ (max: ${RISK_LIMITS.maxTotalExposure}¢)`);\n  }\n\n  // Check 4: Concentration limit (max % in single market)\n  // Skip concentration check if this is the first trade (exposure = 0)\n  const existingPosition = positions.find(p => p.market_ticker === trade.marketTicker);\n  const existingValue = existingPosition ? parseInt(existingPosition.notional_value) : 0;\n  const newMarketValue = existingValue + tradeValue;\n  const concentration = newExposure > 0 ? newMarketValue / newExposure : 0;\n  // Allow first trade (when exposure is 0) or check concentration\n  const concentrationCheck = exposure === 0 || concentration <= RISK_LIMITS.maxConcentration;\n  checks.push({ name: \"concentration\", passed: concentrationCheck, value: concentration });\n  if (!concentrationCheck) {\n    reasons.push(`Concentration too high: ${(concentration * 100).toFixed(1)}% in ${trade.marketTicker} (max: ${(RISK_LIMITS.maxConcentration * 100).toFixed(0)}%)`);\n  }\n\n  // Calculate risk score (0-100, lower is better)\n  const failedChecks = checks.filter(c => !c.passed).length;\n  const riskScore = Math.min(100, (failedChecks / checks.length) * 100 + (newExposure / RISK_LIMITS.maxTotalExposure) * 50);\n\n  return {\n    approved: reasons.length === 0,\n    reasons,\n    riskScore: Math.round(riskScore),\n    checks,\n    currentState: {\n      dailyPnL: pnl,\n      totalExposure: exposure,\n      newExposure,\n      concentration,\n    },\n  };\n}\n\n/**\n * Record risk check in database\n */\nasync function logRiskCheck(trade, validationResult) {\n  const client = await pool.connect();\n  try {\n    await client.query(`\n      INSERT INTO risk_checks (\n        market_ticker, side, quantity, price, \n        approved, risk_score, reasons, created_at\n      ) VALUES ($1, $2, $3, $4, $5, $6, $7, NOW())\n    `, [\n      trade.marketTicker,\n      trade.side,\n      trade.quantity,\n      trade.price,\n      validationResult.approved,\n      validationResult.riskScore,\n      JSON.stringify(validationResult.reasons),\n    ]);\n  } finally {\n    client.release();\n  }\n}\n\n/**\n * Get risk summary for dashboard\n */\nasync function getRiskSummary() {\n  const [positions, pnl, exposure] = await Promise.all([\n    getCurrentPositions(),\n    getTodayPnL(),\n    getTotalExposure(),\n  ]);\n\n  return {\n    limits: RISK_LIMITS,\n    current: {\n      dailyPnL: pnl,\n      totalExposure: exposure,\n      openPositions: positions.length,\n    },\n    utilization: {\n      dailyLoss: Math.abs(pnl.total) / RISK_LIMITS.maxDailyLoss,\n      exposure: exposure / RISK_LIMITS.maxTotalExposure,\n    },\n    status: pnl.total < -RISK_LIMITS.maxDailyLoss || exposure > RISK_LIMITS.maxTotalExposure ? \"AT_RISK\" : \"OK\",\n  };\n}\n\n// RiskManager class for live_runner.js integration\nclass RiskManager {\n  async filterSignals(signals) {\n    const approved = [];\n    const rejected = [];\n    let context = null;\n\n    try {\n      const summary = await getRiskSummary();\n      context = {\n        dailyPnl: summary.current.dailyPnL.total || 0,\n        openExposure: summary.current.totalExposure || 0,\n        openPositionsCount: summary.current.openPositions || 0,\n        drawdown: summary.utilization.exposure || 0,\n      };\n    } catch (dbErr) {\n      // Database not available — run without DB-backed risk checks\n      context = {\n        dailyPnl: 0,\n        openExposure: 0,\n        openPositionsCount: 0,\n        drawdown: 0,\n      };\n    }\n\n    for (const signal of signals) {\n      const trade = {\n        marketTicker: signal.ticker || signal.marketId,\n        side: signal.side ? signal.side.toUpperCase() : \"YES\",\n        quantity: signal.recommendedContracts || signal.positionSize || 1,\n        price: Math.round((signal.currentPrice || signal.targetPrice || 50) * 100),\n      };\n\n      try {\n        const result = await validateTrade(trade);\n        if (result.approved) {\n          approved.push(signal);\n        } else {\n          rejected.push({ signal, reason: result.reasons.join(\"; \") });\n        }\n      } catch (err) {\n        // If DB is down, approve signal with a warning\n        approved.push(signal);\n      }\n    }\n\n    return { approved, rejected, context };\n  }\n}\n\nmodule.exports = {\n  RiskManager,\n  validateTrade,\n  logRiskCheck,\n  getRiskSummary,\n  getCurrentPositions,\n  getTodayPnL,\n  RISK_LIMITS,\n};\n\n// CLI for testing\nif (require.main === module) {\n  async function main() {\n    const args = process.argv.slice(2);\n    \n    if (args[0] === \"summary\") {\n      const summary = await getRiskSummary();\n      console.log(JSON.stringify(summary, null, 2));\n    } else if (args[0] === \"check\") {\n      const trade = {\n        marketTicker: args[1] || \"TEST-MARKET\",\n        side: args[2] || \"YES\",\n        quantity: parseInt(args[3]) || 10,\n        price: parseInt(args[4]) || 50,\n      };\n      const result = await validateTrade(trade);\n      console.log(JSON.stringify(result, null, 2));\n    } else {\n      console.log(`\nRisk Manager CLI\n\nUsage:\n  node risk_manager.js summary           Show risk summary\n  node risk_manager.js check <ticker> <side> <qty> <price>   Validate a trade\n\nExamples:\n  node risk_manager.js summary\n  node risk_manager.js check BTCW-26-JUN30-100K YES 10 65\n`);\n    }\n    process.exit(0);\n  }\n\n  main().catch(e => {\n    console.error(\"Error:\", e);\n    process.exit(1);\n  });\n}\n","numLines":342,"startLine":1,"totalLines":342}}}
