  510\tCREATE TABLE IF NOT EXISTS strategy_trades (\n   511\t    id UUID PRIMARY
KEY DEFAULT uuid_generate_v4(),\n   512\t    strategy_id UUID NOT NULL REFERENCE
S strategies(id),\n   513\t    trade_id UUID NOT NULL REFERENCES trades(id),\n  
514\t    \n   515\t    -- Attribution\n   516\t    attributed_pnl INTEGER, -- P&
L attributed to this strategy\n   517\t    \n   518\t    -- Timestamps\n   519\t
   recorded_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()\n   520\t);\n   521\t\n   
522\t-- Indexes for strategy trades\n   523\tCREATE INDEX IF NOT EXISTS idx_stra
tegy_trades_strategy ON strategy_trades(strategy_id);\n   524\tCREATE INDEX IF N
OT EXISTS idx_strategy_trades_trade ON strategy_trades(trade_id);\n   525\tCREAT
E INDEX IF NOT EXISTS idx_strategy_trades_recorded ON strategy_trades(recorded_a
t);\n   526\t\n   527\t-- ------------------------------------------------------
---------------------\n   528\t-- Strategy Performance Table\n   529\t-- Time-se
ries performance data for strategies\n   530\t-- -------------------------------
--------------------------------------------\n   531\tCREATE TABLE IF NOT EXISTS
strategy_performance (\n   532\t    id UUID PRIMARY KEY DEFAULT uuid_generate_v4
(),\n   533\t    strategy_id UUID NOT NULL REFERENCES strategies(id) ON DELETE C
ASCADE,\n   534\t    \n   535\t    -- Period\n   536\t    period VARCHAR(20) NOT
NULL, -- \'hourly\', \'daily\', \'weekly\', \'monthly\'\n   537\t    period_star
t TIMESTAMP WITH TIME ZONE NOT NULL,\n   538\t    \n   539\t    -- Metrics\n   5
40\t    trades_count INTEGER DEFAULT 0,\n   541\t    signals_count INTEGER DEFAU
LT 0,\n   542\t    realized_pnl INTEGER DEFAULT 0,\n   543\t    unrealized_pnl I
NTEGER DEFAULT 0,\n   544\t    total_pnl INTEGER DEFAULT 0,\n   545\t    win_rat
e DECIMAL(5,4), -- 0.0 to 1.0\n   546\t    max_exposure INTEGER, -- max position
value during period\n   547\t    cumulative_pnl INTEGER DEFAULT 0, -- running to
tal\n   548\t    \n   549\t    -- Unique constraint\n   550\t    UNIQUE(strategy
_id, period, period_start)\n   551\t);\n   552\t\n   553\t-- Indexes for perform
ance\n   554\tCREATE INDEX IF NOT EXISTS idx_strategy_performance_strategy ON st
rategy_performance(strategy_id);\n   555\tCREATE INDEX IF NOT EXISTS idx_strateg
y_performance_period ON strategy_performance(period, period_start);\n   556\t\n 
 557\t-- -----------------------------------------------------------------------
