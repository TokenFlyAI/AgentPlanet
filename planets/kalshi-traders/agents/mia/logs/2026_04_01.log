n   560\t-- --------------------------------------------------------------------
-------\n   561\tCREATE TABLE IF NOT EXISTS strategy_runs (\n   562\t    id UUID
PRIMARY KEY DEFAULT uuid_generate_v4(),\n   563\t    strategy_id UUID REFERENCES
strategies(id),\n   564\t    \n   565\t    -- Run details\n   566\t    run_type 
VARCHAR(20) NOT NULL, -- \'single\', \'batch\', \'backtest\'\n   567\t    status
VARCHAR(20) NOT NULL, -- \'running\', \'completed\', \'failed\'\n   568\t    \n 
 569\t    -- Results\n   570\t    markets_scanned INTEGER DEFAULT 0,\n   571\t  
 signals_generated INTEGER DEFAULT 0,\n   572\t    signals_executed INTEGER DEFA
ULT 0,\n   573\t    error_message TEXT,\n   574\t    \n   575\t    -- Timing\n  
576\t    started_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),\n   577\t    complet
ed_at TIMESTAMP WITH TIME ZONE\n   578\t);\n   579\t\n   580\t-- Indexes for run
s\n   581\tCREATE INDEX IF NOT EXISTS idx_strategy_runs_strategy ON strategy_run
s(strategy_id);\n   582\tCREATE INDEX IF NOT EXISTS idx_strategy_runs_status ON 
strategy_runs(status);\n   583\tCREATE INDEX IF NOT EXISTS idx_strategy_runs_sta
rted ON strategy_runs(started_at);\n   584\t\n   585\t-- -----------------------
----------------------------------------------------\n   586\t-- Views for Strat
egy Framework\n   587\t-- ------------------------------------------------------
---------------------\n   588\t\n   589\t-- Strategy positions with P&L view\n  
590\tCREATE OR REPLACE VIEW strategy_positions_view AS\n   591\tSELECT \n   592\
t    sp.*,\n   593\t    p.side,\n   594\t    p.contracts,\n   595\t    p.avg_ent
ry_price,\n   596\t    p.status as position_status,\n   597\t    m.ticker,\n   5
98\t    m.title as market_title,\n   599\t    amp.calculated_unrealized_pnl\n   
600\tFROM strategy_positions sp\n   601\tJOIN positions p ON sp.position_id = p.
id\n   602\tJOIN markets m ON sp.market_id = m.id\n   603\tLEFT JOIN open_positi
ons_with_markets amp ON p.id = amp.id;\n   604\t\n   605\t-- Active signals with
market info\n   606\tCREATE OR REPLACE VIEW active_signals_view AS\n   607\tSELE
CT \n   608\t    ss.*,\n   609\t    s.name as strategy_name,\n   610\t    s.stra
tegy_type,\n   611\t    m.ticker,\n   612\t    m.title as market_title,\n   613\
t    m.category\n   614\tFROM strategy_signals ss\n   615\tJOIN strategies s ON 
ss.strategy_id = s.id\n   616\tJOIN markets m ON ss.market_id = m.id\n   617\tWH
ERE ss.status = \'pending\'\n   618\t  AND (ss.expires_at IS NULL OR ss.expires_
at > NOW())\n   619\tORDER BY ss.confidence DESC, ss.generated_at DESC;\n   620\
t\n   621\t-- Strategy summary view\n   622\tCREATE OR REPLACE VIEW strategy_sum
mary_view AS\n   623\tSELECT \n   624\t    s.*,\n   625\t    COALESCE(sp.recent_
pnl, 0) as recent_pnl,\n   626\t    COALESCE(sp.recent_trades, 0) as recent_trad
es,\n   627\t    CASE \n   628\t        WHEN s.total_trades > 0 THEN s.winning_t
rades::decimal / s.total_trades\n   629\t        ELSE 0\n   630\t    END as calc
ulated_win_rate\n   631\tFROM strategies s\n   632\tLEFT JOIN (\n   633\t    SEL
ECT \n   634\t        strategy_id,\n   635\t        SUM(total_pnl) as recent_pnl
,\n   636\t        SUM(trades_count) as recent_trades\n   637\t    FROM strategy
_performance\n   638\t    WHERE period = \'daily\'\n   639\t      AND period_sta
rt >= CURRENT_DATE - INTERVAL \'7 days\'\n   640\t    GROUP BY strategy_id\n   6
41\t) sp ON s.id = sp.strategy_id;\n   642\t\n   643\t-- -----------------------
----------------------------------------------------\n   644\t-- Update triggers
for strategy tables\n   645\t-- ------------------------------------------------
---------------------------\n   646\tDROP TRIGGER IF EXISTS update_strategies_up
dated_at ON strategies;\n   647\tCREATE TRIGGER update_strategies_updated_at\n  
648\t    BEFORE UPDATE ON strategies\n   649\t    FOR EACH ROW\n   650\t    EXEC
UTE FUNCTION update_updated_at_column();\n   651\t\n   652\t-- -----------------
----------------------------------------------------------\n   653\t-- Comments 
for strategy tables\n   654\t-- ------------------------------------------------
---------------------------\n   655\tCOMMENT ON TABLE strategies IS \'Trading st
rategy definitions and configuration\';\n   656\tCOMMENT ON TABLE strategy_signa
ls IS \'Trading signals generated by strategies\';\n   657\tCOMMENT ON TABLE str
ategy_positions IS \'Position attribution to strategies\';\n   658\tCOMMENT ON T
ABLE strategy_trades IS \'Trade attribution to strategies for P&L tracking\';\n 
 659\tCOMMENT ON TABLE strategy_performance IS \'Time-series performance metrics
per strategy\';\n   660\tCOMMENT ON TABLE strategy_runs IS \'Log of strategy exe
cution runs\';\n',
